{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "astro",
  "cleanUrls": true,
  "trailingSlash": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    },
    {
      "source": "/(.*)\\.(jpg|jpeg|png|webp|gif|svg|ico|woff|woff2|ttf|eot)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/home/", "destination": "/", "permanent": true },
    { "source": "/apply-for-mortgage", "destination": "https://stairwaymortgage.my1003app.com/", "permanent": true },
    { "source": "/apply-for-mortgage/", "destination": "https://stairwaymortgage.my1003app.com/", "permanent": true },
    { "source": "/mortgage-preapproval", "destination": "https://stairwaymortgage.my1003app.com/", "permanent": true },
    { "source": "/mortgage-preapproval/", "destination": "https://stairwaymortgage.my1003app.com/", "permanent": true }
  ]
}
