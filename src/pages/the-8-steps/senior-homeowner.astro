  .step-body :global(p) { font-size:17px; line-height:1.75; margin-bottom:1.2rem; color:var(--color-ink-light); }
  .step-body :global(ul) { margin:0 0 1.5rem 1.25rem; display:flex; flex-direction:column; gap:.5rem; }
  .step-body :global(li) { font-size:17px; line-height:1.6; }
  .step-cta-card { background:var(--color-paper); border:1px solid var(--color-bone); border-radius:16px; padding:2.5rem; text-align:center; display:flex; flex-direction:column; align-items:center; gap:1rem; margin-top:2rem; }
  .step-cta-card--summit { background:var(--color-ink); color:var(--color-paper); }
  .step-cta-card--summit h2 { color:var(--color-paper); }
  .step-next { display:flex; flex-direction:column; gap:.35rem; margin-top:1.5rem; padding:1.5rem 1.75rem; border:1px solid var(--color-bone); border-radius:14px; background:var(--color-paper-tint); text-decoration:none; transition:border-color .2s,transform .2s; }
  .step-next:hover { border-color:var(--color-blue); transform:translateY(-2px); }
  .step-next__label { font-size:11px; letter-spacing:.06em; text-transform:uppercase; color:var(--color-blue); }
  .step-next__title { font-family:var(--font-display); font-size:1.4rem; color:var(--color-ink); }
  .step-next__tag { font-size:12px; color:var(--color-mute); }
  .step-summit-note { margin-top:1.5rem; padding:1.75rem; border:1px solid #E0A96D; border-radius:14px; background:rgba(224,169,109,0.08); }
  .step-summit-note .mono { font-size:11px; letter-spacing:.08em; text-transform:uppercase; color:#B5803F; }
  .step-summit-note p { margin-top:.5rem; font-size:16px; color:var(--color-ink-light); }
  .step-back { display:inline-block; margin-top:2rem; font-size:13px; color:var(--color-blue); text-decoration:none; }

  .res-section { padding: clamp(2.5rem,5vw,4rem) 0; background: var(--color-paper-tint); border-top:1px solid var(--color-bone); border-bottom:1px solid var(--color-bone); margin-top:3rem; }
