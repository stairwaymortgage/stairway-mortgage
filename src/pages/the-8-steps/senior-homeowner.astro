<style>
  .step-hero { padding: clamp(2.5rem,6vw,5rem) 0 clamp(2rem,4vw,3rem); background: linear-gradient(180deg,var(--color-paper-tint),var(--color-paper)); border-bottom:1px solid var(--color-bone); position:relative; }
  .step-hero--summit { background: var(--color-ink); }
  .step-hero--summit .step-hero__title, .step-hero--summit .step-hero__lede { color: var(--color-paper); }
