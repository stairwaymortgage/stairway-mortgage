---
import Layout from '../layouts/Layout.astro';

// External GHL donation survey (receipt submission handled there — no in-page upload).
const DONATE_URL = 'https://forms.stairwaymortgage.com/widget/survey/JaFWaMekf5ieavS4KUSb';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://stairwaymortgage.com/" },
    { "@type": "ListItem", "position": 2, "name": "Community & Causes" }
  ]
};

const steps = [
  { n: '01', t: 'Close your loan with Stairway Mortgage', d: 'Every closing opens the door to give back — no extra cost to you.' },
  { n: '02', t: 'Choose a cause you care about', d: 'Pick the charity or community that means the most to you.' },
  { n: '03', t: 'Make a donation', d: 'Give what feels right. Then submit your receipt for matching.' },
  { n: '04', t: 'We match your gift', d: 'We match your donation, dollar for dollar, amplifying your impact.' },
  { n: '05', t: 'Your gift becomes shared impact', d: "We'll share our collective progress with the community each year." },
];

const values = [
  'Encourage Client Participation',
  'Strengthen Community Bonds',
  'Create Tangible Results',
  'Choose Your Cause',
  'Claim Tax Benefits',
];
---

<Layout
  title="Community Giving & Social Responsibility | Stairway"
  description="How we give back to our communities. Charitable partnerships, client donation matching, and our commitment to making a difference beyond mortgages."
  canonical="https://stairwaymortgage.com/community-causes/"
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="cc-scope">

    <!-- ============================== HERO ============================== -->
    <section class="cc-hero">
      <div class="container-page">
        <nav class="cc-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a> <span>/</span> <span>Community &amp; Causes</span>
        </nav>
        <div class="cc-hero-inner">
          <span class="eyebrow eyebrow-blue mb-4">Community &amp; Causes</span>
          <h1 class="display-lg cc-h1">This Isn't About Writing Checks. It's About Writing a Brighter Future.</h1>
          <p class="cc-lede">
            We're creating a movement rooted in love, committed to justice, and driven by the belief in
            shared abundance. Every home we finance is a step toward a more empowered, equitable, and
            thriving future for all.
          </p>
          <div class="cc-actions">
            <a href={DONATE_URL} class="btn btn-blue btn-arrow" target="_blank" rel="noopener">Donate Now</a>
            <a href="/schedule-call/" class="btn btn-ghost">Talk to Our Team</a>
          </div>
          <p class="cc-trust">Reviewed by Jim Blackburn · NMLS #1072866 · Giving back is built into how we work.</p>
        </div>
      </div>
    </section>

    <!-- ===================== HOW GIVING BACK WORKS ===================== -->
    <section class="cc-section">
      <div class="container-page">
        <div class="cc-head">
          <span class="eyebrow eyebrow-blue mb-3">How it works</span>
          <h2 class="display-md">Giving back, built into every closing</h2>
          <p class="cc-sub">
            A portion of every closed loan goes toward families building futures. When a client gives to a
            cause they care about, we match it — dollar for dollar — turning everyday closings into lasting
            community impact.
          </p>
        </div>

        <div class="cc-steps">
          {steps.map((s) => (
            <div class="cc-step">
              <span class="cc-step-num">{s.n}</span>
              <h3 class="cc-step-t">{s.t}</h3>
              <p class="cc-step-d">{s.d}</p>
            </div>
          ))}
        </div>

        <div class="cc-values">
          {values.map((v) => (
            <span class="cc-chip">{v}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- ===================== OPPORTUNITY INTERNATIONAL ===================== -->
    <section class="cc-section cc-oi">
      <div class="container-page">
        <div class="cc-oi-grid">
          <div class="cc-oi-media">
            <img
              src="/wp-content/uploads/2025/04/opportunity-international1722510558.logowik.com_.svg"
              alt="Opportunity International logo"
              width="240" height="96" loading="lazy" decoding="async"
              onerror="this.onerror=null;this.src='https://placehold.co/240x96/ffffff/0A0E1A?text=Opportunity+International';"
            />
          </div>
          <div class="cc-oi-copy">
            <span class="eyebrow eyebrow-blue mb-3">Featured partner</span>
            <h2 class="display-md">Opportunity International</h2>
            <p>
              We proudly highlight
              <a href="https://opportunity.org" target="_blank" rel="noopener">Opportunity International</a>
              — a pioneering force in ending poverty through empowerment, not dependency.
            </p>
            <h3 class="cc-h3">Why we support them</h3>
            <ul class="cc-list">
              <li>Over 9 million people die each year from hunger.</li>
              <li>800 million+ live with chronic malnutrition.</li>
              <li>Opportunity Int'l delivers sustainable solutions, not temporary handouts.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================== CLOSING CTA ============================== -->
    <section class="cc-cta">
      <div class="container-page">
        <div class="cc-cta-inner">
          <span class="eyebrow eyebrow-on-dark mb-3">Make an impact</span>
          <h2 class="display-md cc-cta-h">Ready to make your first donation?</h2>
          <p class="cc-cta-p">
            Choose a charity you care about and submit your receipt for matching. Every gift becomes
            shared impact for the community.
          </p>
          <div class="cc-actions cc-actions--center">
            <a href={DONATE_URL} class="btn btn-blue btn-arrow" target="_blank" rel="noopener">Donate Now</a>
            <a href="/schedule-call/" class="btn btn-ghost cc-btn-on-dark">Talk to Our Team</a>
          </div>
        </div>
      </div>
    </section>

  </div>
</Layout>

<style>
  .cc-scope {
    --cc-ink: var(--color-ink, #0A0E1A);
    --cc-ink-light: var(--color-ink-light, #4A5568);
    --cc-paper: var(--color-paper, #FAFAF7);
    --cc-paper-tint: var(--color-paper-tint, #F4F4EE);
    --cc-bone: var(--color-bone, #E5E5DE);
    --cc-mute: var(--color-mute, #6B7280);
    --cc-blue: var(--color-blue, #1845D6);
    --cc-gold: #B8860B;
    --cc-serif: var(--stw-display, 'Fraunces'), Georgia, serif;
    --cc-mono: var(--stw-mono, 'JetBrains Mono'), monospace;
  }

  /* ---------- HERO ---------- */
  .cc-hero {
    background:
      radial-gradient(120% 90% at 85% -10%, #F5EBD0 0%, transparent 55%),
      var(--cc-paper);
    border-bottom: 1px solid var(--cc-bone);
    padding-bottom: 4rem;
  }
  .cc-breadcrumb {
    font-family: var(--cc-mono); font-size: 12px; color: var(--cc-mute);
    padding-top: 2rem; padding-bottom: 1.5rem;
  }
  .cc-breadcrumb a { color: var(--cc-mute); text-decoration: none; }
  .cc-breadcrumb a:hover { color: var(--cc-blue); }
  .cc-breadcrumb span { margin-inline: 0.4rem; opacity: 0.5; }
  .cc-hero-inner { max-width: 760px; padding-top: 1rem; }
  .cc-h1 { margin: 0.5rem 0 1.25rem; font-style: normal; max-width: 18ch; }
  .cc-lede { font-size: 1.1875rem; line-height: 1.55; color: var(--cc-ink-light); max-width: 60ch; margin-bottom: 2rem; }
  .cc-actions { display: flex; flex-wrap: wrap; gap: 0.85rem; align-items: center; }
  .cc-actions--center { justify-content: center; }
  .cc-trust { font-family: var(--cc-mono); font-size: 12px; color: var(--cc-mute); margin-top: 1.75rem; letter-spacing: 0.02em; }

  /* ---------- SECTIONS ---------- */
  .cc-section { padding: 5rem 0; }
  .cc-head { max-width: 640px; margin: 0 auto 3rem; text-align: center; }
  .cc-sub { font-size: 1.0625rem; line-height: 1.65; color: var(--cc-ink-light); margin-top: 1rem; }

  /* ---------- STEPS ---------- */
  .cc-steps {
    display: grid; grid-template-columns: repeat(5, 1fr); gap: 1.25rem;
  }
  .cc-step {
    background: var(--cc-paper); border: 1px solid var(--cc-bone); border-radius: 14px;
    padding: 1.5rem 1.25rem; border-top: 3px solid var(--cc-gold);
  }
  .cc-step-num { font-family: var(--cc-mono); font-size: 1.05rem; color: var(--cc-gold); letter-spacing: 0.04em; }
  .cc-step-t { font-family: var(--cc-serif); font-weight: 500; font-size: 1.0625rem; line-height: 1.25; color: var(--cc-ink); margin: 0.75rem 0 0.5rem; }
  .cc-step-d { font-size: 13.5px; line-height: 1.55; color: var(--cc-mute); margin: 0; }

  .cc-values { display: flex; flex-wrap: wrap; gap: 0.6rem; justify-content: center; margin-top: 2.5rem; }
  .cc-chip {
    font-family: var(--cc-mono); font-size: 12px; letter-spacing: 0.04em;
    color: var(--cc-ink); background: var(--cc-paper-tint);
    border: 1px solid var(--cc-bone); border-radius: 100px; padding: 0.5rem 1rem;
  }

  /* ---------- OPPORTUNITY INTERNATIONAL ---------- */
  .cc-oi { background: var(--cc-paper-tint); border-top: 1px solid var(--cc-bone); border-bottom: 1px solid var(--cc-bone); }
  .cc-oi-grid { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: 3rem; align-items: center; }
  .cc-oi-media {
    display: flex; align-items: center; justify-content: center;
    background: #fff; border: 1px solid var(--cc-bone); border-radius: 16px; padding: 2.5rem;
    box-shadow: 0 16px 44px -28px rgba(10,14,26,0.3);
  }
  .cc-oi-media img { max-width: 100%; height: auto; object-fit: contain; display: block; }
  .cc-oi-copy p { font-size: 1.0625rem; line-height: 1.65; color: var(--cc-ink-light); margin: 1rem 0; }
  .cc-oi-copy a { color: var(--cc-blue); text-decoration: underline; text-underline-offset: 2px; }
  .cc-h3 { font-family: var(--cc-serif); font-weight: 500; font-size: 1.2rem; color: var(--cc-ink); margin: 1.5rem 0 0.75rem; }
  .cc-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.6rem; }
  .cc-list li { position: relative; padding-left: 1.6rem; font-size: 15px; line-height: 1.5; color: var(--cc-ink-light); }
  .cc-list li::before { content: '✦'; position: absolute; left: 0; color: var(--cc-gold); }

  /* ---------- CLOSING CTA ---------- */
  .cc-cta { background: var(--cc-ink); color: var(--cc-paper); padding: 5.5rem 0; }
  .cc-cta-inner { max-width: 620px; margin: 0 auto; text-align: center; }
  .cc-cta-h { color: var(--cc-paper); margin: 0.75rem auto 1rem; }
  .cc-cta-p { font-size: 1.0625rem; line-height: 1.6; color: rgba(250,250,247,0.78); margin: 0 auto 2rem; }
  .cc-btn-on-dark { color: var(--cc-paper); border-color: rgba(250,250,247,0.3); }
  .cc-btn-on-dark:hover { border-color: var(--cc-paper); }

  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 900px) {
    .cc-steps { grid-template-columns: repeat(2, 1fr); }
    .cc-oi-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
  @media (max-width: 560px) {
    .cc-steps { grid-template-columns: 1fr; }
    .cc-section { padding: 3.5rem 0; }
    .cc-actions { flex-direction: column; align-items: stretch; }
    .cc-actions .btn { justify-content: center; }
  }
</style>
