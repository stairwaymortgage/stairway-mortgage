---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Courses — Stairway Mortgage" description="Video learning library. Mortgage education and wealth-building.">
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">Learn · Courses</span>
        <h1 class="display-xl mt-6 mb-6">Learn at your <em class="italic text-[var(--color-blue)]">own pace</em>.</h1>
        <p class="lede max-w-xl mx-auto mb-8">Video courses on mortgages, investing, and wealth-building. Coming soon.</p>
        <div class="card max-w-lg mx-auto p-8 text-center">
          <p class="text-[14px] text-[var(--color-mute)]"><!-- TODO: Add course listings --></p>
        </div>
        <div class="flex flex-wrap gap-3 justify-center mt-10">
          <a href="/guides/" class="btn btn-blue btn-arrow text-base px-6 py-3.5">Get Free Guides Instead</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
