const faqSchema={"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "What is clouded title and can I get a mortgage with it?", "acceptedAnswer": {"@type": "Answer", "text": "Clouded title means legal uncertainty exists about property ownership. Unresolved liens, boundary disputes, or inheritance issues create clouds. Standard mortgages require clear title at closing."}}, {"@type": "Question", "name": "How do foreign nationals qualify for U.S. mortgages without Social Security numbers?", "acceptedAnswer": {"@type": "Answer", "text": "Foreign national mortgage programs use passport-based qualification instead of Social Security numbers. Lenders verify international employment and income. Bank statements from your home country prove financial capacity."}}, {"@type": "Question", "name": "What's the difference between a co-borrower and co-signer?", "acceptedAnswer": {"@type": "Answer", "text": "Co-borrowers share full ownership and responsibility for the property. Both names appear on the title deed and mortgage note. Both incomes and credit profiles factor into qualification."}}, {"@type": "Question", "name": "Why do lenders care about arms length transactions?", "acceptedAnswer": {"@type": "Answer", "text": "Arms length transactions occur between unrelated parties negotiating independently. This prevents inflated pricing and fraudulent cash-back schemes. Lenders protect themselves from coordinated fraud between related parties."}}, {"@type": "Question", "name": "Can you buy a house from your parents with a mortgage?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, through portfolio lenders willing to structure non-arms-length purchases. You'll need independent appraisal establishing market value. The purchase price should match or fall below appraised value."}}, {"@type": "Question", "name": "How do judgment liens affect property sales?", "acceptedAnswer": {"@type": "Answer", "text": "Judgment liens must be satisfied before title can transfer cleanly. Sellers must pay off liens from sales proceeds. Sometimes lien amounts exceed available equity."}}, {"@type": "Question", "name": "How long after foreclosure can you buy another home?", "acceptedAnswer": {"@type": "Answer", "text": "FHA requires three years from foreclosure completion. Conventional loans typically require seven years. VA loans allow Veterans to qualify after two years."}}, {"@type": "Question", "name": "Can you get a mortgage for a fixer-upper that needs major repairs?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, through renovation loan programs combining purchase and repair financing. FHA 203k loans finance both components with just 3.5% initial investment. Conventional HomeStyle Renovation loans offer similar structure."}}, {"@type": "Question", "name": "What documents do you need to buy a house in a flood zone?", "acceptedAnswer": {"@type": "Answer", "text": "Flood zone purchases require standard mortgage documents plus flood insurance. FEMA flood zone determination occurs during appraisal. Properties in high-risk zones need National Flood Insurance Program coverage."}}, {"@type": "Question", "name": "Can you buy investment property with tenants already in place?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, investment property financing specifically allows tenant occupancy. The existing rental income can count toward qualification. Lenders verify lease terms and rental payment history."}}, {"@type": "Question", "name": "How does an FHA non-occupant co-borrower work?", "acceptedAnswer": {"@type": "Answer", "text": "FHA allows family members to co-borrow even when not living in the property. Parents, siblings, or adult children can strengthen your application. Their income and credit factor into qualification."}}, {"@type": "Question", "name": "Can you get a mortgage with an ITIN instead of Social Security number?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, ITIN mortgage programs serve borrowers without Social Security numbers. Two years of tax returns filed with your ITIN establish income. Pay stubs and bank statements prove financial capacity."}}, {"@type": "Question", "name": "What are portfolio loans and when do you need them?", "acceptedAnswer": {"@type": "Answer", "text": "Portfolio loans are held by lenders in their own portfolios. This provides flexibility for non-standard situations. Complex income documentation becomes manageable. Non-standard property types gain eligibility."}}, {"@type": "Question", "name": "How long after bankruptcy can you buy a home?", "acceptedAnswer": {"@type": "Answer", "text": "FHA allows purchasing two years after Chapter 7 discharge. Conventional loans typically require four years. Chapter 13 allows purchasing during active repayment with trustee approval."}}, {"@type": "Question", "name": "How do you refinance to remove an ex-spouse from the mortgage?", "acceptedAnswer": {"@type": "Answer", "text": "Refinancing in your name alone is the only removal method. The divorce decree doesn't release mortgage obligation. You must qualify independently using only your income."}}, {"@type": "Question", "name": "What are bank statement loan programs for self-employed borrowers?", "acceptedAnswer": {"@type": "Answer", "text": "Bank statement loans qualify you based on deposits rather than tax returns. Lenders analyze 12-24 months of business bank statements. This avoids explaining complex business deductions."}}, {"@type": "Question", "name": "Can you use FHA or VA loans for mixed-use properties?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, if commercial space represents 25% or less of total square footage. You must occupy the residential portion as your primary residence. The commercial use can't create safety hazards."}}, {"@type": "Question", "name": "How much does flood insurance cost in high-risk zones?", "acceptedAnswer": {"@type": "Answer", "text": "Costs vary dramatically by location and flood zone designation. High-risk coastal areas might pay several thousand dollars annually. Inland moderate flood zones might pay several hundred."}}, {"@type": "Question", "name": "What if FEMA remaps and your property enters a flood zone?", "acceptedAnswer": {"@type": "Answer", "text": "You must add flood insurance even if your original mortgage didn't require it. The lender will force-place expensive insurance if you don't obtain coverage voluntarily."}}, {"@type": "Question", "name": "Can foreign nationals refinance their U.S. property investments?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, foreign national refinance programs exist for rate improvement and cash-out scenarios. Your payment history on the existing mortgage matters significantly. Updated income documentation and property valuation are required."}}]};
