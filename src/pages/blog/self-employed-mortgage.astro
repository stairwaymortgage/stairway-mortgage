const faqSchema={"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "What credit score do I need for a bank statement loan?", "acceptedAnswer": {"@type": "Answer", "text": "Bank statement loan programs typically require 620-680 minimum credit scores. Higher scores unlock better pricing and program flexibility. A 680 score qualifies for most programs with reasonable rates."}}, {"@type": "Question", "name": "How much can self employed borrowers qualify to borrow?", "acceptedAnswer": {"@type": "Answer", "text": "Self employed mortgage amounts depend on income documentation method chosen. Bank statement programs often double qualifying income versus tax returns. A $10,000 monthly deposit with 50% expense ratio creates $5,000 income."}}, {"@type": "Question", "name": "Can I use business bank statements from multiple accounts?", "acceptedAnswer": {"@type": "Answer", "text": "Most bank statement lenders accept multiple business account combinations. Deposits from all accounts get aggregated for income calculation. Chase business plus Wells Fargo business statements work together perfectly."}}, {"@type": "Question", "name": "What if my business is less than two years old?", "acceptedAnswer": {"@type": "Answer", "text": "First-year self employed borrowers face significant traditional lending obstacles. Some bank statement lenders accept 12 months of consistent deposits. Strong credit above 700 and substantial reserves help tremendously."}}, {"@type": "Question", "name": "Do no doc loans still exist after the financial crisis?", "acceptedAnswer": {"@type": "Answer", "text": "Modern no doc loans differ dramatically from pre-2008 lending practices. Today's programs target high-net-worth borrowers with exceptional financial strength. Minimum 25-30% initial investment and 700+ credit scores required."}}, {"@type": "Question", "name": "How does depreciation affect my mortgage qualification?", "acceptedAnswer": {"@type": "Answer", "text": "Depreciation significantly reduces qualifying income on traditional applications. $30,000 annual depreciation lowers income by $2,500 monthly. Real estate investors, equipment-heavy contractors, and vehicle-dependent businesses suffer most."}}, {"@type": "Question", "name": "What documentation do I need for a 1099 loan?", "acceptedAnswer": {"@type": "Answer", "text": "1099 loan programs require 1099 forms from all income sources. Two years of forms demonstrate consistent contractor relationships. Year-to-date profit/loss statements show current earning trajectory clearly."}}, {"@type": "Question", "name": "Can I qualify with declining business income?", "acceptedAnswer": {"@type": "Answer", "text": "Declining income creates significant challenges across all mortgage programs. Traditional underwriting uses conservative two-year averaging with downward trends. A $120,000 then $90,000 pattern might qualify using only $90,000."}}, {"@type": "Question", "name": "What are typical bank statement loan rates?", "acceptedAnswer": {"@type": "Answer", "text": "Bank statement loan rates price 0.5-1.5% above conventional mortgage rates. Alternative documentation creates risk premiums for lenders universally. A 6.5% conventional rate becomes 7.0-7.5% for bank statements."}}, {"@type": "Question", "name": "How do DSCR loans work for self employed investors?", "acceptedAnswer": {"@type": "Answer", "text": "DSCR loans qualify borrowers using only rental property income exclusively. Personal income documentation isn't required at all for these programs. Property cash flow must cover its own mortgage obligation adequately."}}, {"@type": "Question", "name": "What initial investment do alternative programs require?", "acceptedAnswer": {"@type": "Answer", "text": "Bank statement programs typically require 10-20% minimum initial investment amounts. Stronger credit and reserves sometimes reduce to 10% minimums. Primary residences qualify at lower investment than rental properties."}}, {"@type": "Question", "name": "Can I refinance with self employed mortgage programs?", "acceptedAnswer": {"@type": "Answer", "text": "All self employed mortgage programs work for refinancing existing properties. Rate-term refinances reduce costs without extracting equity from properties. Cash-out refinances fund business needs or property improvements tax-free."}}, {"@type": "Question", "name": "What reserves do self employed borrowers need?", "acceptedAnswer": {"@type": "Answer", "text": "Reserve requirements vary by program type and loan characteristics. Traditional programs require 2-6 months depending on property type. Investment properties need more reserves than primary residences always."}}, {"@type": "Question", "name": "How long does self employed mortgage approval take?", "acceptedAnswer": {"@type": "Answer", "text": "Self employed approvals require 35-50 days from application to final closing. Traditional W-2 borrowers close in 30-40 days typically for comparison. Additional time stems from business documentation review complexity throughout."}}, {"@type": "Question", "name": "What if I have multiple business entities?", "acceptedAnswer": {"@type": "Answer", "text": "Multiple business entities complicate traditional qualification significantly with combined analysis. S-corporations, LLCs, and Schedule C activities all require documentation. Each entity contributes proportionate income to total qualification calculation."}}, {"@type": "Question", "name": "Can seasonal businesses qualify for mortgages?", "acceptedAnswer": {"@type": "Answer", "text": "Seasonal businesses show significant annual income fluctuations creating challenges. Landscaping generates 80% of revenue April through October typically. Traditional underwriting struggles with variable monthly income patterns significantly."}}, {"@type": "Question", "name": "What happens if I'm denied for a conventional loan?", "acceptedAnswer": {"@type": "Answer", "text": "Conventional denials don't eliminate homeownership possibilities for self employed borrowers. Alternative documentation programs serve borrowers traditional underwriting rejects unnecessarily. Bank statement and DSCR options remain available after denials."}}, {"@type": "Question", "name": "Do self employed rates improve after closing?", "acceptedAnswer": {"@type": "Answer", "text": "Refinancing opportunities improve rates as equity builds and credit strengthens. Property appreciation creates refinancing opportunities every 12-24 months typically. Rate improvements of 0.5-1.0% justify refinancing costs usually."}}, {"@type": "Question", "name": "Can I use gift funds for my initial investment?", "acceptedAnswer": {"@type": "Answer", "text": "Gift funds work on most self employed mortgage programs identically to traditional lending. Donors must be family members with documented financial ability. Gift letters confirming no repayment expectation are required universally."}}, {"@type": "Question", "name": "What if I just incorporated my business recently?", "acceptedAnswer": {"@type": "Answer", "text": "Recent incorporation doesn't restart self employment history clocks for most lenders. Sole proprietor converting to S-corporation shows business continuity clearly. Same field, same clients, same services demonstrate ongoing operation."}}]};
const articleSchema={"@context": "https://schema.org", "@type": "BlogPosting", "headline": "Self Employed Mortgage: Complete Guide to Qualification, Rates & Process", "datePublished": "2025-11-07", "author": {"@type": "Person", "name": "Jim Blackburn", "identifier": "NMLS #1072866"}, "publisher": {"@type": "Organization", "name": "Stairway Mortgage"}, "mainEntityOfPage": "https://stairwaymortgage.com/blog/self-employed-mortgage/"};
const breadcrumbSchema={"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://stairwaymortgage.com/"}, {"@type": "ListItem", "position": 2, "name": "Blog", "item": "https://stairwaymortgage.com/blog/"}, {"@type": "ListItem", "position": 3, "name": "Self Employed Mortgage"}]};
