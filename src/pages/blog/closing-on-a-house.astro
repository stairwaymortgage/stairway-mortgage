const faqSchema={"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "How much does closing on a house typically cost?", "acceptedAnswer": {"@type": "Answer", "text": "Closing costs for buyers typically range from 2-5% of the purchase price. Your loan type, location, and negotiated terms affect total costs during the real estate closing. A $300,000 home purchase might incur $6,000-$15,000 in closing costs when closing on a house."}}, {"@type": "Question", "name": "Can you close on a house without a realtor?", "acceptedAnswer": {"@type": "Answer", "text": "You can legally close on a house without a realtor representing you. For-sale-by-owner (FSBO) transactions and some new construction purchases proceed without buyer's agents. You'll handle offer negotiation, contract review, inspection coordination, and closing details yourself during the real estate closing."}}, {"@type": "Question", "name": "What is the 3-day closing disclosure rule?", "acceptedAnswer": {"@type": "Answer", "text": "Federal TILA-RESPA regulations require lenders to provide your closing disclosure at least three business days before closing. This waiting period allows you to review final terms during the mortgage closing preparation. You verify cost accuracy and prepare funding when closing on a house."}}, {"@type": "Question", "name": "Do you get your earnest money back if the deal falls through?", "acceptedAnswer": {"@type": "Answer", "text": "Earnest money return depends on why the deal falls through and your contract terms. If you cancel during inspection, financing, or other contingency periods specified in your contract, your earnest money typically returns. Canceling after contingencies expire usually forfeits earnest money to sellers during the real estate closing."}}, {"@type": "Question", "name": "How long after closing can you move in?", "acceptedAnswer": {"@type": "Answer", "text": "Move-in timing depends on possession clauses in your purchase contract. Most contracts grant possession at closing or upon recording of the deed. Some sellers negotiate rent-back agreements allowing them days or weeks after closing on a house."}}, {"@type": "Question", "name": "What happens if your lender doesn't fund on closing day?", "acceptedAnswer": {"@type": "Answer", "text": "Funding delays postpone final settlement even if you've signed documents. The transaction isn't complete until your lender's funds arrive at the title company. Document problems, last-minute underwriting issues, or wire transfer problems cause funding delays during the real estate closing."}}, {"@type": "Question", "name": "Can closing costs be included in the mortgage loan?", "acceptedAnswer": {"@type": "Answer", "text": "Some closing costs can be financed into your loan amount while others require cash payment. Seller-paid closing costs don't increase your loan balance during the real estate closing. Lender credits toward closing costs reduce your cash requirement when closing on a house."}}, {"@type": "Question", "name": "What is title insurance and do you really need it?", "acceptedAnswer": {"@type": "Answer", "text": "Title insurance protects against financial loss from ownership defects in your property's title history. Past unpaid taxes, forged documents, undisclosed heirs, or recording errors could threaten your ownership. Owner's title insurance provides lifetime protection against these risks during and after the real estate closing."}}, {"@type": "Question", "name": "How do you know if you're ready for the final walkthrough?", "acceptedAnswer": {"@type": "Answer", "text": "Schedule your final walkthrough 24-48 hours before closing when time exists to address problems. Bring your home inspection report to compare current condition against documented issues. Take photos or videos documenting property condition at walkthrough before the real estate closing."}}, {"@type": "Question", "name": "What's the difference between closing and settlement?", "acceptedAnswer": {"@type": "Answer", "text": "Closing and settlement are terms used interchangeably in most contexts during the real estate closing. Both refer to the final transaction stage where ownership transfers. Financing funds during this process when closing on a house."}}, {"@type": "Question", "name": "Can you negotiate closing costs after receiving the closing disclosure?", "acceptedAnswer": {"@type": "Answer", "text": "You can request corrections if your closing disclosure contains errors. Charges exceeding your loan estimate without justification should be corrected before the real estate closing. Federal law limits increases in certain fees between estimate and disclosure when closing on a house."}}, {"@type": "Question", "name": "What happens to your earnest money deposit at closing?", "acceptedAnswer": {"@type": "Answer", "text": "Your earnest money deposit held in escrow throughout the transaction applies as a credit. This reduces cash required at the real estate closing. Your closing disclosure shows earnest money as a credit in the cash to close calculation when closing on a house."}}, {"@type": "Question", "name": "Do you pay closing costs on a refinance?", "acceptedAnswer": {"@type": "Answer", "text": "Refinancing includes closing costs similar to purchase transactions during the mortgage closing. Appraisal fees, title work, recording charges, and lender fees apply to refinances. Refinance closing costs typically range from 2-4% of the loan amount when closing on a house."}}, {"@type": "Question", "name": "How much should you have in savings after closing?", "acceptedAnswer": {"@type": "Answer", "text": "Financial experts recommend maintaining 3-6 months of expenses in emergency reserves. Your lender verified you had sufficient funds at closing, but depleting all savings leaves you vulnerable. New homeowners face repair costs, maintenance expenses, and potential income disruptions after the mortgage closing."}}, {"@type": "Question", "name": "What is a clear to close status and when do you get it?", "acceptedAnswer": {"@type": "Answer", "text": "Clear to close means your lender completed final underwriting and approved your loan. This status confirms you satisfied all conditions during the mortgage closing preparation. Your loan is ready for document preparation when closing on a house."}}, {"@type": "Question", "name": "Can sellers stay in the house after closing?", "acceptedAnswer": {"@type": "Answer", "text": "Sellers can remain in the property after closing if your purchase contract includes a rent-back agreement. These post-closing possession arrangements specify exactly how long sellers can stay. Daily rent amounts are detailed in the agreement during the real estate closing."}}, {"@type": "Question", "name": "What should you not do before closing on a house?", "acceptedAnswer": {"@type": "Answer", "text": "Avoid opening new credit accounts that change your debt-to-income ratios. New accounts might disqualify you from financing during the mortgage closing. Don't make large purchases depleting your cash reserves needed for the real estate closing."}}, {"@type": "Question", "name": "How long does it take to close on a house with cash?", "acceptedAnswer": {"@type": "Answer", "text": "Cash purchases without financing typically close in 14-30 days. Title work completion and inspection scheduling determine timeline for the real estate closing. Eliminating mortgage processing, underwriting, and lender conditions significantly reduces timeline when closing on a house."}}, {"@type": "Question", "name": "What percentage of home sales fall through before closing?", "acceptedAnswer": {"@type": "Answer", "text": "Real estate industry data shows approximately 5-10% of home sales fail to close. Common reasons include financing denial, inspection issues, appraisal problems, and buyer cold feet. Proper preparation and thorough contingency periods reduce cancellation risk during the real estate closing."}}, {"@type": "Question", "name": "Do you pay property taxes at closing?", "acceptedAnswer": {"@type": "Answer", "text": "Property tax handling at closing depends on timing relative to local tax due dates. Whether sellers already paid current taxes affects your closing costs. If closing mid-year before taxes are due, you might collect a credit from sellers when closing on a house."}}, {"@type": "Question", "name": "What is the closing disclosure waiting period and why does it exist?", "acceptedAnswer": {"@type": "Answer", "text": "The mandatory three-business-day waiting period between closing disclosure delivery and closing protects consumers. This federal requirement gives you time to review final loan terms during the mortgage closing preparation. You compare costs against estimates and verify accuracy when closing on a house."}}, {"@type": "Question", "name": "Can you close without homeowners insurance?", "acceptedAnswer": {"@type": "Answer", "text": "No lender will fund your mortgage without proof of adequate homeowners insurance. Insurance must be effective at closing to protect both you and your lender's interest. Your policy must meet lender minimum coverage requirements during the real estate closing."}}]};
