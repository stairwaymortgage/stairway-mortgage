---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Relocate Anywhere™ — Stairway Mortgage" description="Relocating? Trusted agents in all 50 states. Pre-approval first, then we connect you.">

<!-- HERO -->
<header class="hero">
  <div class="aurora"><span class="orb orb-1"></span><span class="orb orb-2"></span><span class="orb orb-3"></span></div>
  <div class="container-page hero-inner">
    <span class="eyebrow" style="color:var(--teal);opacity:.9">Tools &amp; Resources &middot; Relocate Anywhere&trade;</span>
    <h1 class="display-lg">Relocating? We have <em>trusted agents</em> waiting in all 50 states.</h1>
    <p class="lead">Before we introduce you to a local real estate professional, we get your financing lined up. Pre-approval first, then we connect you with experienced agents anywhere in the country &mdash; the brands you already know and trust.</p>
    <div class="hero-stats">
      <div class="hstat"><div class="n">355+</div><div class="l">Brokerage Brands</div></div>
      <div class="hstat"><div class="n">122,000+</div><div class="l">Agents Nationwide</div></div>
      <div class="hstat"><div class="n">49</div><div class="l">States Covered</div></div>
    </div>
    <div class="hero-ctas">
      <a href="#start" class="btn-primary">Get pre-approved &amp; speak with a Specialist &rarr;</a>
      <a href="#network" class="btn-ghost">Find an agent in my area</a>
    </div>
    <div class="trust-line">
      <span>Jim Blackburn</span><span class="dot">&middot;</span><span>NMLS #1072866</span><span class="dot">&middot;</span><span>NEXA Mortgage licensed in 48 states</span><span class="dot">&middot;</span><span>(954) 993-1625</span>
    </div>
  </div>
</header>

<!-- FUNNEL BANNER -->
<div class="funnel">
  <div class="container-page funnel-inner">
    <p><strong>Step one is always financing.</strong> &nbsp;Getting pre-approved first means your offer is taken seriously the moment you find the right home &mdash; and we match you to the right agent the moment you&rsquo;re ready.</p>
    <a href="#start" class="btn-primary" style="background:rgba(255,255,255,.16);white-space:nowrap">Start with pre-approval &rarr;</a>
  </div>
</div>

<!-- 1-2-3 -->
<section class="section">
  <div class="container-page">
    <div class="sec-head">
      <span class="eyebrow-blue">The Stairway Method</span>
      <h2 class="display-md">Relocation, made as easy as 1&ndash;2&ndash;3</h2>
      <p class="lead">You focus on your family, your friends, and your life&rsquo;s purpose. We handle the logistics that usually make a long-distance move overwhelming.</p>
    </div>
    <div class="steps">
      <div class="step">
        <div class="step-num">1</div><span class="tag">Start Here</span>
        <h3>Get pre-approved &amp; prepare your home</h3>
        <p>We line up your new-home financing and prepare your current home &mdash; whether you&rsquo;re selling or converting it to a rental.</p>
        <ul><li>Pre-approval before you travel</li><li>Prep your home for sale or rent</li><li>Advance planning of your equity transfer</li></ul>
      </div>
      <div class="step">
        <div class="step-num">2</div><span class="tag">We Match You</span>
        <h3>The right local agent, vetted</h3>
        <p>Once you&rsquo;re prepared, we connect you with an experienced agent in your destination &mdash; from a network of brands you already recognize.</p>
        <ul><li>Vetted, top-producing local agents</li><li>An exclusive relocation credit where available</li><li>Trusted national brokerage brands</li></ul>
      </div>
      <div class="step">
        <div class="step-num">3</div><span class="tag">We Handle The Rest</span>
        <h3>A local concierge on the ground</h3>
        <p>Your local bridge handles the move itself &mdash; so the small stuff is already done when you arrive.</p>
        <ul><li>Coordinated moving help</li><li>Utilities switched and set up</li><li>Everything handled, so you don&rsquo;t have to</li></ul>
      </div>
    </div>
  </div>
</section>

<!-- NATIONWIDE NETWORK (centerpiece) -->
<section class="section section-tint" id="network">
  <div class="container-page">
    <div class="sec-head network-intro">
      <span class="eyebrow-blue">Nationwide Real Estate Referral Network</span>
      <h2 class="display-md">Power and name recognition, coast to coast</h2>
      <p>Before introducing you to a local real estate professional, we help buyers understand their financing options and obtain a mortgage pre-approval whenever appropriate. Once prepared, we can connect clients with experienced real estate professionals throughout the United States.</p><p>The brokerages shown below are examples of companies whose agents have participated in referral transactions with our team or may receive referrals based on a client's location, property type, goals, and specific needs. We are not limited to any single brokerage network and strive to identify the best local real estate professional for each individual situation.</p>
    </div>

    <div class="finder">
      <div class="finder-row">
        <div class="finder-field">
          <label>Where are you moving to?</label>
          <select id="stateSelect"><option value="">Select your destination state&hellip;</option></select>
        </div>
        <a href="#start" class="btn-primary" style="white-space:nowrap">Get pre-approved first &rarr;</a>
      </div>
    </div>

    <div class="network-result" id="networkResult">
      <p class="empty-note">Select a destination state above to see the trusted brokerages our clients get referred to in your area.</p>
    </div>
  </div>
</section>

<!-- CALCULATORS -->
<section class="section">
  <div class="container-page">
    <div class="sec-head">
      <span class="eyebrow-blue">Interactive</span>
      <h2 class="display-md">See what relocating with us is worth</h2>
    </div>
    <div class="calc-grid">
      <div class="calc">
        <span class="eyebrow">Calculator 01</span>
        <h3>Your relocation credit</h3>
        <p class="calc-sub">Enter your estimated list price to see your potential relocation credit through the Stairway network. Estimated; available to eligible clients.</p>
        <div class="field"><label>Estimated list price</label><input type="text" id="listPrice" inputmode="numeric" placeholder="$650,000"></div>
        <div class="result" id="savingsResult">
          <div class="cap">Your estimated relocation credit</div>
          <div class="big" id="savingsBig">$0</div>
          <div class="sub">estimated credit through the Stairway network &middot; eligibility applies</div>
        </div>
        <p class="calc-cta">Ready to make it real? <a href="#start">Start with pre-approval &rarr;</a></p>
      </div>
      <div class="calc">
        <span class="eyebrow">Calculator 02</span>
        <h3>How far is your move?</h3>
        <p class="calc-sub">Tell us where you&rsquo;re moving from and to. We&rsquo;ll show the distance &mdash; and you can explore the network waiting on the other side.</p>
        <div class="row2">
          <div class="field"><label>Moving from</label><input type="text" id="fromCity" placeholder="Chicago, IL"></div>
          <div class="field"><label>Moving to</label><input type="text" id="toCity" placeholder="Austin, TX"></div>
        </div>
        <button onclick="runDistance()" style="width:100%;padding:14px;background:var(--ink);color:#fff;border:none;border-radius:8px;font-family:var(--sans);font-weight:600;cursor:pointer">Calculate distance &rarr;</button>
        <div class="result" id="distResult" style="margin-top:20px">
          <div class="cap">Approximate distance</div>
          <div class="dist-badge" id="distBig">&mdash;</div>
          <div class="sub" id="distSub"></div>
        </div>
        <p class="muted" id="distMuted"></p>
      </div>
    </div>
  </div>
</section>

<!-- CONCIERGE -->
<section class="section section-tint">
  <div class="container-page">
    <div class="sec-head">
      <span class="eyebrow-blue">Step Three, In Detail</span>
      <h2 class="display-md">We handle the move so you can handle what matters</h2>
      <p class="lead">By the time you arrive, financing is closed, your old home is sold or rented, and your local team has the rest covered.</p>
    </div>
    <div class="concierge-grid">
      <div class="svc"><span class="ico">&#9632;</span><div><h4>Moving coordination</h4><p>We help organize and schedule your move end to end.</p></div></div>
      <div class="svc"><span class="ico">&#9632;</span><div><h4>Utilities switched</h4><p>Power, water, internet &mdash; transferred and ready before you walk in.</p></div></div>
      <div class="svc"><span class="ico">&#9632;</span><div><h4>Equity transfer planned</h4><p>Your sale proceeds are timed to fund your new purchase smoothly.</p></div></div>
      <div class="svc"><span class="ico">&#9632;</span><div><h4>A local bridge</h4><p>A trusted point person in your new city, ready the day you land.</p></div></div>
    </div>
  </div>
</section>

<!-- LEAD CAPTURE -->
<section class="section lead-sec" id="start">
  <div class="aurora"><span class="orb orb-1"></span><span class="orb orb-2"></span></div>
  <div class="container-page lead-wrap">
    <div class="lead-copy">
      <span class="eyebrow" style="color:var(--teal);opacity:.9">Your First Step</span>
      <h2 class="display-md">Get pre-approved &amp; meet your Specialist</h2>
      <p class="lead">Tell us about your move. A Relocate Anywhere&trade; Specialist will start your pre-approval and line up a trusted local agent in your destination.</p>
      <span class="pre-badge">&#9679; Pre-approval is always step one</span>
    </div>
    <div class="lead-form" id="leadForm">
      <div class="row2">
        <div class="field"><label>First name</label><input type="text" id="fName" placeholder="First"></div>
        <div class="field"><label>Last name</label><input type="text" id="lName" placeholder="Last"></div>
      </div>
      <div class="field"><label>Email</label><input type="email" id="email" placeholder="you@email.com"></div>
      <div class="field"><label>Phone</label><input type="tel" id="phone" placeholder="(555) 000-0000"></div>
      <div class="row2">
        <div class="field"><label>Moving from</label><input type="text" id="lfFrom" placeholder="City, State"></div>
        <div class="field"><label>Moving to</label><input type="text" id="lfTo" placeholder="City, State"></div>
      </div>
      <button onclick="submitLead()">Connect me with a Specialist &rarr;</button>
      <p class="form-note">No obligation. This is not a commitment to lend.</p>
    </div>
    <div class="lead-form lead-success" id="leadSuccess">
      <div class="big">You&rsquo;re all set.</div>
      <p style="opacity:.85">A Relocate Anywhere&trade; Specialist will be in touch shortly to start your pre-approval. Prefer to talk now? Call <strong>(954)&nbsp;993-1625</strong>.</p>
    </div>
  </div>
</section>

<!-- DISCLOSURE (Jim's exact language) -->
<section class="disclosure">
  <div class="container-page">
    <h4>Important Disclosure</h4>
    <p>Brokerage names, trademarks, service marks, and logos are the property of their respective owners and are displayed solely for identification and informational purposes. References to any brokerage do not imply ownership, sponsorship, endorsement, approval, agency relationship, joint venture, exclusive affiliation, or partnership with Stairway Mortgage, the Blackburn Real Estate Team, Jim Blackburn, Olga Blackburn, The Keyes Company, or any affiliated entity unless expressly stated.</p><p>The appearance of a brokerage logo on this website does not constitute a recommendation of one brokerage over another and is intended only to illustrate the broad range of real estate professionals and companies to which clients may be referred.</p><p>If you represent a brokerage displayed on this website and would prefer that your company's logo not be shown, please contact us and we will promptly review and address your request.</p>
  </div>
</section>

<!-- FOOTER -->

</Layout>

<style>





.container-page{max-width:1180px;margin:0 auto;padding:0 28px}
.eyebrow{font-family:var(--font-mono);font-size:.72rem;letter-spacing:.22em;text-transform:uppercase;color:var(--color-ink);opacity:.55;font-weight:500}
.eyebrow-blue{font-family:var(--font-mono);font-size:.72rem;letter-spacing:.22em;text-transform:uppercase;color:var(--color-blue);font-weight:600}
.display-lg{font-family:var(--font-display);font-weight:400;font-size:clamp(2.8rem,6vw,5rem);line-height:1.02;letter-spacing:-.01em}
.display-md{font-family:var(--font-display);font-weight:400;font-size:clamp(2rem,4vw,3.2rem);line-height:1.08}
.lead{font-size:1.18rem;line-height:1.62;opacity:.82;font-weight:300}

.hero{position:relative;overflow:hidden;padding:120px 0 96px;background:var(--color-ink);color:var(--color-paper)}
.aurora{position:absolute;inset:0;z-index:0;overflow:hidden}
.orb{position:absolute;border-radius:50%;filter:blur(80px);opacity:.55;mix-blend-mode:screen}
.orb-1{width:520px;height:520px;background:var(--color-blue);top:-120px;left:-80px;animation:drift1 24s ease-in-out infinite}
.orb-2{width:440px;height:440px;background:var(--teal);bottom:-140px;right:-60px;animation:drift2 28s ease-in-out infinite}
.orb-3{width:380px;height:380px;background:var(--peri);top:30%;left:55%;animation:drift3 33s ease-in-out infinite}
@keyframes drift1{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(60px,40px) scale(1.1)}}
@keyframes drift2{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(-50px,-30px) scale(1.08)}}
@keyframes drift3{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(-40px,50px) scale(.92)}}
.hero-inner{position:relative;z-index:1;max-width:860px}
.hero h1{margin:22px 0 24px}
.hero h1 em{font-style:italic;color:var(--teal)}
.hero .lead{opacity:.88;max-width:640px}
.hero-stats{display:flex;gap:36px;margin-top:40px;flex-wrap:wrap}
.hstat .n{font-family:var(--font-display);font-size:2.6rem;line-height:1;color:var(--teal)}
.hstat .l{font-family:var(--font-mono);font-size:.68rem;letter-spacing:.12em;text-transform:uppercase;opacity:.6;margin-top:6px}
.hero-ctas{display:flex;gap:14px;margin-top:38px;flex-wrap:wrap}
.btn-primary{display:inline-flex;align-items:center;gap:10px;background:var(--color-blue);color:#fff;padding:15px 30px;border-radius:6px;font-weight:600;font-size:.98rem;text-decoration:none;transition:transform .2s,box-shadow .2s;border:none;cursor:pointer;font-family:var(--font-body)}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 12px 32px rgba(24,69,214,.4)}
.btn-ghost{display:inline-flex;align-items:center;gap:10px;background:transparent;color:var(--color-paper);padding:15px 26px;border-radius:6px;font-weight:600;font-size:.98rem;text-decoration:none;border:1.5px solid rgba(255,255,255,.25);transition:border-color .2s,background .2s}
.btn-ghost:hover{border-color:var(--teal);background:rgba(255,255,255,.05)}
.trust-line{font-family:var(--font-mono);font-size:.74rem;letter-spacing:.04em;margin-top:34px;opacity:.55;display:flex;gap:10px;flex-wrap:wrap}
.trust-line .dot{opacity:.4}

.section{padding:96px 0}
.section-tint{background:var(--color-paper-tint)}
.sec-head{max-width:720px;margin-bottom:54px}
.sec-head h2{margin:16px 0 18px}

/* funnel banner */
.funnel{background:linear-gradient(100deg,var(--color-blue),var(--peri));color:#fff;padding:30px 0}
.funnel-inner{display:flex;align-items:center;gap:24px;justify-content:space-between;flex-wrap:wrap}
.funnel p{font-size:1.05rem;font-weight:500;max-width:680px}
.funnel strong{font-family:var(--font-display);font-style:italic;font-weight:400;font-size:1.2rem}

/* steps */
.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:28px}
.step{background:var(--color-paper);border:1px solid var(--color-bone);border-radius:12px;padding:34px 30px;position:relative;overflow:hidden;transition:transform .25s,box-shadow .25s}
.step:hover{transform:translateY(-4px);box-shadow:0 18px 44px rgba(10,14,26,.09)}
.step::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:var(--accent)}
.step:nth-child(1){--accent:var(--color-blue)}.step:nth-child(2){--accent:var(--teal)}.step:nth-child(3){--accent:var(--color-rust)}
.step-num{font-family:var(--font-display);font-size:3.4rem;line-height:1;color:var(--accent)}
.step .tag{font-family:var(--font-mono);font-size:.66rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);font-weight:600;margin-top:6px;display:block}
.step h3{font-family:var(--font-display);font-weight:400;font-size:1.5rem;margin:6px 0 12px;line-height:1.12}
.step p{font-size:.96rem;opacity:.78}
.step ul{list-style:none;margin-top:14px;display:flex;flex-direction:column;gap:8px}
.step li{font-size:.88rem;opacity:.74;padding-left:20px;position:relative}
.step li::before{content:'';position:absolute;left:0;top:9px;width:7px;height:7px;border-radius:50%;background:var(--accent)}

/* NETWORK / find-an-agent centerpiece */
.network-intro p{font-size:1.05rem;opacity:.82;max-width:760px;margin-bottom:16px;font-weight:300}
.finder{background:var(--color-paper);border:1px solid var(--color-bone);border-radius:16px;padding:34px;margin-top:36px;box-shadow:0 14px 40px rgba(10,14,26,.06)}
.finder-row{display:flex;gap:14px;align-items:flex-end;flex-wrap:wrap}
.finder-field{flex:1;min-width:200px}
.finder-field label{display:block;font-family:var(--font-mono);font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;opacity:.6;margin-bottom:8px}
.finder-field select,.finder-field input{width:100%;padding:14px 16px;border:1.5px solid var(--color-bone);border-radius:8px;font-family:var(--font-body);font-size:1.02rem;background:var(--color-paper);color:var(--color-ink)}
.finder-field select:focus,.finder-field input:focus{outline:none;border-color:var(--color-blue)}

.network-result{margin-top:40px}
.nr-head{display:flex;justify-content:space-between;align-items:baseline;gap:16px;flex-wrap:wrap;margin-bottom:20px}
.nr-head h3{font-family:var(--font-display);font-weight:400;font-size:1.8rem}
.nr-head .count{font-family:var(--font-mono);font-size:.78rem;letter-spacing:.08em;opacity:.6}
.logo-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px}
.logo-card{background:var(--color-paper);border:1px solid var(--color-bone);border-radius:10px;padding:22px 20px;min-height:104px;display:flex;flex-direction:column;justify-content:center;gap:6px;transition:transform .2s,box-shadow .2s,border-color .2s;animation:fadeUp .4s both}
.logo-card:hover{transform:translateY(-3px);box-shadow:0 14px 32px rgba(10,14,26,.1);border-color:var(--color-blue)}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
/* the brand wordmark - styled placeholder, logo-ready */
.logo-card .logo-img{max-width:100%;max-height:52px;width:auto;object-fit:contain;align-self:flex-start}
.logo-card .wordmark{font-family:var(--font-display);font-size:1.18rem;line-height:1.15;color:var(--color-ink);display:none}
.logo-card.has-text .wordmark{display:block}
.logo-card .meta{font-family:var(--font-mono);font-size:.68rem;letter-spacing:.06em;opacity:.55;text-transform:uppercase}
.logo-card .state-tag{font-family:var(--font-mono);font-size:.64rem;opacity:.45;letter-spacing:.08em}
.empty-note{opacity:.6;font-style:italic;padding:30px 0}

/* calculators */
.calc-grid{display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:start}
.calc{background:var(--color-paper);border:1px solid var(--color-bone);border-radius:14px;padding:38px 34px}
.calc h3{font-family:var(--font-display);font-weight:400;font-size:1.7rem;margin:14px 0 6px}
.calc .calc-sub{font-size:.94rem;opacity:.7;margin-bottom:26px}
.field{margin-bottom:20px}
.field label{display:block;font-family:var(--font-mono);font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;opacity:.6;margin-bottom:8px}
.field input,.field select{width:100%;padding:14px 16px;border:1.5px solid var(--color-bone);border-radius:8px;font-family:var(--font-body);font-size:1.02rem;background:var(--color-paper);color:var(--color-ink)}
.field input:focus,.field select:focus{outline:none;border-color:var(--color-blue)}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.result{margin-top:8px;padding:24px;border-radius:10px;background:var(--color-ink);color:var(--color-paper);text-align:center;opacity:0;transform:translateY(8px);transition:opacity .35s,transform .35s}
.result.show{opacity:1;transform:none}
.result .big{font-family:var(--font-display);font-size:3.2rem;line-height:1;color:var(--teal);margin:6px 0}
.result .cap{font-family:var(--font-mono);font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;opacity:.65}
.result .sub{font-size:.92rem;opacity:.8;margin-top:10px}
.dist-badge{font-family:var(--font-display);font-size:2.6rem;color:var(--teal);line-height:1}
.muted{font-size:.84rem;opacity:.55;margin-top:14px;line-height:1.5}
.calc-cta{margin-top:18px;font-size:.9rem;opacity:.8;text-align:center}
.calc-cta a{color:var(--color-blue);font-weight:600;text-decoration:none}

/* concierge */
.concierge-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:18px;margin-top:40px}
.svc{display:flex;gap:16px;align-items:flex-start;padding:22px 24px;background:var(--color-paper);border:1px solid var(--color-bone);border-radius:10px}
.svc .ico{font-family:var(--font-display);font-size:1.5rem;color:var(--color-blue)}
.svc h4{font-size:1.02rem;margin-bottom:4px}
.svc p{font-size:.9rem;opacity:.72}

/* lead capture */
.lead-sec{background:var(--color-ink);color:var(--color-paper);position:relative;overflow:hidden}
.lead-sec .aurora .orb{opacity:.4}
.lead-wrap{position:relative;z-index:1;display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center}
.lead-copy h2{color:var(--color-paper);margin:16px 0 18px}
.lead-copy .lead{opacity:.85}
.lead-copy .pre-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(13,191,177,.14);border:1px solid rgba(13,191,177,.4);color:var(--teal);font-family:var(--font-mono);font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;padding:8px 14px;border-radius:40px;margin-top:18px}
.lead-form{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.12);border-radius:16px;padding:36px 32px;backdrop-filter:blur(8px)}
.lead-form .field label{color:var(--color-paper);opacity:.7}
.lead-form .field input,.lead-form .field select{background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.18);color:var(--color-paper)}
.lead-form .field input::placeholder{color:rgba(255,255,255,.4)}
.lead-form button{width:100%;padding:16px;background:var(--color-blue);color:#fff;border:none;border-radius:8px;font-family:var(--font-body);font-weight:600;font-size:1.02rem;cursor:pointer;transition:transform .2s,box-shadow .2s;margin-top:6px}
.lead-form button:hover{transform:translateY(-2px);box-shadow:0 12px 32px rgba(24,69,214,.45)}
.form-note{font-size:.78rem;opacity:.55;margin-top:16px;text-align:center}
.lead-success{display:none;text-align:center;padding:40px 10px}
.lead-success.show{display:block}
.lead-success .big{font-family:var(--font-display);font-size:2.2rem;color:var(--teal);margin-bottom:10px}

/* disclosure */
