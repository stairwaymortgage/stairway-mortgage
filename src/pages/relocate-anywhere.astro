const stateSel=document.getElementById('stateSelect');
const states=Object.keys(PARTNERS).sort();
states.forEach(s=>{const o=document.createElement('option');o.value=s;o.textContent=s;stateSel.appendChild(o);});

stateSel.addEventListener('change',()=>{if(stateSel.value)renderState(stateSel.value);});

const LOGO_BASE='/logos/';            // repo public/logos/  -> served at /logos/
const LOGO_EXT=['jpg','png','webp','svg']; // try in this order, mixed formats OK
function slugify(name){
  return name.toLowerCase()
    .replace(/&/g,'and')
    .replace(/[\u2019\u2018']/g,'')
    .replace(/[^a-z0-9]+/g,'-')
    .replace(/^-+|-+$/g,'');
}
// img cascades through extensions on error; when all fail it removes itself,
// revealing the styled text wordmark underneath. Page never shows a broken image.
function logoCard(brand,state,i){
  const meta = brand.a ? brand.a.toLocaleString('en-US')+' agents' : 'Network partner';
  const st = state ? '<div class="state-tag">'+state+'</div>' : '';
  const slug = slugify(brand.n);
  const first = LOGO_BASE+slug+'.'+LOGO_EXT[0];
  const onerr = "var x=this,e=JSON.parse(x.dataset.ext),n=++x.dataset.i|0;"
              + "if(n<e.length){x.src='"+LOGO_BASE+slug+".'+e[n];}else{x.parentNode.classList.add('has-text');x.remove();}";
  const img = '<img class="logo-img" src="'+first+'" alt="'+brand.n+' logo" '
            + 'data-ext='+"'"+JSON.stringify(LOGO_EXT)+"'"+' data-i="0" '
            + 'onerror="'+onerr+'">';
  return '<div class="logo-card" style="animation-delay:'+(i*0.03)+'s">'
       + img
       + '<div class="wordmark">'+brand.n+'</div>'
       + '<div class="meta">'+meta+'</div>'+st+'</div>';
}
function renderState(state){
  const d=PARTNERS[state];const box=document.getElementById('networkResult');
  let h='<div class="nr-head"><h3>Trusted brokerages in '+state+'</h3><span class="count">'+d.total+' brokerage'+(d.total!==1?'s':'')+' in our network</span></div>';
  h+='<div class="logo-grid">'+d.brands.map((b,i)=>logoCard(b,'',i)).join('')+'</div>';
  box.innerHTML=h;
}

// Calc A
const lp=document.getElementById('listPrice'),sRes=document.getElementById('savingsResult'),sBig=document.getElementById('savingsBig');
lp.addEventListener('input',()=>{
  let raw=lp.value.replace(/[^0-9]/g,'');
  lp.value=raw?'$'+parseInt(raw,10).toLocaleString('en-US'):'';
  const v=parseInt(raw||'0',10);
  if(v>0){sBig.textContent='$'+Math.round(v*0.005).toLocaleString('en-US');sRes.classList.add('show');}else{sRes.classList.remove('show');}
});

// Calc B
async function geocode(q){const u='https://nominatim.openstreetmap.org/search?format=json&limit=1&q='+encodeURIComponent(q);const r=await fetch(u,{headers:{'Accept':'application/json'}});const j=await r.json();return j.length?{lat:parseFloat(j[0].lat),lon:parseFloat(j[0].lon)}:null;}
function haversine(a,b){const R=3958.8,t=x=>x*Math.PI/180;const dLat=t(b.lat-a.lat),dLon=t(b.lon-a.lon);const h=Math.sin(dLat/2)**2+Math.cos(t(a.lat))*Math.cos(t(b.lat))*Math.sin(dLon/2)**2;return 2*R*Math.asin(Math.sqrt(h));}
async function runDistance(){
  const from=document.getElementById('fromCity').value.trim(),to=document.getElementById('toCity').value.trim();
  const dRes=document.getElementById('distResult'),dBig=document.getElementById('distBig'),dSub=document.getElementById('distSub');
  if(!from||!to){return;}
  dBig.textContent='Calculating…';dRes.classList.add('show');dSub.textContent='';
  try{const[a,b]=await Promise.all([geocode(from),geocode(to)]);
    if(a&&b){const mi=haversine(a,b);dBig.innerHTML=Math.round(mi).toLocaleString('en-US')+' <span style="font-size:1.1rem">miles</span>';dSub.textContent='straight-line distance from '+from+' to '+to;}
    else{dBig.textContent='—';dSub.textContent='Couldn’t locate one of those cities — check spelling.';}
  }catch(e){dBig.textContent='—';dSub.textContent='Distance lookup unavailable right now.';}
}

// Lead
function submitLead(){
  const f=document.getElementById('fName').value.trim(),email=document.getElementById('email').value.trim();
  if(!f||!email){alert('Please add at least your first name and email.');return;}
  document.getElementById('leadForm').style.display='none';
  document.getElementById('leadSuccess').classList.add('show');
}
