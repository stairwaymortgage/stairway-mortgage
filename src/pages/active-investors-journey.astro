---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Real-Estate Investor — Stairway Mortgage" description="Scale your rental portfolio with rental-income loans and 300+ lenders.">
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">Your Situation · Real-Estate Investor</span>
        <h1 class="display-xl mt-6 mb-6">Scale your portfolio <em class="not-italic text-[var(--color-blue)]">faster</em>.</h1>
        <p class="lede max-w-xl mx-auto mb-6">Rental-income loans, flexible-income programs, and portfolio strategies — built for investors who move at deal speed.</p>
        <p class="mono text-[11px] text-[var(--color-mute)] mt-6">NMLS #1072866</p>
        <div class="flex flex-wrap gap-3 justify-center mt-10">
          <a href="/build-a-wealth-plan-journey/" class="btn btn-blue btn-arrow text-base px-6 py-3.5">See Investor Loans</a>
          <a href="/contact-us/" class="btn btn-ghost text-base px-6 py-3.5">Talk to Our Team</a>
        </div>
      </div>

      <!-- stw-img: Pexels 8847133 -->
      <figure class="hero-photo" style="max-width:1040px;margin:2.5rem auto 0;border-radius:20px;overflow:hidden;box-shadow:0 30px 70px -28px rgba(10,14,26,.45);aspect-ratio:16/9;">
        <img src="https://images.pexels.com/photos/8847133/pexels-photo-8847133.jpeg?auto=compress&cs=tinysrgb&w=1200"
             alt="Two real estate investment professionals reviewing documents together" loading="eager"
             style="width:100%;height:100%;object-fit:cover;object-position:center 30%;display:block;"
             onerror="this.onerror=null;this.src='https://placehold.co/1000x1100/16335B/FAFAF9?text=Stairway';">
      </figure>
    </div>
  </section>
</Layout>
