---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Real-Estate Investor — Stairway Mortgage" description="Scale your rental portfolio with rental-income loans and 300+ lenders.">
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">Your Situation · Real-Estate Investor</span>
        <h1 class="display-xl mt-6 mb-6">Scale your portfolio <em class="not-italic text-[var(--color-blue)]">faster</em>.</h1>
        <p class="lede max-w-xl mx-auto mb-6">Rental-income loans, flexible-income programs, and portfolio strategies — built for investors who move at deal speed.</p>
        <p class="mono text-[11px] text-[var(--color-mute)] mt-6">NMLS #1072866</p>
        <!-- stw-img: Pexels 8847133 -->
        <figure class="hero-photo" style="max-width:900px;margin:1.75rem auto 2.25rem;border-radius:20px;overflow:hidden;box-shadow:0 30px 70px -28px rgba(10,14,26,.45);aspect-ratio:3/2;">
          <img src="https://images.pexels.com/photos/8847133/pexels-photo-8847133.jpeg?auto=compress&cs=tinysrgb&w=1280"
               alt="Two real estate investment professionals reviewing documents together" loading="eager"
               style="width:100%;height:100%;object-fit:cover;object-position:center 30%;display:block;"
               onerror="this.onerror=null;this.src='https://placehold.co/1000x667/16335B/FAFAF9?text=Stairway';">
        </figure>

        <div class="flex flex-wrap gap-3 justify-center mt-10">
          <a href="/see-my-options/" class="btn btn-blue btn-arrow text-base px-6 py-3.5">See Investor Loans</a>
          <a href="/contact-us/" class="btn btn-ghost text-base px-6 py-3.5">Talk to Our Team</a>
        </div>
      </div>
    </div>
  </section>

  <!-- LIFE GALLERY — real people, real milestones -->
  <section class="section-tight bg-[var(--color-paper-tint)]">
    <div class="container-page">
      <div class="text-center max-w-2xl mx-auto mb-8 reveal">
        <span class="eyebrow eyebrow-blue mb-4">The investor's playbook</span>
        <h2 class="display-lg mt-4">Where strategy meets <em class="not-italic font-light">real life</em>.</h2>
      </div>
      <div class="grid sm:grid-cols-3 gap-5">
        <figure class="reveal" style="margin:0;">
          <!-- stw-img: Pexels 7979605 -->
          <div style="border-radius:16px;overflow:hidden;aspect-ratio:4/3;box-shadow:0 20px 45px -22px rgba(10,14,26,.4);">
            <img src="https://images.pexels.com/photos/7979605/pexels-photo-7979605.jpeg?auto=compress&cs=tinysrgb&w=800"
                 alt="Investor shaking hands with a lending advisor after structuring a deal" loading="lazy"
                 style="width:100%;height:100%;object-fit:cover;object-position:center 35%;display:block;"
                 onerror="this.onerror=null;this.src='https://placehold.co/600x450/16335B/FAFAF9?text=Stairway';">
          </div>
          <figcaption style="text-align:center;font-size:12.5px;color:var(--color-mute);margin-top:0.6rem;">Partnering with advisors who structure the deal</figcaption>
        </figure>
        <figure class="reveal" style="margin:0;transition-delay:80ms;">
          <!-- stw-img: Pexels 9869388 -->
          <div style="border-radius:16px;overflow:hidden;aspect-ratio:4/3;box-shadow:0 20px 45px -22px rgba(10,14,26,.4);">
            <img src="https://images.pexels.com/photos/9869388/pexels-photo-9869388.jpeg?auto=compress&cs=tinysrgb&w=800"
                 alt="Investor couple running the numbers on a rental property at their laptop" loading="lazy"
                 style="width:100%;height:100%;object-fit:cover;object-position:center 35%;display:block;"
                 onerror="this.onerror=null;this.src='https://placehold.co/600x450/16335B/FAFAF9?text=Stairway';">
          </div>
          <figcaption style="text-align:center;font-size:12.5px;color:var(--color-mute);margin-top:0.6rem;">Running the numbers before every offer</figcaption>
        </figure>
        <figure class="reveal" style="margin:0;transition-delay:160ms;">
          <!-- stw-img: Pexels 8120623 -->
          <div style="border-radius:16px;overflow:hidden;aspect-ratio:4/3;box-shadow:0 20px 45px -22px rgba(10,14,26,.4);">
            <img src="https://images.pexels.com/photos/8120623/pexels-photo-8120623.jpeg?auto=compress&cs=tinysrgb&w=800"
                 alt="Family enjoying the home their real-estate income helped provide" loading="lazy"
                 style="width:100%;height:100%;object-fit:cover;object-position:center 35%;display:block;"
                 onerror="this.onerror=null;this.src='https://placehold.co/600x450/16335B/FAFAF9?text=Stairway';">
          </div>
          <figcaption style="text-align:center;font-size:12.5px;color:var(--color-mute);margin-top:0.6rem;">Cash flow that funds the life you want</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- People image -->
  <div style="max-width:1140px;margin:0 auto;padding:0 1.5rem;">
    <figure style="margin:0;border-radius:12px;overflow:hidden;aspect-ratio:21/9;">
      <img src="https://images.pexels.com/photos/7681091/pexels-photo-7681091.jpeg?auto=compress&cs=tinysrgb&w=1800" alt="Real estate investor reviewing property portfolio" loading="lazy" style="width:100%;height:100%;object-fit:cover;object-position:center 35%;display:block;" onerror="this.onerror=null;this.parentElement.style.display='none';">
    </figure>
  </div>

  <!-- People image -->
  <div style="max-width:1140px;margin:0 auto;padding:0 1.5rem;margin-top:2rem;">
    <figure style="margin:0;border-radius:12px;overflow:hidden;aspect-ratio:21/9;">
      <img src="https://images.pexels.com/photos/3184306/pexels-photo-3184306.jpeg?auto=compress&cs=tinysrgb&w=1800" alt="Investment team planning a real estate wealth strategy" loading="lazy" style="width:100%;height:100%;object-fit:cover;object-position:center 35%;display:block;" onerror="this.onerror=null;this.parentElement.style.display='none';">
    </figure>
  </div>
</Layout>
