---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Reverse Mortgage Quote — Stairway Mortgage" description="Explore reverse mortgage options for homeowners 55+.">
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">Quick Quote · Reverse Mortgage</span>
        <h1 class="display-xl mt-6 mb-6">Explore your <em class="not-italic text-[var(--color-blue)]">options</em>.</h1>
        <p class="lede max-w-xl mx-auto mb-8">See how your home equity can fund retirement. HECM at 62+; some programs at 55+. No obligation.</p>
        <div class="flex flex-wrap gap-3 justify-center mt-10">
          <a href="/reverse-mortgage-journey/" class="btn btn-blue btn-arrow text-base px-6 py-3.5">See My Options</a>
          <a href="tel:+19549931625" class="btn btn-ghost text-base px-6 py-3.5">Call (954) 993-1625</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
