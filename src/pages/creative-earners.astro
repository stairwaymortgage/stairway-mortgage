      <div class="testimonials-grid">

        <article class="testim-card">
          <div class="testim-avatar testim-avatar-1"><img src="https://i.pravatar.cc/300?img=56" alt="Mariah K., YouTube creator and brand-sponsorship LLC owner" width="300" height="300" loading="lazy" onerror="this.onerror=null;this.src='https://placehold.co/300x300/E8EEFF/0F2EA0/png?text=56';"></div>
