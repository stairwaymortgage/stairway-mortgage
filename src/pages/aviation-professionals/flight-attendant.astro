          padding-bottom: var(--s-3);
          border-bottom: 1px solid var(--border);
        }
        .sources-list { list-style: none; padding: 0; }
        .sources-list li {
          padding: var(--s-3) 0;
          font-size: var(--text-sm);
          line-height: 1.55;
          color: var(--ink-light);
          border-bottom: 1px solid var(--border);
        }
        .sources-list li:last-child { border-bottom: 0; }
        .sources-list a {
          color: var(--blue);
          text-decoration: underline;
          text-underline-offset: 2px;
        }
        .sources-list a:hover { color: var(--blue-deep); }
