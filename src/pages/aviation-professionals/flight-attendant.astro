    </div>
  </section>

  <!-- ============================================================
       SECTION 16 · PRE-CTA
       ============================================================ -->
  <section class="section">
    <div class="container">
      <div class="section-header" style="margin-bottom: var(--s-6);">
        <div class="eyebrow">11 · The outcome</div>
        <h2>A flight attendant mortgage, structured around the pay stub you actually fly.</h2>
      </div>
      <div class="pre-cta-photo">
        <img src="https://images.pexels.com/photos/5778355/pexels-photo-5778355.jpeg?auto=compress&cs=tinysrgb&w=1400" alt="Airline pilot and flight attendant standing together in uniforms" loading="lazy" onerror="this.onerror=null;this.src='https://placehold.co/1400x700/0A0E1A/E8EEFF/png?text=Airline+Crew';">
        <div class="pre-cta-photo-caption">
          <span class="label">What we're building for</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 17 · FINAL CTA
       ============================================================ -->
