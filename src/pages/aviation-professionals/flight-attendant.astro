    <div class="container">
      <div class="eyebrow" style="color: var(--blue-soft); margin-bottom: var(--s-5);">Ready when you are</div>
      <h2 class="display-2" style="color: var(--paper);">Talk to a lender who reads your CBA, not just your W-2.</h2>
      <p>Twenty minutes on the phone with Jim. He'll tell you which income components qualify, what your monthly payment looks like at your target home price, and what to do next. No credit pull, no commitment.</p>
      <div class="final-cta-actions">
        <a href="https://stairwaymortgage.com/purchase-inquiry/" class="btn btn-on-dark btn-large">Get your flight attendant pre-approval</a>
        <a href="https://stairwaymortgage.com/schedule-call" class="btn btn-on-dark-secondary btn-large">Talk to Our Team</a>
        <a href="https://stairwaymortgage.com/discovery-quiz/" class="btn btn-on-dark-secondary btn-large">Take the discovery quiz</a>
      </div>
    </div>
  </section>

`;
