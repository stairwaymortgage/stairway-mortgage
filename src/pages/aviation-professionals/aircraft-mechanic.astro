          <figure class="bio-photo">
            <img src="https://images.pexels.com/photos/2381069/pexels-photo-2381069.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=600" alt="Jim Blackburn, founder of Stairway Mortgage" width="600" height="600" loading="lazy" onerror="this.onerror=null;this.src='https://placehold.co/600x600/0A0E1A/E8EEFF/png?text=Jim+Blackburn';">
          </figure>
