  }
  .rate-vs-cost__bar--a { background: var(--color-bone); }
  .rate-vs-cost__bar--b { background: var(--color-blue); }
  .rate-vs-cost__val { font-size: 14px; font-weight: 500; color: var(--color-ink); }
  .rate-vs-cost__bar--b .rate-vs-cost__val { color: var(--color-paper); }
  .rate-vs-cost__sub {
    display: block;
    font-size: 11px;
    color: var(--color-mute);
    margin-top: 0.4rem;
  }
  .rate-vs-cost__total {
    display: block;
    font-size: 16px;
    font-weight: 500;
    margin-top: 0.25rem;
  }

  /* ── Stat band ── */
  .stat-band {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 2rem;
  }
  .stat-band__item { text-align: center; flex: 1; min-width: 120px; }
  .stat-band__num {
    display: block;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-paper);
  }
  .stat-band__label {
    display: block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.5;
    margin-top: 0.4rem;
  }

  /* ── Blue-wash stat band overrides ── */
  .stat-band-blue .stat-band__num { color: var(--color-ink); }
  .stat-band-blue .stat-band__label { color: var(--color-mute); opacity: 1; }

  /* ── Flip cards ── */
  .flip-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }
  .flip-card {
    perspective: 600px;
    cursor: pointer;
    height: 180px;
  }
  .flip-card__inner {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.5s;
    transform-style: preserve-3d;
  }
  .flip-card:hover .flip-card__inner,
  .flip-card:focus .flip-card__inner {
    transform: rotateY(180deg);
  }
  .flip-card__front,
  .flip-card__back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    border: 1px solid var(--color-bone);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .flip-card__front { background: var(--color-paper); }
  .flip-card__back {
    background: var(--color-ink);
    color: var(--color-paper);
    transform: rotateY(180deg);
    gap: 0.5rem;
    align-items: center;
    text-align: center;
  }
  .flip-card__num {
    font-size: 11px;
    color: var(--color-rust);
    margin-bottom: 0.5rem;
  }

  /* ── Reviews carousel ── */
  .reviews-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 1rem;
  }
  .reviews-track {
    display: flex;
    gap: 1.25rem;
    animation: scroll-reviews 40s linear infinite;
    width: max-content;
  }
  @keyframes scroll-reviews {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .reviews-track:hover { animation-play-state: paused; }
  .review-card {
    flex-shrink: 0;
    width: 380px;
    border: 1px solid rgba(250, 250, 247, 0.15);
    border-radius: 16px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .review-card__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-blue-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .review-card__initials {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-paper);
  }
  .review-card__text {
    font-size: 15px;
    line-height: 1.45;
    color: var(--color-paper);
    font-weight: 400;
    flex: 1;
  }
  .review-card__meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-size: 12px;
    color: rgba(250, 250, 247, 0.6);
  }
  .review-card__meta strong { color: var(--color-paper); font-weight: 500; }
  .review-card__source {
    margin-left: auto;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.5;
  }

  /* ── Summit glow ── */
  .summit-glow {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .summit-glow__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
  }
  .summit-glow__blob--blue {
    width: 200px;
    height: 200px;
    background: var(--color-blue);
    opacity: 0.2;
    bottom: -40px;
    right: 10%;
  }
  .summit-glow__blob--rust {
    width: 160px;
    height: 160px;
    background: var(--color-rust);
    opacity: 0.15;
    top: -20px;
    left: 15%;
  }

  /* ── Mobile sticky CTA bar ── */
  .mobile-cta-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--color-ink);
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    z-index: 45;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 -4px 20px rgba(10, 14, 26, 0.3);
  }
  .mobile-cta-bar.is-visible { transform: translateY(0); }
  @media (min-width: 980px) { .mobile-cta-bar { display: none !important; } }
  .mobile-cta-bar__btn { flex: 1; text-align: center; font-size: 14px !important; padding: 0.6rem 1rem !important; }
  .mobile-cta-bar__phone {
    color: var(--color-paper);
    text-decoration: none;
    font-size: 12px;
    opacity: 0.7;
    white-space: nowrap;
  }
  .mobile-cta-bar__close {
    color: var(--color-paper);
    background: none;
    border: none;
    font-size: 20px;
    cursor: pointer;
    opacity: 0.5;
    padding: 4px;
  }

  /* ── Mobile headline weight fix ── */
  @media (max-width: 640px) {
    .display-xl, .display-lg, .display-md {
      font-weight: 500;
      font-variation-settings: "opsz" 48;
    }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .reviews-track { animation: none; }
    .flip-card__inner { transition: none; }
    .equity-bar__mortgage,
    .equity-bar__available,
    .equity-bar__reserved { transition: none; }
  }
</style>

<!-- ═══════════════════════════════════════════════════════════
     PAGE SCRIPT — calculator, path toggle, reviews, count-up
     ═══════════════════════════════════════════════════════════ -->
<script is:inline>
(function() {
  'use strict';
  var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ── Count-up on scroll ── */
  function countUp(el) {
    var target = parseFloat(el.dataset.countup);
    var suffix = el.dataset.suffix || '';
    var prefix = el.dataset.prefix || '';
    var decimals = parseInt(el.dataset.decimals) || 0;
    var duration = 1200;
    var start = performance.now();

    function tick(now) {
      var elapsed = now - start;
      var progress = Math.min(elapsed / duration, 1);
      var ease = 1 - Math.pow(1 - progress, 3);
      var current = ease * target;
      el.textContent = prefix + (decimals ? current.toFixed(decimals) : Math.round(current)) + suffix;
      if (progress < 1) requestAnimationFrame(tick);
    }
    if (prefersReduced) {
      el.textContent = prefix + (decimals ? target.toFixed(decimals) : target) + suffix;
    } else {
      requestAnimationFrame(tick);
    }
  }

  /* ── Scroll observer for reveals + count-ups ── */
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (!e.isIntersecting) return;
        e.target.classList.add('in-view');
        io.unobserve(e.target);
        e.target.querySelectorAll('[data-countup]').forEach(countUp);
        if (e.target.dataset && e.target.dataset.countup) countUp(e.target);
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal, .trust-ribbon, .stat-band').forEach(function(el) {
      io.observe(el);
    });
  }

  /* ── Path toggle ── */
  var pathToggle = document.getElementById('path-toggle');
  var refiCalc = document.getElementById('refi-calc');
  var helocCalc = document.getElementById('heloc-calc');

  if (pathToggle) {
    var pathCards = pathToggle.querySelectorAll('.path-card');
    pathCards.forEach(function(card) {
      card.addEventListener('click', function() {
        pathCards.forEach(function(c) {
          c.classList.remove('is-active');
          c.setAttribute('aria-pressed', 'false');
        });
        card.classList.add('is-active');
        card.setAttribute('aria-pressed', 'true');

        var path = card.dataset.path;
        if (path === 'refi') {
          refiCalc.style.display = '';
          helocCalc.style.display = 'none';
        } else {
          refiCalc.style.display = 'none';
          helocCalc.style.display = '';
        }
      });
    });
  }

  /* ── Helpers ── */
  function parseCurrency(str) {
    return parseFloat(str.replace(/[^0-9.]/g, '')) || 0;
  }
  function parseRate(str) {
    return parseFloat(str.replace(/[^0-9.]/g, '')) || 0;
  }
  function formatCurrency(n) {
    return '$' + Math.round(n).toLocaleString('en-US');
  }

  /* ── Refi Calculator ── */
  var refiBtn = document.getElementById('refi-calc-btn');
  if (refiBtn) {
    refiBtn.addEventListener('click', function() {
      var balance = parseCurrency(document.getElementById('refi-balance').value);
      var currentRate = parseRate(document.getElementById('refi-current-rate').value) / 100 / 12;
      var newRate = parseRate(document.getElementById('refi-new-rate').value) / 100 / 12;
      var n = 360; // 30-year
      var closingCosts = 6000;

      if (balance <= 0 || currentRate <= 0 || newRate <= 0) return;

      var currentPayment = balance * (currentRate * Math.pow(1 + currentRate, n)) / (Math.pow(1 + currentRate, n) - 1);
      var newPayment = balance * (newRate * Math.pow(1 + newRate, n)) / (Math.pow(1 + newRate, n) - 1);
      var monthlySavings = currentPayment - newPayment;

      if (monthlySavings <= 0) {
        document.getElementById('refi-monthly').textContent = '$0';
        document.getElementById('refi-breakeven').textContent = 'N/A';
        document.getElementById('refi-total').textContent = '$0';
        return;
      }

      var breakeven = Math.ceil(closingCosts / monthlySavings);
      var totalSavings = (monthlySavings * n) - closingCosts;

      document.getElementById('refi-monthly').textContent = formatCurrency(monthlySavings);
      document.getElementById('refi-breakeven').textContent = breakeven;
      document.getElementById('refi-total').textContent = formatCurrency(Math.max(0, totalSavings));
    });
  }

  /* ── HELOC / Equity Calculator ── */
  var helocBtn = document.getElementById('heloc-calc-btn');
  if (helocBtn) {
    helocBtn.addEventListener('click', function() {
      var value = parseCurrency(document.getElementById('heloc-value').value);
      var balance = parseCurrency(document.getElementById('heloc-balance').value);

      if (value <= 0) return;

      var equity = value - balance;
      var maxLoan = value * 0.8;
      var available = Math.max(0, maxLoan - balance);
      var reserve = value * 0.2;

      document.getElementById('heloc-equity').textContent = formatCurrency(Math.max(0, equity));
      document.getElementById('heloc-available').textContent = formatCurrency(available);

      // Update bar
      var mortPct = Math.min(100, (balance / value) * 100);
      var availPct = Math.min(100 - mortPct, (available / value) * 100);
      var reservePct = Math.max(0, 100 - mortPct - availPct);

      document.getElementById('eq-mortgage').style.width = mortPct + '%';
      document.getElementById('eq-available').style.width = availPct + '%';
      document.getElementById('eq-reserved').style.width = reservePct + '%';
    });
  }

  /* ── Reviews: duplicate track for infinite scroll ── */
  var track = document.getElementById('reviews-track');
  if (track && !prefersReduced) {
    var clone = track.innerHTML;
    track.innerHTML += clone;
  }

  /* ── Mobile sticky CTA bar ── */
  var mobileBar = document.getElementById('mobile-cta-bar');
  var mobileClose = document.getElementById('mobile-cta-close');
  var mobileDismissed = false;

  if (mobileBar) {
    window.addEventListener('scroll', function() {
      if (mobileDismissed) return;
      var scrollH = document.documentElement.scrollHeight - window.innerHeight;
      var progress = scrollH > 0 ? (window.scrollY / scrollH) : 0;
      if (progress > 0.6) {
        mobileBar.classList.add('is-visible');
        mobileBar.setAttribute('aria-hidden', 'false');
      }
    }, { passive: true });

    if (mobileClose) {
      mobileClose.addEventListener('click', function() {
        mobileDismissed = true;
        mobileBar.classList.remove('is-visible');
        mobileBar.setAttribute('aria-hidden', 'true');
      });
    }
  }
})();
</script>
