  }
  .calc-card__num {
    display: block;
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-paper);
  }
  .calc-card__label {
    display: block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(250, 250, 247, 0.5);
    margin-top: 0.4rem;
  }
  .calc-disclaimer {
    text-align: center;
    font-size: 11px;
    color: rgba(250, 250, 247, 0.35);
