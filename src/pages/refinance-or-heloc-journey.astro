  .idle-equity__bar--idle { width: 30%; background: var(--color-bone); }
  .idle-equity__bar--work { width: 70%; background: var(--color-green); }
  .idle-equity__text { font-size: 13px; color: var(--color-ink); }

  /* ── Q3: Rate vs total cost ── */
  .rate-vs-cost {
    display: flex;
    align-items: flex-end;
    gap: 1.5rem;
    height: 180px;
    justify-content: center;
  }
  .rate-vs-cost__col { text-align: center; width: 90px; }
  .rate-vs-cost__bar {
    width: 100%;
    border-radius: 8px 8px 0 0;
    display: flex;
    align-items: flex-start;
    justify-content: center;
