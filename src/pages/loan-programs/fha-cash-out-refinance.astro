import RefiCalc from '../../components/RefiCalc.astro';
const productSchema={"@context": "https://schema.org", "@type": ["FinancialProduct", "Service"], "name": "FHA Cash-Out Refinance", "description": "Convert home equity into cash using FHA-backed financing \u2014 often with more forgiving credit requirements than conventional cash-out.", "provider": {"@type": "Organization", "name": "Stairway Mortgage"}, "areaServed": "US"};
const faqSchema={"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "How much cash can I get from an FHA cash-out refinance?", "acceptedAnswer": {"@type": "Answer", "text": "Generally up to 80% of your home's appraised value, minus your current loan payoff and closing costs. Your actual amount depends on your equity and the appraisal."}}, {"@type": "Question", "name": "What credit score do I need?", "acceptedAnswer": {"@type": "Answer", "text": "FHA cash-out programs are often more flexible than conventional, but lender requirements vary. Many lenders look for mid-600s or higher for cash-out specifically. We can compare lenders to find the best fit for your profile."}}, {"@type": "Question", "name": "Does an FHA cash-out require mortgage insurance?", "acceptedAnswer": {"@type": "Answer", "text": "Yes. FHA loans carry both an upfront and annual mortgage insurance premium. That cost is the trade-off for FHA's flexible credit standards, and it factors into whether the refinance makes sense for you."}}, {"@type": "Question", "name": "Can I do an FHA cash-out if my current loan is conventional?", "acceptedAnswer": {"@type": "Answer", "text": "Yes \u2014 you can refinance a conventional loan into an FHA cash-out, as long as you and the property qualify under FHA guidelines."}}, {"@type": "Question", "name": "Is a cash-out refinance the same as a HELOC?", "acceptedAnswer": {"@type": "Answer", "text": "No. A cash-out refinance replaces your entire mortgage with one new loan. A HELOC is a separate second loan/line against your equity. Which is better depends on your current rate and how you want to access funds \u2014 we can walk through both."}}]};
const breadcrumbSchema={"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://stairwaymortgage.com/"}, {"@type": "ListItem", "position": 2, "name": "Loan Programs", "item": "https://stairwaymortgage.com/loan-programs/"}, {"@type": "ListItem", "position": 3, "name": "FHA Cash-Out Refinance"}]};
---

<Layout title="FHA Cash-Out Refinance | Stairway" description="Convert home equity into cash using FHA-backed financing — often with more forgiving credit requirements than conventional cash-out." canonical="https://stairwaymortgage.com/loan-programs/fha-cash-out-refinance/">
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <nav class="container-page lp-breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a> <span>/</span> <a href="/loan-programs/">Loan Programs</a> <span>/</span> <span>FHA Cash-Out Refinance</span>
  </nav>
  <header class="container-prose lp-header">
    <span class="eyebrow eyebrow-blue mb-5">Loan Program · Refinance</span>
    <h1 class="display-lg">FHA Cash-Out Refinance: Tap Your Equity With Flexible Credit</h1>
    <p class="lede lp-lede">Convert home equity into cash using FHA-backed financing — often with more forgiving credit requirements than conventional cash-out. Guided by Jim Blackburn · <span class="mono">NMLS #1072866</span></p>
    <div class="lp-cta-row"><a href="/see-my-options/" class="btn btn-blue btn-arrow">See My Options</a><a href="tel:+19549931625" class="btn btn-ghost">(954) 993-1625</a></div>
  </header>
  <div class="lp-main">
  <article class="prose-editorial lp-body" set:html={`<h2><b>What an FHA Cash-Out Refinance Is</b></h2><p>An FHA cash-out refinance replaces your existing mortgage with a new, larger FHA-insured loan and returns the difference to you in cash. Because it's government-backed, it tends to accept lower credit scores than a conventional cash-out, making it a path to equity for borrowers who might not qualify elsewhere.</p><h2><b>Who It's For</b></h2><ul><li>Homeowners with substantial equity but credit that falls short of conventional cash-out standards</li><li>Borrowers who want to consolidate higher-interest debt into their mortgage</li><li>Owners funding renovations, education, or other large expenses</li><li>Those already in an FHA loan looking to access equity</li></ul><h2><b>How It Works</b></h2><p>FHA cash-out refinances typically allow you to borrow up to 80% of your home's appraised value. You receive the difference between your new loan and your current payoff, minus closing costs, as cash. The new loan carries FHA mortgage insurance, which is the trade-off for the program's flexible qualification. Whether the math works depends on your equity, the rate environment, and how you'll use the funds.</p><h2><b>Frequently Asked Questions</b></h2><h3><b>How much cash can I get from an FHA cash-out refinance?</b></h3><p>Generally up to 80% of your home's appraised value, minus your current loan payoff and closing costs. Your actual amount depends on your equity and the appraisal.</p><h3><b>What credit score do I need?</b></h3><p>FHA cash-out programs are often more flexible than conventional, but lender requirements vary. Many lenders look for mid-600s or higher for cash-out specifically. We can compare lenders to find the best fit for your profile.</p><h3><b>Does an FHA cash-out require mortgage insurance?</b></h3><p>Yes. FHA loans carry both an upfront and annual mortgage insurance premium. That cost is the trade-off for FHA's flexible credit standards, and it factors into whether the refinance makes sense for you.</p><h3><b>Can I do an FHA cash-out if my current loan is conventional?</b></h3><p>Yes — you can refinance a conventional loan into an FHA cash-out, as long as you and the property qualify under FHA guidelines.</p><h3><b>Is a cash-out refinance the same as a HELOC?</b></h3><p>No. A cash-out refinance replaces your entire mortgage with one new loan. A HELOC is a separate second loan/line against your equity. Which is better depends on your current rate and how you want to access funds — we can walk through both.</p>`} />

    <PostSidebar />
  </div>
  <div class="container-prose"><RefiCalc mode="cash-out" /></div>
  <div class="container-prose"><p class="lp-compliance mono">This page is for educational purposes and is not a commitment to lend or an offer of a specific rate. Loan terms, rates, and qualification depend on your individual circumstances and are subject to underwriting approval. Stairway Mortgage is a division of NEXA Mortgage LLC.</p></div>

  <section class="section-tight lp-final-cta"><div class="container-prose"><div class="card lp-final-cta__card">
    <h2 class="display-md">Is refinancing right for you?</h2>
    <p class="lede">We'll run your real numbers and tell you straight whether it pencils — no credit pull to start.</p>
    <a href="/schedule-call/" class="btn btn-blue btn-arrow">Talk to Our Team</a>
  </div></div></section>
</Layout>

<style>
  .lp-main { display: grid; grid-template-columns: 1fr 300px; gap: 2.5rem; max-width: var(--container-max, 1320px); margin: 0 auto; padding-inline: clamp(1.25rem, 4vw, 2.5rem); }
  @media (max-width: 900px) { .lp-main { grid-template-columns: 1fr; } }
  .lp-breadcrumb { font-family:var(--stw-mono, 'JetBrains Mono'), monospace; font-size:12px; color:var(--color-mute); padding-top:2rem; padding-bottom:1.25rem; }
  .lp-breadcrumb a { color:var(--color-mute); text-decoration:none; } .lp-breadcrumb a:hover { color:var(--color-blue); }
  .lp-breadcrumb span { margin-inline:0.4rem; opacity:0.5; }
  .lp-header h1 { margin-bottom:1.25rem; } .lp-lede { margin-bottom:1.5rem; }
  .lp-cta-row { display:flex; gap:0.75rem; flex-wrap:wrap; }
  .lp-body { margin-top:2.5rem; }
  .lp-body :global(h2) { font-family:var(--stw-display, 'Fraunces'), Georgia, serif; font-variation-settings:"opsz" 96; font-weight:500; font-size:clamp(1.6rem,3vw,2.25rem); line-height:1.15; margin-top:3rem; margin-bottom:1.1rem; }
  .lp-body :global(h3) { font-family:var(--stw-display, 'Fraunces'), Georgia, serif; font-weight:500; font-size:clamp(1.2rem,2vw,1.55rem); margin-top:2rem; margin-bottom:0.8rem; }
  .lp-body :global(p) { font-size:17px; line-height:1.75; margin-bottom:1.25rem; color:var(--color-ink-light); }
  .lp-body :global(ul) { margin:0 0 1.5rem 1.25rem; display:flex; flex-direction:column; gap:0.5rem; }
  .lp-body :global(li) { font-size:17px; line-height:1.65; }
  .lp-body :global(a) { color:var(--color-blue); text-decoration:underline; text-underline-offset:2px; }
  .lp-compliance { font-size:11px; line-height:1.6; color:var(--color-mute); padding:1.5rem 0; border-top:1px solid var(--color-bone); margin-top:2rem; letter-spacing:0.01em; }
  .lp-final-cta__card { text-align:center; display:flex; flex-direction:column; align-items:center; gap:1rem; padding:2.5rem; }
</style>
