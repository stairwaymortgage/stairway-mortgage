const faqSchema={"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "Can you act as your own general contractor?", "acceptedAnswer": {"@type": "Answer", "text": "FHA construction loan programs generally require licensed general contractors for construction management and oversight. Owner-builder scenarios where borrowers manage construction themselves face significant restrictions, substantially higher equity requirements, and limited lender participation."}}, {"@type": "Question", "name": "What if construction costs exceed initial estimates?", "acceptedAnswer": {"@type": "Answer", "text": "Construction projects frequently encounter unexpected expenses\u2014site conditions, code requirements, material cost increases, or desired upgrades\u2014causing budgets to exceed original estimates. Contingency reserves (typically 10-15% of construction budget) help manage these overruns."}}, {"@type": "Question", "name": "How long do you have to complete construction?", "acceptedAnswer": {"@type": "Answer", "text": "FHA construction loans establish maximum completion timeframes\u2014typically 12-18 months from closing to final completion. Extensions may be available with lender approval when circumstances justify delays, but the program expects timely construction completion."}}, {"@type": "Question", "name": "Can you make changes to plans after approval?", "acceptedAnswer": {"@type": "Answer", "text": "Change orders\u2014modifications to approved construction plans\u2014require lender approval, potentially revised appraisals, and updated documentation. Minor changes like material substitutions typically process smoothly. Major scope changes may require substantial re-evaluation."}}, {"@type": "Question", "name": "Can you purchase land separately before applying for construction financing?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, you can purchase land using cash or separate land financing, then later apply for FHA construction loans to build on owned land. The construction loan finances only building costs since you already own the site. However, combining land purchase with construction financing in single transactions often provides better overall terms and simplifies the process."}}, {"@type": "Question", "name": "What if you're self-employed\u2014can you still qualify?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, self-employed borrowers qualify for FHA construction loans using the same documentation standards as regular FHA financing. You'll provide business tax returns, profit and loss statements, verification of business continuity, and standard self-employment documentation."}}, {"@type": "Question", "name": "How do FHA construction loans handle energy-efficient features?", "acceptedAnswer": {"@type": "Answer", "text": "Energy-efficient construction including superior insulation, high-efficiency HVAC systems, solar panels, or energy-efficient windows qualifies as eligible construction costs under FHA programs. Additionally, FHA Energy Efficient Mortgages (EEM) may increase loan amounts above standard limits when energy features create sufficient utility savings."}}, {"@type": "Question", "name": "Can you build spec homes for sale using FHA construction loans?", "acceptedAnswer": {"@type": "Answer", "text": "No, FHA construction loans serve primary residence construction only. You must occupy the completed property as your main home. Builders constructing homes for sale to others cannot use FHA construction financing\u2014they need commercial construction financing or builder-specific programs."}}, {"@type": "Question", "name": "What happens if construction quality issues arise?", "acceptedAnswer": {"@type": "Answer", "text": "Construction defects, workmanship problems, or code violations discovered during inspections must be corrected before draw releases or final completion. FHA inspection processes protect borrowers by ensuring construction quality meets standards before releasing funds to contractors."}}, {"@type": "Question", "name": "Can foreign nationals qualify for FHA construction loans?", "acceptedAnswer": {"@type": "Answer", "text": "Foreign nationals face the same FHA restrictions for construction loans as standard FHA purchases\u2014generally requiring U.S. citizenship or lawful permanent resident status. Non-permanent resident aliens may qualify with appropriate work visas and employment authorization, though documentation requirements increase substantially."}}, {"@type": "Question", "name": "How do FHA construction loans handle modular or prefabricated homes?", "acceptedAnswer": {"@type": "Answer", "text": "FHA construction loans can accommodate modular or factory-built homes when they meet FHA manufactured housing standards, are permanently affixed to owned land with appropriate foundations, are classified as real property, and comply with local building codes."}}, {"@type": "Question", "name": "What if you want to build in phases over time?", "acceptedAnswer": {"@type": "Answer", "text": "Traditional FHA construction loans require continuous construction from start to completion within the loan term. Building in phases over extended periods typically needs alternative financing strategies rather than single FHA construction loans."}}, {"@type": "Question", "name": "Can you refinance during construction if rates drop?", "acceptedAnswer": {"@type": "Answer", "text": "Construction-to-permanent FHA loans with locked rates cannot refinance during construction periods. The rate lock protects you from increases but prevents capitalizing on decreases during building. Once construction completes and the loan converts to permanent FHA financing, standard FHA streamline refinancing becomes available after appropriate seasoning."}}, {"@type": "Question", "name": "How do divorce or inheritance situations affect construction projects?", "acceptedAnswer": {"@type": "Answer", "text": "Construction projects interrupted by divorce, death, or other major life changes create complex scenarios. If borrowers divorce during construction, determining who continues the project, how construction loan obligations divide, and whether remaining borrower(s) can continue requires legal and financial restructuring."}}]};
