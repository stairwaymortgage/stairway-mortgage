const faqSchema={"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "Can you live in the property during renovations?", "acceptedAnswer": {"@type": "Answer", "text": "Whether you can occupy properties during FHA 203k renovations depends on the scope and safety considerations. Limited 203k projects involving cosmetic improvements often allow occupancy during work. Standard 203k projects involving major systems, structural work, or health hazards typically require alternative housing during renovation periods."}}, {"@type": "Question", "name": "What happens if renovation costs exceed initial estimates?", "acceptedAnswer": {"@type": "Answer", "text": "Renovation projects frequently encounter unexpected issues\u2014hidden damage, code compliance requirements, or material cost increases\u2014causing budgets to exceed original estimates. The contingency reserve (typically 10-20% of renovation costs) addresses these overruns."}}, {"@type": "Question", "name": "How long do you have to complete renovations?", "acceptedAnswer": {"@type": "Answer", "text": "FHA 203k loans establish maximum renovation completion timeframes\u2014typically six months from closing. Extensions may be available with lender approval when circumstances justify delays, but the program requires timely completion."}}, {"@type": "Question", "name": "Can you change renovation plans after approval?", "acceptedAnswer": {"@type": "Answer", "text": "Change orders\u2014modifications to approved renovation plans\u2014are possible but require lender approval, potentially revised appraisals, and updated documentation. Minor changes like material substitutions typically process smoothly. Major scope changes may require substantial re-evaluation."}}, {"@type": "Question", "name": "Can you use FHA 203k for condo renovations?", "acceptedAnswer": {"@type": "Answer", "text": "Condominium renovation through FHA 203k programs faces significant restrictions. The condo development must be FHA-approved, renovations cannot alter exterior elements or common areas, and improvements must stay within your unit boundaries. Additionally, condo associations may restrict renovation types, timelines, or contractor access."}}, {"@type": "Question", "name": "What if you're self-employed\u2014can you still qualify?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, self-employed borrowers qualify for FHA 203k loans using the same documentation requirements as standard FHA financing. You'll provide business tax returns, profit and loss statements, and verification of business continuity. The renovation financing doesn't change self-employment qualification standards."}}, {"@type": "Question", "name": "How do FHA 203k loans handle lead paint requirements?", "acceptedAnswer": {"@type": "Answer", "text": "Properties built before 1978 potentially contain lead-based paint requiring specific protocols during renovation. FHA 203k projects must comply with HUD lead-safe housing rules including:"}}, {"@type": "Question", "name": "Can you purchase foreclosures or short sales with FHA 203k?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, FHA 203k loans work excellently for foreclosed or short-sale properties that often need repairs due to deferred maintenance or intentional damage. Banks and sellers motivated to sell distressed properties often accept offers contingent on 203k financing."}}, {"@type": "Question", "name": "What happens to your mortgage payment during renovations?", "acceptedAnswer": {"@type": "Answer", "text": "Your full mortgage payment\u2014including principal, interest, taxes, insurance, and mortgage insurance\u2014begins immediately after closing even though renovations are incomplete. You're paying the mortgage while living elsewhere (if the property is uninhabitable during work) and before you can move in."}}, {"@type": "Question", "name": "Can you get FHA 203k for properties with foundation issues?", "acceptedAnswer": {"@type": "Answer", "text": "Foundation problems qualify as eligible improvements under Standard FHA 203k programs when repairs are feasible and cost-effective relative to property value. Severe foundation issues requiring extensive repairs may exceed program practicality or create situations where total renovation costs approach property values."}}, {"@type": "Question", "name": "How do energy efficiency improvements affect FHA 203k financing?", "acceptedAnswer": {"@type": "Answer", "text": "Energy efficiency improvements including insulation, windows, HVAC systems, and weatherization qualify as eligible 203k improvements. Additionally, FHA offers Energy Efficient Mortgages (EEM) that can increase loan amounts above standard FHA limits when energy improvements create sufficient utility cost savings."}}, {"@type": "Question", "name": "What if you want to convert a property to different use?", "acceptedAnswer": {"@type": "Answer", "text": "Converting properties from one configuration to another\u2014such as turning single-family homes into duplexes, converting garages to living space, or creating accessory dwelling units\u2014requires careful review of:"}}, {"@type": "Question", "name": "Can foreign nationals qualify for FHA 203k loans?", "acceptedAnswer": {"@type": "Answer", "text": "Foreign nationals face the same restrictions for FHA 203k as standard FHA loans\u2014generally requiring U.S. citizenship or lawful permanent resident status. Non-permanent resident aliens may qualify with appropriate work visas and employment authorization, but documentation requirements increase."}}, {"@type": "Question", "name": "How do you find contractors experienced with FHA 203k?", "acceptedAnswer": {"@type": "Answer", "text": "Finding contractors familiar with FHA 203k processes improves project success. Resources for locating qualified contractors include:"}}]};
