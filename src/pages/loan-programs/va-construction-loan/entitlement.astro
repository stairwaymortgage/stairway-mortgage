---
import Layout from '../../../layouts/Layout.astro';

// ── VA no-cap compliance sanitizer (ported VERBATIM from the VA county template) ──
// VA is never described as capped. The replacements below neutralize any capped-loan
// phrasing in source text to a neutral "ceiling" — full entitlement carries no VA-set cap.
function sanitizeVA(text: string): string {
  return text
    .replace(/maximum VA loan amount/gi, 'VA loan ceiling')
    .replace(/maximum VA loan/gi, 'VA loan ceiling')
    .replace(/VA loan limit is/gi, 'VA loan ceiling is');
}
// Strip any residual merge placeholders (county / city / base names) then sanitize.
const clean = (t: string): string => sanitizeVA(String(t).replace(/\{[^}]*\}/g, '').replace(/\s{2,}/g, ' ').replace(/\s+([.,])/g, '$1').trim());

// ── Entitlement / funding-fee FAQ set — sourced from faq-va.json. Authored token-free,
//    then run through clean() so no tokens and no capped-loan phrasing can survive.
//    No dollar-limit figures are printed; funding-fee math is deferred to the estimator.
const rawFaqs = [
  {
    q: "What is VA entitlement, and how does it affect how much I can build?",
    a: "Entitlement is the portion of your loan the VA guarantees. With full entitlement, there's no VA-set maximum and no down payment required for qualified borrowers — your build is sized by your qualification, not a VA cap. With partial or reduced entitlement, a down payment may be needed above certain amounts and your county's conforming figure can come into play — we run that math for you.",
  },
  {
    q: "How does remaining (partial) entitlement work?",
    a: "This applies only when you have partial or reduced entitlement — for example, if you already have an active VA loan. The rough idea: take 25% of your county's conforming figure, subtract the entitlement you've already used; what's left, multiplied by four, approximates the loan the VA can back with no down payment. With full entitlement, none of this applies — there's no VA-set maximum.",
  },
  {
    q: "Did the Blue Water Navy Act really remove VA loan limits?",
    a: "Yes. For borrowers with full entitlement, the Blue Water Navy Vietnam Veterans Act of 2020 removed the loan limits that used to cap $0-down VA borrowing. With full entitlement today there's no VA-set maximum — your build is sized by qualification. County-based figures can still matter for partial or reduced entitlement only.",
  },
  {
    q: "I've used my VA loan before — can I use it again to build?",
    a: "Very likely yes. VA entitlement can be restored after a prior VA loan is paid off, and many Veterans have remaining entitlement even with an active VA loan. We check your COE to confirm exactly where you stand.",
  },
  {
    q: "What is second-tier entitlement?",
    a: "It's a general term for using remaining entitlement to take a second VA loan while a first one is still open — a partial-entitlement situation. Whether it works, and whether a down payment is needed, depends on how much entitlement you have left. We calculate it individually from your COE.",
  },
  {
    q: "What is the VA funding fee?",
    a: "A one-time fee that helps keep the program running, charged at closing. It can be financed into the loan rather than paid in cash, and many Veterans are fully exempt. The exact percentage depends on your benefit use and any down payment — we show the figure for your scenario on the closing-cost estimator.",
  },
  {
    q: "Who is exempt from the VA funding fee?",
    a: "Veterans receiving (or entitled to receive) VA disability compensation, Purple Heart recipients on active duty, and surviving spouses receiving DIC are generally exempt from the funding fee entirely. Your exemption status appears right on your COE.",
  },
  {
    q: "Can the funding fee be rolled into my VA loan?",
    a: "Yes — on purchase and construction loans, the funding fee is the one charge that can be financed into the loan amount instead of paid in cash at closing. Unless you're exempt, it's due at loan closing, before construction starts.",
  },
];
const faqs = rawFaqs.map((f) => ({ q: clean(f.q), a: clean(f.a) }));

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://stairwaymortgage.com/" },
    { "@type": "ListItem", position: 2, name: "Loan Programs", item: "https://stairwaymortgage.com/loan-programs/" },
    { "@type": "ListItem", position: 3, name: "VA Construction Loan", item: "https://stairwaymortgage.com/loan-programs/va-construction-loan/" },
    { "@type": "ListItem", position: 4, name: "VA Construction Loan Entitlement" },
  ],
};
---

<Layout
  title="VA Construction Loan Entitlement | Stairway Mortgage"
  description="How VA entitlement works for a one-time-close construction loan — full vs partial entitlement. With full entitlement the VA sets no maximum; your build is sized by qualification. Educational overview."
  canonical="https://stairwaymortgage.com/loan-programs/va-construction-loan/entitlement/">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="va-spoke-scope">
    <!-- VA CLUSTER BAR — sticky, finger-swipeable sub-nav shared across the VA construction cluster -->
    <nav class="cluster-bar" aria-label="VA construction loan guides"><div class="cluster-bar-inner"><span class="cluster-label">VA Construction</span><a href="/loan-programs/va-loan/">Program Guide</a><a href="/loan-programs/va-construction-loan/eligibility/">Eligibility</a><a href="/loan-programs/va-construction-loan/entitlement/" class="active">Entitlement</a><a href="/loan-programs/va-construction-loan/closing-cost-calculator/">Closing Costs</a><a href="/loan-programs/construction-loan/">Compare Programs</a><a href="/loan-programs/va-construction-loan/">FL Counties</a></div></nav>

    <div class="hero"><div class="container">
      <span class="status-pill">Educational Guide</span>
      <h1>VA construction loan <span class="accent">entitlement</span></h1>
      <p class="lede">Entitlement is the portion of your loan the VA guarantees — and it's the single biggest factor in how much you can build. The headline for those who served: with full entitlement, the VA sets no maximum on your loan. This page explains full versus partial entitlement, the Blue Water Navy Act, restoration, and the funding fee. Final eligibility and loan size are determined by the VA and by underwriting.</p>
      <div class="cta-row"><a class="btn btn-primary" href="/see-my-options/">See My Options</a>
      <a class="btn btn-secondary" href="/schedule-call/">Talk to Our Team</a></div>
      <p class="trust-line">Jim Blackburn · NMLS #1072866 · 7× Scotsman Guide Top Producer · $500M+ closed · (954) 993-1625</p>
    </div></div>

    <section style="background:var(--white);border-bottom:1px solid var(--border);"><div class="container">
      <span class="eyebrow">Full Entitlement</span>
      <h2>With full entitlement, there's <span class="accent">no VA-set maximum</span></h2>
      <p class="section-lede">This is the heart of the VA benefit. If you have full entitlement, the VA places no maximum on your loan amount — there is no VA cap and no county ceiling on how much you can build with $0 down. Your build is sized by your qualification: your income, your credit, and the home's appraised value — not by any VA limit. Reviewed by Jim Blackburn, NMLS #1072866.</p>
      <div class="split">
        <div class="card"><h3>No VA-set maximum</h3><p>With full entitlement, the VA does not set a maximum loan amount and does not require a down payment for qualified borrowers. What you can build is sized by qualification, not a cap.</p></div>
        <div class="card"><h3>Sized by qualification</h3><p>Instead of a VA ceiling, your loan is shaped by your income, credit, debt-to-income, and the appraised value of the completed home — the same underwriting review any borrower goes through.</p></div>
      </div>
    </div></section>

    <section><div class="container">
      <span class="eyebrow">Partial / Reduced Entitlement</span>
      <h2>When <span class="accent">partial or reduced entitlement</span> applies</h2>
      <p class="section-lede">Some Veterans have only partial (also called reduced) entitlement — most commonly when they already have an active VA loan, or have used the benefit before and not restored it. This is the <strong>only</strong> situation where a county-based figure enters the picture: with partial or reduced entitlement, your county's conforming figure can shape how much the VA guarantees with no money down, and a down payment may be needed above certain amounts. It is never a general VA cap — it applies to partial or reduced entitlement only, and we calculate your exact position from your COE. With full entitlement, none of this applies: there's still no VA-set maximum.</p>
    </div></section>

    <section style="background:var(--white);border-top:1px solid var(--border);border-bottom:1px solid var(--border);"><div class="container">
      <span class="eyebrow">The Law Behind It</span>
      <h2>The <span class="accent">Blue Water Navy Act</span></h2>
      <p class="section-lede">The Blue Water Navy Vietnam Veterans Act of 2020 removed VA loan limits for borrowers with full entitlement. Before it, VA-backed $0-down borrowing was tied to county limits; since it took effect, full-entitlement borrowers have no VA-set maximum — the build is sized by qualification, not a cap. County-based figures remain relevant only for partial or reduced entitlement. Every scenario is reviewed personally by Jim Blackburn, NMLS #1072866.</p>
      <div class="split">
        <div class="card"><h3>Restoration</h3><p>Entitlement can generally be restored after a prior VA loan is paid off — often returning you to full entitlement, and with it, no VA-set maximum on your next build.</p></div>
        <div class="card"><h3>Second-tier entitlement</h3><p>Remaining entitlement can sometimes support a second VA loan while a first is still open — a partial-entitlement situation whose down-payment picture we calculate individually.</p></div>
      </div>
    </div></section>

    <section><div class="container">
      <span class="eyebrow">The Funding Fee</span>
      <h2>A one-time fee — and <span class="accent">many are exempt</span></h2>
      <p class="section-lede">The VA funding fee is a one-time charge that helps keep the program running. It can be financed into the loan rather than paid in cash, and — importantly — many Veterans are <strong>fully exempt</strong>: those receiving (or entitled to receive) VA disability compensation, Purple Heart recipients on active duty, and surviving spouses receiving DIC. Your exemption status appears on your COE. The exact percentage depends on your benefit use and any down payment — see the <a href="/loan-programs/va-construction-loan/closing-cost-calculator/" style="color:var(--blue);text-decoration:underline;">closing-cost estimator</a> for the figure in your scenario.</p>
    </div></section>

    <section><div class="container">
      <span class="eyebrow">Common Questions</span>
      <h2>Entitlement <span class="accent">FAQ</span></h2>
      <p class="section-lede">General guidance below reflects typical VA program parameters. It is educational and not a commitment to lend — entitlement is determined by the VA, and qualification by underwriting.</p>
      <div class="faq-cat">
        {faqs.map((f) => (
          <details class="faq"><summary>{f.q}</summary><div class="ans">{f.a}</div></details>
        ))}
      </div>
      <p class="section-lede" style="margin-top:1.6rem;">Not sure how much entitlement you have left? <a href="/schedule-call/" style="color:var(--blue);text-decoration:underline;">Schedule a call</a> with our team and we'll check your COE.</p>
    </div></section>

    <!-- VA SUBFOOTER — sits ABOVE the site's main footer (Layout.astro provides licensing / NMLS #1660690 / EHO) -->
    <div style="background:var(--paper-2);border-top:1px solid var(--border);padding:1.6rem 0;">
      <div class="container">
        <p style="font-size:.75rem;color:var(--ink-lighter);line-height:1.7;margin:0;">
          VA entitlement and eligibility are determined by the U.S. Department of Veterans Affairs; loan qualification (credit, income, and underwriting) applies separately. With full entitlement, the VA sets no maximum on the loan amount — any county-based figure applies only to reduced or partial entitlement. Program guidelines and the funding fee reflect current figures and are subject to change.
          Jim Blackburn, NMLS #1072866. This page is not a commitment to lend or a guarantee of approval.
        </p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .va-spoke-scope{
    --ink:#0A0E1A; --ink-2:#1E2433; --ink-light:#4A5568; --ink-lighter:#6B7280;
    --paper:#FAFAF7; --paper-2:#F4F4EE; --paper-3:#EDEDE5; --white:#FFFFFF;
    --blue:#1845D6; --blue-deep:#0F2EA0; --blue-soft:#E8EEFF; --blue-tint:#F2F5FF;
    --green:#2E9E2E; --green-soft:#E9F7E9; --rust:#8B2C2C;
    --border:#E5E5DE; --border-strong:#D4D4C8;
    --serif:'Fraunces','Iowan Old Style',Georgia,serif;
    --sans:'IBM Plex Sans',-apple-system,BlinkMacSystemFont,sans-serif;
    --mono:'JetBrains Mono','SF Mono',Menlo,monospace;
    font-family:var(--sans);font-size:1.0625rem;line-height:1.6;color:var(--ink);background:var(--paper);-webkit-font-smoothing:antialiased;
  }
  .va-spoke-scope *,.va-spoke-scope *::before,.va-spoke-scope *::after{box-sizing:border-box;margin:0;padding:0;}
  .va-spoke-scope a{color:inherit;text-decoration:none;}
  .va-spoke-scope .container{max-width:1100px;margin:0 auto;padding:0 1.5rem;}
  .va-spoke-scope .eyebrow{font-family:var(--mono);font-size:.75rem;letter-spacing:.14em;text-transform:uppercase;color:var(--blue);font-weight:500;display:inline-block;}
  .va-spoke-scope h1,.va-spoke-scope h2,.va-spoke-scope h3{font-family:var(--serif);font-weight:600;line-height:1.15;color:var(--ink);}
  .va-spoke-scope .accent{font-family:var(--serif);font-style:normal;color:var(--blue);}
  /* Hero */
  .va-spoke-scope .hero{padding:5rem 0 3.5rem;background:linear-gradient(180deg,var(--blue-tint) 0%,var(--paper) 100%);border-bottom:1px solid var(--border);}
  .va-spoke-scope .hero h1{font-size:clamp(2.1rem,5vw,3.4rem);margin:.9rem 0 1.1rem;max-width:820px;}
  .va-spoke-scope .hero p.lede{font-size:1.1875rem;color:var(--ink-light);max-width:680px;margin-bottom:1.8rem;}
  .va-spoke-scope .status-pill{display:inline-flex;align-items:center;gap:.5rem;background:var(--green-soft);border:1px solid #BFE3BF;color:#1E6B1E;border-radius:999px;padding:.4rem 1rem;font-family:var(--mono);font-size:.75rem;letter-spacing:.06em;text-transform:uppercase;font-weight:600;}
  .va-spoke-scope .status-pill::before{content:"";width:8px;height:8px;border-radius:50%;background:var(--green);}
  .va-spoke-scope .cta-row{display:flex;gap:.9rem;flex-wrap:wrap;margin-top:1.6rem;}
  .va-spoke-scope .btn{display:inline-block;padding:.85rem 1.7rem;border-radius:8px;font-weight:600;font-size:1rem;transition:transform .15s ease;}
  .va-spoke-scope .btn:hover{transform:translateY(-1px);}
  .va-spoke-scope .btn-primary{background:var(--blue);color:var(--white);}
  .va-spoke-scope .btn-secondary{background:var(--white);color:var(--ink);border:1.5px solid var(--border-strong);}
  .va-spoke-scope .trust-line{margin-top:1.4rem;font-size:.875rem;color:var(--ink-lighter);}
  /* Sections */
  .va-spoke-scope section{padding:3.5rem 0;}
  .va-spoke-scope section h2{font-size:clamp(1.6rem,3.4vw,2.2rem);margin:.7rem 0 1rem;}
  .va-spoke-scope .section-lede{color:var(--ink-light);max-width:720px;margin-bottom:2rem;}
  .va-spoke-scope .split{display:grid;grid-template-columns:1fr 1fr;gap:2.5rem;align-items:start;}
  @media(max-width:820px){.va-spoke-scope .split{grid-template-columns:1fr;}}
  .va-spoke-scope .card{background:var(--white);border:1px solid var(--border);border-radius:14px;padding:1.8rem;}
  .va-spoke-scope .card:hover{transform:none;box-shadow:none;border-color:var(--border);}
  .va-spoke-scope .card h3{font-size:1.25rem;margin-bottom:.7rem;}
  .va-spoke-scope .card p{color:var(--ink-light);font-size:.9688rem;}
  /* VA cluster bar (sticky, finger-swipeable sub-nav) */
  .va-spoke-scope .cluster-bar{position:sticky;top:0;z-index:50;background:var(--white);border-bottom:1px solid var(--border);box-shadow:0 1px 8px rgba(10,14,26,.05);}
  .va-spoke-scope .cluster-bar-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:.35rem;padding:.55rem 1.5rem;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
  .va-spoke-scope .cluster-bar-inner::-webkit-scrollbar{display:none;}
  .va-spoke-scope .cluster-label{flex:0 0 auto;font-family:var(--mono);font-size:.62rem;letter-spacing:.1em;text-transform:uppercase;color:var(--blue);white-space:nowrap;padding-right:.6rem;border-right:1px solid var(--border);margin-right:.35rem;font-weight:600;}
  .va-spoke-scope .cluster-bar a{flex:0 0 auto;white-space:nowrap;font-size:.76rem;font-weight:500;color:var(--ink-2);text-decoration:none;padding:.36rem .62rem;border-radius:999px;transition:background .15s;}
  .va-spoke-scope .cluster-bar a:hover{background:var(--paper-2);color:var(--ink);}
  .va-spoke-scope .cluster-bar a.active{background:var(--blue);color:#fff;font-weight:600;}
  /* FAQ accordions */
  .va-spoke-scope .faq-cat{margin-top:.5rem;}
  .va-spoke-scope details.faq{background:var(--white);border:1px solid var(--border);border-radius:10px;margin-bottom:.55rem;overflow:hidden;}
  .va-spoke-scope details.faq summary{cursor:pointer;padding:.85rem 1.1rem;font-weight:600;color:var(--ink-2);list-style:none;display:flex;justify-content:space-between;gap:1rem;font-size:.94rem;}
  .va-spoke-scope details.faq summary::-webkit-details-marker{display:none;}
  .va-spoke-scope details.faq summary::after{content:'+';font-family:var(--mono);color:var(--blue);font-weight:600;}
  .va-spoke-scope details.faq[open] summary::after{content:'–';}
  .va-spoke-scope details.faq[open] summary{border-bottom:1px solid var(--border);}
  .va-spoke-scope details.faq .ans{padding:.9rem 1.1rem;font-size:.9rem;color:var(--ink-light);line-height:1.65;}
</style>
