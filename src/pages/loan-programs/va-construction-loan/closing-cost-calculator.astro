---
import Layout from '../../../layouts/Layout.astro';

// ── VA no-cap compliance sanitizer (ported VERBATIM from the VA county template) ──
// VA is never described as capped. The replacements below neutralize any capped-loan
// phrasing in source text to a neutral "ceiling" — full entitlement carries no VA-set cap.
function sanitizeVA(text: string): string {
  return text
    .replace(/maximum VA loan amount/gi, 'VA loan ceiling')
    .replace(/maximum VA loan/gi, 'VA loan ceiling')
    .replace(/VA loan limit is/gi, 'VA loan ceiling is');
}
// Strip any residual merge placeholders then sanitize — belt-and-suspenders for authored copy.
const clean = (t: string): string => sanitizeVA(String(t).replace(/\{[^}]*\}/g, '').replace(/\s{2,}/g, ' ').replace(/\s+([.,])/g, '$1').trim());

// ── VA funding-fee DEFAULT schedule (education only — the VA sets the official schedule).
//    Each rate is labeled as a default to verify; EXEMPT is $0 and called out prominently.
const feeTiers = [
  { key: 'first215', rate: 0.0215, label: 'First use, $0 down — 2.15% (default)' },
  { key: 'sub33',    rate: 0.033,  label: 'Subsequent use, $0 down — 3.3% (default)' },
  { key: 'down5',    rate: 0.015,  label: '5% or more down — 1.5% (default)' },
  { key: 'down10',   rate: 0.0125, label: '10% or more down — 1.25% (default)' },
  { key: 'exempt',   rate: 0,      label: 'EXEMPT (VA disability comp, Purple Heart, certain surviving spouses) — 0%' },
];

const faqNote = clean('These figures are educational estimates for a VA one-time-close construction loan and are not a quote or a Loan Estimate.');

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://stairwaymortgage.com/" },
    { "@type": "ListItem", position: 2, name: "Loan Programs", item: "https://stairwaymortgage.com/loan-programs/" },
    { "@type": "ListItem", position: 3, name: "VA Construction Loan", item: "https://stairwaymortgage.com/loan-programs/va-construction-loan/" },
    { "@type": "ListItem", position: 4, name: "VA Construction Loan Closing Cost Estimator" },
  ],
};
const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "VA Construction Loan Closing Cost Estimator",
  description: "An educational estimator for potential closing costs on a VA one-time-close construction loan, including the VA funding fee and exemptions. Estimates only — not a quote, Loan Estimate, or commitment to lend.",
  url: "https://stairwaymortgage.com/loan-programs/va-construction-loan/closing-cost-calculator/",
};
---

<Layout
  title="VA Construction Loan Closing Cost Estimator | Stairway Mortgage"
  description="An educational estimate of potential closing costs for a VA one-time-close construction loan, including the VA funding fee and exemptions. With full entitlement the VA sets no maximum. Estimates only — never a quote or Loan Estimate."
  canonical="https://stairwaymortgage.com/loan-programs/va-construction-loan/closing-cost-calculator/">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />

  <div class="va-spoke-scope">
    <!-- VA CLUSTER BAR — sticky, finger-swipeable sub-nav shared across the VA construction cluster -->
    <nav class="cluster-bar" aria-label="VA construction loan guides"><div class="cluster-bar-inner"><span class="cluster-label">VA Construction</span><a href="/loan-programs/va-loan/">Program Guide</a><a href="/loan-programs/va-construction-loan/eligibility/">Eligibility</a><a href="/loan-programs/va-construction-loan/entitlement/">Entitlement</a><a href="/loan-programs/va-construction-loan/closing-cost-calculator/" class="active">Closing Costs</a><a href="/loan-programs/construction-loan/">Compare Programs</a><a href="/loan-programs/va-construction-loan/">FL Counties</a></div></nav>

    <div class="hero"><div class="container">
      <span class="status-pill">Interactive Estimator + Worked Example</span>
      <h1>VA construction loan <span class="accent">closing cost estimator</span></h1>
      <p class="lede">First: a complete hypothetical worksheet on a $500,000 build ($100K land + $400K construction), organized like your Loan Estimate — every fee deliberately over-estimated. Then enter your own project cost, pick your funding-fee scenario, and watch the same math scale. This is an educational estimate for a VA one-time-close construction loan — clearly not a quote or a Loan Estimate. The good news for those who served: with full entitlement the VA sets no maximum on your loan, so your build is sized by qualification, not a cap.</p>
      <div class="cta-row"><a class="btn btn-primary" href="/see-my-options/">See My Options</a>
      <a class="btn btn-secondary" href="/schedule-call/">Talk to Our Team</a></div>
      <p class="trust-line">Jim Blackburn · NMLS #1072866 · 7× Scotsman Guide Top Producer · $500M+ closed · (954) 993-1625</p>
    </div></div>

    <section><div class="container">
      <span class="eyebrow">The VA Fees</span>
      <h2>The funding fee — and <span class="accent">why many pay $0</span></h2>
      <p class="section-lede">Reviewed by Jim Blackburn, NMLS #1072866.</p>
      <div class="split" style="grid-template-columns:repeat(auto-fit,minmax(280px,1fr));">
        <div class="card"><h3>VA funding fee — a one-time charge</h3><p>The VA funding fee is a one-time charge that helps keep the program running. It can be FINANCED into the loan rather than paid in cash at closing, so it need not be money out of pocket. The percentage depends on your benefit use and any down payment — the estimator below shows the figure for the scenario you pick.</p></div>
        <div class="card"><h3>Many Veterans are EXEMPT — $0</h3><p>This matters: Veterans receiving (or entitled to receive) VA disability compensation, Purple Heart recipients on active duty, and certain surviving spouses are generally exempt from the funding fee entirely — $0. Your exemption status appears on your COE. Choose "EXEMPT" in the estimator to see it drop to zero.</p></div>
        <div class="card"><h3>No monthly mortgage insurance</h3><p>Unlike FHA and most conventional low-down-payment loans, a VA loan carries no monthly mortgage insurance at all. There is no recurring MI line in your payment — a structural feature of the VA benefit, framed here generally and not a rate or payment quote.</p></div>
      </div>
    </div></section>

    <section style="background:var(--white);border-top:1px solid var(--border);border-bottom:1px solid var(--border);">
      <div class="container">
        <span class="eyebrow">The Real Numbers</span>
        <h2>A complete hypothetical example — <span class="accent">$500,000 build</span></h2>
        <p class="section-lede">$100,000 land + $400,000 construction in Florida — a genuinely nice home. Below is what a closing-cost worksheet can look like, organized the way your Loan Estimate organizes it, with the funding fee shown at the first-use, $0-down default of 2.15%. <strong>Every figure is hypothetical and deliberately on the generous side</strong> — your real numbers come on your real Loan Estimate.</p>

        <table class="va-compare cost">
          <thead><tr><th>Section A — Origination &amp; Lender Charges</th><th>Hypothetical</th></tr></thead>
          <tbody>
            <tr><td>Underwriting fee</td><td>$1,495</td></tr>
            <tr><td>Processing fee</td><td>$995</td></tr>
            <tr><td>Document preparation</td><td>$495</td></tr>
          </tbody>
        </table>
        <table class="va-compare cost" style="margin-top:1rem;">
          <thead><tr><th>Section B — Services You Cannot Shop For</th><th>Hypothetical</th></tr></thead>
          <tbody>
            <tr><td>Construction appraisal (as-completed value)</td><td>$1,200</td></tr>
            <tr><td>Final completion inspection</td><td>$350</td></tr>
            <tr><td>Draw inspections (5 × $150)</td><td>$750</td></tr>
            <tr><td>Credit report</td><td>$120</td></tr>
            <tr><td>Flood certification</td><td>$25</td></tr>
            <tr><td>Tax service fee</td><td>$85</td></tr>
            <tr class="va-key-row"><td>VA funding fee (first use, $0 down — 2.15% default, typically FINANCED into the loan, not cash; $0 if exempt)</td><td>$10,750</td></tr>
          </tbody>
        </table>
        <table class="va-compare cost" style="margin-top:1rem;">
          <thead><tr><th>Section C — Services You Can Shop For</th><th>Hypothetical</th></tr></thead>
          <tbody>
            <tr><td>Title insurance (owner's + lender's)</td><td>$3,000</td></tr>
            <tr><td>Settlement / closing fee</td><td>$795</td></tr>
            <tr><td>Survey</td><td>$650</td></tr>
            <tr><td>Pest inspection</td><td>$150</td></tr>
          </tbody>
        </table>
        <table class="va-compare cost" style="margin-top:1rem;">
          <thead><tr><th>Section E — Florida Taxes &amp; Government Fees</th><th>Hypothetical</th></tr></thead>
          <tbody>
            <tr><td>Documentary stamps on the note (0.35%)</td><td>$1,750</td></tr>
            <tr><td>Intangible tax (0.20%)</td><td>$1,000</td></tr>
            <tr><td>Recording fees</td><td>$350</td></tr>
          </tbody>
        </table>
        <table class="va-compare cost" style="margin-top:1rem;">
          <thead><tr><th>Section F — Prepaids &amp; Escrows</th><th>Hypothetical</th></tr></thead>
          <tbody>
            <tr><td>First year homeowner's insurance</td><td>$2,400</td></tr>
            <tr><td>Property tax escrow deposit</td><td>$1,200</td></tr>
            <tr><td>Builder's risk coverage (construction period)</td><td>$1,800</td></tr>
          </tbody>
        </table>

        <table class="va-compare cost" style="margin-top:1.4rem;">
          <tbody>
            <tr class="va-total"><td><strong>Total hypothetical closing costs + prepaids (first-use funding fee)</strong></td><td><strong>$29,360</strong></td></tr>
            <tr><td>Less: VA funding fee typically financed into the loan</td><td>− $10,750</td></tr>
            <tr class="va-total"><td><strong>Cash-relevant total</strong></td><td><strong>$18,610</strong></td></tr>
            <tr class="va-good"><td><strong>If EXEMPT: funding fee is $0</strong> — Total drops to <strong>$18,610</strong>, all of it cash-relevant</td><td><strong>✓ No fee</strong></td></tr>
          </tbody>
        </table>
        <p style="font-size:.75rem;color:var(--ink-lighter);margin-top:1rem;">Fully hypothetical illustration on a fictional property — deliberately over-estimated, not a quote, not an offer, and excluding financing costs that vary by scenario. The funding-fee percentages are current defaults set by the VA and subject to change; exemptions apply. Your actual figures appear on your Loan Estimate.</p>
      </div>
    </section>

    <section>
      <div class="container">
        <span class="eyebrow">Now Try Yours</span>
        <h2>Enter any total project cost — <span class="accent">see the hypothetical math</span></h2>
        <p class="section-lede">Land plus construction, any number you're imagining, and pick the funding-fee scenario that fits you. This scales the same over-estimated hypothetical worksheet to your figure. Estimates only — never a quote. For your real figures, review your Loan Estimate with our team; reviewed by Jim Blackburn, NMLS #1072866.</p>

        <div class="fee-note">
          <strong>About the funding-fee percentages:</strong> the rates below are current <em>default</em> figures shown for education only. The U.S. Department of Veterans Affairs sets the official funding-fee schedule and it is subject to change, and exemptions apply — including for many Veterans receiving VA disability compensation. These percentages are not guaranteed. Confirm your exact funding fee — or your exemption — with the VA and your loan officer before relying on any number here.
        </div>

        <div class="card" style="max-width:640px;">
          <div class="checker-form" style="margin-bottom:.9rem;">
            <input id="cc-price" type="text" inputmode="numeric" placeholder="Total project cost, e.g. 500000" aria-label="Total project cost" style="border:1px solid var(--border);background:var(--paper);color:var(--ink);">
          </div>
          <label for="cc-fee" style="display:block;font-size:.8rem;font-weight:600;color:var(--ink-2);margin-bottom:.4rem;">Your VA funding-fee scenario (default — verify with the VA)</label>
          <select id="cc-fee" aria-label="VA funding-fee scenario" style="width:100%;padding:.8rem 1.1rem;border:1px solid var(--border);border-radius:8px;background:var(--paper);color:var(--ink);font:inherit;font-size:.9375rem;margin-bottom:.9rem;">
            {feeTiers.map((t) => (
              <option value={t.rate} data-key={t.key}>{t.label}</option>
            ))}
          </select>
          <div class="checker-form">
            <a id="cc-go" class="btn btn-primary" href="javascript:void(0)">Estimate My Costs</a>
          </div>
          <div id="cc-out" style="display:none;margin-top:1rem;">
            <table class="va-compare"><tbody id="cc-rows"></tbody></table>
            <p id="cc-exempt" style="display:none;font-size:.8rem;color:#1E6B1E;font-weight:600;margin-top:.7rem;">✓ EXEMPT selected — no VA funding fee applies ($0). Many Veterans qualify; your COE confirms it.</p>
            <p style="font-size:.72rem;color:var(--ink-lighter);margin-top:.8rem;">This is a hypothetical, deliberately generous estimate on a fictional scenario — not a quote, not a Loan Estimate, and not a commitment to lend. Funding-fee percentages are VA defaults, subject to change, and exemptions apply. Excludes financing costs that vary case-by-case. Your Loan Estimate is the real document.</p>
            <div class="cta-row" style="margin-top:1rem;"><a class="btn btn-primary" href="/see-my-options/">See My Options</a></div>
          </div>
        </div>
      </div>
    </section>

    <script is:inline>
    (function(){
      const $=id=>document.getElementById(id);
      const fmt=n=>'$'+Math.round(n).toLocaleString();
      function calc(P){
        const sel=$('cc-fee'); const rate=parseFloat(sel.value)||0;
        const key=sel.options[sel.selectedIndex].getAttribute('data-key');
        const isExempt = key==='exempt';
        const flat = 1495+995+495 + 1200+350+750+120+25+85 + 3000+795+650+150 + 350 + 2400+1200+1800;
        const base = P;                    // VA at $0 down: loan amount approximates project cost — estimate only
        const fundingFee = isExempt ? 0 : base*rate;   // VA funding fee, typically financed; $0 if exempt
        const docstamp = P*0.0035, intang = P*0.002;
        const total = flat+fundingFee+docstamp+intang, cashRel = total-fundingFee;
        const feeLabel = isExempt
          ? "VA funding fee — EXEMPT (0%), no fee applies"
          : "VA funding fee ("+(rate*100).toFixed(rate*100%1?2:0)+"% default, typically financed)";
        const rows=[["Lender + third-party + prepaids (flat items)",fmt(flat)],
          [feeLabel, isExempt ? "$0" : fmt(fundingFee)],
          ["FL doc stamps (0.35%) + intangible tax (0.20%)",fmt(docstamp+intang)],
          ["<strong>Total hypothetical costs</strong>","<strong>"+fmt(total)+"</strong>"],
          ["Cash-relevant total (funding fee financed)",fmt(cashRel)],
          ["<strong>No monthly mortgage insurance</strong> — a VA loan carries none","<strong>$0/mo MI</strong>"]];
        $('cc-rows').innerHTML = rows.map((r,i)=>'<tr'+(i>=3?' class="va-key-row"':'')+'><td>'+r[0]+'</td><td>'+r[1]+'</td></tr>').join('');
        $('cc-exempt').style.display = isExempt ? 'block' : 'none';
        $('cc-out').style.display='block';
      }
      $('cc-go').onclick=()=>{const v=parseFloat(($('cc-price').value||'').replace(/[^0-9.]/g,'')); if(v>=50000&&v<=5000000) calc(v); else alert('Enter a total between $50,000 and $5,000,000');};
      $('cc-price').addEventListener('keydown',e=>{if(e.key==='Enter'){e.preventDefault();$('cc-go').click();}});
      $('cc-fee').addEventListener('change',()=>{ if($('cc-out').style.display==='block'){ $('cc-go').click(); }});
    })();
    </script>

    <!-- VA SUBFOOTER — sits ABOVE the site's main footer (Layout.astro provides licensing / NMLS #1660690 / EHO) -->
    <div style="background:var(--paper-2);border-top:1px solid var(--border);padding:1.6rem 0;">
      <div class="container">
        <p style="font-size:.75rem;color:var(--ink-lighter);line-height:1.7;margin:0;">
          The VA funding fee and its exemptions are set by the U.S. Department of Veterans Affairs and are subject to change; the percentages on this page are current defaults, not guaranteed figures — confirm your exact fee, or your exemption, with the VA. With full entitlement the VA sets no maximum on the loan amount; any county-based figure applies only to reduced or partial entitlement. Every figure on this page is a hypothetical, deliberately over-estimated illustration — not a quote, not a Loan Estimate, and not an offer. Your actual costs appear on your official Loan Estimate.
          Jim Blackburn, NMLS #1072866. This page is educational and is not a commitment to lend or a guarantee of approval.
        </p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .va-spoke-scope{
    --ink:#0A0E1A; --ink-2:#1E2433; --ink-light:#4A5568; --ink-lighter:#6B7280;
    --paper:#FAFAF7; --paper-2:#F4F4EE; --paper-3:#EDEDE5; --white:#FFFFFF;
    --blue:#1845D6; --blue-deep:#0F2EA0; --blue-soft:#E8EEFF; --blue-tint:#F2F5FF;
    --green:#2E9E2E; --green-soft:#E9F7E9; --rust:#8B2C2C;
    --border:#E5E5DE; --border-strong:#D4D4C8;
    --serif:'Fraunces','Iowan Old Style',Georgia,serif;
    --sans:'IBM Plex Sans',-apple-system,BlinkMacSystemFont,sans-serif;
    --mono:'JetBrains Mono','SF Mono',Menlo,monospace;
    font-family:var(--sans);font-size:1.0625rem;line-height:1.6;color:var(--ink);background:var(--paper);-webkit-font-smoothing:antialiased;
  }
  .va-spoke-scope *,.va-spoke-scope *::before,.va-spoke-scope *::after{box-sizing:border-box;margin:0;padding:0;}
  .va-spoke-scope a{color:inherit;text-decoration:none;}
  .va-spoke-scope .container{max-width:1100px;margin:0 auto;padding:0 1.5rem;}
  .va-spoke-scope .eyebrow{font-family:var(--mono);font-size:.75rem;letter-spacing:.14em;text-transform:uppercase;color:var(--blue);font-weight:500;display:inline-block;}
  .va-spoke-scope h1,.va-spoke-scope h2,.va-spoke-scope h3{font-family:var(--serif);font-weight:600;line-height:1.15;color:var(--ink);}
  .va-spoke-scope .accent{font-family:var(--serif);font-style:normal;color:var(--blue);}
  /* Hero */
  .va-spoke-scope .hero{padding:5rem 0 3.5rem;background:linear-gradient(180deg,var(--blue-tint) 0%,var(--paper) 100%);border-bottom:1px solid var(--border);}
  .va-spoke-scope .hero h1{font-size:clamp(2.1rem,5vw,3.4rem);margin:.9rem 0 1.1rem;max-width:820px;}
  .va-spoke-scope .hero p.lede{font-size:1.1875rem;color:var(--ink-light);max-width:680px;margin-bottom:1.8rem;}
  .va-spoke-scope .status-pill{display:inline-flex;align-items:center;gap:.5rem;background:var(--green-soft);border:1px solid #BFE3BF;color:#1E6B1E;border-radius:999px;padding:.4rem 1rem;font-family:var(--mono);font-size:.75rem;letter-spacing:.06em;text-transform:uppercase;font-weight:600;}
  .va-spoke-scope .status-pill::before{content:"";width:8px;height:8px;border-radius:50%;background:var(--green);}
  .va-spoke-scope .cta-row{display:flex;gap:.9rem;flex-wrap:wrap;margin-top:1.6rem;}
  .va-spoke-scope .btn{display:inline-block;padding:.85rem 1.7rem;border-radius:8px;font-weight:600;font-size:1rem;transition:transform .15s ease;}
  .va-spoke-scope .btn:hover{transform:translateY(-1px);}
  .va-spoke-scope .btn-primary{background:var(--blue);color:var(--white);}
  .va-spoke-scope .btn-secondary{background:var(--white);color:var(--ink);border:1.5px solid var(--border-strong);}
  .va-spoke-scope .trust-line{margin-top:1.4rem;font-size:.875rem;color:var(--ink-lighter);}
  /* Sections */
  .va-spoke-scope section{padding:3.5rem 0;}
  .va-spoke-scope section h2{font-size:clamp(1.6rem,3.4vw,2.2rem);margin:.7rem 0 1rem;}
  .va-spoke-scope .section-lede{color:var(--ink-light);max-width:720px;margin-bottom:2rem;}
  .va-spoke-scope .split{display:grid;grid-template-columns:1fr 1fr;gap:2.5rem;align-items:start;}
  @media(max-width:820px){.va-spoke-scope .split{grid-template-columns:1fr;}}
  .va-spoke-scope .card{background:var(--white);border:1px solid var(--border);border-radius:14px;padding:1.8rem;}
  .va-spoke-scope .card:hover{transform:none;box-shadow:none;border-color:var(--border);}
  .va-spoke-scope .card h3{font-size:1.25rem;margin-bottom:.7rem;}
  .va-spoke-scope .card p{color:var(--ink-light);font-size:.9688rem;}
  /* Funding-fee accuracy note */
  .va-spoke-scope .fee-note{background:var(--blue-tint);border:1px solid #C9D6FF;border-left:4px solid var(--blue);border-radius:10px;padding:1rem 1.2rem;font-size:.85rem;color:var(--ink-light);line-height:1.6;max-width:640px;margin-bottom:1.4rem;}
  .va-spoke-scope .fee-note strong{color:var(--ink-2);}
  /* Checker form (calculator input row) */
  .va-spoke-scope .checker-form{display:flex;gap:.7rem;flex-wrap:wrap;}
  .va-spoke-scope .checker-form input{flex:1;min-width:240px;padding:.85rem 1.1rem;border-radius:8px;font:inherit;font-size:.9688rem;}
  /* VA cluster bar (sticky, finger-swipeable sub-nav) */
  .va-spoke-scope .cluster-bar{position:sticky;top:0;z-index:50;background:var(--white);border-bottom:1px solid var(--border);box-shadow:0 1px 8px rgba(10,14,26,.05);}
  .va-spoke-scope .cluster-bar-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:.35rem;padding:.55rem 1.5rem;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
  .va-spoke-scope .cluster-bar-inner::-webkit-scrollbar{display:none;}
  .va-spoke-scope .cluster-label{flex:0 0 auto;font-family:var(--mono);font-size:.62rem;letter-spacing:.1em;text-transform:uppercase;color:var(--blue);white-space:nowrap;padding-right:.6rem;border-right:1px solid var(--border);margin-right:.35rem;font-weight:600;}
  .va-spoke-scope .cluster-bar a{flex:0 0 auto;white-space:nowrap;font-size:.76rem;font-weight:500;color:var(--ink-2);text-decoration:none;padding:.36rem .62rem;border-radius:999px;transition:background .15s;}
  .va-spoke-scope .cluster-bar a:hover{background:var(--paper-2);color:var(--ink);}
  .va-spoke-scope .cluster-bar a.active{background:var(--blue);color:#fff;font-weight:600;}
  /* Cost / comparison tables */
  .va-spoke-scope .va-compare{width:100%;border-collapse:separate;border-spacing:0;background:var(--white);border:1px solid var(--border);border-radius:14px;overflow:hidden;font-size:.92rem;box-shadow:0 1px 10px rgba(10,14,26,.05);}
  .va-spoke-scope .va-compare th,.va-spoke-scope .va-compare td{padding:.9rem 1.15rem;text-align:left;vertical-align:top;border-bottom:1px solid var(--border);}
  .va-spoke-scope .va-compare thead th{font-family:var(--mono);font-size:.7rem;letter-spacing:.09em;text-transform:uppercase;color:#fff;background:var(--ink);border-bottom:2px solid var(--ink);}
  .va-spoke-scope .va-compare tbody tr:nth-child(even) td{background:#FBFBF8;}
  .va-spoke-scope .va-compare tbody tr:last-child td{border-bottom:none;}
  .va-spoke-scope .va-compare td:first-child{font-weight:600;color:var(--ink-2);width:26%;}
  .va-spoke-scope .va-compare.cost{max-width:620px;margin-left:auto;margin-right:auto;}
  .va-spoke-scope .va-compare.cost td:last-child,.va-spoke-scope .va-compare.cost th:last-child{text-align:right;font-variant-numeric:tabular-nums;font-weight:600;white-space:nowrap;width:1%;padding-left:1.6rem;}
  .va-spoke-scope .va-compare.cost td:first-child{width:auto;font-weight:500;}
  .va-spoke-scope .va-key-row td{background:#F0F5FF !important;}
  .va-spoke-scope .va-total td{background:#FFF9E6 !important;font-weight:700;}
  .va-spoke-scope .va-good td{background:#E9F7E9 !important;font-weight:700;color:#1E6B1E;}
  @media(max-width:720px){.va-spoke-scope .va-compare{display:block;overflow-x:auto;}}
</style>
