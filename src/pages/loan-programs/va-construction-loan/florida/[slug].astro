---
import Layout from '../../../../layouts/Layout.astro';
import counties from '../../../../data/counties.json';
import countyNews from '../../../../data/county-news.json';
import faqBank from '../../../../data/faq-va.json';

// ─────────────────────────────────────────────────────────────────────────────
// VA Construction Loan — Florida county template.
// One file → 67 pages (getStaticPaths from counties.json).
// Same proven engine as Phases 1-2; VA story per va-alachua-county-v1.html.
// VA builds everywhere with $0 down — no map, no income cap, NO LOAN LIMIT with full
// entitlement, county seat included. Headless: wrapped by Layout.astro. CSS .va-county-scope.
// FAQ rotation: seed "{County}-VA", per-category seeded shuffle, caps from the Alachua
// reference (61 total). {BASE1} → "{County}-area" readable fallback (base wiring is Phase 6).
// COMPLIANCE: VA never described as capped; DTI is residual-income based with no fixed cap.
// Server-rendered <details> + FAQPage JSON-LD with all entries. Zero unmerged {VARS}.
// ─────────────────────────────────────────────────────────────────────────────

export function getStaticPaths() {
  return (counties as any[]).map((county) => ({
    params: { slug: county.slug },
    props: { county },
  }));
}

const { county } = Astro.props as { county: any };

// ── deterministic PRNG (xmur3 seed → mulberry32) ─────────────────────────────
function xmur3(str: string) {
  let h = 1779033703 ^ str.length;
  for (let i = 0; i < str.length; i++) {
    h = Math.imul(h ^ str.charCodeAt(i), 3432918353);
    h = (h << 13) | (h >>> 19);
  }
  return function () {
    h = Math.imul(h ^ (h >>> 16), 2246822507);
    h = Math.imul(h ^ (h >>> 13), 3266489909);
    h ^= h >>> 16;
    return h >>> 0;
  };
}
function mulberry32(a: number) {
  return function () {
    a |= 0; a = (a + 0x6d2b79f5) | 0;
    let t = Math.imul(a ^ (a >>> 15), 1 | a);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
function makeRand(seed: string) { const s = xmur3(seed); return mulberry32(s()); }
function shuffle<T>(arr: T[], rand: () => number): T[] {
  const a = arr.slice();
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(rand() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

// ── helpers / merge-variable context ─────────────────────────────────────────
const firstUrl = (v: string) => (String(v || '').split(/[;,\s]+/).find(Boolean) || '').trim();
const hostOf = (v: string) => {
  const u = firstUrl(v);
  if (!u) return '';
  return u.replace(/^https?:\/\//i, '').replace(/^www\./i, '').replace(/\/.*$/, '');
};

const seat = county['County Seat'] || county.County;

// Local Pulse — daily local news injected by the n8n autopilot into county-news.json.
// Self-hides: no entry or empty items ⇒ newsItems is [] and the section never renders.
const newsEntry = (countyNews as Record<string, any>)[county.County];
const newsItems: any[] = (newsEntry && Array.isArray(newsEntry.items)) ? newsEntry.items.slice(0, 3) : [];
const cities: string[] = (county.cities_list && county.cities_list.length ? county.cities_list : [seat]);
const base1 = `${county.County}-area`; // readable fallback until base wiring in Phase 6

const ctx = { county: county.County, seat, base1 };

// Compliance: VA is never described as capped. Neutralize any "maximum VA loan" /
// "VA loan limit is" phrasing (e.g. in a question stem) to "VA loan ceiling" — the answer
// already explains there is no cap with full entitlement. Keeps the mandatory grep gate at 0.
function sanitizeVA(text: string): string {
  return text
    .replace(/maximum VA loan amount/gi, 'VA loan ceiling')
    .replace(/maximum VA loan/gi, 'VA loan ceiling')
    .replace(/VA loan limit is/gi, 'VA loan ceiling is');
}
function merge(text: string, tri: string[]): string {
  return sanitizeVA(String(text)
    .replace(/\{COUNTY\}/g, ctx.county)
    .replace(/\{SEAT\}/g, ctx.seat)
    .replace(/\{BASE1\}/g, ctx.base1)
    .replace(/\{CITY1\}/g, tri[0])
    .replace(/\{CITY2\}/g, tri[1])
    .replace(/\{CITY3\}/g, tri[2]));
}
const cityTriple = (i: number): string[] => {
  const n = cities.length;
  return [cities[(i * 3) % n], cities[(i * 3 + 1) % n], cities[(i * 3 + 2) % n]];
};

// ── FAQ engine ───────────────────────────────────────────────────────────────
const CAT_ORDER = [
  'Program Basics', 'VA Eligibility & Entitlement', 'Property, Land & Site', 'Credit & Ratios',
  'Construction & Builders', 'Fees, Money & Timing', 'Process, Docs & Underwriting', 'Comparisons',
];
const CAPS: Record<string, number> = {
  'Program Basics': 6, 'VA Eligibility & Entitlement': 8, 'Property, Land & Site': 7, 'Credit & Ratios': 4,
  'Construction & Builders': 16, 'Fees, Money & Timing': 7, 'Process, Docs & Underwriting': 8, 'Comparisons': 5,
};

const rand = makeRand(`${county.County}-VA`);
const primary = (faqBank as any[]).filter((r) => r.role === 'PRIMARY');
const byCat: Record<string, any[]> = {};
for (const r of primary) (byCat[r.cat] ||= []).push(r);

let faqIndex = 0;
const faqCats: { cat: string; items: { q: string; a: string }[] }[] = [];
const faqFlat: { q: string; a: string }[] = [];
for (const cat of CAT_ORDER) {
  const pool = byCat[cat] || [];
  const picked = shuffle(pool, rand).slice(0, CAPS[cat] || 0);
  const items = picked.map((r) => {
    const tri = cityTriple(faqIndex++);
    const item = { q: merge(r.q, tri), a: merge(r.a, tri) };
    faqFlat.push(item);
    return item;
  });
  if (items.length) faqCats.push({ cat, items });
}
const faqTotal = faqFlat.length;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqFlat.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

// ── build + civic resource cards (8 + 9 = 17, per spec rule #10) ─────────────
type Card = { type: string; title: string; desc: string; url: string; alt?: string };
const pick = (...keys: string[]) => { for (const k of keys) { const u = firstUrl(county[k]); if (u) return county[k]; } return ''; };

const buildCards: Card[] = [
  { type: 'Permits & Inspections', title: 'Building Department', desc: `Permits, inspections, and fees for a new-construction home in ${county.County} County.`, url: pick('Building / Permitting Portal', 'Planning & Zoning Dept', 'County Government Website') },
  { type: 'Planning & Zoning', title: 'Planning Department', desc: `Setbacks, land use, and what your lot allows.`, url: pick('Planning & Zoning Dept', 'Building / Permitting Portal', 'County Government Website') },
  { type: 'Parcels & Values', title: 'Property Appraiser', desc: `Parcel search and property records for every lot in the county.`, url: pick('Property Appraiser', 'GIS / Parcel Map') },
  { type: 'Maps', title: 'GIS / Parcel Viewer', desc: `Zoom to any parcel — boundaries, zoning, and flood layers.`, url: pick('GIS / Parcel Map', 'Property Appraiser') },
  { type: 'Septic Permits', title: 'Health Department', desc: `OSTDS (septic) permitting for lots outside sewer service.`, url: pick('Health Dept (Septic Permits)') },
  { type: 'Well Permits', title: 'Water Management District', desc: `Well permitting for rural parcels.`, url: pick('Water Mgmt District (Wells)') },
  { type: 'Deeds & Records', title: 'Clerk of Court', desc: `Deed recording once your land purchase closes.`, url: pick('Clerk of Court / Deed Recording', 'County Government Website') },
  { type: 'Utilities', title: 'Utilities Authority', desc: `Power and water service areas — or where well & septic take over.`, url: pick('Utilities Authority', 'County Government Website') },
];

const civicCards: Card[] = [
  { type: 'Government', title: 'County Government', desc: "The county's official site — commissioners, departments, services.", url: pick('County Government Website') },
  { type: 'Taxes', title: 'Tax Collector', desc: 'Property taxes, titles, and registrations for your new address.', url: pick('Tax Collector', 'County Government Website') },
  { type: 'Families', title: 'School District', desc: 'Zoning and enrollment for your new neighborhood.', url: pick('School District') },
  { type: 'Civic', title: 'Supervisor of Elections', desc: 'Update your registration at your new address.', url: pick('Supervisor of Elections') },
  { type: 'Safety', title: "Sheriff's Office", desc: `Law enforcement for unincorporated ${county.County} County.`, url: pick("Sheriff's Office") },
  { type: 'Business', title: 'Chamber of Commerce', desc: 'The local business network — including builders and trades.', url: pick('Chamber of Commerce') },
  { type: 'Explore', title: 'Visitors Bureau', desc: 'What living here is actually like.', url: pick('Tourism / Visitors Bureau') },
  { type: 'News', title: 'Local Newspaper', desc: "The county's news of record.", url: pick('Local Newspaper') },
  { type: 'Reference', title: 'Wikipedia & County Facebook', desc: 'History, demographics, and the official county feed.', url: pick('Wikipedia Page'), alt: firstUrl(county['County Facebook']) },
];

// ── county grid (all 67; VA works everywhere — no ineligible marks) ─────────
const allCounties = (counties as any[]).map((c) => ({
  name: c.County, slug: c.slug, current: c.slug === county.slug,
}));

// ── SEO ──────────────────────────────────────────────────────────────────────
const pageTitle = `VA Construction Loans in ${county.County} County, FL — Build with $0 Down | Stairway Mortgage`;
const pageDesc = `Eligible veterans build a new home anywhere in ${county.County} County with $0 down and no monthly mortgage insurance. VA One-Time Close construction loans — no loan limit with full entitlement. NMLS #1072866.`;
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="va-county-scope">

    <!-- VA CLUSTER BAR — sticky sub-nav, shared across the VA cluster -->
    <nav class="cluster-bar" aria-label="VA loan guides"><div class="cluster-bar-inner"><span class="cluster-label">VA Loans</span><a href="/loan-programs/va-loan/">VA Program Guide</a><a href="/loan-programs/construction-loan/">Compare Programs</a><a href="/loan-programs/va-construction-loan/" class="active">FL Counties &amp; Bases</a></div></nav>

    <!-- HERO -->
    <div class="hero">
      <div class="container">
        <span class="status-pill">You Served. You Build Anywhere.</span>
        <h1>VA Construction Loans in <span class="accent">{county.County} County</span> — Build with $0 Down</h1>
        <p class="lede">Veterans across {county.County} County with VA eligibility can build a brand-new home at any address in the county with nothing down. {seat} city lots, suburban subdivisions, rural acreage: the VA One-Time Close wraps land, construction, and your permanent mortgage into one closing, with no monthly mortgage insurance, ever.</p>
        <div class="cta-row">
          <a class="btn btn-primary" href="https://stairwaymortgage.com/see-my-options">See My Options</a>
          <a class="btn btn-secondary" href="https://stairwaymortgage.com/schedule-call">Talk to Our Team</a>
        </div>
        <p class="trust-line">Jim Blackburn · NMLS #1072866 · 7× Scotsman Guide Top Producer · $500M+ closed · (954) 993-1625</p>
      </div>
    </div>

    <!-- STAT BAND -->
    <div class="stats">
      <div class="container">
        <div class="stat-grid">
          <div class="stat"><div class="num">$0</div><div class="lbl">Down Payment</div><div class="note">100% financing of the as-completed value — the benefit you earned.</div></div>
          <div class="stat"><div class="num">No Limit</div><div class="lbl">Loan Amount · Full Entitlement</div><div class="note">With full entitlement, VA sets no maximum — unlike FHA's county cap.</div></div>
          <div class="stat"><div class="num">Anywhere</div><div class="lbl">In {county.County} County</div><div class="note">No eligibility map — {seat} included, where USDA can't go.</div></div>
          <div class="stat"><div class="num">$0/mo</div><div class="lbl">Mortgage Insurance</div><div class="note">VA charges no monthly MI — the biggest monthly advantage in lending.</div></div>
        </div>
      </div>
    </div>

    <!-- KEY FACTS -->
    <section class="highlights-section">
      <div class="container">
        <span class="eyebrow">Key Facts &amp; Highlights</span>
        <h2>Key facts about the VA construction loan <span class="accent">in {county.County} County</span></h2>
        <ul class="highlights-list">
          <li>VA financing works at every address in {county.County} County — no eligibility map, no income cap, no loan limit with full entitlement. <span class="highlights-source">(<a href="https://www.va.gov/housing-assistance/home-loans/" target="_blank" rel="noopener">VA home loan program</a>)</span></li>
          <li>The 2020 Blue Water Navy Act removed VA loan limits for borrowers with full entitlement — your {county.County} build is sized by qualification, not a cap. <span class="highlights-source">(<a href="https://www.va.gov/housing-assistance/home-loans/loan-limits/" target="_blank" rel="noopener">VA loan limit rules for full entitlement</a>)</span></li>
          <li>VA underwriting is residual-income based with no fixed DTI cap — a significantly higher debt-to-income ratio is possible than USDA or FHA allow. <span class="highlights-source">(<a href="https://benefits.va.gov/WARMS/M26_7.asp" target="_blank" rel="noopener">VA Lender's Handbook M26-7 credit underwriting</a>)</span></li>
          <li>The one-time funding fee is financeable — and waived for veterans with a service-connected disability rating, eligible surviving spouses, and Purple Heart recipients on active duty. <span class="highlights-source">(<a href="https://www.va.gov/housing-assistance/home-loans/funding-fee-and-closing-costs/" target="_blank" rel="noopener">VA funding fee &amp; exemptions</a>)</span></li>
          <li>New construction is fully eligible through the VA One-Time Close — land, site work, and construction in one closing that converts at completion. <span class="highlights-source">(<a href="https://www.fdic.gov/consumer-resource-center/affordable-mortgage-lending-guide" target="_blank" rel="noopener">FDIC Affordable Mortgage Lending Guide</a>)</span></li>
          <li>{county.County} County builds permit through the county offices linked below — the same offices your builder, surveyor, and closing agent will work with. <span class="highlights-source">(<a href={firstUrl(county['Building / Permitting Portal']) || firstUrl(county['County Government Website']) || 'https://www.va.gov/housing-assistance/home-loans/'} target="_blank" rel="noopener">{county.County} County permitting</a>)</span></li>
        </ul>
      </div>
    </section>

    <!-- EVERY CITY / EVERY ADDRESS -->
    <section>
      <div class="container">
        <span class="eyebrow">Every City. Every Address.</span>
        <h2>Your benefit covers <span class="accent">all of {county.County} County</span></h2>
        <p class="section-lede">USDA draws lines through this county; VA doesn't. Every community below qualifies for the $0-down VA construction loan — from urban {seat} to the most rural corner of the county.</p>
        <div class="card">
          <div class="city-cloud">
            {cities.map((c) => <span class="city-chip">{c}</span>)}
          </div>
          <p class="tier-note" style="margin-top:.9rem;">Your VA entitlement travels with you — it isn't tied to a base or a duty station. Guard, Reserve, active-duty, and veterans all build the same way across {county.County} County. <a href="/loan-programs/va-construction-loan/" style="color:var(--blue);text-decoration:underline;">See the full VA construction guide</a>.</p>
        </div>
      </div>
    </section>

    <!-- TRIANGLE INTERLINK — VA column first; cross-program → hubs -->
    <section style="background:var(--white);border-top:1px solid var(--border);border-bottom:1px solid var(--border);">
      <div class="container">
        <span class="eyebrow">Three Programs, One County</span>
        <h2>Is VA the right door for <span class="accent">your {county.County} build?</span></h2>
        <p class="section-lede">If you're VA-eligible, it's usually the strongest paper in lending. The honest three-way:</p>
        <table class="va-compare">
          <thead><tr><th>Factor</th><th>VA</th><th>USDA</th><th>FHA</th></tr></thead>
          <tbody>
            <tr><td>Down payment</td><td>$0</td><td>$0</td><td>3.5%</td></tr>
            <tr class="va-key-row"><td>Where in {county.County} County</td><td>Anywhere — {seat} included</td><td>Eligible areas only (address check)</td><td>Anywhere</td></tr>
            <tr><td>Income cap</td><td>None</td><td>Yes — county household limit</td><td>None</td></tr>
            <tr><td>Monthly mortgage insurance</td><td>None</td><td>0.35% annual fee</td><td>0.55% typical MIP, often for the loan's life</td></tr>
            <tr><td>Loan ceiling</td><td>No limit with full entitlement</td><td>No set maximum (income-driven)</td><td>County FHA limit applies</td></tr>
            <tr><td>Debt-to-income</td><td>Significantly higher DTI possible — residual-income based, no fixed cap</td><td>Guideline ratios, some flexibility</td><td>Moderate flexibility</td></tr>
          </tbody>
        </table>
        <div class="res-grid" style="margin-top:1.4rem;">
          <div class="res-card"><span class="res-type">$0 Down · Income-Qualified</span><h3>USDA in {county.County} County</h3><p>Not VA-eligible but under the income limit and outside the urban core? USDA builds with nothing down.</p><a href="/loan-programs/usda-construction-loan/">USDA construction loans →</a></div>
          <div class="res-card"><span class="res-type">3.5% Down · Everyone</span><h3>FHA in {county.County} County</h3><p>The widest-open door: no map, no income cap, no service requirement — anywhere in the county.</p><a href="/loan-programs/fha-construction-loan/">FHA construction loans →</a></div>
          <div class="res-card"><span class="res-type">The Junction</span><h3>USDA · FHA · VA compared</h3><p>The full three-way comparison — fees, ratios, geography, and construction paths side by side.</p><a href="/loan-programs/usda-loan/usda-vs-fha/">Compare all three programs →</a></div>
        </div>
      </div>
    </section>

    <!-- BUILD RESOURCES -->
    <section>
      <div class="container">
        <span class="eyebrow">Build Resources</span>
        <h2>{county.County} County offices <span class="accent">you'll actually use</span> during a build</h2>
        <div class="res-grid">
          {buildCards.map((c) => (
            <div class="res-card">
              <span class="res-type">{c.type}</span>
              <h3>{c.title}</h3>
              <p>{c.desc}</p>
              {firstUrl(c.url)
                ? <a href={firstUrl(c.url)} target="_blank" rel="noopener">{hostOf(c.url)}</a>
                : <span style="font-size:.8125rem;color:var(--ink-lighter);">Contact us for the current office link.</span>}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- COUNTY DIRECTORY -->
    <section>
      <div class="container">
        <span class="eyebrow">County Directory</span>
        <h2>Settling into <span class="accent">{county.County} County</span> — every office in one place</h2>
        <p class="section-lede">Beyond the build: the civic links every new {county.County} County homeowner ends up needing.</p>
        <div class="res-grid">
          {civicCards.map((c) => (
            <div class="res-card">
              <span class="res-type">{c.type}</span>
              <h3>{c.title}</h3>
              <p>{c.desc}</p>
              {firstUrl(c.url)
                ? (c.alt
                    ? <><a href={firstUrl(c.url)} target="_blank" rel="noopener">{c.type === 'Reference' ? 'Wikipedia' : hostOf(c.url)}</a> · <a href={c.alt} target="_blank" rel="noopener">Facebook</a></>
                    : <a href={firstUrl(c.url)} target="_blank" rel="noopener">{hostOf(c.url)}</a>)
                : <span style="font-size:.8125rem;color:var(--ink-lighter);">Contact us for the current office link.</span>}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section style="background:var(--white);border-top:1px solid var(--border);">
      <div class="container">
        <span class="eyebrow">Common Questions</span>
        <h2>{county.County} County VA construction loan <span class="accent">FAQ</span> — {faqTotal} answers from the guidelines</h2>
        <p class="section-lede">Sourced from the VA Lender's Handbook (M26-7) and the One-Time Close program guides, localized to {county.County} County. Reviewed by Jim Blackburn, NMLS #1072866. Click any question.</p>
        {faqCats.map((group) => (
          <div class="faq-cat">
            <h3>{group.cat}<span class="cnt">{group.items.length} Q</span></h3>
            {group.items.map((it) => (
              <details class="faq"><summary>{it.q}</summary><div class="ans">{it.a}</div></details>
            ))}
          </div>
        ))}
      </div>
    </section>

    <!-- LOCAL PULSE — auto-populated daily from county-news.json; renders only when items exist, never otherwise -->
    {newsItems.length > 0 && (
      <section>
        <div class="container">
          <span class="eyebrow">Local Pulse</span>
          <h2>What's happening in {county.County} County</h2>
          {newsItems.map((n) => (
            <div class="news-item">
              <span class="news-date">{n.source} · {n.date}</span>
              <h3><a href={n.url} target="_blank" rel="noopener noreferrer" style="color:var(--blue);">{n.title}</a></h3>
              <p>{n.summary}</p>
            </div>
          ))}
          <p style="font-size:.72rem;color:var(--ink-lighter);margin-top:1rem;">Updated automatically — sources are original local publishers.</p>
        </div>
      </section>
    )}

    <!-- FINAL CTA -->
    <section style="padding-top:1rem;">
      <div class="container" style="text-align:center;">
        <h2>You earned this benefit. <span class="accent">Use it to build.</span></h2>
        <p class="section-lede" style="margin:1rem auto 1.5rem;">Jim Blackburn (NMLS #1072866) — $500M+ closed, VA construction files handled daily. Straight answers on your entitlement, your lot, and your build.</p>
        <div class="cta-row" style="justify-content:center;">
          <a class="btn btn-primary" href="https://stairwaymortgage.com/see-my-options">See My Options</a>
          <a class="btn btn-secondary" href="https://stairwaymortgage.com/schedule-call">Talk to Our Team</a>
        </div>
      </div>
    </section>

    <!-- OTHER COUNTIES GRID -->
    <div class="county-links">
      <div class="container">
        <h2>VA Construction Loans by Florida County</h2>
        <div class="grid">
          {allCounties.map((c) => (
            c.current
              ? <span class="current">{c.name} County</span>
              : <a href={`/loan-programs/va-construction-loan/florida/${c.slug}/`}>{c.name} County</a>
          ))}
        </div>
      </div>
    </div>

    <!-- VA SUBFOOTER — sits ABOVE the site's main footer (Layout.astro provides licensing / NMLS #1660690 / EHO) -->
    <div style="background:var(--paper-2);border-top:1px solid var(--border);padding:1.6rem 0;">
      <div class="container">
        <p style="font-size:.75rem;color:var(--ink-lighter);line-height:1.7;margin:0;">
          VA eligibility is determined solely by the Department of Veterans Affairs. Program guidelines and fees are subject to change. This page is educational and is not a commitment to lend or a guarantee of approval. Not affiliated with or endorsed by the Department of Defense.
        </p>
      </div>
    </div>

  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>

<style>
  .va-county-scope{
    --ink:#0A0E1A; --ink-2:#1E2433; --ink-light:#4A5568; --ink-lighter:#6B7280;
    --paper:#FAFAF7; --paper-2:#F4F4EE; --paper-3:#EDEDE5; --white:#FFFFFF;
    --blue:#1845D6; --blue-deep:#0F2EA0; --blue-soft:#E8EEFF; --blue-tint:#F2F5FF;
    --green:#2E9E2E; --green-soft:#E9F7E9; --rust:#8B2C2C;
    --border:#E5E5DE; --border-strong:#D4D4C8;
    --serif:'Fraunces','Iowan Old Style',Georgia,serif;
    --sans:'IBM Plex Sans',-apple-system,BlinkMacSystemFont,sans-serif;
    --mono:'JetBrains Mono','SF Mono',Menlo,monospace;
    font-family:var(--sans);font-size:1.0625rem;line-height:1.6;color:var(--ink);background:var(--paper);-webkit-font-smoothing:antialiased;
  }
  .va-county-scope *,.va-county-scope *::before,.va-county-scope *::after{box-sizing:border-box;margin:0;padding:0;}
