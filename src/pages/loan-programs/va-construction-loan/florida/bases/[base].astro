---
import Layout from '../../../../../layouts/Layout.astro';
import counties from '../../../../../data/counties.json';
import faqBank from '../../../../../data/faq-va.json';
import interlinks from '../../../../../data/interlinks.json';

// ─────────────────────────────────────────────────────────────────────────────
// VA Construction Loan — Florida MILITARY BASE pages (Phase 6).
// One file → 14 pages (getStaticPaths from interlinks.json).
// Lives in /florida/bases/ to avoid a route collision with florida/[slug].astro.
// Data-driven: base facts from interlinks.json, all local content (cities, resource
// directory) from the host county object in counties.json. FAQ rotation seeded by base.
// COMPLIANCE: VA never described as capped — sanitizeVA() neutralizes any capped phrasing;
// full entitlement = no VA-set maximum. Headless: wrapped by Layout.astro. CSS .va-base-scope.
// ─────────────────────────────────────────────────────────────────────────────

export function getStaticPaths() {
  return (interlinks as any[]).map((base) => {
    const county = (counties as any[]).find((c) => c.slug === base.hostCountySlug);
    return { params: { base: base.slug }, props: { base, county } };
  });
}

const { base, county } = Astro.props as { base: any; county: any };

// ── deterministic PRNG (xmur3 seed → mulberry32) ─────────────────────────────
function xmur3(str: string) {
  let h = 1779033703 ^ str.length;
  for (let i = 0; i < str.length; i++) {
    h = Math.imul(h ^ str.charCodeAt(i), 3432918353);
    h = (h << 13) | (h >>> 19);
  }
  return function () {
    h = Math.imul(h ^ (h >>> 16), 2246822507);
    h = Math.imul(h ^ (h >>> 13), 3266489909);
    h ^= h >>> 16;
    return h >>> 0;
  };
}
function mulberry32(a: number) {
  return function () {
    a |= 0; a = (a + 0x6d2b79f5) | 0;
    let t = Math.imul(a ^ (a >>> 15), 1 | a);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
function makeRand(seed: string) { const s = xmur3(seed); return mulberry32(s()); }
function shuffle<T>(arr: T[], rand: () => number): T[] {
  const a = arr.slice();
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(rand() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

// ── helpers ──────────────────────────────────────────────────────────────────
const firstUrl = (v: string) => (String(v || '').split(/[;,\s]+/).find(Boolean) || '').trim();
const hostOf = (v: string) => {
  const u = firstUrl(v);
  if (!u) return '';
  return u.replace(/^https?:\/\//i, '').replace(/^www\./i, '').replace(/\/.*$/, '');
};

const seat = county['County Seat'] || county.County;
const cities: string[] = (county.cities_list && county.cities_list.length ? county.cities_list : [seat]);
const c1 = cities[0] || seat;
const c2 = cities[1] || c1;
const c3 = cities[2] || c2;
const nameBySlug: Record<string, string> = Object.fromEntries((counties as any[]).map((c) => [c.slug, c.County]));

// ── merge-variable context ───────────────────────────────────────────────────
const ctx = { county: county.County, seat, base1: base.displayName };

// Compliance: VA is never described as capped. Neutralize any "maximum VA loan" /
// "VA loan limit is" phrasing (e.g. in a question stem) to "VA loan ceiling" — the answer
// already explains there is no cap with full entitlement. Keeps the mandatory grep gate at 0.
function sanitizeVA(text: string): string {
  return text
    .replace(/maximum VA loan amount/gi, 'VA loan ceiling')
    .replace(/maximum VA loan/gi, 'VA loan ceiling')
    .replace(/VA loan limit is/gi, 'VA loan ceiling is');
}
function merge(text: string, tri: string[]): string {
  return sanitizeVA(String(text)
    .replace(/\{COUNTY\}/g, ctx.county)
    .replace(/\{SEAT\}/g, ctx.seat)
    .replace(/\{BASE1\}/g, ctx.base1)
    .replace(/\{CITY1\}/g, tri[0])
    .replace(/\{CITY2\}/g, tri[1])
    .replace(/\{CITY3\}/g, tri[2]));
}
const cityTriple = (i: number): string[] => {
  const n = cities.length;
  return [cities[(i * 3) % n], cities[(i * 3 + 1) % n], cities[(i * 3 + 2) % n]];
};

// ── FAQ engine (seeded by base — per-base uniqueness) ────────────────────────
const CAT_ORDER = [
  'Program Basics', 'VA Eligibility & Entitlement', 'Construction & Builders',
  'Fees, Money & Timing', 'Process, Docs & Underwriting', 'Comparisons',
];
const CAPS: Record<string, number> = {
  'Program Basics': 3, 'VA Eligibility & Entitlement': 5, 'Construction & Builders': 5,
  'Fees, Money & Timing': 4, 'Process, Docs & Underwriting': 2, 'Comparisons': 2,
};

const rand = makeRand(`${base.slug}-VA`);
const primary = (faqBank as any[]).filter((r) => r.role === 'PRIMARY');
const byCat: Record<string, any[]> = {};
for (const r of primary) (byCat[r.cat] ||= []).push(r);

let faqIndex = 0;
const faqCats: { cat: string; items: { q: string; a: string }[] }[] = [];
const faqFlat: { q: string; a: string }[] = [];
for (const cat of CAT_ORDER) {
  const pool = byCat[cat] || [];
  const picked = shuffle(pool, rand).slice(0, CAPS[cat] || 0);
  const items = picked.map((r) => {
    const tri = cityTriple(faqIndex++);
    const item = { q: merge(r.q, tri), a: merge(r.a, tri) };
    faqFlat.push(item);
    return item;
  });
  if (items.length) faqCats.push({ cat, items });
}

// ── host-county resource directory (8 build + 9 civic) ───────────────────────
type Card = { type: string; title: string; desc: string; url: string; alt?: string };
const pick = (...keys: string[]) => { for (const k of keys) { const u = firstUrl(county[k]); if (u) return county[k]; } return ''; };
const buildCards: Card[] = [
  { type: 'Permits & Inspections', title: 'Building Department', desc: `Permits, inspections, and fees for a new-construction home in ${county.County} County.`, url: pick('Building / Permitting Portal', 'Planning & Zoning Dept', 'County Government Website') },
  { type: 'Planning & Zoning', title: 'Planning Department', desc: `Setbacks, land use, and what your lot allows.`, url: pick('Planning & Zoning Dept', 'Building / Permitting Portal', 'County Government Website') },
  { type: 'Parcels & Values', title: 'Property Appraiser', desc: `Parcel search and property records for every lot in the county.`, url: pick('Property Appraiser', 'GIS / Parcel Map') },
  { type: 'Maps', title: 'GIS / Parcel Viewer', desc: `Zoom to any parcel — boundaries, zoning, and flood layers.`, url: pick('GIS / Parcel Map', 'Property Appraiser') },
  { type: 'Septic Permits', title: 'Health Department', desc: `OSTDS (septic) permitting for lots outside sewer service.`, url: pick('Health Dept (Septic Permits)') },
  { type: 'Well Permits', title: 'Water Management District', desc: `Well permitting for rural parcels.`, url: pick('Water Mgmt District (Wells)') },
  { type: 'Deeds & Records', title: 'Clerk of Court', desc: `Deed recording once your land purchase closes.`, url: pick('Clerk of Court / Deed Recording', 'County Government Website') },
  { type: 'Utilities', title: 'Utilities Authority', desc: `Power and water service areas — or where well & septic take over.`, url: pick('Utilities Authority', 'County Government Website') },
];
const civicCards: Card[] = [
  { type: 'Government', title: 'County Government', desc: "The county's official site — commissioners, departments, services.", url: pick('County Government Website') },
  { type: 'Taxes', title: 'Tax Collector', desc: 'Property taxes, titles, and registrations for your new address.', url: pick('Tax Collector', 'County Government Website') },
  { type: 'Families', title: 'School District', desc: 'Zoning and enrollment for your new neighborhood.', url: pick('School District') },
  { type: 'Civic', title: 'Supervisor of Elections', desc: 'Update your registration at your new address.', url: pick('Supervisor of Elections') },
  { type: 'Safety', title: "Sheriff's Office", desc: `Law enforcement for unincorporated ${county.County} County.`, url: pick("Sheriff's Office") },
  { type: 'Business', title: 'Chamber of Commerce', desc: 'The local business network — including builders and trades.', url: pick('Chamber of Commerce') },
  { type: 'Explore', title: 'Visitors Bureau', desc: 'What living here is actually like.', url: pick('Tourism / Visitors Bureau') },
  { type: 'News', title: 'Local Newspaper', desc: "The county's news of record.", url: pick('Local Newspaper') },
  { type: 'Reference', title: 'Wikipedia & County Facebook', desc: 'History, demographics, and the official county feed.', url: pick('Wikipedia Page'), alt: firstUrl(county['County Facebook']) },
];

// ── SEO ──────────────────────────────────────────────────────────────────────
const pageTitle = `VA Construction Loans near ${base.displayName} — Build with $0 Down | Stairway Mortgage`;
const pageDesc = `Build a new home near ${base.name} in ${county.County} County with $0 down. VA One-Time Close construction loans for active duty, veterans & Guard — no income cap, no VA-set maximum with full entitlement. NMLS #1072866.`;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqFlat.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.stairwaymortgage.com/' },
    { '@type': 'ListItem', position: 2, name: 'Loan Programs', item: 'https://www.stairwaymortgage.com/loan-programs/' },
    { '@type': 'ListItem', position: 3, name: 'VA Construction Loan', item: 'https://www.stairwaymortgage.com/loan-programs/va-construction-loan/' },
    { '@type': 'ListItem', position: 4, name: `VA Construction Loans near ${base.displayName}` },
  ],
};

const SITE = ''; // internal nav is root-relative (domain-agnostic); JSON-LD schema below keeps absolute canonical URLs
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="va-base-scope">

    <!-- VA CLUSTER BAR — sticky, finger-swipeable sub-nav (absolute URLs, county-page convention) -->
    <nav class="cluster-bar" aria-label="VA construction loan guides"><div class="cluster-bar-inner"><span class="cluster-label">VA Construction</span><a href={`${SITE}/loan-programs/va-loan/`}>Program Guide</a><a href={`${SITE}/loan-programs/va-construction-loan/eligibility/`}>Eligibility</a><a href={`${SITE}/loan-programs/va-construction-loan/entitlement/`}>Entitlement</a><a href={`${SITE}/loan-programs/va-construction-loan/closing-cost-calculator/`}>Closing Costs</a><a href={`${SITE}/loan-programs/construction-loan/`}>Compare Programs</a><a href={`${SITE}/loan-programs/va-construction-loan/`} class="active">FL Counties &amp; Bases</a></div></nav>

    <!-- HERO -->
    <div class="hero"><div class="container">
      <span class="status-pill">For Those Who Serve at {base.displayName}</span>
      <span class="eyebrow" style="display:block;margin-top:1rem;">{base.branch} · {county.County} County</span>
      <h1>Build a new home near <span class="accent">{base.displayName}</span> with $0 down — VA construction loans</h1>
      <p class="lede">One loan. One closing. Land, construction, and your permanent mortgage — no down payment, no income cap, and no VA-set maximum with full entitlement. Build near {base.name} across {county.County} County: on-base proximity or country quiet, your call.</p>
      <div class="cta-row">
        <a class="btn btn-primary" href={`${SITE}/see-my-options/`}>See My Options</a>
        <a class="btn btn-secondary" href={`${SITE}/schedule-call/`}>Talk to Our Team</a>
      </div>
      <p class="trust-line">Jim Blackburn · NMLS #1072866 · 7× Scotsman Guide Top Producer · $500M+ closed · (954) 993-1625</p>
    </div></div>

    <!-- STAT BAND -->
    <div class="stats"><div class="container">
      <div class="stat-grid">
        <div class="stat"><div class="num">$0</div><div class="lbl">Down Payment</div><div class="note">VA-backed loans allow 100% financing for eligible service members and veterans.</div></div>
        <div class="stat"><div class="num">No Cap</div><div class="lbl">Income Limit</div><div class="note">VA has no income limit — eligibility is about service, not earnings.</div></div>
        <div class="stat"><div class="num">No Limit</div><div class="lbl">Loan Amount · Full Entitlement</div><div class="note">With full entitlement, the VA sets no maximum — sized by qualification, not a cap.</div></div>
        <div class="stat"><div class="num">1</div><div class="lbl">Closing · Start to Finish</div><div class="note">Financing locks before construction begins. No payments due until the home is complete.</div></div>
      </div>
    </div></div>

    <!-- WHY BUILD -->
    <section style="background:var(--white);border-bottom:1px solid var(--border);"><div class="container">
      <span class="eyebrow">{base.displayName} Country</span>
      <h2>The $0-down way to build near <span class="accent">{base.displayName}</span></h2>
      <p class="section-lede">{base.displayName} anchors a busy military housing market, and inventory near the gate can run thin. The VA construction loan flips the problem: pick your lot, pick your registered builder, and build the house your BAH math actually likes — with $0 down and no payments during construction. From {c1} to {c2} to the acreage beyond, your VA benefit builds anywhere near {base.displayName} — on-base proximity or country quiet. Every file is guided personally by Jim Blackburn, NMLS #1072866.</p>
      <div class="cta-row"><a class="btn btn-primary" href={`${SITE}/see-my-options/`}>See My Options</a></div>
    </div></section>

    <!-- KEY FACTS -->
    <section><div class="container">
      <span class="eyebrow">Key Facts &amp; Highlights</span>
      <h2>What the VA benefit means near <span class="accent">{base.displayName}</span></h2>
      <p class="section-lede">Each point below is sourced from federal authorities. Verify any of them through the linked references.</p>
      <ul class="highlights-list">
        <li>VA financing works at every address near {base.displayName} in {county.County} County — no eligibility map, no income cap, and no VA-set maximum with full entitlement. <span class="highlights-source">(<a href="https://www.va.gov/housing-assistance/home-loans/" target="_blank" rel="noopener">VA home loan program</a>)</span></li>
        <li>The 2020 Blue Water Navy Vietnam Veterans Act removed VA loan limits for borrowers with full entitlement — your build near {base.displayName} is sized by qualification, not a cap. <span class="highlights-source">(<a href="https://www.va.gov/housing-assistance/home-loans/loan-limits/" target="_blank" rel="noopener">VA loan limit rules for full entitlement</a>)</span></li>
        <li>New construction is eligible: a VA One-Time Close wraps the land, the build, and the permanent 30-year mortgage into a single closing — one approval, one set of closing costs. <span class="highlights-source">(<a href="https://www.va.gov/housing-assistance/home-loans/loan-types/" target="_blank" rel="noopener">VA loan types</a>)</span></li>
        <li>Many Veterans are exempt from the VA funding fee — including those receiving VA disability compensation. Your exemption status appears on your Certificate of Eligibility. <span class="highlights-source">(<a href="https://www.va.gov/housing-assistance/home-loans/funding-fee-and-closing-costs/" target="_blank" rel="noopener">VA funding fee</a>)</span></li>
        <li>Your entitlement travels with you — it isn't tied to a base or a duty station. Guard, Reserve, active-duty, and veterans near {base.displayName} all build the same way. Confirm your service history on your COE, reviewed with Jim Blackburn, NMLS #1072866.</li>
      </ul>
    </div></section>

    <!-- 1 LOAN / 1 APPROVAL / 1 CLOSING -->
    <section style="background:var(--white);border-top:1px solid var(--border);border-bottom:1px solid var(--border);"><div class="container">
      <span class="eyebrow">How It Works</span>
      <h2>One loan. <span class="accent">One approval. One closing.</span></h2>
      <div class="split">
        <div class="card"><h3>One approval, up front</h3><p>You qualify once, before construction begins. The construction phase and the permanent 30-year VA mortgage are the same loan — a true One-Time Close.</p></div>
        <div class="card"><h3>One closing, one set of costs</h3><p>A single closing means one set of closing costs and a single appraisal — a real saving versus a traditional two-close construction loan.</p></div>
      </div>
    </div></section>

    <!-- WHERE FAMILIES LIVE -->
    <section><div class="container">
      <span class="eyebrow">Where {base.displayName} Families Live</span>
      <h2>Communities within reach of <span class="accent">{base.displayName}</span></h2>
      <p class="section-lede">Every community below sits within realistic commuting range in {county.County} County. Your VA benefit builds in any of them — and the ones in USDA-eligible territory give dual-eligible families two $0-down paths to compare.</p>
      <div class="city-cloud">
        {cities.map((c) => <span class="city-chip">{c}</span>)}
      </div>
    </div></section>

    <!-- BUILD RESOURCES · HOST COUNTY -->
    <section style="background:var(--white);border-top:1px solid var(--border);"><div class="container">
      <span class="eyebrow">Build Resources · Host County</span>
      <h2>{county.County} County offices <span class="accent">you'll actually use</span></h2>
      <p class="section-lede">{base.displayName}'s host county — the offices your builder, surveyor, and closing agent work with on a {county.County} County build. Every link points to the official county or state authority.</p>
      <div class="res-grid">
        {buildCards.map((c) => (
          <div class="res-card">
            <span class="res-type">{c.type}</span>
            <h3>{c.title}</h3>
            <p>{c.desc}</p>
            {firstUrl(c.url)
              ? <a href={firstUrl(c.url)} target="_blank" rel="noopener">{hostOf(c.url)}</a>
              : <span style="font-size:.8125rem;color:var(--ink-lighter);">Contact us for the current office link.</span>}
          </div>
        ))}
      </div>
      <div class="res-grid" style="margin-top:1rem;">
        {civicCards.map((c) => (
          <div class="res-card">
            <span class="res-type">{c.type}</span>
            <h3>{c.title}</h3>
            <p>{c.desc}</p>
            {firstUrl(c.url)
              ? (c.alt
                  ? <><a href={firstUrl(c.url)} target="_blank" rel="noopener">{c.type === 'Reference' ? 'Wikipedia' : hostOf(c.url)}</a> · <a href={c.alt} target="_blank" rel="noopener">Facebook</a></>
                  : <a href={firstUrl(c.url)} target="_blank" rel="noopener">{hostOf(c.url)}</a>)
              : <span style="font-size:.8125rem;color:var(--ink-lighter);">Contact us for the current office link.</span>}
          </div>
        ))}
      </div>
    </div></section>

    <!-- DUAL-ELIGIBLE CROSS-LINKS -->
    <section><div class="container">
      <span class="eyebrow">Where {base.displayName} Families Build</span>
      <h2>Compare your <span class="accent">$0-down paths</span> by county</h2>
      <p class="section-lede">Your VA benefit builds anywhere in the region. But some communities near {base.displayName} also sit in USDA-eligible territory — dual-eligible buyers can compare both $0-down paths. County-by-county construction guides:</p>
      <div class="county-links"><div class="grid">
        {base.linksTo.map((slug: string) => (
          <a href={`${SITE}/loan-programs/usda-construction-loan/florida/${slug}/`}>{nameBySlug[slug]} County</a>
        ))}
      </div></div>
      <p class="section-lede" style="margin-top:1.6rem;">New to the VA benefit? Start with <a href={`${SITE}/loan-programs/va-construction-loan/eligibility/`} style="color:var(--blue);text-decoration:underline;">who qualifies</a> and <a href={`${SITE}/loan-programs/va-construction-loan/entitlement/`} style="color:var(--blue);text-decoration:underline;">how entitlement works</a>, or see every county on the <a href={`${SITE}/loan-programs/va-construction-loan/`} style="color:var(--blue);text-decoration:underline;">VA construction hub</a>. Reviewed by Jim Blackburn, NMLS #1072866.</p>
    </div></section>

    <!-- FAQ -->
    <section style="background:var(--white);border-top:1px solid var(--border);"><div class="container">
      <span class="eyebrow">Common Questions</span>
      <h2>VA construction loan <span class="accent">FAQ</span> — near {base.displayName}</h2>
      <p class="section-lede">Sourced from the VA program guides, localized to {county.County} County. Reviewed by Jim Blackburn, NMLS #1072866.</p>
      {faqCats.map((group) => (
        <div class="faq-cat">
          <h3>{group.cat}<span class="cnt">{group.items.length} Q</span></h3>
          {group.items.map((it) => (
            <details class="faq"><summary>{it.q}</summary><div class="ans">{it.a}</div></details>
          ))}
        </div>
      ))}
    </div></section>

    <!-- VA SUBFOOTER — sits ABOVE the site's main footer (Layout.astro provides licensing / NMLS #1660690 / EHO) -->
    <div style="background:var(--paper-2);border-top:1px solid var(--border);padding:1.6rem 0;">
      <div class="container">
        <p style="font-size:.75rem;color:var(--ink-lighter);line-height:1.7;margin:0;">
          VA home loan eligibility and entitlement are determined by the U.S. Department of Veterans Affairs; loan qualification (credit, income, and underwriting) applies separately. With full entitlement, the VA sets no maximum on the loan amount — any county-based figure applies only to reduced or partial entitlement. Program guidelines and the funding fee reflect current figures and are subject to change.
          Jim Blackburn, NMLS #1072866. This page is not a commitment to lend or a guarantee of approval.
        </p>
      </div>
    </div>

  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>

<style>
  .va-base-scope{
    --ink:#0A0E1A; --ink-2:#1E2433; --ink-light:#4A5568; --ink-lighter:#6B7280;
    --paper:#FAFAF7; --paper-2:#F4F4EE; --paper-3:#EDEDE5; --white:#FFFFFF;
    --blue:#1845D6; --blue-deep:#0F2EA0; --blue-soft:#E8EEFF; --blue-tint:#F2F5FF;
    --green:#2E9E2E; --green-soft:#E9F7E9; --rust:#8B2C2C;
    --border:#E5E5DE; --border-strong:#D4D4C8;
    --serif:'Fraunces','Iowan Old Style',Georgia,serif;
    --sans:'IBM Plex Sans',-apple-system,BlinkMacSystemFont,sans-serif;
    --mono:'JetBrains Mono','SF Mono',Menlo,monospace;
    font-family:var(--sans);font-size:1.0625rem;line-height:1.6;color:var(--ink);background:var(--paper);-webkit-font-smoothing:antialiased;
  }
  .va-base-scope *,.va-base-scope *::before,.va-base-scope *::after{box-sizing:border-box;margin:0;padding:0;}
  .va-base-scope a{color:inherit;text-decoration:none;}
  .va-base-scope .container{max-width:1100px;margin:0 auto;padding:0 1.5rem;}
  .va-base-scope .eyebrow{font-family:var(--mono);font-size:.75rem;letter-spacing:.14em;text-transform:uppercase;color:var(--blue);font-weight:500;display:inline-block;}
  .va-base-scope h1,.va-base-scope h2,.va-base-scope h3{font-family:var(--serif);font-weight:600;line-height:1.15;color:var(--ink);}
  .va-base-scope .accent{font-family:var(--serif);font-style:normal;color:var(--blue);}
  /* Hero */
  .va-base-scope .hero{padding:5rem 0 3.5rem;background:linear-gradient(180deg,var(--blue-tint) 0%,var(--paper) 100%);border-bottom:1px solid var(--border);}
  .va-base-scope .hero h1{font-size:clamp(2.1rem,5vw,3.4rem);margin:.9rem 0 1.1rem;max-width:820px;}
  .va-base-scope .hero p.lede{font-size:1.1875rem;color:var(--ink-light);max-width:680px;margin-bottom:1.8rem;}
  .va-base-scope .status-pill{display:inline-flex;align-items:center;gap:.5rem;background:var(--green-soft);border:1px solid #BFE3BF;color:#1E6B1E;border-radius:999px;padding:.4rem 1rem;font-family:var(--mono);font-size:.75rem;letter-spacing:.06em;text-transform:uppercase;font-weight:600;}
  .va-base-scope .status-pill::before{content:"";width:8px;height:8px;border-radius:50%;background:var(--green);}
  .va-base-scope .cta-row{display:flex;gap:.9rem;flex-wrap:wrap;margin-top:1.6rem;}
