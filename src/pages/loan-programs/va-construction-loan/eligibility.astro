---
import Layout from '../../../layouts/Layout.astro';

// ── VA no-cap compliance sanitizer (ported VERBATIM from the VA county template) ──
// VA is never described as capped. The replacements below neutralize any capped-loan
// phrasing in source text to a neutral "ceiling" — full entitlement carries no VA-set cap.
function sanitizeVA(text: string): string {
  return text
    .replace(/maximum VA loan amount/gi, 'VA loan ceiling')
    .replace(/maximum VA loan/gi, 'VA loan ceiling')
    .replace(/VA loan limit is/gi, 'VA loan ceiling is');
}
// Strip any residual merge placeholders (county / city / base names) then sanitize.
const clean = (t: string): string => sanitizeVA(String(t).replace(/\{[^}]*\}/g, '').replace(/\s{2,}/g, ' ').replace(/\s+([.,—])/g, '$1').trim());

// ── Eligibility FAQ set — sourced from faq-va.json (Program Basics / VA Eligibility &
//    Entitlement). Authored token-free, then run through clean() so no county/city/base
//    tokens and no capped-loan phrasing can survive. Educational only.
const rawFaqs = [
  {
    q: "Who is eligible for a VA home loan?",
    a: "Active-duty service members, Veterans with qualifying service and discharge, National Guard and Reserve members meeting service requirements, and certain surviving spouses. The VA — not the lender — makes the eligibility call.",
  },
  {
    q: "What is a Certificate of Eligibility, and how do I get one?",
    a: "The Certificate of Eligibility (COE) proves to lenders you've earned the benefit. Most lenders pull it electronically through the VA's system in seconds — or you can apply at VA.gov or by mail with VA Form 26-1880. We handle this for you.",
  },
  {
    q: "How much military service do I need to qualify?",
    a: "Currently serving: generally 90 continuous days. Gulf War-era Veterans: generally 24 continuous months, or the full period called to active duty (at least 90 days). Earlier eras have their own thresholds — we check yours in minutes.",
  },
  {
    q: "Do National Guard and Reserve members qualify?",
    a: "Yes — generally either 90 days of qualifying Title 10 active duty, or six creditable years in the Selected Reserve or Guard with honorable service, continued service, or retirement. Many Guard members are eligible and don't know it.",
  },
  {
    q: "Does active duty for training count toward eligibility?",
    a: "By itself, generally no — training time doesn't count as active duty for VA loan purposes. The six-year Selected Reserve or Guard path is usually how drilling members qualify.",
  },
  {
    q: "My discharge wasn't honorable — am I out of options?",
    a: "Not necessarily. An honorable period of service can establish eligibility even with a later less-than-honorable discharge, and discharge upgrades or VA character-of-discharge reviews are available. It's worth a real conversation.",
  },
  {
    q: "Can surviving spouses use the VA home loan benefit?",
    a: "Yes — unremarried surviving spouses receiving qualifying DIC, spouses of service members MIA or POW over 90 days, and certain remarried spouses (after age 57, on or after Dec 16, 2003) may qualify, including for construction.",
  },
  {
    q: "I've used my VA loan before — can I use it again to build?",
    a: "Very likely yes. VA entitlement can be restored after a prior VA loan is paid off, and many Veterans have remaining entitlement even with an active VA loan. We check your COE to confirm exactly where you stand.",
  },
];
const faqs = rawFaqs.map((f) => ({ q: clean(f.q), a: clean(f.a) }));

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://stairwaymortgage.com/" },
    { "@type": "ListItem", position: 2, name: "Loan Programs", item: "https://stairwaymortgage.com/loan-programs/" },
    { "@type": "ListItem", position: 3, name: "VA Construction Loan", item: "https://stairwaymortgage.com/loan-programs/va-construction-loan/" },
    { "@type": "ListItem", position: 4, name: "VA Construction Loan Eligibility" },
  ],
};
---

<Layout
  title="VA Construction Loan Eligibility | Stairway Mortgage"
  description="Who qualifies for a VA one-time-close construction loan, and how the Certificate of Eligibility (COE) works. Educational overview; eligibility is determined by the VA and underwriting."
  canonical="https://stairwaymortgage.com/loan-programs/va-construction-loan/eligibility/">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="va-spoke-scope">
    <!-- VA CLUSTER BAR — sticky, finger-swipeable sub-nav shared across the VA construction cluster -->
    <nav class="cluster-bar" aria-label="VA construction loan guides"><div class="cluster-bar-inner"><span class="cluster-label">VA Construction</span><a href="/loan-programs/va-loan/">Program Guide</a><a href="/loan-programs/va-construction-loan/eligibility/" class="active">Eligibility</a><a href="/loan-programs/va-construction-loan/entitlement/">Entitlement</a><a href="/loan-programs/va-construction-loan/closing-cost-calculator/">Closing Costs</a><a href="/loan-programs/construction-loan/">Compare Programs</a><a href="/loan-programs/va-construction-loan/">FL Counties</a></div></nav>

    <div class="hero"><div class="container">
      <span class="status-pill">Educational Guide</span>
      <h1>VA construction loan <span class="accent">eligibility</span></h1>
      <p class="lede">The VA benefit is one of the most powerful ways for those who served to build a new home — $0 down, no monthly mortgage insurance, and with full entitlement, no VA-set loan maximum. This page covers who generally qualifies for a VA one-time-close construction loan and how the Certificate of Eligibility (COE) works. Eligibility is established by the VA, and lender qualification applies separately.</p>
      <div class="cta-row"><a class="btn btn-primary" href="/see-my-options/">See My Options</a>
      <a class="btn btn-secondary" href="/schedule-call/">Talk to Our Team</a></div>
      <p class="trust-line">Jim Blackburn · NMLS #1072866 · 7× Scotsman Guide Top Producer · $500M+ closed · (954) 993-1625</p>
    </div></div>

    <section style="background:var(--white);border-bottom:1px solid var(--border);"><div class="container">
      <span class="eyebrow">Who Qualifies</span>
      <h2>Four paths to <span class="accent">VA eligibility</span></h2>
      <p class="section-lede">If you qualify for a VA purchase loan, you can generally use that same benefit to build. The VA — not the lender — makes the eligibility determination. Reviewed by Jim Blackburn, NMLS #1072866.</p>
      <div class="split">
        <div class="card"><h3>Veterans</h3><p>Those with qualifying service and a qualifying discharge. Even a less-than-honorable discharge isn't automatically the end — an honorable period of service or a character-of-discharge review can still establish eligibility.</p></div>
        <div class="card"><h3>Active-duty service members</h3><p>Currently serving members generally qualify after about 90 continuous days of service. Your entitlement travels with you — it isn't tied to a base or a duty station.</p></div>
        <div class="card"><h3>National Guard &amp; Reserve</h3><p>Generally 90 days of qualifying Title 10 active duty, or six creditable years in the Selected Reserve or Guard with honorable service. Many Guard members are eligible and don't realize it.</p></div>
        <div class="card"><h3>Surviving spouses</h3><p>Certain surviving spouses — including unremarried spouses receiving qualifying DIC and some remarried spouses — may use the benefit, including for construction.</p></div>
      </div>
    </div></section>

    <section><div class="container">
      <span class="eyebrow">The COE</span>
      <h2>The <span class="accent">Certificate of Eligibility</span></h2>
      <p class="section-lede">The COE is the VA's document confirming you've earned the home loan benefit. It's the piece that establishes eligibility — and it's usually quick to obtain.</p>
      <div class="split">
        <div class="card"><h3>What it proves</h3><p>The COE confirms to a lender that the VA recognizes your eligibility and shows your entitlement status, including any funding-fee exemption. It's the VA's call, documented.</p></div>
        <div class="card"><h3>How it's obtained</h3><p>Most lenders pull the COE electronically through the VA's system in seconds during your application. You can also request it yourself at VA.gov or by mail with VA Form 26-1880. Complicated service histories can take longer — we chase those down for you.</p></div>
      </div>
    </div></section>

    <section style="background:var(--white);border-top:1px solid var(--border);border-bottom:1px solid var(--border);"><div class="container">
      <span class="eyebrow">Two Things You Need</span>
      <h2>Eligibility <span class="accent">and</span> qualification</h2>
      <p class="section-lede">A VA construction loan takes two green lights: the VA confirms your <em>eligibility</em> (via the COE), and the lender confirms your <em>qualification</em> (credit, income, and underwriting review of the file). Both are needed, and they're decided by different parties — so meeting one doesn't guarantee the other. On the loan-size question, the good news for those who served: with full entitlement, the VA sets no maximum — your build is sized by your qualification, not a cap. Any county-based figure applies only to reduced or partial entitlement, which is a separate situation we walk through individually. Every scenario is reviewed personally by Jim Blackburn, NMLS #1072866.</p>
      <div class="cta-row"><a class="btn btn-primary" href="/see-my-options/">See My Options</a></div>
    </div></section>

    <section><div class="container">
      <span class="eyebrow">Common Questions</span>
      <h2>Eligibility <span class="accent">FAQ</span></h2>
      <p class="section-lede">General guidance below reflects typical VA program parameters. It is educational and not a commitment to lend — eligibility is determined by the VA, and qualification by underwriting.</p>
      <div class="faq-cat">
        {faqs.map((f) => (
          <details class="faq"><summary>{f.q}</summary><div class="ans">{f.a}</div></details>
        ))}
      </div>
      <p class="section-lede" style="margin-top:1.6rem;">Not sure where your service history lands? <a href="/schedule-call/" style="color:var(--blue);text-decoration:underline;">Schedule a call</a> with our team and we'll check your COE.</p>
    </div></section>

    <!-- VA SUBFOOTER — sits ABOVE the site's main footer (Layout.astro provides licensing / NMLS #1660690 / EHO) -->
    <div style="background:var(--paper-2);border-top:1px solid var(--border);padding:1.6rem 0;">
      <div class="container">
        <p style="font-size:.75rem;color:var(--ink-lighter);line-height:1.7;margin:0;">
          VA home loan eligibility is determined by the U.S. Department of Veterans Affairs based on service history and confirmed by your Certificate of Eligibility; lender qualification (credit, income, and underwriting) applies separately. With full entitlement, the VA sets no maximum — any county-based figure applies only to reduced or partial entitlement. Program guidelines reflect current figures and are subject to change.
          Jim Blackburn, NMLS #1072866. This page is not a commitment to lend or a guarantee of approval.
        </p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .va-spoke-scope{
    --ink:#0A0E1A; --ink-2:#1E2433; --ink-light:#4A5568; --ink-lighter:#6B7280;
    --paper:#FAFAF7; --paper-2:#F4F4EE; --paper-3:#EDEDE5; --white:#FFFFFF;
    --blue:#1845D6; --blue-deep:#0F2EA0; --blue-soft:#E8EEFF; --blue-tint:#F2F5FF;
    --green:#2E9E2E; --green-soft:#E9F7E9; --rust:#8B2C2C;
    --border:#E5E5DE; --border-strong:#D4D4C8;
    --serif:'Fraunces','Iowan Old Style',Georgia,serif;
    --sans:'IBM Plex Sans',-apple-system,BlinkMacSystemFont,sans-serif;
    --mono:'JetBrains Mono','SF Mono',Menlo,monospace;
    font-family:var(--sans);font-size:1.0625rem;line-height:1.6;color:var(--ink);background:var(--paper);-webkit-font-smoothing:antialiased;
  }
  .va-spoke-scope *,.va-spoke-scope *::before,.va-spoke-scope *::after{box-sizing:border-box;margin:0;padding:0;}
  .va-spoke-scope a{color:inherit;text-decoration:none;}
  .va-spoke-scope .container{max-width:1100px;margin:0 auto;padding:0 1.5rem;}
  .va-spoke-scope .eyebrow{font-family:var(--mono);font-size:.75rem;letter-spacing:.14em;text-transform:uppercase;color:var(--blue);font-weight:500;display:inline-block;}
  .va-spoke-scope h1,.va-spoke-scope h2,.va-spoke-scope h3{font-family:var(--serif);font-weight:600;line-height:1.15;color:var(--ink);}
  .va-spoke-scope .accent{font-family:var(--serif);font-style:normal;color:var(--blue);}
  /* Hero */
  .va-spoke-scope .hero{padding:5rem 0 3.5rem;background:linear-gradient(180deg,var(--blue-tint) 0%,var(--paper) 100%);border-bottom:1px solid var(--border);}
  .va-spoke-scope .hero h1{font-size:clamp(2.1rem,5vw,3.4rem);margin:.9rem 0 1.1rem;max-width:820px;}
  .va-spoke-scope .hero p.lede{font-size:1.1875rem;color:var(--ink-light);max-width:680px;margin-bottom:1.8rem;}
  .va-spoke-scope .status-pill{display:inline-flex;align-items:center;gap:.5rem;background:var(--green-soft);border:1px solid #BFE3BF;color:#1E6B1E;border-radius:999px;padding:.4rem 1rem;font-family:var(--mono);font-size:.75rem;letter-spacing:.06em;text-transform:uppercase;font-weight:600;}
  .va-spoke-scope .status-pill::before{content:"";width:8px;height:8px;border-radius:50%;background:var(--green);}
  .va-spoke-scope .cta-row{display:flex;gap:.9rem;flex-wrap:wrap;margin-top:1.6rem;}
  .va-spoke-scope .btn{display:inline-block;padding:.85rem 1.7rem;border-radius:8px;font-weight:600;font-size:1rem;transition:transform .15s ease;}
  .va-spoke-scope .btn:hover{transform:translateY(-1px);}
  .va-spoke-scope .btn-primary{background:var(--blue);color:var(--white);}
  .va-spoke-scope .btn-secondary{background:var(--white);color:var(--ink);border:1.5px solid var(--border-strong);}
  .va-spoke-scope .trust-line{margin-top:1.4rem;font-size:.875rem;color:var(--ink-lighter);}
  /* Sections */
  .va-spoke-scope section{padding:3.5rem 0;}
  .va-spoke-scope section h2{font-size:clamp(1.6rem,3.4vw,2.2rem);margin:.7rem 0 1rem;}
  .va-spoke-scope .section-lede{color:var(--ink-light);max-width:680px;margin-bottom:2rem;}
  .va-spoke-scope .split{display:grid;grid-template-columns:1fr 1fr;gap:2.5rem;align-items:start;}
  @media(max-width:820px){.va-spoke-scope .split{grid-template-columns:1fr;}}
  .va-spoke-scope .card{background:var(--white);border:1px solid var(--border);border-radius:14px;padding:1.8rem;}
  .va-spoke-scope .card:hover{transform:none;box-shadow:none;border-color:var(--border);}
  .va-spoke-scope .card h3{font-size:1.25rem;margin-bottom:.7rem;}
  .va-spoke-scope .card p{color:var(--ink-light);font-size:.9688rem;}
  /* VA cluster bar (sticky, finger-swipeable sub-nav) */
  .va-spoke-scope .cluster-bar{position:sticky;top:0;z-index:50;background:var(--white);border-bottom:1px solid var(--border);box-shadow:0 1px 8px rgba(10,14,26,.05);}
  .va-spoke-scope .cluster-bar-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:.35rem;padding:.55rem 1.5rem;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
  .va-spoke-scope .cluster-bar-inner::-webkit-scrollbar{display:none;}
  .va-spoke-scope .cluster-label{flex:0 0 auto;font-family:var(--mono);font-size:.62rem;letter-spacing:.1em;text-transform:uppercase;color:var(--blue);white-space:nowrap;padding-right:.6rem;border-right:1px solid var(--border);margin-right:.35rem;font-weight:600;}
  .va-spoke-scope .cluster-bar a{flex:0 0 auto;white-space:nowrap;font-size:.76rem;font-weight:500;color:var(--ink-2);text-decoration:none;padding:.36rem .62rem;border-radius:999px;transition:background .15s;}
  .va-spoke-scope .cluster-bar a:hover{background:var(--paper-2);color:var(--ink);}
  .va-spoke-scope .cluster-bar a.active{background:var(--blue);color:#fff;font-weight:600;}
  /* FAQ accordions */
  .va-spoke-scope .faq-cat{margin-top:.5rem;}
  .va-spoke-scope details.faq{background:var(--white);border:1px solid var(--border);border-radius:10px;margin-bottom:.55rem;overflow:hidden;}
  .va-spoke-scope details.faq summary{cursor:pointer;padding:.85rem 1.1rem;font-weight:600;color:var(--ink-2);list-style:none;display:flex;justify-content:space-between;gap:1rem;font-size:.94rem;}
  .va-spoke-scope details.faq summary::-webkit-details-marker{display:none;}
  .va-spoke-scope details.faq summary::after{content:'+';font-family:var(--mono);color:var(--blue);font-weight:600;}
  .va-spoke-scope details.faq[open] summary::after{content:'–';}
  .va-spoke-scope details.faq[open] summary{border-bottom:1px solid var(--border);}
  .va-spoke-scope details.faq .ans{padding:.9rem 1.1rem;font-size:.9rem;color:var(--ink-light);line-height:1.65;}
</style>
