---
import Layout from '../../layouts/Layout.astro';
import PostSidebar from '../../components/PostSidebar.astro';
const productSchema={"@context": "https://schema.org", "@type": ["FinancialProduct", "Service"], "name": "Mortgage Recast", "description": "Make a lump-sum payment and have your lender re-amortize \u2014 lower payment, same rate, no refinance.", "provider": {"@type": "Organization", "name": "Stairway Mortgage"}, "areaServed": "US"};
const faqSchema={"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "How is a recast different from a refinance?", "acceptedAnswer": {"@type": "Answer", "text": "A recast keeps your existing loan, rate, and term \u2014 only the payment drops after a lump-sum principal payment. A refinance replaces the loan entirely. Recasting avoids closing costs."}}, {"@type": "Question", "name": "Is every loan eligible to recast?", "acceptedAnswer": {"@type": "Answer", "text": "No \u2014 eligibility depends on your loan type and servicer. Government loans often aren't eligible. We can help you check."}}, {"@type": "Question", "name": "How much do I need to pay to recast?", "acceptedAnswer": {"@type": "Answer", "text": "Lenders usually require a minimum lump sum (often several thousand dollars). A modest recast fee typically applies."}}]};
const breadcrumbSchema={"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://stairwaymortgage.com/"}, {"@type": "ListItem", "position": 2, "name": "Loan Programs", "item": "https://stairwaymortgage.com/loan-programs/"}, {"@type": "ListItem", "position": 3, "name": "Mortgage Recast"}]};
---

<Layout title="Mortgage Recast | Stairway" description="Make a lump-sum payment and have your lender re-amortize — lower payment, same rate, no refinance." canonical="https://stairwaymortgage.com/loan-programs/mortgage-recast/">
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <nav class="container-page lp-breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/loan-programs/">Loan Programs</a> <span>/</span> <span>Mortgage Recast</span></nav>
  <header class="container-prose lp-header">
    <span class="eyebrow eyebrow-blue mb-5">Loan Program</span>
    <h1 class="display-lg">Mortgage Recast: Lower Your Payment Without Refinancing</h1>
    <p class="lede lp-lede">Make a lump-sum payment and have your lender re-amortize — lower payment, same rate, no refinance. Guided by Jim Blackburn · <span class="mono">NMLS #1072866</span></p>
    <div class="lp-cta-row"><a href="/see-my-options/" class="btn btn-blue btn-arrow">See My Options</a><a href="tel:+19549931625" class="btn btn-ghost">(954) 993-1625</a></div>
  </header>
  <div class="lp-main">
  <article class="prose-editorial lp-body" set:html={`<h2><b>What a Mortgage Recast Is</b></h2><p>A mortgage recast lets you make a large lump-sum principal payment, after which the lender re-amortizes the loan over the remaining term — lowering your monthly payment while keeping your existing rate and avoiding refinance costs.</p><h2><b>Who It's For</b></h2><ul><li>Homeowners who received a windfall or sold another property</li><li>Borrowers happy with their rate who want a lower payment</li><li>Those wanting to avoid refinance closing costs</li><li>Owners reducing their payment without restarting the term</li></ul><h2><b>How It Works</b></h2><p>You pay a lump sum toward principal, then the lender recalculates your monthly payment based on the lower balance over the remaining term. Your rate and term stay the same — you simply pay less monthly. Not all loans are eligible, and a modest recast fee usually applies.</p><h2><b>Frequently Asked Questions</b></h2><h3><b>How is a recast different from a refinance?</b></h3><p>A recast keeps your existing loan, rate, and term — only the payment drops after a lump-sum principal payment. A refinance replaces the loan entirely. Recasting avoids closing costs.</p><h3><b>Is every loan eligible to recast?</b></h3><p>No — eligibility depends on your loan type and servicer. Government loans often aren't eligible. We can help you check.</p><h3><b>How much do I need to pay to recast?</b></h3><p>Lenders usually require a minimum lump sum (often several thousand dollars). A modest recast fee typically applies.</p>`} />

    <PostSidebar />
  </div>
  <div class="container-prose"><p class="lp-compliance mono">This page is for educational purposes and is not a commitment to lend or an offer of a specific rate. Loan terms, rates, and qualification depend on your individual circumstances and are subject to underwriting approval. Stairway Mortgage is a division of NEXA Mortgage LLC.</p></div>
  <section class="section-tight lp-final-cta"><div class="container-prose"><div class="card lp-final-cta__card">
    <h2 class="display-md">Ready to explore this program?</h2>
    <p class="lede">Talk through your scenario with our team — straight answers, no credit pull to start.</p>
    <a href="/schedule-call/" class="btn btn-blue btn-arrow">Talk to Our Team</a>
  </div></div></section>
</Layout>

<style>
  .lp-main { display: grid; grid-template-columns: 1fr 300px; gap: 2.5rem; max-width: var(--container-max, 1320px); margin: 0 auto; padding-inline: clamp(1.25rem, 4vw, 2.5rem); }
  @media (max-width: 900px) { .lp-main { grid-template-columns: 1fr; } }
  .lp-breadcrumb { font-family:var(--stw-mono, 'JetBrains Mono'), monospace; font-size:12px; color:var(--color-mute); padding-top:2rem; padding-bottom:1.25rem; }
  .lp-breadcrumb a { color:var(--color-mute); text-decoration:none; } .lp-breadcrumb a:hover { color:var(--color-blue); }
  .lp-breadcrumb span { margin-inline:0.4rem; opacity:0.5; }
  .lp-header h1 { margin-bottom:1.25rem; } .lp-lede { margin-bottom:1.5rem; }
  .lp-cta-row { display:flex; gap:0.75rem; flex-wrap:wrap; }
  .lp-body { margin-top:2.5rem; }
  .lp-body :global(h2) { font-family:var(--stw-display, 'Fraunces'), Georgia, serif; font-variation-settings:"opsz" 96; font-weight:500; font-size:clamp(1.6rem,3vw,2.25rem); line-height:1.15; margin-top:3rem; margin-bottom:1.1rem; }
  .lp-body :global(h3) { font-family:var(--stw-display, 'Fraunces'), Georgia, serif; font-weight:500; font-size:clamp(1.2rem,2vw,1.55rem); margin-top:2rem; margin-bottom:0.8rem; }
  .lp-body :global(p) { font-size:17px; line-height:1.75; margin-bottom:1.25rem; color:var(--color-ink-light); }
  .lp-body :global(ul) { margin:0 0 1.5rem 1.25rem; display:flex; flex-direction:column; gap:0.5rem; }
  .lp-body :global(li) { font-size:17px; line-height:1.65; }
  .lp-body :global(a) { color:var(--color-blue); text-decoration:underline; text-underline-offset:2px; }
  .lp-compliance { font-size:11px; line-height:1.6; color:var(--color-mute); padding:1.5rem 0; border-top:1px solid var(--color-bone); margin-top:2rem; }
  .lp-final-cta__card { text-align:center; display:flex; flex-direction:column; align-items:center; gap:1rem; padding:2.5rem; }
</style>
