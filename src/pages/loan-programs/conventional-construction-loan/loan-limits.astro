---
import Layout from '../../../layouts/Layout.astro';
import counties from '../../../data/counties.json';

// ── helper (verbatim from the FHA/USDA county templates) ─────────────────────
const fmtMoney = (v: string) => {
  const n = Number(String(v).replace(/[^0-9.]/g, ''));
  return isNaN(n) || n === 0 ? '' : '$' + n.toLocaleString('en-US');
};

// ── derive baseline + exceptions from the data (nothing hardcoded) ───────────
const CONV_KEY = '2026 Conventional Limit (1-unit)';
const total = (counties as any[]).length;
const counts: Record<string, number> = {};
for (const c of counties as any[]) { const v = String(c[CONV_KEY]); counts[v] = (counts[v] || 0) + 1; }
const baselineRaw = Object.entries(counts).sort((a, b) => b[1] - a[1])[0][0];
const baselineCount = counts[baselineRaw];
const baseline = fmtMoney(baselineRaw);
const exceptions = (counties as any[])
  .filter((c) => String(c[CONV_KEY]) !== baselineRaw)
  .map((c) => ({ county: c.County, slug: c.slug, limit: fmtMoney(c[CONV_KEY]), raw: Number(String(c[CONV_KEY]).replace(/[^0-9.]/g, '')) }))
  .sort((a, b) => b.raw - a.raw);

// FAQ set — answers derived from the computed values so schema == visible text
const faqs = [
  {
    q: "What is the 2026 conventional loan limit in Florida?",
    a: `For 2026, the conforming one-unit loan limit is ${baseline} across ${baselineCount} of ${total} Florida counties.${exceptions.length === 1 ? ` ${exceptions[0].county} County is the one exception, with a higher limit of ${exceptions[0].limit}.` : exceptions.length > 1 ? ` ${exceptions.length} counties carry a higher limit.` : ''} These conforming limits are set annually by the Federal Housing Finance Agency.`,
  },
  {
    q: "Do conventional construction loans use the same limit?",
    a: "Yes. A conventional one-time-close construction loan is a conforming loan, so the same FHFA county limit caps the final loan amount — land and construction combined. Financing above the conforming limit moves into jumbo construction territory.",
  },
  {
    q: "Do the conforming limits change?",
    a: "Yes — the FHFA reviews and updates conforming loan limits every year based on national home-price movement. The figures on this page are the published 2026 amounts; verify your county's current limit with our team.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://stairwaymortgage.com/" },
    { "@type": "ListItem", position: 2, name: "Loan Programs", item: "https://stairwaymortgage.com/loan-programs/" },
    { "@type": "ListItem", position: 3, name: "Conventional Construction Loan", item: "https://stairwaymortgage.com/loan-programs/conventional-construction-loan/" },
    { "@type": "ListItem", position: 4, name: "Conventional Construction Loan Limits — Florida 2026" },
  ],
};
---

<Layout
  title="2026 Conventional Construction Loan Limits in Florida | Stairway Mortgage"
  description="The 2026 conforming one-unit loan limit for Florida and how it applies to conventional one-time-close construction loans — set annually by the Federal Housing Finance Agency."
  canonical="https://stairwaymortgage.com/loan-programs/conventional-construction-loan/loan-limits/">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="conv-spoke-scope">
    <!-- CONVENTIONAL CLUSTER BAR — sticky, finger-swipeable sub-nav shared across the conventional construction cluster -->
    <nav class="cluster-bar" aria-label="Conventional construction loan guides"><div class="cluster-bar-inner"><span class="cluster-label">Conventional Construction</span><a href="/loan-programs/conventional-loan/">Program Guide</a><a href="/loan-programs/conventional-construction-loan/loan-limits/" class="active">Loan Limits</a><a href="/loan-programs/construction-loan/">Compare Programs</a><a href="/loan-programs/conventional-construction-loan/">FL Counties</a></div></nav>

    <div class="hero"><div class="container">
      <span class="status-pill">2026 Figures</span>
      <h1>2026 conventional construction loan limits in <span class="accent">Florida</span></h1>
      <p class="lede">A conventional construction loan is a conforming loan, so it's capped by the one-unit conforming loan limit the Federal Housing Finance Agency sets for your county — land and build combined. In Florida, that ceiling is nearly uniform, with only high-cost areas running higher.</p>
      <div class="cta-row"><a class="btn btn-primary" href="/see-my-options/">See My Options</a>
      <a class="btn btn-secondary" href="/schedule-call/">Talk to Our Team</a></div>
      <p class="trust-line">Jim Blackburn · NMLS #1072866 · 7× Scotsman Guide Top Producer · $500M+ closed · (954) 993-1625</p>
    </div></div>

    <section style="background:var(--white);border-bottom:1px solid var(--border);"><div class="container">
      <span class="eyebrow">The Baseline</span>
      <h2>One conforming limit covers <span class="accent">nearly all of Florida</span></h2>
      <p class="section-lede">For 2026, the conforming one-unit loan limit is <strong>{baseline}</strong> across {baselineCount} of {total} Florida counties. As long as your conventional one-time-close construction financing lands at or under that figure, the conventional path is on the table; builds that need more move to jumbo construction financing. Reviewed by Jim Blackburn, NMLS #1072866.</p>
    </div></section>

    <section><div class="container">
      <span class="eyebrow">The Exceptions</span>
      <h2>Where the limit runs <span class="accent">higher</span></h2>
      <p class="section-lede">{exceptions.length === 0 ? 'Every Florida county uses the same conforming limit this year.' : exceptions.length === 1 ? 'One Florida county carries a higher, high-cost limit for 2026:' : `${exceptions.length} Florida counties carry higher, high-cost limits for 2026:`}</p>
      {exceptions.length > 0 && (
        <table class="va-compare limits"><thead><tr><th>County</th><th>2026 Conventional Limit (1-unit)</th></tr></thead>
          <tbody>
            {exceptions.map((e) => (
              <tr>
                <td><a href={`/loan-programs/conventional-construction-loan/florida/${e.slug}/`}>{e.county} County</a></td>
                <td class="amt">{e.limit}</td>
              </tr>
            ))}
          </tbody></table>
      )}
      <p style="font-size:.8rem;color:var(--ink-lighter);margin-top:1rem;">Source: Federal Housing Finance Agency (FHFA) 2026 conforming loan limits, one-unit. Baseline applies in {baselineCount} of {total} Florida counties; high-cost areas are set higher. Figures update annually — verify your county's current figure with our team.</p>
    </div></section>

    <section style="background:var(--white);border-top:1px solid var(--border);border-bottom:1px solid var(--border);"><div class="container">
      <span class="eyebrow">What It Means</span>
      <h2>The conforming limit is the <span class="accent">ceiling on your loan</span></h2>
      <p class="section-lede">On a conventional construction loan, the conforming limit caps the total loan amount — your land purchase and the cost to build, together. It is not a cap on the home's value; it is the most you can finance conventionally before the loan becomes a jumbo. Buyers building above the limit still have a path — jumbo one-time-close construction financing — it simply follows different guidelines. Every scenario is reviewed personally by Jim Blackburn, NMLS #1072866.</p>
      <div class="cta-row"><a class="btn btn-primary" href="/see-my-options/">See My Options</a></div>
    </div></section>

    <section><div class="container">
      <span class="eyebrow">How Limits Are Set</span>
      <h2>The FHFA sets the limit <span class="accent">every year</span></h2>
      <p class="section-lede">The conforming loan limit is published annually by the Federal Housing Finance Agency and moves with national home prices — it generally rises year to year. Most of the country shares a single baseline figure, while designated high-cost areas carry a higher ceiling. Because the number resets each year, it's worth confirming the current figure for your county before you finalize a build budget.</p>
    </div></section>

    <section><div class="container">
      <span class="eyebrow">Common Questions</span>
      <h2>Limits <span class="accent">FAQ</span></h2>
      <div class="faq-cat">
        {faqs.map((f) => (
          <details class="faq"><summary>{f.q}</summary><div class="ans">{f.a}</div></details>
        ))}
      </div>
      <p class="section-lede" style="margin-top:1.6rem;">Wondering whether your build fits under the conforming limit? <a href="/schedule-call/" style="color:var(--blue);text-decoration:underline;">Schedule a call</a> with our team.</p>
    </div></section>

    <!-- CONVENTIONAL SUBFOOTER — sits ABOVE the site's main footer (Layout.astro provides licensing / NMLS #1660690 / EHO) -->
    <div style="background:var(--paper-2);border-top:1px solid var(--border);padding:1.6rem 0;">
      <div class="container">
        <p style="font-size:.75rem;color:var(--ink-lighter);line-height:1.7;margin:0;">
          Conforming loan limits are set by the Federal Housing Finance Agency (FHFA) and are updated annually; designated high-cost areas may carry higher limits. Loan limits and program guidelines reflect published 2026 figures and are subject to change.
          Jim Blackburn, NMLS #1072866. This page is educational and is not a commitment to lend or a guarantee of approval.
        </p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .conv-spoke-scope{
    --ink:#0A0E1A; --ink-2:#1E2433; --ink-light:#4A5568; --ink-lighter:#6B7280;
    --paper:#FAFAF7; --paper-2:#F4F4EE; --paper-3:#EDEDE5; --white:#FFFFFF;
    --blue:#1845D6; --blue-deep:#0F2EA0; --blue-soft:#E8EEFF; --blue-tint:#F2F5FF;
    --green:#2E9E2E; --green-soft:#E9F7E9; --rust:#8B2C2C;
    --border:#E5E5DE; --border-strong:#D4D4C8;
    --serif:'Fraunces','Iowan Old Style',Georgia,serif;
    --sans:'IBM Plex Sans',-apple-system,BlinkMacSystemFont,sans-serif;
    --mono:'JetBrains Mono','SF Mono',Menlo,monospace;
    font-family:var(--sans);font-size:1.0625rem;line-height:1.6;color:var(--ink);background:var(--paper);-webkit-font-smoothing:antialiased;
  }
  .conv-spoke-scope *,.conv-spoke-scope *::before,.conv-spoke-scope *::after{box-sizing:border-box;margin:0;padding:0;}
  .conv-spoke-scope a{color:inherit;text-decoration:none;}
  .conv-spoke-scope .container{max-width:1100px;margin:0 auto;padding:0 1.5rem;}
  .conv-spoke-scope .eyebrow{font-family:var(--mono);font-size:.75rem;letter-spacing:.14em;text-transform:uppercase;color:var(--blue);font-weight:500;display:inline-block;}
  .conv-spoke-scope h1,.conv-spoke-scope h2,.conv-spoke-scope h3{font-family:var(--serif);font-weight:600;line-height:1.15;color:var(--ink);}
  .conv-spoke-scope .accent{font-family:var(--serif);font-style:normal;color:var(--blue);}
  /* Hero */
  .conv-spoke-scope .hero{padding:5rem 0 3.5rem;background:linear-gradient(180deg,var(--blue-tint) 0%,var(--paper) 100%);border-bottom:1px solid var(--border);}
  .conv-spoke-scope .hero h1{font-size:clamp(2.1rem,5vw,3.4rem);margin:.9rem 0 1.1rem;max-width:820px;}
  .conv-spoke-scope .hero p.lede{font-size:1.1875rem;color:var(--ink-light);max-width:680px;margin-bottom:1.8rem;}
  .conv-spoke-scope .status-pill{display:inline-flex;align-items:center;gap:.5rem;background:var(--green-soft);border:1px solid #BFE3BF;color:#1E6B1E;border-radius:999px;padding:.4rem 1rem;font-family:var(--mono);font-size:.75rem;letter-spacing:.06em;text-transform:uppercase;font-weight:600;}
  .conv-spoke-scope .status-pill::before{content:"";width:8px;height:8px;border-radius:50%;background:var(--green);}
  .conv-spoke-scope .cta-row{display:flex;gap:.9rem;flex-wrap:wrap;margin-top:1.6rem;}
  .conv-spoke-scope .btn{display:inline-block;padding:.85rem 1.7rem;border-radius:8px;font-weight:600;font-size:1rem;transition:transform .15s ease;}
  .conv-spoke-scope .btn:hover{transform:translateY(-1px);}
  .conv-spoke-scope .btn-primary{background:var(--blue);color:var(--white);}
  .conv-spoke-scope .btn-secondary{background:var(--white);color:var(--ink);border:1.5px solid var(--border-strong);}
  .conv-spoke-scope .trust-line{margin-top:1.4rem;font-size:.875rem;color:var(--ink-lighter);}
  /* Sections */
  .conv-spoke-scope section{padding:3.5rem 0;}
  .conv-spoke-scope section h2{font-size:clamp(1.6rem,3.4vw,2.2rem);margin:.7rem 0 1rem;}
  .conv-spoke-scope .section-lede{color:var(--ink-light);max-width:660px;margin-bottom:2rem;}
  .conv-spoke-scope .card{background:var(--white);border:1px solid var(--border);border-radius:14px;padding:1.8rem;}
  .conv-spoke-scope .card h3{font-size:1.25rem;margin-bottom:.7rem;}
  .conv-spoke-scope .card p{color:var(--ink-light);font-size:.9688rem;}
  /* FHFA cluster bar (sticky, finger-swipeable sub-nav) */
  .conv-spoke-scope .cluster-bar{position:sticky;top:0;z-index:50;background:var(--white);border-bottom:1px solid var(--border);box-shadow:0 1px 8px rgba(10,14,26,.05);}
  .conv-spoke-scope .cluster-bar-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:.35rem;padding:.55rem 1.5rem;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
  .conv-spoke-scope .cluster-bar-inner::-webkit-scrollbar{display:none;}
  .conv-spoke-scope .cluster-label{flex:0 0 auto;font-family:var(--mono);font-size:.62rem;letter-spacing:.1em;text-transform:uppercase;color:var(--blue);white-space:nowrap;padding-right:.6rem;border-right:1px solid var(--border);margin-right:.35rem;font-weight:600;}
  .conv-spoke-scope .cluster-bar a{flex:0 0 auto;white-space:nowrap;font-size:.76rem;font-weight:500;color:var(--ink-2);text-decoration:none;padding:.36rem .62rem;border-radius:999px;transition:background .15s;}
  .conv-spoke-scope .cluster-bar a:hover{background:var(--paper-2);color:var(--ink);}
  .conv-spoke-scope .cluster-bar a.active{background:var(--blue);color:#fff;font-weight:600;}
  /* Limits table */
  .conv-spoke-scope .va-compare{width:100%;border-collapse:separate;border-spacing:0;background:var(--white);border:1px solid var(--border);border-radius:14px;overflow:hidden;font-size:.92rem;box-shadow:0 1px 10px rgba(10,14,26,.05);max-width:620px;}
  .conv-spoke-scope .va-compare th,.conv-spoke-scope .va-compare td{padding:.9rem 1.15rem;text-align:left;vertical-align:top;border-bottom:1px solid var(--border);}
  .conv-spoke-scope .va-compare thead th{font-family:var(--mono);font-size:.7rem;letter-spacing:.09em;text-transform:uppercase;color:#fff;background:var(--ink);border-bottom:2px solid var(--ink);}
  .conv-spoke-scope .va-compare tbody tr:last-child td{border-bottom:none;}
  .conv-spoke-scope .va-compare td:first-child{font-weight:600;color:var(--ink-2);}
  .conv-spoke-scope .va-compare.limits td.amt{text-align:right;font-variant-numeric:tabular-nums;font-weight:600;white-space:nowrap;color:var(--ink);}
  .conv-spoke-scope .va-compare.limits td:first-child a{color:var(--blue);text-decoration:none;}
  .conv-spoke-scope .va-compare.limits td:first-child a:hover{text-decoration:underline;}
  /* FAQ accordions */
  .conv-spoke-scope .faq-cat{margin-top:.5rem;}
  .conv-spoke-scope details.faq{background:var(--white);border:1px solid var(--border);border-radius:10px;margin-bottom:.55rem;overflow:hidden;}
  .conv-spoke-scope details.faq summary{cursor:pointer;padding:.85rem 1.1rem;font-weight:600;color:var(--ink-2);list-style:none;display:flex;justify-content:space-between;gap:1rem;font-size:.94rem;}
  .conv-spoke-scope details.faq summary::-webkit-details-marker{display:none;}
  .conv-spoke-scope details.faq summary::after{content:'+';font-family:var(--mono);color:var(--blue);font-weight:600;}
  .conv-spoke-scope details.faq[open] summary::after{content:'–';}
  .conv-spoke-scope details.faq[open] summary{border-bottom:1px solid var(--border);}
  .conv-spoke-scope details.faq .ans{padding:.9rem 1.1rem;font-size:.9rem;color:var(--ink-light);line-height:1.65;}
  @media(max-width:720px){.conv-spoke-scope .va-compare{display:block;overflow-x:auto;}}
</style>
