---
import Layout from '../../../layouts/Layout.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://stairwaymortgage.com/" },
    { "@type": "ListItem", position: 2, name: "Loan Programs", item: "https://stairwaymortgage.com/loan-programs/" },
    { "@type": "ListItem", position: 3, name: "Conventional Construction Loan", item: "https://stairwaymortgage.com/loan-programs/conventional-construction-loan/" },
    { "@type": "ListItem", position: 4, name: "Conventional Construction Loan Closing Cost Estimator" },
  ],
};
---

<Layout
  title="Conventional Construction Loan Closing Cost Estimator | Stairway Mortgage"
  description="An educational estimate of potential closing costs for a conventional one-time-close construction loan, plus an interactive worksheet that scales to your project cost. Estimates only — never a quote or Loan Estimate."
  canonical="https://stairwaymortgage.com/loan-programs/conventional-construction-loan/closing-cost-calculator/">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="conv-spoke-scope">
    <!-- CONVENTIONAL CLUSTER BAR — sticky, finger-swipeable sub-nav shared across the conventional construction cluster -->
    <nav class="cluster-bar" aria-label="Conventional construction loan guides"><div class="cluster-bar-inner"><span class="cluster-label">Conventional Construction</span><a href="/loan-programs/conventional-loan/">Program Guide</a><a href="/loan-programs/conventional-construction-loan/loan-limits/">Loan Limits</a><a href="/loan-programs/conventional-construction-loan/credit-requirements/">Credit Requirements</a><a href="/loan-programs/conventional-construction-loan/closing-cost-calculator/" class="active">Closing Costs</a><a href="/loan-programs/construction-loan/">Compare Programs</a><a href="/loan-programs/conventional-construction-loan/">FL Counties</a></div></nav>

    <div class="hero"><div class="container">
      <span class="status-pill">Interactive Estimator + Worked Example</span>
      <h1>Conventional construction loan <span class="accent">closing cost estimator</span></h1>
      <p class="lede">First: a complete hypothetical worksheet on a $500,000 build ($100K land + $400K construction), organized like your Loan Estimate — every fee deliberately over-estimated. Then enter your own project cost and watch the same math scale. This is an educational estimate for a conventional one-time-close construction loan — clearly not a quote or a Loan Estimate.</p>
      <div class="cta-row"><a class="btn btn-primary" href="/see-my-options/">See My Options</a>
      <a class="btn btn-secondary" href="/schedule-call/">Talk to Our Team</a></div>
      <p class="trust-line">Jim Blackburn · NMLS #1072866 · 7× Scotsman Guide Top Producer · $500M+ closed · (954) 993-1625</p>
    </div></div>

    <section><div class="container">
      <span class="eyebrow">The Conventional Difference</span>
      <h2>No one-time insurance charge <span class="accent">rolled into closing</span></h2>
      <p class="section-lede">Reviewed by Jim Blackburn, NMLS #1072866.</p>
      <div class="split" style="grid-template-columns:repeat(auto-fit,minmax(280px,1fr));">
        <div class="card"><h3>No one-time MI charge</h3><p>Conventional loans carry no financed, one-time mortgage-insurance charge at closing — nothing rolled into the loan the way some government programs add a one-time premium. That keeps the closing-cost math simpler.</p></div>
        <div class="card"><h3>PMI is monthly, and often removable</h3><p>With less than 20% down, a conventional loan typically carries private mortgage insurance (PMI), paid monthly. It is not a closing cost — it is a monthly item — and it generally can be removed later as your equity grows. We walk you through how it fits your budget before you commit.</p></div>
        <div class="card"><h3>Seller/builder credit — up to 6%</h3><p>A seller or builder can contribute toward your closing costs and prepaids (up to actual charges, never cash back). The exact cap depends on your down payment — commonly 6% on the larger down payments typical of construction loans, 3% with minimal down, and up to 9% at 25%+ down.</p></div>
      </div>
    </div></section>

    <section style="background:var(--white);border-top:1px solid var(--border);border-bottom:1px solid var(--border);">
      <div class="container">
        <span class="eyebrow">The Real Numbers</span>
        <h2>A complete hypothetical example — <span class="accent">$500,000 build</span></h2>
        <p class="section-lede">$100,000 land + $400,000 construction in Florida — a genuinely nice home. Below is what a closing-cost worksheet can look like, organized the way your Loan Estimate organizes it. <strong>Every figure is hypothetical and deliberately on the generous side</strong> — your real numbers come on your real Loan Estimate.</p>

        <table class="va-compare cost">
          <thead><tr><th>Section A — Origination &amp; Lender Charges</th><th>Hypothetical</th></tr></thead>
          <tbody>
            <tr><td>Underwriting fee</td><td>$1,495</td></tr>
            <tr><td>Processing fee</td><td>$995</td></tr>
            <tr><td>Document preparation</td><td>$495</td></tr>
          </tbody>
        </table>
        <table class="va-compare cost" style="margin-top:1rem;">
          <thead><tr><th>Section B — Services You Cannot Shop For</th><th>Hypothetical</th></tr></thead>
          <tbody>
            <tr><td>Construction appraisal (as-completed value)</td><td>$1,200</td></tr>
            <tr><td>Final completion inspection</td><td>$350</td></tr>
            <tr><td>Draw inspections (5 × $150)</td><td>$750</td></tr>
            <tr><td>Credit report</td><td>$120</td></tr>
            <tr><td>Flood certification</td><td>$25</td></tr>
            <tr><td>Tax service fee</td><td>$85</td></tr>
          </tbody>
        </table>
        <table class="va-compare cost" style="margin-top:1rem;">
          <thead><tr><th>Section C — Services You Can Shop For</th><th>Hypothetical</th></tr></thead>
          <tbody>
            <tr><td>Title insurance (owner's + lender's)</td><td>$3,000</td></tr>
            <tr><td>Settlement / closing fee</td><td>$795</td></tr>
            <tr><td>Survey</td><td>$650</td></tr>
            <tr><td>Pest inspection</td><td>$150</td></tr>
          </tbody>
        </table>
        <table class="va-compare cost" style="margin-top:1rem;">
          <thead><tr><th>Section E — Florida Taxes &amp; Government Fees</th><th>Hypothetical</th></tr></thead>
          <tbody>
            <tr><td>Documentary stamps on the note (0.35%)</td><td>$1,750</td></tr>
            <tr><td>Intangible tax (0.20%)</td><td>$1,000</td></tr>
            <tr><td>Recording fees</td><td>$350</td></tr>
          </tbody>
        </table>
        <table class="va-compare cost" style="margin-top:1rem;">
          <thead><tr><th>Section F — Prepaids &amp; Escrows</th><th>Hypothetical</th></tr></thead>
          <tbody>
            <tr><td>First year homeowner's insurance</td><td>$2,400</td></tr>
            <tr><td>Property tax escrow deposit</td><td>$1,200</td></tr>
            <tr><td>Builder's risk coverage (construction period)</td><td>$1,800</td></tr>
          </tbody>
        </table>

        <table class="va-compare cost" style="margin-top:1.4rem;">
          <tbody>
            <tr class="va-total"><td><strong>Total hypothetical closing costs + prepaids</strong></td><td><strong>$18,610</strong></td></tr>
            <tr class="va-good"><td><strong>Seller/builder credit at 6% of $500,000</strong> (cap varies by down payment)</td><td><strong>$30,000</strong></td></tr>
            <tr class="va-good"><td><strong>Result: a 6% credit MORE than covers every cost above</strong> — credits can cover closing costs and prepaids up to actual charges (never cash back)</td><td><strong>✓ Covered</strong></td></tr>
          </tbody>
        </table>
        <p style="font-size:.75rem;color:var(--ink-lighter);margin-top:1rem;">Fully hypothetical illustration on a fictional property — deliberately over-estimated, not a quote, not an offer, and excluding financing costs that vary by scenario. Conventional interested-party contribution caps depend on your down payment. Your actual figures appear on your Loan Estimate.</p>
      </div>
    </section>

    <section>
      <div class="container">
        <span class="eyebrow">Now Try Yours</span>
        <h2>Enter any total project cost — <span class="accent">see the hypothetical math</span></h2>
        <p class="section-lede">Land plus construction, any number you're imagining. This scales the same over-estimated hypothetical worksheet to your figure and shows what a seller/builder credit does to it. Estimates only — never a quote. For your real figures, review your Loan Estimate with our team; reviewed by Jim Blackburn, NMLS #1072866.</p>
        <div class="card" style="max-width:640px;">
          <div class="checker-form" style="margin-bottom:1rem;">
            <input id="cc-price" type="text" inputmode="numeric" placeholder="Total project cost, e.g. 500000" aria-label="Total project cost" style="border:1px solid var(--border);background:var(--paper);color:var(--ink);">
            <a id="cc-go" class="btn btn-primary" href="javascript:void(0)">Estimate My Costs</a>
          </div>
          <div id="cc-out" style="display:none;">
            <table class="va-compare"><tbody id="cc-rows"></tbody></table>
            <p style="font-size:.72rem;color:var(--ink-lighter);margin-top:.8rem;">This is a hypothetical, deliberately generous estimate on a fictional scenario — not a quote, not a Loan Estimate, and not a commitment to lend. Excludes financing costs that vary case-by-case, and interested-party contribution caps depend on your down payment. Your Loan Estimate is the real document.</p>
            <div class="cta-row" style="margin-top:1rem;"><a class="btn btn-primary" href="/see-my-options/">See My Options</a></div>
          </div>
        </div>
      </div>
    </section>

    <script is:inline>
    (function(){
      const $=id=>document.getElementById(id);
      const fmt=n=>'$'+Math.round(n).toLocaleString();
      function calc(P){
        const flat = 1495+995+495 + 1200+350+750+120+25+85 + 3000+795+650+150 + 350 + 2400+1200+1800;
        const docstamp = P*0.0035, intang = P*0.002;
        const total = flat+docstamp+intang, credit = P*0.06;
        const rows=[["Lender + third-party + prepaids (flat items)",fmt(flat)],
          ["FL doc stamps (0.35%) + intangible tax (0.20%)",fmt(docstamp+intang)],
          ["<strong>Total estimated closing costs</strong>","<strong>"+fmt(total)+"</strong>"],
          ["<strong>Seller/builder credit — up to 6% (cap varies by down payment)</strong>","<strong>"+fmt(credit)+"</strong>"],
          [credit>=total?"<strong>✓ A 6% credit covers it</strong> — up to actual charges, never cash back":"<strong>Credit covers most of it</strong> — remaining gap: "+fmt(total-credit), credit>=total?"✓":""]];
        $('cc-rows').innerHTML = rows.map((r,i)=>'<tr'+(i>=2?' class="va-key-row"':'')+'><td>'+r[0]+'</td><td>'+r[1]+'</td></tr>').join('');
        $('cc-out').style.display='block';
      }
      $('cc-go').onclick=()=>{const v=parseFloat(($('cc-price').value||'').replace(/[^0-9.]/g,'')); if(v>=50000&&v<=5000000) calc(v); else alert('Enter a total between $50,000 and $5,000,000');};
      $('cc-price').addEventListener('keydown',e=>{if(e.key==='Enter'){e.preventDefault();$('cc-go').click();}});
    })();
    </script>

    <!-- CONVENTIONAL SUBFOOTER — sits ABOVE the site's main footer (Layout.astro provides licensing / NMLS #1660690 / EHO) -->
    <div style="background:var(--paper-2);border-top:1px solid var(--border);padding:1.6rem 0;">
      <div class="container">
        <p style="font-size:.75rem;color:var(--ink-lighter);line-height:1.7;margin:0;">
          Conventional (conforming) loans follow Fannie Mae and Freddie Mac guidelines and carry no financed, one-time mortgage-insurance charge at closing; any private mortgage insurance is a monthly item, not a closing cost. Every figure on this page is a hypothetical, deliberately over-estimated illustration — not a quote, not a Loan Estimate, and not an offer. Your actual costs appear on your official Loan Estimate.
          Jim Blackburn, NMLS #1072866. This page is educational and is not a commitment to lend or a guarantee of approval.
        </p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .conv-spoke-scope{
    --ink:#0A0E1A; --ink-2:#1E2433; --ink-light:#4A5568; --ink-lighter:#6B7280;
    --paper:#FAFAF7; --paper-2:#F4F4EE; --paper-3:#EDEDE5; --white:#FFFFFF;
    --blue:#1845D6; --blue-deep:#0F2EA0; --blue-soft:#E8EEFF; --blue-tint:#F2F5FF;
    --green:#2E9E2E; --green-soft:#E9F7E9; --rust:#8B2C2C;
    --border:#E5E5DE; --border-strong:#D4D4C8;
    --serif:'Fraunces','Iowan Old Style',Georgia,serif;
    --sans:'IBM Plex Sans',-apple-system,BlinkMacSystemFont,sans-serif;
    --mono:'JetBrains Mono','SF Mono',Menlo,monospace;
    font-family:var(--sans);font-size:1.0625rem;line-height:1.6;color:var(--ink);background:var(--paper);-webkit-font-smoothing:antialiased;
  }
  .conv-spoke-scope *,.conv-spoke-scope *::before,.conv-spoke-scope *::after{box-sizing:border-box;margin:0;padding:0;}
  .conv-spoke-scope a{color:inherit;text-decoration:none;}
  .conv-spoke-scope .container{max-width:1100px;margin:0 auto;padding:0 1.5rem;}
  .conv-spoke-scope .eyebrow{font-family:var(--mono);font-size:.75rem;letter-spacing:.14em;text-transform:uppercase;color:var(--blue);font-weight:500;display:inline-block;}
  .conv-spoke-scope h1,.conv-spoke-scope h2,.conv-spoke-scope h3{font-family:var(--serif);font-weight:600;line-height:1.15;color:var(--ink);}
  .conv-spoke-scope .accent{font-family:var(--serif);font-style:normal;color:var(--blue);}
  /* Hero */
  .conv-spoke-scope .hero{padding:5rem 0 3.5rem;background:linear-gradient(180deg,var(--blue-tint) 0%,var(--paper) 100%);border-bottom:1px solid var(--border);}
  .conv-spoke-scope .hero h1{font-size:clamp(2.1rem,5vw,3.4rem);margin:.9rem 0 1.1rem;max-width:820px;}
  .conv-spoke-scope .hero p.lede{font-size:1.1875rem;color:var(--ink-light);max-width:680px;margin-bottom:1.8rem;}
  .conv-spoke-scope .status-pill{display:inline-flex;align-items:center;gap:.5rem;background:var(--green-soft);border:1px solid #BFE3BF;color:#1E6B1E;border-radius:999px;padding:.4rem 1rem;font-family:var(--mono);font-size:.75rem;letter-spacing:.06em;text-transform:uppercase;font-weight:600;}
  .conv-spoke-scope .status-pill::before{content:"";width:8px;height:8px;border-radius:50%;background:var(--green);}
  .conv-spoke-scope .cta-row{display:flex;gap:.9rem;flex-wrap:wrap;margin-top:1.6rem;}
  .conv-spoke-scope .btn{display:inline-block;padding:.85rem 1.7rem;border-radius:8px;font-weight:600;font-size:1rem;transition:transform .15s ease;}
  .conv-spoke-scope .btn:hover{transform:translateY(-1px);}
  .conv-spoke-scope .btn-primary{background:var(--blue);color:var(--white);}
  .conv-spoke-scope .btn-secondary{background:var(--white);color:var(--ink);border:1.5px solid var(--border-strong);}
  .conv-spoke-scope .trust-line{margin-top:1.4rem;font-size:.875rem;color:var(--ink-lighter);}
  /* Sections */
  .conv-spoke-scope section{padding:3.5rem 0;}
  .conv-spoke-scope section h2{font-size:clamp(1.6rem,3.4vw,2.2rem);margin:.7rem 0 1rem;}
  .conv-spoke-scope .section-lede{color:var(--ink-light);max-width:660px;margin-bottom:2rem;}
  .conv-spoke-scope .split{display:grid;grid-template-columns:1fr 1fr;gap:2.5rem;align-items:start;}
  @media(max-width:820px){.conv-spoke-scope .split{grid-template-columns:1fr;}}
  .conv-spoke-scope .card{background:var(--white);border:1px solid var(--border);border-radius:14px;padding:1.8rem;}
  .conv-spoke-scope .card:hover{transform:none;box-shadow:none;border-color:var(--border);}
  .conv-spoke-scope .card h3{font-size:1.25rem;margin-bottom:.7rem;}
  .conv-spoke-scope .card p{color:var(--ink-light);font-size:.9688rem;}
  /* Checker form (calculator input row) */
  .conv-spoke-scope .checker-form{display:flex;gap:.7rem;flex-wrap:wrap;}
  .conv-spoke-scope .checker-form input{flex:1;min-width:240px;padding:.85rem 1.1rem;border-radius:8px;font:inherit;font-size:.9688rem;}
  /* Conventional cluster bar (sticky, finger-swipeable sub-nav) */
  .conv-spoke-scope .cluster-bar{position:sticky;top:0;z-index:50;background:var(--white);border-bottom:1px solid var(--border);box-shadow:0 1px 8px rgba(10,14,26,.05);}
  .conv-spoke-scope .cluster-bar-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:.35rem;padding:.55rem 1.5rem;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
  .conv-spoke-scope .cluster-bar-inner::-webkit-scrollbar{display:none;}
  .conv-spoke-scope .cluster-label{flex:0 0 auto;font-family:var(--mono);font-size:.62rem;letter-spacing:.1em;text-transform:uppercase;color:var(--blue);white-space:nowrap;padding-right:.6rem;border-right:1px solid var(--border);margin-right:.35rem;font-weight:600;}
  .conv-spoke-scope .cluster-bar a{flex:0 0 auto;white-space:nowrap;font-size:.76rem;font-weight:500;color:var(--ink-2);text-decoration:none;padding:.36rem .62rem;border-radius:999px;transition:background .15s;}
  .conv-spoke-scope .cluster-bar a:hover{background:var(--paper-2);color:var(--ink);}
  .conv-spoke-scope .cluster-bar a.active{background:var(--blue);color:#fff;font-weight:600;}
  /* Cost / comparison tables */
  .conv-spoke-scope .va-compare{width:100%;border-collapse:separate;border-spacing:0;background:var(--white);border:1px solid var(--border);border-radius:14px;overflow:hidden;font-size:.92rem;box-shadow:0 1px 10px rgba(10,14,26,.05);}
  .conv-spoke-scope .va-compare th,.conv-spoke-scope .va-compare td{padding:.9rem 1.15rem;text-align:left;vertical-align:top;border-bottom:1px solid var(--border);}
  .conv-spoke-scope .va-compare thead th{font-family:var(--mono);font-size:.7rem;letter-spacing:.09em;text-transform:uppercase;color:#fff;background:var(--ink);border-bottom:2px solid var(--ink);}
  .conv-spoke-scope .va-compare tbody tr:nth-child(even) td{background:#FBFBF8;}
  .conv-spoke-scope .va-compare tbody tr:last-child td{border-bottom:none;}
  .conv-spoke-scope .va-compare td:first-child{font-weight:600;color:var(--ink-2);width:26%;}
  .conv-spoke-scope .va-compare.cost{max-width:620px;margin-left:auto;margin-right:auto;}
  .conv-spoke-scope .va-compare.cost td:last-child,.conv-spoke-scope .va-compare.cost th:last-child{text-align:right;font-variant-numeric:tabular-nums;font-weight:600;white-space:nowrap;width:1%;padding-left:1.6rem;}
  .conv-spoke-scope .va-compare.cost td:first-child{width:auto;font-weight:500;}
  .conv-spoke-scope .va-key-row td{background:#F0F5FF !important;}
  .conv-spoke-scope .va-total td{background:#FFF9E6 !important;font-weight:700;}
  .conv-spoke-scope .va-good td{background:#E9F7E9 !important;font-weight:700;color:#1E6B1E;}
  @media(max-width:720px){.conv-spoke-scope .va-compare{display:block;overflow-x:auto;}}
</style>
