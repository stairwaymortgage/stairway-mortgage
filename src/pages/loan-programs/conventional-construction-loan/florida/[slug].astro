---
import Layout from '../../../../layouts/Layout.astro';
import counties from '../../../../data/counties.json';
import faqBank from '../../../../data/faq-conventional.json';

// ─────────────────────────────────────────────────────────────────────────────
// Conventional Construction Loan — Florida county template (final county leg).
// One file → 67 pages (getStaticPaths from counties.json).
// Same proven engine as Phases 1-3; conventional story per conventional-alachua-county-v1.html.
// Builds everywhere — no map, no income cap, no government fee, cancellable PMI.
// Headless: wrapped by Layout.astro. CSS scoped .conventional-county-scope.
// FAQ rotation: seed "{County}-CONV", per-category seeded shuffle, caps from the Alachua
// reference (61 total). {CONF} → the county's own 2026 conforming (conventional) limit.
// Server-rendered <details> + FAQPage JSON-LD with all entries. Zero unmerged {VARS}.
// ─────────────────────────────────────────────────────────────────────────────

export function getStaticPaths() {
  return (counties as any[]).map((county) => ({
    params: { slug: county.slug },
    props: { county },
  }));
}

const { county } = Astro.props as { county: any };

// ── deterministic PRNG (xmur3 seed → mulberry32) ─────────────────────────────
function xmur3(str: string) {
  let h = 1779033703 ^ str.length;
  for (let i = 0; i < str.length; i++) {
    h = Math.imul(h ^ str.charCodeAt(i), 3432918353);
    h = (h << 13) | (h >>> 19);
  }
  return function () {
    h = Math.imul(h ^ (h >>> 16), 2246822507);
    h = Math.imul(h ^ (h >>> 13), 3266489909);
    h ^= h >>> 16;
    return h >>> 0;
  };
}
function mulberry32(a: number) {
  return function () {
    a |= 0; a = (a + 0x6d2b79f5) | 0;
    let t = Math.imul(a ^ (a >>> 15), 1 | a);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
function makeRand(seed: string) { const s = xmur3(seed); return mulberry32(s()); }
function shuffle<T>(arr: T[], rand: () => number): T[] {
  const a = arr.slice();
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(rand() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

// ── helpers / merge-variable context ─────────────────────────────────────────
const fmtMoney = (v: string) => {
  const n = Number(String(v).replace(/[^0-9.]/g, ''));
  return isNaN(n) || n === 0 ? '' : '$' + n.toLocaleString('en-US');
};
const firstUrl = (v: string) => (String(v || '').split(/[;,\s]+/).find(Boolean) || '').trim();
const hostOf = (v: string) => {
  const u = firstUrl(v);
  if (!u) return '';
  return u.replace(/^https?:\/\//i, '').replace(/^www\./i, '').replace(/\/.*$/, '');
};

const seat = county['County Seat'] || county.County;
const cities: string[] = (county.cities_list && county.cities_list.length ? county.cities_list : [seat]);
const CONF = fmtMoney(county['2026 Conventional Limit (1-unit)']) || '$832,750';
const FHA = fmtMoney(county['2026 FHA Limit (1-unit)']) || '$541,287';

// In high-cost counties (e.g. Monroe) the FHA limit equals the conforming limit, so the
// "well above FHA's cap" framing would be false — branch the stat note on it.
const confAboveFha = Number(String(county['2026 Conventional Limit (1-unit)']).replace(/[^0-9.]/g, ''))
  > Number(String(county['2026 FHA Limit (1-unit)']).replace(/[^0-9.]/g, ''));

const ctx = { county: county.County, seat, conf: CONF, fha: FHA };

function merge(text: string, tri: string[]): string {
  return String(text)
    .replace(/\{COUNTY\}/g, ctx.county)
    .replace(/\{SEAT\}/g, ctx.seat)
    .replace(/\{CONF\}/g, ctx.conf)
    .replace(/\{CONV\}/g, ctx.conf)
    .replace(/\{FHA\}/g, ctx.fha)
    .replace(/\{CITY1\}/g, tri[0])
    .replace(/\{CITY2\}/g, tri[1])
    .replace(/\{CITY3\}/g, tri[2]);
}
const cityTriple = (i: number): string[] => {
  const n = cities.length;
  return [cities[(i * 3) % n], cities[(i * 3 + 1) % n], cities[(i * 3 + 2) % n]];
};

// ── FAQ engine ───────────────────────────────────────────────────────────────
const CAT_ORDER = [
  'Program Basics', 'Eligibility & Credit', 'Property, Land & Site',
  'Construction & Builders', 'Fees, Money & Timing', 'Process, Docs & Underwriting', 'Comparisons',
];
const CAPS: Record<string, number> = {
  'Program Basics': 7, 'Eligibility & Credit': 8, 'Property, Land & Site': 6,
  'Construction & Builders': 20, 'Fees, Money & Timing': 8, 'Process, Docs & Underwriting': 7, 'Comparisons': 5,
};

const rand = makeRand(`${county.County}-CONV`);
const primary = (faqBank as any[]).filter((r) => r.role === 'PRIMARY');
const byCat: Record<string, any[]> = {};
for (const r of primary) (byCat[r.cat] ||= []).push(r);

let faqIndex = 0;
const faqCats: { cat: string; items: { q: string; a: string }[] }[] = [];
const faqFlat: { q: string; a: string }[] = [];
for (const cat of CAT_ORDER) {
  const pool = byCat[cat] || [];
  const picked = shuffle(pool, rand).slice(0, CAPS[cat] || 0);
  const items = picked.map((r) => {
    const tri = cityTriple(faqIndex++);
    const item = { q: merge(r.q, tri), a: merge(r.a, tri) };
    faqFlat.push(item);
    return item;
  });
  if (items.length) faqCats.push({ cat, items });
}
const faqTotal = faqFlat.length;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqFlat.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

// ── build + civic resource cards (8 + 9 = 17, per spec rule #10) ─────────────
type Card = { type: string; title: string; desc: string; url: string; alt?: string };
const pick = (...keys: string[]) => { for (const k of keys) { const u = firstUrl(county[k]); if (u) return county[k]; } return ''; };

const buildCards: Card[] = [
  { type: 'Permits & Inspections', title: 'Building Department', desc: `Permits, inspections, and fees for a new-construction home in ${county.County} County.`, url: pick('Building / Permitting Portal', 'Planning & Zoning Dept', 'County Government Website') },
  { type: 'Planning & Zoning', title: 'Planning Department', desc: `Setbacks, land use, and what your lot allows.`, url: pick('Planning & Zoning Dept', 'Building / Permitting Portal', 'County Government Website') },
  { type: 'Parcels & Values', title: 'Property Appraiser', desc: `Parcel search and property records for every lot in the county.`, url: pick('Property Appraiser', 'GIS / Parcel Map') },
  { type: 'Maps', title: 'GIS / Parcel Viewer', desc: `Zoom to any parcel — boundaries, zoning, and flood layers.`, url: pick('GIS / Parcel Map', 'Property Appraiser') },
  { type: 'Septic Permits', title: 'Health Department', desc: `OSTDS (septic) permitting for lots outside sewer service.`, url: pick('Health Dept (Septic Permits)') },
  { type: 'Well Permits', title: 'Water Management District', desc: `Well permitting for rural parcels.`, url: pick('Water Mgmt District (Wells)') },
  { type: 'Deeds & Records', title: 'Clerk of Court', desc: `Deed recording once your land purchase closes.`, url: pick('Clerk of Court / Deed Recording', 'County Government Website') },
  { type: 'Utilities', title: 'Utilities Authority', desc: `Power and water service areas — or where well & septic take over.`, url: pick('Utilities Authority', 'County Government Website') },
];

const civicCards: Card[] = [
  { type: 'Government', title: 'County Government', desc: "The county's official site — commissioners, departments, services.", url: pick('County Government Website') },
  { type: 'Taxes', title: 'Tax Collector', desc: 'Property taxes, titles, and registrations for your new address.', url: pick('Tax Collector', 'County Government Website') },
  { type: 'Families', title: 'School District', desc: 'Zoning and enrollment for your new neighborhood.', url: pick('School District') },
  { type: 'Civic', title: 'Supervisor of Elections', desc: 'Update your registration at your new address.', url: pick('Supervisor of Elections') },
  { type: 'Safety', title: "Sheriff's Office", desc: `Law enforcement for unincorporated ${county.County} County.`, url: pick("Sheriff's Office") },
  { type: 'Business', title: 'Chamber of Commerce', desc: 'The local business network — including builders and trades.', url: pick('Chamber of Commerce') },
  { type: 'Explore', title: 'Visitors Bureau', desc: 'What living here is actually like.', url: pick('Tourism / Visitors Bureau') },
  { type: 'News', title: 'Local Newspaper', desc: "The county's news of record.", url: pick('Local Newspaper') },
  { type: 'Reference', title: 'Wikipedia & County Facebook', desc: 'History, demographics, and the official county feed.', url: pick('Wikipedia Page'), alt: firstUrl(county['County Facebook']) },
];

// ── county grid (all 67; conventional works everywhere) ──────────────────────
const allCounties = (counties as any[]).map((c) => ({
  name: c.County, slug: c.slug, current: c.slug === county.slug,
}));

// ── SEO ──────────────────────────────────────────────────────────────────────
const pageTitle = `Conventional Construction Loans in ${county.County} County, FL — Build Anywhere, PMI That Cancels | Stairway Mortgage`;
const pageDesc = `Build a new home anywhere in ${county.County} County with a conventional One-Time Close — up to ${CONF} (2026), no income cap, and PMI that cancels. NMLS #1072866.`;
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="conventional-county-scope">

    <!-- CONVENTIONAL CLUSTER BAR — sticky sub-nav -->
    <nav class="cluster-bar" aria-label="Conventional loan guides"><div class="cluster-bar-inner"><span class="cluster-label">Conventional</span><a href="/loan-programs/conventional-loan/">Program Guide</a><a href="/loan-programs/conventional-loan/credit-requirements/">Credit &amp; Down Payment</a><a href="/loan-programs/conventional-loan/loan-limits/">FL Loan Limits</a><a href="/loan-programs/usda-loan/usda-vs-fha/">USDA · FHA · VA · Conv</a><a href="/loan-programs/conventional-construction-loan/florida/" class="active">FL Counties</a></div></nav>

    <!-- HERO -->
    <div class="hero">
      <div class="container">
        <span class="status-pill">The Strong-File Play</span>
        <h1>Conventional Construction Loans in <span class="accent">{county.County} County</span> — Build Anywhere, PMI That Cancels</h1>
        <p class="lede">No map. No income cap. No government fee. The conventional One-Time Close builds at any {county.County} County address — with mortgage insurance that actually goes away, a {CONF} ceiling that fits large custom builds, and one closing for land, construction, and your permanent mortgage.</p>
        <div class="cta-row">
          <a class="btn btn-primary" href="https://stairwaymortgage.com/see-my-options">See My Options</a>
          <a class="btn btn-secondary" href="https://stairwaymortgage.com/schedule-call">Talk to Our Team</a>
        </div>
        <p class="trust-line">Jim Blackburn · NMLS #1072866 · 7× Scotsman Guide Top Producer · $500M+ closed · (954) 993-1625</p>
      </div>
    </div>

    <!-- STAT BAND -->
    <div class="stats">
      <div class="container">
        <div class="stat-grid">
          <div class="stat"><div class="num">5%</div><div class="lbl">Common Minimum Down</div><div class="note">On total acquisition cost — larger down payments shrink or remove PMI entirely.</div></div>
          <div class="stat"><div class="num">{CONF}</div><div class="lbl">2026 {county.County} County Limit</div><div class="note">{confAboveFha ? `Well above FHA's ${FHA} cap — room for serious custom builds.` : `At Florida's high-cost ceiling — room for serious custom builds.`}</div></div>
          <div class="stat"><div class="num">Anywhere</div><div class="lbl">In the County</div><div class="note">{seat} to the most rural corner — no eligibility map.</div></div>
          <div class="stat"><div class="num">Cancels</div><div class="lbl">Mortgage Insurance</div><div class="note">PMI removes at sufficient equity — FHA's typically never does.</div></div>
        </div>
      </div>
    </div>

    <!-- KEY FACTS -->
    <section class="highlights-section">
      <div class="container">
        <span class="eyebrow">Key Facts &amp; Highlights</span>
        <h2>Key facts about the conventional construction loan <span class="accent">in {county.County} County</span></h2>
        <ul class="highlights-list">
          <li>The 2026 conforming loan limit for a one-unit home in {county.County} County is {CONF} — set by FHFA, and this figure is {county.County}'s. Above it, the loan becomes jumbo construction. <span class="highlights-source">(<a href="https://www.fhfa.gov/data/conforming-loan-limit-values" target="_blank" rel="noopener">FHFA conforming loan limit values</a>)</span></li>
          <li>Fannie Mae and Freddie Mac both support single-close construction-to-permanent financing — one approval, one closing, no requalifying at completion. <span class="highlights-source">(<a href="https://selling-guide.fanniemae.com/" target="_blank" rel="noopener">Fannie Mae Selling Guide — construction-to-permanent</a>)</span></li>
          <li>Down payments start as low as 3–5%, and gift funds from family can cover the down payment and closing costs on a primary residence. <span class="highlights-source">(<a href="https://selling-guide.fanniemae.com/" target="_blank" rel="noopener">Agency selling-guide gift-fund rules</a>)</span></li>
          <li>Conventional PMI cancels as equity grows — automatically at 78% of original value, or by request at 80% — unlike FHA mortgage insurance, which often runs for the life of the loan. <span class="highlights-source">(<a href="https://www.consumerfinance.gov/ask-cfpb/when-can-i-remove-private-mortgage-insurance-pmi-from-my-loan-en-202/" target="_blank" rel="noopener">CFPB on PMI cancellation</a>)</span></li>
          <li>New construction is fully eligible through the conventional One-Time Close: land, site work, and construction in a single closing that converts to the permanent mortgage. <span class="highlights-source">(<a href="https://www.fdic.gov/consumer-resource-center/affordable-mortgage-lending-guide" target="_blank" rel="noopener">FDIC Affordable Mortgage Lending Guide</a>)</span></li>
          <li>{county.County} County permits, inspections, and septic approvals run through the county offices linked below — the same offices your builder will work with. <span class="highlights-source">(<a href={firstUrl(county['Building / Permitting Portal']) || firstUrl(county['County Government Website']) || 'https://www.fhfa.gov/data/conforming-loan-limit-values'} target="_blank" rel="noopener">{county.County} County permitting</a>)</span></li>
        </ul>
      </div>
    </section>

    <!-- EVERY CITY / EVERY ADDRESS -->
    <section>
      <div class="container">
        <span class="eyebrow">Every City. Every Address.</span>
        <h2>Conventional builds in <span class="accent">all of {county.County} County</span></h2>
        <p class="section-lede">Same freedom as FHA and VA — every community qualifies — with the pricing advantage that rewards strong credit and real down payments.</p>
        <div class="card">
          <div class="city-cloud">
            {cities.map((c) => <span class="city-chip">{c}</span>)}
          </div>
          <p class="tier-note" style="margin-top:.9rem;">Income under the county limit and building outside {seat}? Price the <a href={`/loan-programs/usda-construction-loan/florida/${county.slug}/`} style="color:var(--blue);text-decoration:underline;">$0-down USDA construction loan in {county.County} County</a> first.</p>
        </div>
      </div>
    </section>

    <!-- SQUARE INTERLINK — Conventional column first; cross-program → hubs -->
    <section style="background:var(--white);border-top:1px solid var(--border);border-bottom:1px solid var(--border);">
      <div class="container">
        <span class="eyebrow">Four Programs, One County</span>
        <h2>Is conventional the right door for <span class="accent">your {county.County} build?</span></h2>
        <table class="va-compare">
          <thead><tr><th>Factor</th><th>Conventional</th><th>FHA</th><th>USDA</th><th>VA</th></tr></thead>
          <tbody>
            <tr><td>Down payment</td><td>5% common</td><td>3.5%</td><td>$0</td><td>$0</td></tr>
            <tr class="va-key-row"><td>Where in {county.County} County</td><td>Anywhere</td><td>Anywhere</td><td>Eligible areas only</td><td>Anywhere</td></tr>
            <tr><td>Income cap</td><td>None</td><td>None</td><td>Yes — county limit</td><td>None</td></tr>
            <tr><td>Monthly mortgage insurance</td><td>PMI — cancels at equity</td><td>0.55% typical, often loan-life</td><td>0.35% annual fee</td><td>None</td></tr>
            <tr><td>2026 ceiling</td><td>{CONF}</td><td>{FHA}</td><td>No set max (income-driven)</td><td>No limit, full entitlement</td></tr>
            <tr><td>Upfront government fee</td><td>None</td><td>1.75% MIP</td><td>1% guarantee fee</td><td>Funding fee (waivable)</td></tr>
          </tbody>
        </table>
        <div class="res-grid" style="margin-top:1.4rem;">
          <div class="res-card"><span class="res-type">$0 Down · Income-Qualified</span><h3>USDA in {county.County} County</h3><p>Under the limit, outside the urban core? Nothing down.</p><a href="/loan-programs/usda-construction-loan/">USDA construction loans →</a></div>
          <div class="res-card"><span class="res-type">3.5% Down · Flexible Credit</span><h3>FHA in {county.County} County</h3><p>Lower down and wider credit flexibility than conventional.</p><a href="/loan-programs/fha-construction-loan/">FHA construction loans →</a></div>
          <div class="res-card"><span class="res-type">$0 Down · Veterans</span><h3>VA in {county.County} County</h3><p>Eligible? Usually the strongest paper in lending.</p><a href="/loan-programs/va-construction-loan/">VA construction loans →</a></div>
        </div>
      </div>
    </section>

    <!-- BUILD RESOURCES -->
    <section style="background:var(--white);border-top:1px solid var(--border);">
      <div class="container">
        <span class="eyebrow">Build Resources</span>
        <h2>{county.County} County offices <span class="accent">you'll actually use</span> during a build</h2>
        <div class="res-grid">
          {buildCards.map((c) => (
            <div class="res-card">
              <span class="res-type">{c.type}</span>
              <h3>{c.title}</h3>
              <p>{c.desc}</p>
              {firstUrl(c.url)
                ? <a href={firstUrl(c.url)} target="_blank" rel="noopener">{hostOf(c.url)}</a>
                : <span style="font-size:.8125rem;color:var(--ink-lighter);">Contact us for the current office link.</span>}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- COUNTY DIRECTORY -->
    <section>
      <div class="container">
        <span class="eyebrow">County Directory</span>
        <h2>Settling into <span class="accent">{county.County} County</span> — every office in one place</h2>
        <p class="section-lede">Beyond the build: the civic links every new {county.County} County homeowner ends up needing.</p>
        <div class="res-grid">
          {civicCards.map((c) => (
            <div class="res-card">
              <span class="res-type">{c.type}</span>
              <h3>{c.title}</h3>
              <p>{c.desc}</p>
              {firstUrl(c.url)
                ? (c.alt
                    ? <><a href={firstUrl(c.url)} target="_blank" rel="noopener">{c.type === 'Reference' ? 'Wikipedia' : hostOf(c.url)}</a> · <a href={c.alt} target="_blank" rel="noopener">Facebook</a></>
                    : <a href={firstUrl(c.url)} target="_blank" rel="noopener">{hostOf(c.url)}</a>)
                : <span style="font-size:.8125rem;color:var(--ink-lighter);">Contact us for the current office link.</span>}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section style="background:var(--white);border-top:1px solid var(--border);">
      <div class="container">
        <span class="eyebrow">Common Questions</span>
        <h2>{county.County} County conventional construction loan <span class="accent">FAQ</span> — {faqTotal} answers from the guidelines</h2>
        <p class="section-lede">Sourced from agency selling guides and construction program guides, localized to {county.County} County. Reviewed by Jim Blackburn, NMLS #1072866. Click any question.</p>
        {faqCats.map((group) => (
          <div class="faq-cat">
            <h3>{group.cat}<span class="cnt">{group.items.length} Q</span></h3>
            {group.items.map((it) => (
              <details class="faq"><summary>{it.q}</summary><div class="ans">{it.a}</div></details>
            ))}
          </div>
        ))}
      </div>
    </section>

    <!-- FINAL CTA -->
    <section style="padding-top:1rem;">
      <div class="container" style="text-align:center;">
        <h2>Strong file? <span class="accent">Make it work for you.</span></h2>
        <p class="section-lede" style="margin:1rem auto 1.5rem;">Jim Blackburn (NMLS #1072866) — $500M+ closed. Conventional priced against USDA, FHA, and VA on your actual numbers, every time.</p>
        <div class="cta-row" style="justify-content:center;">
          <a class="btn btn-primary" href="https://stairwaymortgage.com/see-my-options">See My Options</a>
          <a class="btn btn-secondary" href="https://stairwaymortgage.com/schedule-call">Talk to Our Team</a>
        </div>
      </div>
    </section>

    <!-- OTHER COUNTIES GRID -->
    <div class="county-links">
      <div class="container">
        <h2>Conventional Construction Loans by Florida County</h2>
        <div class="grid">
          {allCounties.map((c) => (
            c.current
              ? <span class="current">{c.name} County</span>
              : <a href={`/loan-programs/conventional-construction-loan/florida/${c.slug}/`}>{c.name} County</a>
          ))}
        </div>
      </div>
    </div>

    <!-- CONVENTIONAL SUBFOOTER — sits ABOVE the site's main footer (Layout.astro provides licensing / NMLS #1660690 / EHO) -->
    <div style="background:var(--paper-2);border-top:1px solid var(--border);padding:1.6rem 0;">
      <div class="container">
        <p style="font-size:.75rem;color:var(--ink-lighter);line-height:1.7;margin:0;">
          Conforming loan limits are set by FHFA and subject to change. Program guidelines are subject to change. Educational content — not a commitment to lend or a guarantee of approval. Down payment and PMI treatment depend on qualification.
        </p>
      </div>
    </div>

  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>

<style>
  .conventional-county-scope{
    --ink:#0A0E1A; --ink-2:#1E2433; --ink-light:#4A5568; --ink-lighter:#6B7280;
    --paper:#FAFAF7; --paper-2:#F4F4EE; --paper-3:#EDEDE5; --white:#FFFFFF;
    --blue:#1845D6; --blue-deep:#0F2EA0; --blue-soft:#E8EEFF; --blue-tint:#F2F5FF;
    --green:#2E9E2E; --green-soft:#E9F7E9; --rust:#8B2C2C;
    --border:#E5E5DE; --border-strong:#D4D4C8;
    --serif:'Fraunces','Iowan Old Style',Georgia,serif;
    --sans:'IBM Plex Sans',-apple-system,BlinkMacSystemFont,sans-serif;
    --mono:'JetBrains Mono','SF Mono',Menlo,monospace;
    font-family:var(--sans);font-size:1.0625rem;line-height:1.6;color:var(--ink);background:var(--paper);-webkit-font-smoothing:antialiased;
  }
  .conventional-county-scope *,.conventional-county-scope *::before,.conventional-county-scope *::after{box-sizing:border-box;margin:0;padding:0;}
  .conventional-county-scope a{color:inherit;text-decoration:none;}
  .conventional-county-scope .container{max-width:1100px;margin:0 auto;padding:0 1.5rem;}
  .conventional-county-scope .eyebrow{font-family:var(--mono);font-size:.75rem;letter-spacing:.14em;text-transform:uppercase;color:var(--blue);font-weight:500;display:inline-block;}
  .conventional-county-scope h1,.conventional-county-scope h2,.conventional-county-scope h3{font-family:var(--serif);font-weight:600;line-height:1.15;color:var(--ink);}
  .conventional-county-scope .accent{font-family:var(--serif);font-style:normal;color:var(--blue);}

