---
import Layout from '../../layouts/Layout.astro';
import PostSidebar from '../../components/PostSidebar.astro';
const productSchema={"@context": "https://schema.org", "@type": ["FinancialProduct", "Service"], "name": "Conventional 97 Loan", "description": "A conventional loan requiring only 3% down \u2014 a low-down-payment path that isn't FHA.", "provider": {"@type": "Organization", "name": "Stairway Mortgage"}, "areaServed": "US"};
const faqSchema={"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "Can I really buy with just 3% down?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, if you qualify. Conventional 97 allows a 3% down payment for eligible buyers, with PMI until you reach 20% equity."}}, {"@type": "Question", "name": "How is this different from FHA?", "acceptedAnswer": {"@type": "Answer", "text": "Conventional 97's mortgage insurance can be cancelled at 20% equity; FHA insurance often lasts the loan's life. For buyers with good credit, Conventional 97 can cost less over time."}}, {"@type": "Question", "name": "Do I need to be a first-time buyer?", "acceptedAnswer": {"@type": "Answer", "text": "Not necessarily \u2014 repeat buyers can qualify too, though some terms favor first-time buyers. We can confirm your eligibility."}}]};
const breadcrumbSchema={"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://stairwaymortgage.com/"}, {"@type": "ListItem", "position": 2, "name": "Loan Programs", "item": "https://stairwaymortgage.com/loan-programs/"}, {"@type": "ListItem", "position": 3, "name": "Conventional 97 Loan"}]};
---

<Layout title="Conventional 97 Loan | Stairway" description="A conventional loan requiring only 3% down — a low-down-payment path that isn't FHA." canonical="https://stairwaymortgage.com/loan-programs/conventional-97/">
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <nav class="container-page lp-breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/loan-programs/">Loan Programs</a> <span>/</span> <span>Conventional 97 Loan</span></nav>
  <header class="container-prose lp-header">
    <span class="eyebrow eyebrow-blue mb-5">Loan Program</span>
    <h1 class="display-lg">Conventional 97: Buy With Just 3% Down</h1>
    <p class="lede lp-lede">A conventional loan requiring only 3% down — a low-down-payment path that isn't FHA. Guided by Jim Blackburn · <span class="mono">NMLS #1072866</span></p>
    <div class="lp-cta-row"><a href="/same-day-approval/" class="btn btn-blue btn-arrow">See My Options</a><a href="tel:+19549931625" class="btn btn-ghost">(954) 993-1625</a></div>
  </header>
  <div class="lp-main">
  <article class="prose-editorial lp-body" set:html={`<h2><b>What a Conventional 97 Loan Is</b></h2><p>The Conventional 97 program lets qualified buyers purchase with 3% down on a conventional loan. Unlike FHA, its mortgage insurance can be cancelled at 20% equity, which can make it more cost-effective over time for buyers with solid credit.</p><h2><b>Who It's For</b></h2><ul><li>First-time and repeat buyers with limited down-payment savings</li><li>Borrowers with good credit avoiding FHA mortgage insurance</li><li>Buyers who plan to build equity and cancel PMI later</li><li>Those wanting a conventional loan with a low entry point</li></ul><h2><b>How It Works</b></h2><p>You put 3% down and finance 97%. PMI applies until you reach 20% equity, then it can be cancelled — a key advantage over FHA, where insurance often lasts the loan's life. Credit and income follow conventional standards.</p><h2><b>Frequently Asked Questions</b></h2><h3><b>Can I really buy with just 3% down?</b></h3><p>Yes, if you qualify. Conventional 97 allows a 3% down payment for eligible buyers, with PMI until you reach 20% equity.</p><h3><b>How is this different from FHA?</b></h3><p>Conventional 97's mortgage insurance can be cancelled at 20% equity; FHA insurance often lasts the loan's life. For buyers with good credit, Conventional 97 can cost less over time.</p><h3><b>Do I need to be a first-time buyer?</b></h3><p>Not necessarily — repeat buyers can qualify too, though some terms favor first-time buyers. We can confirm your eligibility.</p>`} />

    <PostSidebar />
  </div>
  <div class="container-prose"><p class="lp-compliance mono">This page is for educational purposes and is not a commitment to lend or an offer of a specific rate. Loan terms, rates, and qualification depend on your individual circumstances and are subject to underwriting approval. Stairway Mortgage is a division of NEXA Mortgage LLC.</p></div>
  <section class="section-tight lp-final-cta"><div class="container-prose"><div class="card lp-final-cta__card">
    <h2 class="display-md">Ready to explore this program?</h2>
    <p class="lede">Talk through your scenario with our team — straight answers, no credit pull to start.</p>
    <a href="/schedule-call/" class="btn btn-blue btn-arrow">Talk to Our Team</a>
  </div></div></section>
</Layout>

<style>
  .lp-main { display: grid; grid-template-columns: 1fr 300px; gap: 2.5rem; max-width: var(--container-max, 1320px); margin: 0 auto; padding-inline: clamp(1.25rem, 4vw, 2.5rem); }
  @media (max-width: 900px) { .lp-main { grid-template-columns: 1fr; } }
  .lp-breadcrumb { font-family:var(--stw-mono, 'JetBrains Mono'), monospace; font-size:12px; color:var(--color-mute); padding-top:2rem; padding-bottom:1.25rem; }
  .lp-breadcrumb a { color:var(--color-mute); text-decoration:none; } .lp-breadcrumb a:hover { color:var(--color-blue); }
  .lp-breadcrumb span { margin-inline:0.4rem; opacity:0.5; }
  .lp-header h1 { margin-bottom:1.25rem; } .lp-lede { margin-bottom:1.5rem; }
  .lp-cta-row { display:flex; gap:0.75rem; flex-wrap:wrap; }
  .lp-body { margin-top:2.5rem; }
  .lp-body :global(h2) { font-family:var(--stw-display, 'Fraunces'), Georgia, serif; font-variation-settings:"opsz" 96; font-weight:500; font-size:clamp(1.6rem,3vw,2.25rem); line-height:1.15; margin-top:3rem; margin-bottom:1.1rem; }
  .lp-body :global(h3) { font-family:var(--stw-display, 'Fraunces'), Georgia, serif; font-weight:500; font-size:clamp(1.2rem,2vw,1.55rem); margin-top:2rem; margin-bottom:0.8rem; }
  .lp-body :global(p) { font-size:17px; line-height:1.75; margin-bottom:1.25rem; color:var(--color-ink-light); }
  .lp-body :global(ul) { margin:0 0 1.5rem 1.25rem; display:flex; flex-direction:column; gap:0.5rem; }
  .lp-body :global(li) { font-size:17px; line-height:1.65; }
  .lp-body :global(a) { color:var(--color-blue); text-decoration:underline; text-underline-offset:2px; }
  .lp-compliance { font-size:11px; line-height:1.6; color:var(--color-mute); padding:1.5rem 0; border-top:1px solid var(--color-bone); margin-top:2rem; }
  .lp-final-cta__card { text-align:center; display:flex; flex-direction:column; align-items:center; gap:1rem; padding:2.5rem; }
</style>
