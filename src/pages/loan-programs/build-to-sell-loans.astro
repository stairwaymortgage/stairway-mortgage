---
import Layout from '../../layouts/Layout.astro';
const productSchema={"@context": "https://schema.org", "@type": ["FinancialProduct", "Service"], "name": "Build-to-Sell Loan", "description": "Short-term construction financing for builders constructing homes to sell.", "provider": {"@type": "Organization", "name": "Stairway Mortgage"}, "areaServed": "US"};
const faqSchema={"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "How is repayment structured?", "acceptedAnswer": {"@type": "Answer", "text": "The loan is short-term and repaid from the proceeds when the completed home sells. Underwriting focuses on the project's economics and your experience."}}, {"@type": "Question", "name": "Do I need building experience?", "acceptedAnswer": {"@type": "Answer", "text": "Lenders generally favor builders with a track record, though terms vary. We can match you to lenders whose criteria fit your experience level."}}, {"@type": "Question", "name": "How fast can funds be available?", "acceptedAnswer": {"@type": "Answer", "text": "Build-to-sell financing is often structured for speed, since spec projects are time-sensitive. Timelines depend on the lender and project."}}]};
const breadcrumbSchema={"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://stairwaymortgage.com/"}, {"@type": "ListItem", "position": 2, "name": "Loan Programs", "item": "https://stairwaymortgage.com/loan-programs/"}, {"@type": "ListItem", "position": 3, "name": "Build-to-Sell Loan"}]};
---

<Layout title="Build-to-Sell Loan | Stairway" description="Short-term construction financing for builders constructing homes to sell." canonical="https://stairwaymortgage.com/loan-programs/build-to-sell-loans/">
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <nav class="container-page lp-breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/loan-programs/">Loan Programs</a> <span>/</span> <span>Build-to-Sell Loan</span></nav>
  <header class="container-prose lp-header">
    <span class="eyebrow eyebrow-blue mb-5">Loan Program</span>
    <h1 class="display-lg">Build-to-Sell Loan: Construction Financing for Spec Builders</h1>
    <p class="lede lp-lede">Short-term construction financing for builders constructing homes to sell. Guided by Jim Blackburn · <span class="mono">NMLS #1072866</span></p>
    <div class="lp-cta-row"><a href="/same-day-approval/" class="btn btn-blue btn-arrow">See My Options</a><a href="tel:+19549931625" class="btn btn-ghost">(954) 993-1625</a></div>
  </header>
  <article class="container-prose prose-editorial lp-body" set:html={`<h2><b>What a Build-to-Sell Loan Is</b></h2><p>A build-to-sell loan provides short-term construction financing for builders and developers constructing homes intended for sale (spec building). It funds the build, then is repaid from sale proceeds.</p><h2><b>Who It's For</b></h2><ul><li>Spec builders and developers</li><li>Investors constructing homes for resale</li><li>Experienced builders with a track record</li><li>Those needing fast, project-based construction capital</li></ul><h2><b>How It Works</b></h2><p>Funds release in draws as construction progresses. Because the exit is the sale of the completed home, underwriting focuses on project economics — build costs, projected sale value, and the builder's experience. Terms are short-term, structured around the build-and-sell timeline.</p><h2><b>Frequently Asked Questions</b></h2><h3><b>How is repayment structured?</b></h3><p>The loan is short-term and repaid from the proceeds when the completed home sells. Underwriting focuses on the project's economics and your experience.</p><h3><b>Do I need building experience?</b></h3><p>Lenders generally favor builders with a track record, though terms vary. We can match you to lenders whose criteria fit your experience level.</p><h3><b>How fast can funds be available?</b></h3><p>Build-to-sell financing is often structured for speed, since spec projects are time-sensitive. Timelines depend on the lender and project.</p>`} />
  <div class="container-prose"><p class="lp-compliance mono">This page is for educational purposes and is not a commitment to lend or an offer of a specific rate. Loan terms, rates, and qualification depend on your individual circumstances and are subject to underwriting approval. Stairway Mortgage is a division of NEXA Mortgage LLC.</p></div>
  <section class="section-tight lp-final-cta"><div class="container-prose"><div class="card lp-final-cta__card">
    <h2 class="display-md">Ready to explore this program?</h2>
    <p class="lede">Talk through your scenario with our team — straight answers, no credit pull to start.</p>
    <a href="/schedule-call/" class="btn btn-blue btn-arrow">Talk to Our Team</a>
  </div></div></section>
</Layout>

<style>
  .lp-breadcrumb { font-family:var(--font-mono); font-size:12px; color:var(--color-mute); padding-top:2rem; padding-bottom:1.25rem; }
  .lp-breadcrumb a { color:var(--color-mute); text-decoration:none; } .lp-breadcrumb a:hover { color:var(--color-blue); }
  .lp-breadcrumb span { margin-inline:0.4rem; opacity:0.5; }
  .lp-header h1 { margin-bottom:1.25rem; } .lp-lede { margin-bottom:1.5rem; }
  .lp-cta-row { display:flex; gap:0.75rem; flex-wrap:wrap; }
  .lp-body { margin-top:2.5rem; }
  .lp-body :global(h2) { font-family:var(--font-display); font-variation-settings:"opsz" 96; font-weight:500; font-size:clamp(1.6rem,3vw,2.25rem); line-height:1.15; margin-top:3rem; margin-bottom:1.1rem; }
  .lp-body :global(h3) { font-family:var(--font-display); font-weight:500; font-size:clamp(1.2rem,2vw,1.55rem); margin-top:2rem; margin-bottom:0.8rem; }
  .lp-body :global(p) { font-size:17px; line-height:1.75; margin-bottom:1.25rem; color:var(--color-ink-light); }
  .lp-body :global(ul) { margin:0 0 1.5rem 1.25rem; display:flex; flex-direction:column; gap:0.5rem; }
  .lp-body :global(li) { font-size:17px; line-height:1.65; }
  .lp-body :global(a) { color:var(--color-blue); text-decoration:underline; text-underline-offset:2px; }
  .lp-compliance { font-size:11px; line-height:1.6; color:var(--color-mute); padding:1.5rem 0; border-top:1px solid var(--color-bone); margin-top:2rem; }
  .lp-final-cta__card { text-align:center; display:flex; flex-direction:column; align-items:center; gap:1rem; padding:2.5rem; }
</style>
