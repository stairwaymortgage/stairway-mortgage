---
import Layout from '../../layouts/Layout.astro';
const productSchema={"@context": "https://schema.org", "@type": ["FinancialProduct", "Service"], "name": "Manufactured Home Loan", "description": "Financing options for manufactured and modular homes \u2014 purchase or refinance.", "provider": {"@type": "Organization", "name": "Stairway Mortgage"}, "areaServed": "US"};
const faqSchema={"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "Can I get a conventional loan on a manufactured home?", "acceptedAnswer": {"@type": "Answer", "text": "Often yes, if the home is permanently affixed to land you own and titled as real property. Eligibility depends on the home and foundation meeting program standards."}}, {"@type": "Question", "name": "What's the difference between real and personal property?", "acceptedAnswer": {"@type": "Answer", "text": "A manufactured home permanently affixed to owned land is typically real property (more financing options). One not affixed may be personal property (different, often costlier financing)."}}, {"@type": "Question", "name": "Can I finance the land and home together?", "acceptedAnswer": {"@type": "Answer", "text": "In many cases, yes \u2014 when the home is or will be permanently affixed to the land. We can review your specific situation."}}]};
const breadcrumbSchema={"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://stairwaymortgage.com/"}, {"@type": "ListItem", "position": 2, "name": "Loan Programs", "item": "https://stairwaymortgage.com/loan-programs/"}, {"@type": "ListItem", "position": 3, "name": "Manufactured Home Loan"}]};
---

<Layout title="Manufactured Home Loan | Stairway" description="Financing options for manufactured and modular homes — purchase or refinance." canonical="https://stairwaymortgage.com/loan-programs/manufactured-home-loan/">
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <nav class="container-page lp-breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/loan-programs/">Loan Programs</a> <span>/</span> <span>Manufactured Home Loan</span></nav>
  <header class="container-prose lp-header">
    <span class="eyebrow eyebrow-blue mb-5">Loan Program</span>
    <h1 class="display-lg">Manufactured Home Loan: Financing for Factory-Built Homes</h1>
    <p class="lede lp-lede">Financing options for manufactured and modular homes — purchase or refinance. Guided by Jim Blackburn · <span class="mono">NMLS #1072866</span></p>
    <div class="lp-cta-row"><a href="/same-day-approval/" class="btn btn-blue btn-arrow">See My Options</a><a href="tel:+19549931625" class="btn btn-ghost">(954) 993-1625</a></div>
  </header>
  <article class="container-prose prose-editorial lp-body" set:html={`<h2><b>What a Manufactured Home Loan Is</b></h2><p>A manufactured home loan finances HUD-standard factory-built homes. Depending on whether the home is titled as real property and permanently affixed, conventional, FHA, VA, and USDA options may apply.</p><h2><b>Who It's For</b></h2><ul><li>Buyers of new or existing manufactured homes</li><li>Owners refinancing a manufactured home on owned land</li><li>Buyers placing a home on a permanent foundation</li><li>Those seeking an affordable path to ownership</li></ul><h2><b>How It Works</b></h2><p>Financing depends largely on whether the home is real property (permanently affixed to land you own) versus personal property. Real-property manufactured homes can often access the same programs as site-built homes, including FHA and conventional, frequently with competitive terms.</p><h2><b>Frequently Asked Questions</b></h2><h3><b>Can I get a conventional loan on a manufactured home?</b></h3><p>Often yes, if the home is permanently affixed to land you own and titled as real property. Eligibility depends on the home and foundation meeting program standards.</p><h3><b>What's the difference between real and personal property?</b></h3><p>A manufactured home permanently affixed to owned land is typically real property (more financing options). One not affixed may be personal property (different, often costlier financing).</p><h3><b>Can I finance the land and home together?</b></h3><p>In many cases, yes — when the home is or will be permanently affixed to the land. We can review your specific situation.</p>`} />
  <div class="container-prose"><p class="lp-compliance mono">This page is for educational purposes and is not a commitment to lend or an offer of a specific rate. Loan terms, rates, and qualification depend on your individual circumstances and are subject to underwriting approval. Stairway Mortgage is a division of NEXA Mortgage LLC.</p></div>
  <section class="section-tight lp-final-cta"><div class="container-prose"><div class="card lp-final-cta__card">
    <h2 class="display-md">Ready to explore this program?</h2>
    <p class="lede">Talk through your scenario with our team — straight answers, no credit pull to start.</p>
    <a href="/schedule-call/" class="btn btn-blue btn-arrow">Talk to Our Team</a>
  </div></div></section>
</Layout>

<style>
  .lp-breadcrumb { font-family:var(--stw-mono, 'JetBrains Mono'), monospace; font-size:12px; color:var(--color-mute); padding-top:2rem; padding-bottom:1.25rem; }
  .lp-breadcrumb a { color:var(--color-mute); text-decoration:none; } .lp-breadcrumb a:hover { color:var(--color-blue); }
  .lp-breadcrumb span { margin-inline:0.4rem; opacity:0.5; }
  .lp-header h1 { margin-bottom:1.25rem; } .lp-lede { margin-bottom:1.5rem; }
  .lp-cta-row { display:flex; gap:0.75rem; flex-wrap:wrap; }
  .lp-body { margin-top:2.5rem; }
  .lp-body :global(h2) { font-family:var(--stw-display, 'Fraunces'), Georgia, serif; font-variation-settings:"opsz" 96; font-weight:500; font-size:clamp(1.6rem,3vw,2.25rem); line-height:1.15; margin-top:3rem; margin-bottom:1.1rem; }
  .lp-body :global(h3) { font-family:var(--stw-display, 'Fraunces'), Georgia, serif; font-weight:500; font-size:clamp(1.2rem,2vw,1.55rem); margin-top:2rem; margin-bottom:0.8rem; }
  .lp-body :global(p) { font-size:17px; line-height:1.75; margin-bottom:1.25rem; color:var(--color-ink-light); }
  .lp-body :global(ul) { margin:0 0 1.5rem 1.25rem; display:flex; flex-direction:column; gap:0.5rem; }
  .lp-body :global(li) { font-size:17px; line-height:1.65; }
  .lp-body :global(a) { color:var(--color-blue); text-decoration:underline; text-underline-offset:2px; }
  .lp-compliance { font-size:11px; line-height:1.6; color:var(--color-mute); padding:1.5rem 0; border-top:1px solid var(--color-bone); margin-top:2rem; }
  .lp-final-cta__card { text-align:center; display:flex; flex-direction:column; align-items:center; gap:1rem; padding:2.5rem; }
</style>
