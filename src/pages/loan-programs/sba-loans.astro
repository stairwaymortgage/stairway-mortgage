---
import Layout from '../../layouts/Layout.astro';
const productSchema={"@context": "https://schema.org", "@type": ["FinancialProduct", "Service"], "name": "SBA Loan", "description": "SBA 7(a) and 504 financing for business acquisition, real estate, and growth.", "provider": {"@type": "Organization", "name": "Stairway Mortgage"}, "areaServed": "US"};
const faqSchema={"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "What's the difference between SBA 7(a) and 504?", "acceptedAnswer": {"@type": "Answer", "text": "7(a) is versatile \u2014 working capital, acquisition, or real estate. 504 targets owner-occupied real estate and major fixed assets with a specific structure. We'll help identify the right fit."}}, {"@type": "Question", "name": "Do SBA loans have lower down payments?", "acceptedAnswer": {"@type": "Answer", "text": "Often yes \u2014 the SBA guarantee can enable lower down payments and longer terms than conventional business financing."}}, {"@type": "Question", "name": "What do I need to qualify?", "acceptedAnswer": {"@type": "Answer", "text": "Generally solid business financials, relevant owner experience, and a qualifying use of funds. Requirements vary by program."}}]};
const breadcrumbSchema={"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://stairwaymortgage.com/"}, {"@type": "ListItem", "position": 2, "name": "Loan Programs", "item": "https://stairwaymortgage.com/loan-programs/"}, {"@type": "ListItem", "position": 3, "name": "SBA Loan"}]};
---

<Layout title="SBA Loan | Stairway" description="SBA 7(a) and 504 financing for business acquisition, real estate, and growth." canonical="https://stairwaymortgage.com/loan-programs/sba-loans/">
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <nav class="container-page lp-breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/loan-programs/">Loan Programs</a> <span>/</span> <span>SBA Loan</span></nav>
  <header class="container-prose lp-header">
    <span class="eyebrow eyebrow-blue mb-5">Loan Program</span>
    <h1 class="display-lg">SBA Loan: Government-Backed Financing for Small Business</h1>
    <p class="lede lp-lede">SBA 7(a) and 504 financing for business acquisition, real estate, and growth. Guided by Jim Blackburn · <span class="mono">NMLS #1072866</span></p>
    <div class="lp-cta-row"><a href="/same-day-approval/" class="btn btn-blue btn-arrow">See My Options</a><a href="tel:+19549931625" class="btn btn-ghost">(954) 993-1625</a></div>
  </header>
  <article class="container-prose prose-editorial lp-body" set:html={`<h2><b>What a SBA Loan Is</b></h2><p>SBA loans are small-business loans partially guaranteed by the U.S. Small Business Administration, reducing lender risk and often enabling lower down payments and longer terms — including for owner-occupied commercial real estate.</p><h2><b>Who It's For</b></h2><ul><li>Small business owners acquiring a business or partner buyout</li><li>Owner-occupants buying their commercial premises</li><li>Businesses funding expansion or major equipment</li><li>Entrepreneurs needing longer terms and lower down payments</li></ul><h2><b>How It Works</b></h2><p>The SBA guarantees a portion of the loan, lowering lender risk. The 7(a) program is versatile (working capital, acquisition, real estate); the 504 program targets owner-occupied real estate and major fixed assets. Qualification weighs business financials, owner experience, and use of funds.</p><h2><b>Frequently Asked Questions</b></h2><h3><b>What's the difference between SBA 7(a) and 504?</b></h3><p>7(a) is versatile — working capital, acquisition, or real estate. 504 targets owner-occupied real estate and major fixed assets with a specific structure. We'll help identify the right fit.</p><h3><b>Do SBA loans have lower down payments?</b></h3><p>Often yes — the SBA guarantee can enable lower down payments and longer terms than conventional business financing.</p><h3><b>What do I need to qualify?</b></h3><p>Generally solid business financials, relevant owner experience, and a qualifying use of funds. Requirements vary by program.</p>`} />
  <div class="container-prose"><p class="lp-compliance mono">This page is for educational purposes and is not a commitment to lend or an offer of a specific rate. Loan terms, rates, and qualification depend on your individual circumstances and are subject to underwriting approval. Stairway Mortgage is a division of NEXA Mortgage LLC.</p></div>
  <section class="section-tight lp-final-cta"><div class="container-prose"><div class="card lp-final-cta__card">
    <h2 class="display-md">Ready to explore this program?</h2>
    <p class="lede">Talk through your scenario with our team — straight answers, no credit pull to start.</p>
    <a href="/schedule-call/" class="btn btn-blue btn-arrow">Talk to Our Team</a>
  </div></div></section>
</Layout>

<style>
  .lp-breadcrumb { font-family:var(--font-mono); font-size:12px; color:var(--color-mute); padding-top:2rem; padding-bottom:1.25rem; }
  .lp-breadcrumb a { color:var(--color-mute); text-decoration:none; } .lp-breadcrumb a:hover { color:var(--color-blue); }
  .lp-breadcrumb span { margin-inline:0.4rem; opacity:0.5; }
  .lp-header h1 { margin-bottom:1.25rem; } .lp-lede { margin-bottom:1.5rem; }
  .lp-cta-row { display:flex; gap:0.75rem; flex-wrap:wrap; }
  .lp-body { margin-top:2.5rem; }
  .lp-body :global(h2) { font-family:var(--font-display); font-variation-settings:"opsz" 96; font-weight:500; font-size:clamp(1.6rem,3vw,2.25rem); line-height:1.15; margin-top:3rem; margin-bottom:1.1rem; }
  .lp-body :global(h3) { font-family:var(--font-display); font-weight:500; font-size:clamp(1.2rem,2vw,1.55rem); margin-top:2rem; margin-bottom:0.8rem; }
  .lp-body :global(p) { font-size:17px; line-height:1.75; margin-bottom:1.25rem; color:var(--color-ink-light); }
  .lp-body :global(ul) { margin:0 0 1.5rem 1.25rem; display:flex; flex-direction:column; gap:0.5rem; }
  .lp-body :global(li) { font-size:17px; line-height:1.65; }
  .lp-body :global(a) { color:var(--color-blue); text-decoration:underline; text-underline-offset:2px; }
  .lp-compliance { font-size:11px; line-height:1.6; color:var(--color-mute); padding:1.5rem 0; border-top:1px solid var(--color-bone); margin-top:2rem; }
  .lp-final-cta__card { text-align:center; display:flex; flex-direction:column; align-items:center; gap:1rem; padding:2.5rem; }
</style>
