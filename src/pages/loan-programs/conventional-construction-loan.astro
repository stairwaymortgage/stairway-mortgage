---
import Layout from '../../layouts/Layout.astro';
import PostSidebar from '../../components/PostSidebar.astro';
import counties from '../../data/counties.json';
const productSchema={"@context": "https://schema.org", "@type": ["FinancialProduct", "Service"], "name": "Conventional Construction Loan", "description": "Finance new construction with conventional terms \u2014 land, build, and permanent mortgage.", "provider": {"@type": "Organization", "name": "Stairway Mortgage"}, "areaServed": "US"};
const faqSchema={"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "How are funds disbursed during construction?", "acceptedAnswer": {"@type": "Answer", "text": "In draws tied to construction milestones, so you pay interest only on what's been drawn, not the full loan amount."}}, {"@type": "Question", "name": "Is this a one-time or two-time close?", "acceptedAnswer": {"@type": "Answer", "text": "Both structures exist. A one-time close combines construction and permanent financing in a single closing; a two-time close separates them. We can compare which fits your project."}}, {"@type": "Question", "name": "What down payment is needed?", "acceptedAnswer": {"@type": "Answer", "text": "Conventional construction loans typically require a meaningful down payment; the exact amount varies by lender and project. We'll give you specifics for your scenario."}}]};
const breadcrumbSchema={"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://stairwaymortgage.com/"}, {"@type": "ListItem", "position": 2, "name": "Loan Programs", "item": "https://stairwaymortgage.com/loan-programs/"}, {"@type": "ListItem", "position": 3, "name": "Conventional Construction Loan"}]};
---

<Layout title="Conventional Construction Loan | Stairway" description="Finance new construction with conventional terms — land, build, and permanent mortgage." canonical="https://stairwaymortgage.com/loan-programs/conventional-construction-loan/">
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <nav class="cluster-bar" aria-label="Construction loan programs">
    <div class="cluster-bar-inner">
      <span class="cluster-label">Conventional Construction</span>
      <a href="/loan-programs/conventional-loan/">Conventional Program Guide</a>
      <a href="/loan-programs/construction-loan/">← All Construction Loans</a>
      <a href="/loan-programs/usda-loan/usda-vs-fha/">USDA · FHA · VA · Conv</a>
      <a href="#fl-counties" class="active">FL Counties</a>
    </div>
  </nav>
  <nav class="container-page lp-breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/loan-programs/">Loan Programs</a> <span>/</span> <span>Conventional Construction Loan</span></nav>
  <header class="container-prose lp-header">
    <span class="eyebrow eyebrow-blue mb-5">Loan Program</span>
    <h1 class="display-lg">Conventional Construction Loan: Finance Building From the Ground Up</h1>
    <p class="lede lp-lede">Finance new construction with conventional terms — land, build, and permanent mortgage. Guided by Jim Blackburn · <span class="mono">NMLS #1072866</span></p>
    <div class="lp-cta-row"><a href="/see-my-options/" class="btn btn-blue btn-arrow">See My Options</a><a href="tel:+19549931625" class="btn btn-ghost">(954) 993-1625</a></div>
  </header>
  <div class="lp-main">
  <article class="prose-editorial lp-body" set:html={`<h2><b>What a Conventional Construction Loan Is</b></h2><p>A conventional construction loan finances building a new home — land, materials, and labor during construction — then converts to or is replaced by a permanent mortgage once complete.</p><h2><b>Who It's For</b></h2><ul><li>Buyers building a primary or second home from the ground up</li><li>Those who own their lot and need construction financing</li><li>Borrowers who prefer conventional terms over FHA/VA construction</li><li>Owner-builders working with a licensed contractor</li></ul><h2><b>How It Works</b></h2><p>Funds release to your builder in stages (draws) as milestones are met, so you aren't paying interest on the full amount upfront. Many programs offer a one-time-close structure rolling construction and permanent financing into a single loan, avoiding a second closing.</p><h2><b>Frequently Asked Questions</b></h2><h3><b>How are funds disbursed during construction?</b></h3><p>In draws tied to construction milestones, so you pay interest only on what's been drawn, not the full loan amount.</p><h3><b>Is this a one-time or two-time close?</b></h3><p>Both structures exist. A one-time close combines construction and permanent financing in a single closing; a two-time close separates them. We can compare which fits your project.</p><h3><b>What down payment is needed?</b></h3><p>Conventional construction loans typically require a meaningful down payment; the exact amount varies by lender and project. We'll give you specifics for your scenario.</p>`} />

    <PostSidebar />
  </div>

  <section class="county-links" id="fl-counties" aria-label="Conventional construction loans by Florida county">
    <div class="hub-wrap">
      <h2>Conventional Construction Loans by Florida County</h2>
      <p class="county-intro">5% down common, the highest county limits, and PMI that cancels — every Florida county has its own conventional construction guide, with the county conforming limit, local offices, and builders. Guided by Jim Blackburn · <span class="mono">NMLS #1072866</span>.</p>
      <div class="grid">
        {counties.map((c) => (
          <a href={`/loan-programs/conventional-construction-loan/florida/${c.slug}/`}>{c.County}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="hub-cross">
    <div class="hub-wrap">
      <h2>Not sure conventional is <span class="accent">your program?</span></h2>
      <p>Jim Blackburn (NMLS #1072866) prices all four construction paths on your actual numbers — the strongest one wins, every time.</p>
      <div class="cta-row">
        <a class="btn-primary" href="https://stairwaymortgage.com/see-my-options">See My Options</a>
        <a class="btn-outline" href="/loan-programs/construction-loan/">Compare All Four Programs →</a>
      </div>
    </div>
  </section>

  <div class="container-prose"><p class="lp-compliance mono">This page is for educational purposes and is not a commitment to lend or an offer of a specific rate. Loan terms, rates, and qualification depend on your individual circumstances and are subject to underwriting approval. Stairway Mortgage is a division of NEXA Mortgage LLC.</p></div>
  <section class="section-tight lp-final-cta"><div class="container-prose"><div class="card lp-final-cta__card">
    <h2 class="display-md">Ready to explore this program?</h2>
    <p class="lede">Talk through your scenario with our team — straight answers, no credit pull to start.</p>
    <a href="/schedule-call/" class="btn btn-blue btn-arrow">Talk to Our Team</a>
  </div></div></section>
</Layout>

<style>
  .lp-main { display: grid; grid-template-columns: 1fr 300px; gap: 2.5rem; max-width: var(--container-max, 1320px); margin: 0 auto; padding-inline: clamp(1.25rem, 4vw, 2.5rem); }
  @media (max-width: 900px) { .lp-main { grid-template-columns: 1fr; } }
  .lp-breadcrumb { font-family:var(--stw-mono, 'JetBrains Mono'), monospace; font-size:12px; color:var(--color-mute); padding-top:2rem; padding-bottom:1.25rem; }
  .lp-breadcrumb a { color:var(--color-mute); text-decoration:none; } .lp-breadcrumb a:hover { color:var(--color-blue); }
  .lp-breadcrumb span { margin-inline:0.4rem; opacity:0.5; }
  .lp-header h1 { margin-bottom:1.25rem; } .lp-lede { margin-bottom:1.5rem; }
  .lp-cta-row { display:flex; gap:0.75rem; flex-wrap:wrap; }
  .lp-body { margin-top:2.5rem; }
  .lp-body :global(h2) { font-family:var(--stw-display, 'Fraunces'), Georgia, serif; font-variation-settings:"opsz" 96; font-weight:500; font-size:clamp(1.6rem,3vw,2.25rem); line-height:1.15; margin-top:3rem; margin-bottom:1.1rem; }
  .lp-body :global(h3) { font-family:var(--stw-display, 'Fraunces'), Georgia, serif; font-weight:500; font-size:clamp(1.2rem,2vw,1.55rem); margin-top:2rem; margin-bottom:0.8rem; }
  .lp-body :global(p) { font-size:17px; line-height:1.75; margin-bottom:1.25rem; color:var(--color-ink-light); }
  .lp-body :global(ul) { margin:0 0 1.5rem 1.25rem; display:flex; flex-direction:column; gap:0.5rem; }
  .lp-body :global(li) { font-size:17px; line-height:1.65; }
  .lp-body :global(a) { color:var(--color-blue); text-decoration:underline; text-underline-offset:2px; }
  .lp-compliance { font-size:11px; line-height:1.6; color:var(--color-mute); padding:1.5rem 0; border-top:1px solid var(--color-bone); margin-top:2rem; }
  .lp-final-cta__card { text-align:center; display:flex; flex-direction:column; align-items:center; gap:1rem; padding:2.5rem; }

  /* Phase 5 hub additions: cluster bar + county grid + cross-sell */
  .cluster-bar { position:sticky; top:0; z-index:50; background:var(--white); border-bottom:1px solid var(--border); box-shadow:0 1px 8px rgba(10,14,26,.05); }
  .cluster-bar-inner { max-width:1200px; margin:0 auto; display:flex; align-items:center; gap:.35rem; padding:.55rem 1.5rem; overflow-x:auto; -webkit-overflow-scrolling:touch; scrollbar-width:none; }
  .cluster-bar-inner::-webkit-scrollbar { display:none; }
  .cluster-label { flex:0 0 auto; font-family:var(--mono); font-size:.62rem; letter-spacing:.1em; text-transform:uppercase; color:var(--blue); white-space:nowrap; padding-right:.6rem; border-right:1px solid var(--border); margin-right:.35rem; font-weight:600; }
  .cluster-bar a { flex:0 0 auto; white-space:nowrap; font-size:.76rem; font-weight:500; color:var(--ink-2); text-decoration:none; padding:.36rem .62rem; border-radius:999px; transition:background .15s; }
  .cluster-bar a:hover { background:var(--paper-2); color:var(--ink); }
  .cluster-bar a.active { background:var(--blue); color:#fff; font-weight:600; }
  .hub-wrap { max-width:1100px; margin:0 auto; padding-inline:clamp(1.25rem,4vw,2.5rem); }
  .county-links { background:var(--paper-2); border-top:1px solid var(--border); padding:2.6rem 0 2.2rem; margin-top:3rem; }
  .county-links h2 { font-family:var(--serif); font-size:1.2rem; font-weight:600; margin-bottom:.35rem; color:var(--ink); }
  .county-links .county-intro { font-size:.9rem; color:var(--ink-light); margin-bottom:1.2rem; max-width:640px; }
  .county-links .grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(170px,1fr)); gap:.3rem .9rem; }
  .county-links .grid a { font-size:.8125rem; color:var(--ink-light); padding:.18rem 0; display:block; text-decoration:none; }
  .county-links .grid a:hover { color:var(--blue); text-decoration:underline; }
  .hub-cross { padding:3rem 0 1rem; text-align:center; }
  .hub-cross h2 { font-family:var(--serif); font-weight:600; font-size:clamp(1.4rem,3vw,1.9rem); margin-bottom:.6rem; }
  .hub-cross .accent { color:var(--blue); }
  .hub-cross p { color:var(--ink-light); max-width:560px; margin:0 auto 1.3rem; font-size:.95rem; }
  .hub-cross .cta-row { display:flex; gap:.9rem; flex-wrap:wrap; justify-content:center; }
  .hub-cross .btn-primary { display:inline-block; padding:.85rem 1.7rem; border-radius:8px; font-weight:600; background:var(--blue); color:#fff; text-decoration:none; }
  .hub-cross .btn-outline { display:inline-block; padding:.85rem 1.7rem; border-radius:8px; font-weight:600; background:var(--white); color:var(--ink); border:1.5px solid var(--border-strong); text-decoration:none; }
</style>
