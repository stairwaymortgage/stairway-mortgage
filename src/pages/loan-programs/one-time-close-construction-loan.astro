---
import Layout from '../../layouts/Layout.astro';
import PostSidebar from '../../components/PostSidebar.astro';
const productSchema={"@context": "https://schema.org", "@type": ["FinancialProduct", "Service"], "name": "One-Time Close Construction Loan", "description": "One closing covers construction and your permanent mortgage \u2014 no second closing, no requalification.", "provider": {"@type": "Organization", "name": "Stairway Mortgage"}, "areaServed": "US"};
const faqSchema={"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "What's the advantage over a two-time close?", "acceptedAnswer": {"@type": "Answer", "text": "One closing means one set of costs, locked terms before you build, and no requalification risk after construction \u2014 protection against rate or income changes during the build."}}, {"@type": "Question", "name": "Can I lock my rate before construction?", "acceptedAnswer": {"@type": "Answer", "text": "Yes \u2014 that's a core benefit of the one-time close structure. We'll explain the lock options available."}}, {"@type": "Question", "name": "What happens when construction finishes?", "acceptedAnswer": {"@type": "Answer", "text": "The loan automatically converts to your permanent mortgage on the terms you locked at closing \u2014 no new application."}}]};
const breadcrumbSchema={"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://stairwaymortgage.com/"}, {"@type": "ListItem", "position": 2, "name": "Loan Programs", "item": "https://stairwaymortgage.com/loan-programs/"}, {"@type": "ListItem", "position": 3, "name": "One-Time Close Construction Loan"}]};
---

<Layout title="One-Time Close Construction Loan | Stairway" description="One closing covers construction and your permanent mortgage — no second closing, no requalification." canonical="https://stairwaymortgage.com/loan-programs/one-time-close-construction-loan/">
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <nav class="container-page lp-breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/loan-programs/">Loan Programs</a> <span>/</span> <span>One-Time Close Construction Loan</span></nav>
  <header class="container-prose lp-header">
    <span class="eyebrow eyebrow-blue mb-5">Loan Program</span>
    <h1 class="display-lg">One-Time Close Construction Loan: Build and Finance in a Single Loan</h1>
    <p class="lede lp-lede">One closing covers construction and your permanent mortgage — no second closing, no requalification. Guided by Jim Blackburn · <span class="mono">NMLS #1072866</span></p>
    <div class="lp-cta-row"><a href="/see-my-options/" class="btn btn-blue btn-arrow">See My Options</a><a href="tel:+19549931625" class="btn btn-ghost">(954) 993-1625</a></div>
  </header>
  <div class="lp-main">
  <article class="prose-editorial lp-body" set:html={`<h2><b>What a One-Time Close Construction Loan Is</b></h2><p>A one-time close (OTC) construction loan combines construction financing and your permanent mortgage into a single loan with one closing. You lock terms once, before construction, and the loan converts automatically when the home is complete.</p><h2><b>Who It's For</b></h2><ul><li>Buyers who want rate and cost certainty before building</li><li>Those avoiding a second closing and its costs</li><li>Borrowers concerned about requalifying after construction</li><li>Anyone building a primary residence on a timeline</li></ul><h2><b>How It Works</b></h2><p>You close once before the build starts, locking your terms. During construction, funds release in draws. When finished, the loan converts to a standard mortgage automatically — no requalification, no second closing, no mid-build rate risk.</p><h2><b>Frequently Asked Questions</b></h2><h3><b>What's the advantage over a two-time close?</b></h3><p>One closing means one set of costs, locked terms before you build, and no requalification risk after construction — protection against rate or income changes during the build.</p><h3><b>Can I lock my rate before construction?</b></h3><p>Yes — that's a core benefit of the one-time close structure. We'll explain the lock options available.</p><h3><b>What happens when construction finishes?</b></h3><p>The loan automatically converts to your permanent mortgage on the terms you locked at closing — no new application.</p>`} />

    <PostSidebar />
  </div>
  <div class="container-prose"><p class="lp-compliance mono">This page is for educational purposes and is not a commitment to lend or an offer of a specific rate. Loan terms, rates, and qualification depend on your individual circumstances and are subject to underwriting approval. Stairway Mortgage is a division of NEXA Mortgage LLC.</p></div>
  <section class="section-tight lp-final-cta"><div class="container-prose"><div class="card lp-final-cta__card">
    <h2 class="display-md">Ready to explore this program?</h2>
    <p class="lede">Talk through your scenario with our team — straight answers, no credit pull to start.</p>
    <a href="/schedule-call/" class="btn btn-blue btn-arrow">Talk to Our Team</a>
  </div></div></section>
</Layout>

<style>
  .lp-main { display: grid; grid-template-columns: 1fr 300px; gap: 2.5rem; max-width: var(--container-max, 1320px); margin: 0 auto; padding-inline: clamp(1.25rem, 4vw, 2.5rem); }
  @media (max-width: 900px) { .lp-main { grid-template-columns: 1fr; } }
  .lp-breadcrumb { font-family:var(--stw-mono, 'JetBrains Mono'), monospace; font-size:12px; color:var(--color-mute); padding-top:2rem; padding-bottom:1.25rem; }
  .lp-breadcrumb a { color:var(--color-mute); text-decoration:none; } .lp-breadcrumb a:hover { color:var(--color-blue); }
  .lp-breadcrumb span { margin-inline:0.4rem; opacity:0.5; }
  .lp-header h1 { margin-bottom:1.25rem; } .lp-lede { margin-bottom:1.5rem; }
  .lp-cta-row { display:flex; gap:0.75rem; flex-wrap:wrap; }
  .lp-body { margin-top:2.5rem; }
  .lp-body :global(h2) { font-family:var(--stw-display, 'Fraunces'), Georgia, serif; font-variation-settings:"opsz" 96; font-weight:500; font-size:clamp(1.6rem,3vw,2.25rem); line-height:1.15; margin-top:3rem; margin-bottom:1.1rem; }
  .lp-body :global(h3) { font-family:var(--stw-display, 'Fraunces'), Georgia, serif; font-weight:500; font-size:clamp(1.2rem,2vw,1.55rem); margin-top:2rem; margin-bottom:0.8rem; }
  .lp-body :global(p) { font-size:17px; line-height:1.75; margin-bottom:1.25rem; color:var(--color-ink-light); }
  .lp-body :global(ul) { margin:0 0 1.5rem 1.25rem; display:flex; flex-direction:column; gap:0.5rem; }
  .lp-body :global(li) { font-size:17px; line-height:1.65; }
  .lp-body :global(a) { color:var(--color-blue); text-decoration:underline; text-underline-offset:2px; }
  .lp-compliance { font-size:11px; line-height:1.6; color:var(--color-mute); padding:1.5rem 0; border-top:1px solid var(--color-bone); margin-top:2rem; }
  .lp-final-cta__card { text-align:center; display:flex; flex-direction:column; align-items:center; gap:1rem; padding:2.5rem; }
</style>
