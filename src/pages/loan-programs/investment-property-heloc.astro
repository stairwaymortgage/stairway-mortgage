---
import Layout from '../../layouts/Layout.astro';
import PostSidebar from '../../components/PostSidebar.astro';
const productSchema={"@context": "https://schema.org", "@type": ["FinancialProduct", "Service"], "name": "Investment Property HELOC", "description": "Access the equity in your rental properties through a revolving line of credit.", "provider": {"@type": "Organization", "name": "Stairway Mortgage"}, "areaServed": "US"};
const faqSchema={"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "Can I get a HELOC on a rental property?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, though terms are typically stricter and rates higher than on a primary residence. Available equity and the property's performance drive approval."}}, {"@type": "Question", "name": "How is it different from a cash-out refinance?", "acceptedAnswer": {"@type": "Answer", "text": "A HELOC is a revolving line you draw on as needed, leaving your first mortgage intact. A cash-out refinance replaces your mortgage with a larger one. Each fits different needs."}}, {"@type": "Question", "name": "What can I use the funds for?", "acceptedAnswer": {"@type": "Answer", "text": "Commonly renovations, down payments on additional properties, or reserves \u2014 investors value the flexibility to draw only when an opportunity arises."}}]};
const breadcrumbSchema={"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://stairwaymortgage.com/"}, {"@type": "ListItem", "position": 2, "name": "Loan Programs", "item": "https://stairwaymortgage.com/loan-programs/"}, {"@type": "ListItem", "position": 3, "name": "Investment Property HELOC"}]};
---

<Layout title="Investment Property HELOC | Stairway" description="Access the equity in your rental properties through a revolving line of credit." canonical="https://stairwaymortgage.com/loan-programs/investment-property-heloc/">
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <nav class="container-page lp-breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/loan-programs/">Loan Programs</a> <span>/</span> <span>Investment Property HELOC</span></nav>
  <header class="container-prose lp-header">
    <span class="eyebrow eyebrow-blue mb-5">Loan Program</span>
    <h1 class="display-lg">Investment Property HELOC: Tap Rental Equity as a Line of Credit</h1>
    <p class="lede lp-lede">Access the equity in your rental properties through a revolving line of credit. Guided by Jim Blackburn · <span class="mono">NMLS #1072866</span></p>
    <div class="lp-cta-row"><a href="/same-day-approval/" class="btn btn-blue btn-arrow">See My Options</a><a href="tel:+19549931625" class="btn btn-ghost">(954) 993-1625</a></div>
  </header>
  <div class="lp-main">
  <article class="prose-editorial lp-body" set:html={`<h2><b>What a Investment Property HELOC Is</b></h2><p>An investment property HELOC is a revolving credit line secured by a rental property's equity. It lets investors access funds flexibly — for renovations, the next down payment, or reserves — drawing only what they need.</p><h2><b>Who It's For</b></h2><ul><li>Investors wanting flexible access to rental equity</li><li>Those funding renovations or the next down payment</li><li>Portfolio builders who value a reusable credit line</li><li>Owners with substantial equity in stabilized rentals</li></ul><h2><b>How It Works</b></h2><p>Like a primary-residence HELOC, you're approved for a limit based on equity and can draw, repay, and redraw during the draw period — paying interest only on what you use. Investment-property HELOCs typically carry stricter terms and higher rates than primary lines, reflecting added risk.</p><h2><b>Frequently Asked Questions</b></h2><h3><b>Can I get a HELOC on a rental property?</b></h3><p>Yes, though terms are typically stricter and rates higher than on a primary residence. Available equity and the property's performance drive approval.</p><h3><b>How is it different from a cash-out refinance?</b></h3><p>A HELOC is a revolving line you draw on as needed, leaving your first mortgage intact. A cash-out refinance replaces your mortgage with a larger one. Each fits different needs.</p><h3><b>What can I use the funds for?</b></h3><p>Commonly renovations, down payments on additional properties, or reserves — investors value the flexibility to draw only when an opportunity arises.</p>`} />

    <PostSidebar />
  </div>
  <div class="container-prose"><p class="lp-compliance mono">This page is for educational purposes and is not a commitment to lend or an offer of a specific rate. Loan terms, rates, and qualification depend on your individual circumstances and are subject to underwriting approval. Stairway Mortgage is a division of NEXA Mortgage LLC.</p></div>
  <section class="section-tight lp-final-cta"><div class="container-prose"><div class="card lp-final-cta__card">
    <h2 class="display-md">Ready to explore this program?</h2>
    <p class="lede">Talk through your scenario with our team — straight answers, no credit pull to start.</p>
    <a href="/schedule-call/" class="btn btn-blue btn-arrow">Talk to Our Team</a>
  </div></div></section>
</Layout>

<style>
  .lp-main { display: grid; grid-template-columns: 1fr 300px; gap: 2.5rem; max-width: var(--container-max, 1320px); margin: 0 auto; padding-inline: clamp(1.25rem, 4vw, 2.5rem); }
  @media (max-width: 900px) { .lp-main { grid-template-columns: 1fr; } }
  .lp-breadcrumb { font-family:var(--stw-mono, 'JetBrains Mono'), monospace; font-size:12px; color:var(--color-mute); padding-top:2rem; padding-bottom:1.25rem; }
  .lp-breadcrumb a { color:var(--color-mute); text-decoration:none; } .lp-breadcrumb a:hover { color:var(--color-blue); }
  .lp-breadcrumb span { margin-inline:0.4rem; opacity:0.5; }
  .lp-header h1 { margin-bottom:1.25rem; } .lp-lede { margin-bottom:1.5rem; }
  .lp-cta-row { display:flex; gap:0.75rem; flex-wrap:wrap; }
  .lp-body { margin-top:2.5rem; }
  .lp-body :global(h2) { font-family:var(--stw-display, 'Fraunces'), Georgia, serif; font-variation-settings:"opsz" 96; font-weight:500; font-size:clamp(1.6rem,3vw,2.25rem); line-height:1.15; margin-top:3rem; margin-bottom:1.1rem; }
  .lp-body :global(h3) { font-family:var(--stw-display, 'Fraunces'), Georgia, serif; font-weight:500; font-size:clamp(1.2rem,2vw,1.55rem); margin-top:2rem; margin-bottom:0.8rem; }
  .lp-body :global(p) { font-size:17px; line-height:1.75; margin-bottom:1.25rem; color:var(--color-ink-light); }
  .lp-body :global(ul) { margin:0 0 1.5rem 1.25rem; display:flex; flex-direction:column; gap:0.5rem; }
  .lp-body :global(li) { font-size:17px; line-height:1.65; }
  .lp-body :global(a) { color:var(--color-blue); text-decoration:underline; text-underline-offset:2px; }
  .lp-compliance { font-size:11px; line-height:1.6; color:var(--color-mute); padding:1.5rem 0; border-top:1px solid var(--color-bone); margin-top:2rem; }
  .lp-final-cta__card { text-align:center; display:flex; flex-direction:column; align-items:center; gap:1rem; padding:2.5rem; }
</style>
