  <script is:inline>
    (function(){
      var grid=document.getElementById('grid'), tabs=document.getElementById('tabs'), fr=document.getElementById('finderResult');
      var tiles=Array.prototype.slice.call(grid.querySelectorAll('.lp-tile'));
      var activeCat='all', pick={goal:null,income:null,special:null};
      function match(el){
        if(!pick.goal && !pick.income && !pick.special) return null;
        var tags=(el.getAttribute('data-tags')||'').split(' ');
        var ok=true;
        if(pick.goal) ok=ok && tags.indexOf(pick.goal)>-1;
        if(pick.income && pick.income!=='any') ok=ok && tags.indexOf(pick.income)>-1;
        if(pick.special && pick.special!=='none') ok=ok && tags.indexOf(pick.special)>-1;
        return ok;
      }
      function render(){
        var matched=0, shown=0;
        tiles.forEach(function(el){
          var inCat = activeCat==='all' || el.getAttribute('data-cat')===activeCat;
          el.style.display = inCat ? '' : 'none';
          if(!inCat) return;
          shown++;
          var m=match(el);
          el.classList.toggle('is-match', m===true);
          el.classList.toggle('is-dim', m===false);
          if(m===true) matched++;
        });
        if(pick.goal||pick.income||pick.special){
          fr.textContent = matched>0 ? (matched+' program'+(matched>1?'s':'')+' match your answers — highlighted below') : 'No exact match — talk to our team and we will find it';
        }
      }
      tabs.addEventListener('click',function(e){
        var b=e.target.closest('.lp-tab'); if(!b)return;
        tabs.querySelectorAll('.lp-tab').forEach(function(x){x.classList.remove('is-active');});
        b.classList.add('is-active'); activeCat=b.getAttribute('data-cat'); render();
      });
      document.querySelectorAll('.lp-q').forEach(function(q){
        q.addEventListener('click',function(e){
          var b=e.target.closest('button'); if(!b)return;
          q.querySelectorAll('button').forEach(function(x){x.classList.remove('is-sel');});
          b.classList.add('is-sel'); pick[q.getAttribute('data-dim')]=b.getAttribute('data-v');
          if(activeCat!=='all'){activeCat='all';tabs.querySelectorAll('.lp-tab').forEach(function(x){x.classList.remove('is-active');});tabs.querySelector('[data-cat=all]').classList.add('is-active');}
          render(); document.getElementById('catalog').scrollIntoView({behavior:'smooth',block:'start'});
        });
      });
    })();
  </script>

