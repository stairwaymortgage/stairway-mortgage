---
import Layout from '../../layouts/Layout.astro';
const productSchema={"@context": "https://schema.org", "@type": ["FinancialProduct", "Service"], "name": "HomeReady Loan", "description": "Fannie Mae's 3%-down program with flexible income sources and reduced mortgage insurance.", "provider": {"@type": "Organization", "name": "Stairway Mortgage"}, "areaServed": "US"};
const faqSchema={"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "What are the income limits for HomeReady?", "acceptedAnswer": {"@type": "Answer", "text": "Limits are based on the property's area median income. Some areas have no limit. We can check the limit for the home you're considering."}}, {"@type": "Question", "name": "Can I use income from household members who aren't on the loan?", "acceptedAnswer": {"@type": "Answer", "text": "Yes \u2014 HomeReady allows certain non-borrower household income and boarder income to support qualification, which is one of its distinctive features."}}, {"@type": "Question", "name": "Is the mortgage insurance cheaper?", "acceptedAnswer": {"@type": "Answer", "text": "HomeReady offers reduced mortgage insurance compared to standard conventional loans, and it can be cancelled at 20% equity."}}]};
const breadcrumbSchema={"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://stairwaymortgage.com/"}, {"@type": "ListItem", "position": 2, "name": "Loan Programs", "item": "https://stairwaymortgage.com/loan-programs/"}, {"@type": "ListItem", "position": 3, "name": "HomeReady Loan"}]};
---

<Layout title="HomeReady Loan | Stairway" description="Fannie Mae's 3%-down program with flexible income sources and reduced mortgage insurance." canonical="https://stairwaymortgage.com/loan-programs/homeready-loan/">
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <nav class="container-page lp-breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/loan-programs/">Loan Programs</a> <span>/</span> <span>HomeReady Loan</span></nav>
  <header class="container-prose lp-header">
    <span class="eyebrow eyebrow-blue mb-5">Loan Program</span>
    <h1 class="display-lg">HomeReady Loan: Low Down Payment for Modest-Income Buyers</h1>
    <p class="lede lp-lede">Fannie Mae's 3%-down program with flexible income sources and reduced mortgage insurance. Guided by Jim Blackburn · <span class="mono">NMLS #1072866</span></p>
    <div class="lp-cta-row"><a href="/same-day-approval/" class="btn btn-blue btn-arrow">See My Options</a><a href="tel:+19549931625" class="btn btn-ghost">(954) 993-1625</a></div>
  </header>
  <article class="container-prose prose-editorial lp-body" set:html={`<h2><b>What a HomeReady Loan Is</b></h2><p>HomeReady is Fannie Mae's affordable program for creditworthy low-to-moderate-income borrowers, allowing 3% down, reduced mortgage insurance, and flexible income and down-payment sources.</p><h2><b>Who It's For</b></h2><ul><li>Low-to-moderate-income buyers within program limits</li><li>Multi-generational households with multiple income sources</li><li>First-time buyers needing flexible down-payment sources</li><li>Borrowers wanting reduced PMI versus standard conventional</li></ul><h2><b>How It Works</b></h2><p>HomeReady allows 3% down with mortgage insurance priced below standard conventional, and counts flexible income — including non-borrower household and boarder income — toward qualification. Area-based income limits apply.</p><h2><b>Frequently Asked Questions</b></h2><h3><b>What are the income limits for HomeReady?</b></h3><p>Limits are based on the property's area median income. Some areas have no limit. We can check the limit for the home you're considering.</p><h3><b>Can I use income from household members who aren't on the loan?</b></h3><p>Yes — HomeReady allows certain non-borrower household income and boarder income to support qualification, which is one of its distinctive features.</p><h3><b>Is the mortgage insurance cheaper?</b></h3><p>HomeReady offers reduced mortgage insurance compared to standard conventional loans, and it can be cancelled at 20% equity.</p>`} />
  <div class="container-prose"><p class="lp-compliance mono">This page is for educational purposes and is not a commitment to lend or an offer of a specific rate. Loan terms, rates, and qualification depend on your individual circumstances and are subject to underwriting approval. Stairway Mortgage is a division of NEXA Mortgage LLC.</p></div>
  <section class="section-tight lp-final-cta"><div class="container-prose"><div class="card lp-final-cta__card">
    <h2 class="display-md">Ready to explore this program?</h2>
    <p class="lede">Talk through your scenario with our team — straight answers, no credit pull to start.</p>
    <a href="/schedule-call/" class="btn btn-blue btn-arrow">Talk to Our Team</a>
  </div></div></section>
</Layout>

<style>
  .lp-breadcrumb { font-family:var(--stw-mono, 'JetBrains Mono'), monospace; font-size:12px; color:var(--color-mute); padding-top:2rem; padding-bottom:1.25rem; }
  .lp-breadcrumb a { color:var(--color-mute); text-decoration:none; } .lp-breadcrumb a:hover { color:var(--color-blue); }
  .lp-breadcrumb span { margin-inline:0.4rem; opacity:0.5; }
  .lp-header h1 { margin-bottom:1.25rem; } .lp-lede { margin-bottom:1.5rem; }
  .lp-cta-row { display:flex; gap:0.75rem; flex-wrap:wrap; }
  .lp-body { margin-top:2.5rem; }
  .lp-body :global(h2) { font-family:var(--stw-display, 'Fraunces'), Georgia, serif; font-variation-settings:"opsz" 96; font-weight:500; font-size:clamp(1.6rem,3vw,2.25rem); line-height:1.15; margin-top:3rem; margin-bottom:1.1rem; }
  .lp-body :global(h3) { font-family:var(--stw-display, 'Fraunces'), Georgia, serif; font-weight:500; font-size:clamp(1.2rem,2vw,1.55rem); margin-top:2rem; margin-bottom:0.8rem; }
  .lp-body :global(p) { font-size:17px; line-height:1.75; margin-bottom:1.25rem; color:var(--color-ink-light); }
  .lp-body :global(ul) { margin:0 0 1.5rem 1.25rem; display:flex; flex-direction:column; gap:0.5rem; }
  .lp-body :global(li) { font-size:17px; line-height:1.65; }
  .lp-body :global(a) { color:var(--color-blue); text-decoration:underline; text-underline-offset:2px; }
  .lp-compliance { font-size:11px; line-height:1.6; color:var(--color-mute); padding:1.5rem 0; border-top:1px solid var(--color-bone); margin-top:2rem; }
  .lp-final-cta__card { text-align:center; display:flex; flex-direction:column; align-items:center; gap:1rem; padding:2.5rem; }
</style>
