const faqSchema={"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "Can you qualify for an FHA loan immediately after bankruptcy?", "acceptedAnswer": {"@type": "Answer", "text": "FHA requires waiting periods after bankruptcy discharge\u2014typically two years for Chapter 7 bankruptcy and one year into a Chapter 13 repayment plan. These periods are significantly shorter than conventional loan requirements (typically four years for Chapter 7)."}}, {"@type": "Question", "name": "What if you had a previous foreclosure?", "acceptedAnswer": {"@type": "Answer", "text": "FHA typically requires three years from a foreclosure completion date before new FHA loan eligibility. This waiting period is substantially shorter than conventional requirements (typically seven years). Borrowers must demonstrate credit re-establishment and provide documentation explaining the foreclosure circumstances."}}, {"@type": "Question", "name": "Can you use an FHA loan for a second home or investment property?", "acceptedAnswer": {"@type": "Answer", "text": "No, FHA loans serve primary residences only. You must occupy the property as your main home and certify your occupancy intentions. However, you can use an FHA loan to purchase multi-unit properties (2-4 units) where you occupy one unit while renting the others, creating an accessible investment strategy."}}, {"@type": "Question", "name": "What are FHA loan limits?", "acceptedAnswer": {"@type": "Answer", "text": "FHA establishes loan limits varying by county based on local housing costs. Standard limits are tied to conforming loan limits established by the Federal Housing Finance Agency. High-cost areas receive higher limits than standard counties."}}, {"@type": "Question", "name": "Can you have two FHA loans simultaneously?", "acceptedAnswer": {"@type": "Answer", "text": "Generally, FHA restricts borrowers to one FHA loan at a time. However, specific exceptions exist including job relocation requiring housing in new locations, family size increases necessitating larger homes, or other legitimate circumstances justifying multiple FHA-financed properties."}}, {"@type": "Question", "name": "What is FHA's flip rule and how does it affect purchases?", "acceptedAnswer": {"@type": "Answer", "text": "FHA's anti-flipping rule restricts purchasing properties recently acquired by sellers, protecting buyers from predatory flipping schemes. Properties owned by sellers less than 90 days typically cannot finance with FHA loans. Properties owned 91-180 days may face additional scrutiny and appraisal requirements."}}, {"@type": "Question", "name": "Can non-occupant co-borrowers strengthen FHA applications?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, FHA allows non-occupant co-borrowers\u2014family members who don't live in the property but co-sign the mortgage and contribute to qualification. The co-borrower's income strengthens qualifying capacity while they assume equal mortgage liability despite not occupying the home."}}, {"@type": "Question", "name": "How does FHA handle student loan debt?", "acceptedAnswer": {"@type": "Answer", "text": "FHA considers student loan obligations in debt-to-income calculations even when loans are in deferment or income-driven repayment plans. Recent guidance provides specific calculation methods using actual payment amounts when documented, or percentage-based calculations when payments aren't established."}}, {"@type": "Question", "name": "Can you use FHA 203(k) loans for properties needing repairs?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, FHA 203(k) renovation loans combine purchase financing with repair funding in single transactions. These programs accommodate properties needing repairs to meet FHA minimum property standards or buyers wanting to customize properties through renovations."}}, {"@type": "Question", "name": "What if you're self-employed with minimal taxable income?", "acceptedAnswer": {"@type": "Answer", "text": "Self-employed FHA applicants face the same challenge as other mortgage programs\u2014tax return income drives qualification despite tax strategies minimizing reported income. FHA follows standard self-employment documentation protocols analyzing net income after business expenses."}}, {"@type": "Question", "name": "How do FHA loans handle non-traditional credit?", "acceptedAnswer": {"@type": "Answer", "text": "Borrowers lacking traditional credit\u2014credit cards, auto loans, or prior mortgages\u2014can qualify through alternative credit documentation including rental payment history, utility bills, insurance payments, and other regular financial obligations demonstrating payment reliability."}}, {"@type": "Question", "name": "Can foreign nationals qualify for FHA loans?", "acceptedAnswer": {"@type": "Answer", "text": "FHA loans generally require U.S. citizenship or lawful permanent resident status (green card holders). Non-permanent resident aliens may qualify when working in the United States with appropriate visa documentation authorizing extended presence and employment."}}, {"@type": "Question", "name": "What happens if the appraisal comes in lower than the purchase price?", "acceptedAnswer": {"@type": "Answer", "text": "When appraisals fall below purchase prices, buyers face several options. The appraised value becomes the maximum value for FHA loan calculation purposes, affecting your financing structure."}}, {"@type": "Question", "name": "How do FHA loans handle inherited properties?", "acceptedAnswer": {"@type": "Answer", "text": "You cannot use an FHA loan to purchase inherited properties from estate beneficiaries because FHA serves primary residence purchases at arm's length prices. However, if you inherit a property outright through estate settlement, you can refinance any existing mortgage with FHA financing once you establish ownership and occupancy."}}]};
const breadcrumbSchema={"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://stairwaymortgage.com/"}, {"@type": "ListItem", "position": 2, "name": "Loan Programs", "item": "https://stairwaymortgage.com/loan-programs/"}, {"@type": "ListItem", "position": 3, "name": "FHA Loan: 7 Key Advantages for First-Time Home Buyers"}]};
