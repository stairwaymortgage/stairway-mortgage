---
import Layout from '../../layouts/Layout.astro';
const productSchema={"@context": "https://schema.org", "@type": ["FinancialProduct", "Service"], "name": "Build-to-Rent Loan", "description": "Construction financing designed for investors building properties to hold as rentals.", "provider": {"@type": "Organization", "name": "Stairway Mortgage"}, "areaServed": "US"};
const faqSchema={"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "Can I qualify on rental income instead of personal income?", "acceptedAnswer": {"@type": "Answer", "text": "Often yes \u2014 build-to-rent loans frequently convert to DSCR-style permanent financing qualified on the property's rental income, ideal for portfolio investors."}}, {"@type": "Question", "name": "Does it cover both construction and the permanent loan?", "acceptedAnswer": {"@type": "Answer", "text": "Many structures bridge construction into permanent hold financing. We'll explain the options for combining or separating them."}}, {"@type": "Question", "name": "Is this for single homes or communities?", "acceptedAnswer": {"@type": "Answer", "text": "Both \u2014 from a single rental build to multi-unit build-to-rent communities. Terms scale with the project."}}]};
const breadcrumbSchema={"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://stairwaymortgage.com/"}, {"@type": "ListItem", "position": 2, "name": "Loan Programs", "item": "https://stairwaymortgage.com/loan-programs/"}, {"@type": "ListItem", "position": 3, "name": "Build-to-Rent Loan"}]};
---

<Layout title="Build-to-Rent Loan | Stairway" description="Construction financing designed for investors building properties to hold as rentals." canonical="https://stairwaymortgage.com/loan-programs/build-to-rent-loans/">
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <nav class="container-page lp-breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/loan-programs/">Loan Programs</a> <span>/</span> <span>Build-to-Rent Loan</span></nav>
  <header class="container-prose lp-header">
    <span class="eyebrow eyebrow-blue mb-5">Loan Program</span>
    <h1 class="display-lg">Build-to-Rent Loan: Finance Rental Properties From the Ground Up</h1>
    <p class="lede lp-lede">Construction financing designed for investors building properties to hold as rentals. Guided by Jim Blackburn · <span class="mono">NMLS #1072866</span></p>
    <div class="lp-cta-row"><a href="/same-day-approval/" class="btn btn-blue btn-arrow">See My Options</a><a href="tel:+19549931625" class="btn btn-ghost">(954) 993-1625</a></div>
  </header>
  <article class="container-prose prose-editorial lp-body" set:html={`<h2><b>What a Build-to-Rent Loan Is</b></h2><p>A build-to-rent loan finances constructing properties intended to be held as rentals rather than sold. It bridges construction and long-term investment, often converting to DSCR-style permanent financing once built and leased.</p><h2><b>Who It's For</b></h2><ul><li>Investors building single or multiple rental units</li><li>Developers creating build-to-rent communities</li><li>Investors wanting construction plus long-term hold financing</li><li>Those scaling a rental portfolio through new construction</li></ul><h2><b>How It Works</b></h2><p>The loan funds construction in draws, then transitions to permanent investment financing — frequently qualified on projected rental income (DSCR) rather than personal income. This lets investors build purpose-designed rentals and finance them on the property's economics.</p><h2><b>Frequently Asked Questions</b></h2><h3><b>Can I qualify on rental income instead of personal income?</b></h3><p>Often yes — build-to-rent loans frequently convert to DSCR-style permanent financing qualified on the property's rental income, ideal for portfolio investors.</p><h3><b>Does it cover both construction and the permanent loan?</b></h3><p>Many structures bridge construction into permanent hold financing. We'll explain the options for combining or separating them.</p><h3><b>Is this for single homes or communities?</b></h3><p>Both — from a single rental build to multi-unit build-to-rent communities. Terms scale with the project.</p>`} />
  <div class="container-prose"><p class="lp-compliance mono">This page is for educational purposes and is not a commitment to lend or an offer of a specific rate. Loan terms, rates, and qualification depend on your individual circumstances and are subject to underwriting approval. Stairway Mortgage is a division of NEXA Mortgage LLC.</p></div>
  <section class="section-tight lp-final-cta"><div class="container-prose"><div class="card lp-final-cta__card">
    <h2 class="display-md">Ready to explore this program?</h2>
    <p class="lede">Talk through your scenario with our team — straight answers, no credit pull to start.</p>
    <a href="/schedule-call/" class="btn btn-blue btn-arrow">Talk to Our Team</a>
  </div></div></section>
</Layout>

<style>
  .lp-breadcrumb { font-family:var(--stw-mono, 'JetBrains Mono'), monospace; font-size:12px; color:var(--color-mute); padding-top:2rem; padding-bottom:1.25rem; }
  .lp-breadcrumb a { color:var(--color-mute); text-decoration:none; } .lp-breadcrumb a:hover { color:var(--color-blue); }
  .lp-breadcrumb span { margin-inline:0.4rem; opacity:0.5; }
  .lp-header h1 { margin-bottom:1.25rem; } .lp-lede { margin-bottom:1.5rem; }
  .lp-cta-row { display:flex; gap:0.75rem; flex-wrap:wrap; }
  .lp-body { margin-top:2.5rem; }
  .lp-body :global(h2) { font-family:var(--stw-display, 'Fraunces'), Georgia, serif; font-variation-settings:"opsz" 96; font-weight:500; font-size:clamp(1.6rem,3vw,2.25rem); line-height:1.15; margin-top:3rem; margin-bottom:1.1rem; }
  .lp-body :global(h3) { font-family:var(--stw-display, 'Fraunces'), Georgia, serif; font-weight:500; font-size:clamp(1.2rem,2vw,1.55rem); margin-top:2rem; margin-bottom:0.8rem; }
  .lp-body :global(p) { font-size:17px; line-height:1.75; margin-bottom:1.25rem; color:var(--color-ink-light); }
  .lp-body :global(ul) { margin:0 0 1.5rem 1.25rem; display:flex; flex-direction:column; gap:0.5rem; }
  .lp-body :global(li) { font-size:17px; line-height:1.65; }
  .lp-body :global(a) { color:var(--color-blue); text-decoration:underline; text-underline-offset:2px; }
  .lp-compliance { font-size:11px; line-height:1.6; color:var(--color-mute); padding:1.5rem 0; border-top:1px solid var(--color-bone); margin-top:2rem; }
  .lp-final-cta__card { text-align:center; display:flex; flex-direction:column; align-items:center; gap:1rem; padding:2.5rem; }
</style>
