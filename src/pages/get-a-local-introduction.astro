---
import Layout from '../layouts/Layout.astro';
import GetLocalIntroForm from '../components/forms/GetLocalIntroForm.astro';
const breadcrumbSchema={"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://stairwaymortgage.com/"},{"@type":"ListItem","position":2,"name":"Get A Local Introduction"}]};
---

<Layout title="Get Introduced to a Trusted Local Professional | Stairway Mortgage" description="We connect you with fully vetted mortgage, real estate, title, and insurance professionals in your area. Local expertise, national reach." canonical="https://stairwaymortgage.com/get-a-local-introduction/">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <nav class="container-page gli-breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a> <span>/</span> <span>Get A Local Introduction</span>
  </nav>

  <section class="gli-hero">
    <div class="container-page gli-hero__inner">
      <div class="gli-hero__copy">
        <span class="eyebrow eyebrow-blue">Trusted Local Network</span>
        <h1 class="display-lg gli-hero__title">Get introduced to the right<br/>local <em>professional</em>.</h1>
        <p class="lede gli-hero__lede">Before you buy, build, refinance, or invest — make sure the people guiding you are vetted, experienced, and aligned with your goals. We personally introduce you to the right mortgage, real estate, title, insurance, and financial professionals in your market.</p>
        <div class="gli-hero__stats">
          <div><span class="editorial-number">300+</span><small>lenders in our network</small></div>
          <div><span class="editorial-number">48</span><small>states covered</small></div>
          <div><span class="editorial-number">5.0★</span><small>624 reviews</small></div>
        </div>
        <button data-open-local-intro class="btn btn-blue btn-arrow gli-hero__cta">Get My Introduction</button>
        <p class="gli-hero__sub mono">Free · No obligation · Takes ~15 seconds</p>
      </div>
      <div class="gli-hero__visual">
        <div class="gli-card">
          <div class="gli-card__icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-blue)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3 class="gli-card__title font-display">Who do you need?</h3>
          <ul class="gli-card__list">
            <li>Mortgage broker</li>
            <li>Real estate agent</li>
            <li>Title & settlement</li>
            <li>Home insurance</li>
            <li>Financial planner</li>
            <li>Tax professional</li>
            <li>Contractor / builder</li>
            <li>Attorney</li>
          </ul>
          <p class="gli-card__note mono">We vet every referral personally.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-tight gli-how">
    <div class="container-page">
      <h2 class="display-md gli-how__title">How it works</h2>
      <div class="gli-how__grid">
        <div class="gli-how__step">
          <span class="gli-how__num font-display">1</span>
          <h3>Tell us what you need</h3>
          <p>Answer a few quick questions about your situation, location, and the type of professional you're looking for.</p>
        </div>
        <div class="gli-how__step">
          <span class="gli-how__num font-display">2</span>
          <h3>We match you</h3>
          <p>Our team personally selects the best-fit professional from our vetted network — no random referrals.</p>
        </div>
        <div class="gli-how__step">
          <span class="gli-how__num font-display">3</span>
          <h3>Get introduced</h3>
          <p>We make a warm introduction so you're not cold-calling. Your pro already knows your situation.</p>
        </div>
      </div>
      <div class="gli-how__cta-wrap">
        <button data-open-local-intro class="btn btn-blue btn-arrow">Start Now — It's Free</button>
      </div>
    </div>
  </section>

  <section class="section-tight gli-final">
    <div class="container-prose">
      <div class="card gli-final__card">
        <h2 class="display-md">The right people change everything.</h2>
        <p class="lede">One introduction can save you thousands and months of headaches. Let us connect you.</p>
        <button data-open-local-intro class="btn btn-blue btn-arrow">Get My Introduction</button>
      </div>
    </div>
  </section>

  <GetLocalIntroForm />
</Layout>

<style>
  .gli-breadcrumb { font-family:var(--stw-mono, 'JetBrains Mono'), monospace; font-size:12px; color:var(--color-mute); padding-top:2rem; padding-bottom:1.25rem; }
  .gli-breadcrumb a { color:var(--color-mute); text-decoration:none; }
  .gli-breadcrumb a:hover { color:var(--color-blue); }
  .gli-breadcrumb span { margin-inline:0.4rem; opacity:0.5; }

  .gli-hero { padding:clamp(3rem,8vw,6rem) 0 clamp(2rem,5vw,4rem); background:linear-gradient(180deg, var(--color-paper-tint), var(--color-paper)); border-bottom:1px solid var(--color-bone); }
  .gli-hero__inner { display:grid; grid-template-columns:1fr minmax(0,0.7fr); gap:clamp(2rem,5vw,4rem); align-items:center; }
  @media(max-width:820px){ .gli-hero__inner { grid-template-columns:1fr; } }
  .gli-hero__title { margin:1rem 0 1.5rem; }
  .gli-hero__title em { font-style:italic; color:var(--color-blue); }
  .gli-hero__lede { max-width:54ch; margin-bottom:2rem; }
  .gli-hero__stats { display:flex; gap:2.5rem; margin-bottom:2rem; flex-wrap:wrap; }
  .gli-hero__stats div { display:flex; flex-direction:column; }
  .gli-hero__stats .editorial-number { font-size:clamp(1.6rem,3vw,2.2rem); }
  .gli-hero__stats small { font-family:var(--stw-mono, 'JetBrains Mono'), monospace; font-size:10.5px; letter-spacing:0.07em; text-transform:uppercase; color:var(--color-mute); }
  .gli-hero__cta { font-size:16px; padding:0.85rem 2rem; }
  .gli-hero__sub { font-size:11px; color:var(--color-mute); margin-top:0.75rem; }

  .gli-card { background:var(--color-ink); color:var(--color-paper); border-radius:18px; padding:clamp(1.5rem,3vw,2.5rem); box-shadow:0 24px 60px -20px rgba(10,14,26,0.4); }
  .gli-card__icon { margin-bottom:1.25rem; }
  .gli-card__title { font-size:1.3rem; margin-bottom:1rem; }
  .gli-card__list { list-style:none; padding:0; margin:0 0 1.25rem; display:flex; flex-direction:column; gap:0.5rem; }
  .gli-card__list li { display:flex; align-items:center; gap:0.5rem; font-size:14px; color:rgba(250,250,247,0.75); }
  .gli-card__list li::before { content:'\2713'; color:var(--color-green); font-weight:700; }
  .gli-card__note { font-size:10.5px; color:rgba(250,250,247,0.5); letter-spacing:0.04em; }

  .gli-how { padding:clamp(3rem,6vw,5rem) 0; }
  .gli-how__title { margin-bottom:2.5rem; }
  .gli-how__grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:2rem; margin-bottom:2.5rem; }
  .gli-how__step { border:1px solid var(--color-bone); border-radius:14px; padding:1.5rem; background:var(--color-paper); }
  .gli-how__num { font-size:2rem; color:var(--color-blue); margin-bottom:0.5rem; display:block; }
  .gli-how__step h3 { font-family:var(--stw-display, 'Fraunces'), Georgia, serif; font-weight:500; font-size:1.15rem; margin-bottom:0.5rem; }
  .gli-how__step p { font-size:14.5px; line-height:1.6; color:var(--color-ink-light); margin:0; }
  .gli-how__cta-wrap { text-align:center; }

  .gli-final { padding:clamp(2rem,5vw,4rem) 0; }
  .gli-final__card { text-align:center; display:flex; flex-direction:column; align-items:center; gap:1rem; padding:2.5rem; }
</style>
