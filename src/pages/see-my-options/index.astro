---
// see-my-options.astro — Stairway Mortgage "Choose Your Path" page.
// This is the destination the site-wide header "See My Options" button links to.
// It shows six inquiry paths (soft pull) + a prominent full-application path (hard pull).
//
// HEADER WIRING: point the header button here, e.g.
//   <a href="/see-my-options/" class="btn btn-blue btn-arrow">See My Options</a>
//
// Each card opens its funnel via the funnel's exposed open fn (window.STW_OPEN_xx) or, for
// reverse, its data-rm-open trigger. The funnel components are imported + mounted once below.
import PurchaseForm        from "../../components/PurchaseForm.astro";
import RefinanceForm       from "../../components/RefinanceForm.astro";
import HelocForm           from "../../components/HelocForm.astro";
import NewConstructionForm from "../../components/NewConstructionForm.astro";
import RenovationForm      from "../../components/RenovationForm.astro";
import ReverseMortgageForm from "../../components/ReverseMortgageForm.astro";
import Layout              from "../../layouts/Layout.astro";
---

<Layout title="See My Options — Stairway Mortgage" description="Choose your path — start a soft-inquiry funnel or begin a full application. NMLS #1072866.">

<main class="smo-wrap">
  <div class="smo-head">
    <div class="smo-eyebrow">Let&rsquo;s get you to the right place</div>
    <h1 class="smo-h1">What can we help you with?</h1>
    <p class="smo-sub">Two ways to start &mdash; pick the one that fits where you are right now.</p>
  </div>

  <p class="smo-video-cta">Need a <a href="/same-day-approval/">same day approval</a>?</p>

  <div class="smo-video">
    <video
      class="smo-video-el"
      controls
      preload="metadata"
      playsinline
      poster="https://media.stairwaymortgage.com/see-my-option-video_00-00-000.png"
    >
      <source src="https://media.stairwaymortgage.com/see-my-option-video.mp4" type="video/mp4" />
    </video>
  </div>

  <!-- TIER 1: inquiry -->
  <div class="smo-tier">
    <div class="smo-tier-line"></div>
    <div class="smo-tier-label">Just exploring &middot; A few quick questions</div>
    <div class="smo-tier-line"></div>
  </div>

  <div class="smo-grid">
    <button class="smo-card" onclick="window.STW_OPEN_pf && window.STW_OPEN_pf()">
      <h2>Purchase</h2><p>Buying a home &mdash; first or next.</p>
      <span class="smo-start">Start &rarr;</span>
      <span class="smo-pill"><svg viewBox="0 0 24 24" fill="none" stroke="#2E7D32" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l8 3v6c0 5-3.5 8.5-8 11-4.5-2.5-8-6-8-11V5l8-3z"/><path d="M9 12l2 2 4-4"/></svg> Soft inquiry &mdash; no credit pull</span>
    </button>
    <button class="smo-card" onclick="window.STW_OPEN_rf && window.STW_OPEN_rf()">
      <h2>Refinance</h2><p>Lower your rate or change terms.</p>
      <span class="smo-start">Start &rarr;</span>
      <span class="smo-pill"><svg viewBox="0 0 24 24" fill="none" stroke="#2E7D32" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l8 3v6c0 5-3.5 8.5-8 11-4.5-2.5-8-6-8-11V5l8-3z"/><path d="M9 12l2 2 4-4"/></svg> Soft inquiry &mdash; no credit pull</span>
    </button>
    <button class="smo-card" onclick="window.STW_OPEN_hf && window.STW_OPEN_hf()">
      <h2>HELOC</h2><p>Tap equity, keep your first mortgage.</p>
      <span class="smo-start">Start &rarr;</span>
      <span class="smo-pill"><svg viewBox="0 0 24 24" fill="none" stroke="#2E7D32" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l8 3v6c0 5-3.5 8.5-8 11-4.5-2.5-8-6-8-11V5l8-3z"/><path d="M9 12l2 2 4-4"/></svg> Soft inquiry &mdash; no credit pull</span>
    </button>
    <button class="smo-card" onclick="window.STW_OPEN_nc && window.STW_OPEN_nc()">
      <h2>New Construction</h2><p>Build from the ground up.</p>
      <span class="smo-start">Start &rarr;</span>
      <span class="smo-pill"><svg viewBox="0 0 24 24" fill="none" stroke="#2E7D32" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l8 3v6c0 5-3.5 8.5-8 11-4.5-2.5-8-6-8-11V5l8-3z"/><path d="M9 12l2 2 4-4"/></svg> Soft inquiry &mdash; no credit pull</span>
    </button>
    <button class="smo-card" onclick="window.STW_OPEN_rn && window.STW_OPEN_rn()">
      <h2>Renovation</h2><p>Fix, flip, or renovate to live in.</p>
      <span class="smo-start">Start &rarr;</span>
      <span class="smo-pill"><svg viewBox="0 0 24 24" fill="none" stroke="#2E7D32" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l8 3v6c0 5-3.5 8.5-8 11-4.5-2.5-8-6-8-11V5l8-3z"/><path d="M9 12l2 2 4-4"/></svg> Soft inquiry &mdash; no credit pull</span>
    </button>
    <button class="smo-card" data-rm-open>
      <h2>Reverse Mortgage</h2><p>Age 62+ &mdash; access equity, no monthly payment.</p>
      <span class="smo-start">Start &rarr;</span>
      <span class="smo-pill"><svg viewBox="0 0 24 24" fill="none" stroke="#2E7D32" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l8 3v6c0 5-3.5 8.5-8 11-4.5-2.5-8-6-8-11V5l8-3z"/><path d="M9 12l2 2 4-4"/></svg> Soft inquiry &mdash; no credit pull</span>
    </button>
  </div>

  <p class="smo-note">
    Answer a few questions to get general ideas and start a conversation. There&rsquo;s no credit
    check and no obligation &mdash; next you&rsquo;ll schedule a quick consultation, and together
    we&rsquo;ll decide if it&rsquo;s the right time to move forward.
  </p>

  <!-- TIER 2: full application -->
  <div class="smo-tier">
    <div class="smo-tier-line"></div>
    <div class="smo-tier-label">Ready to move forward now</div>
    <div class="smo-tier-line"></div>
  </div>

  <div class="smo-fullapp">
    <div class="smo-fullapp-copy">
      <div class="smo-fa-eyebrow">Full Application</div>
      <h3>Need an approval letter today? Start your full application.</h3>
      <p>For when you&rsquo;ve decided and you&rsquo;re ready to go &mdash; making an offer, on a
      deadline, or you want a fully customized loan estimate. This is the complete application that
      gets you a real pre-approval.</p>
      <div class="smo-hardnote">Includes a credit review (hard pull) &middot; The fastest path to an approval letter.</div>
    </div>
    <a class="smo-fa-btn" href="/get-approved" target="_blank" rel="noopener">Get Approved Now</a>
  </div>
</main>

<!-- mount the six funnels once -->
<PurchaseForm />
<RefinanceForm />
<HelocForm />
<NewConstructionForm />
<RenovationForm />
<ReverseMortgageForm />

<script is:inline>
  (function(){
    var map = {
      '#purchase': 'STW_OPEN_pf',
      '#refinance': 'STW_OPEN_rf',
      '#heloc': 'STW_OPEN_hf',
      '#construction': 'STW_OPEN_nc',
      '#renovation': 'STW_OPEN_rn',
      '#reverse': null
    };
    var h = window.location.hash.toLowerCase();
    if (!h || !map.hasOwnProperty(h)) return;
    function tryOpen(attempts) {
      if (h === '#reverse') {
        var btn = document.querySelector('[data-rm-open]');
        if (btn) { btn.click(); return; }
      } else {
        var fn = window[map[h]];
        if (typeof fn === 'function') { fn(); return; }
      }
      if (attempts < 20) setTimeout(function(){ tryOpen(attempts + 1); }, 150);
    }
    if (document.readyState === 'complete') tryOpen(0);
    else window.addEventListener('load', function(){ tryOpen(0); });
  })();
</script>

</Layout>

<style>
  .smo-wrap{ width:100%; max-width:920px; margin:0 auto; padding:48px 20px 64px;
    font-family:'IBM Plex Sans',system-ui,sans-serif; color:#0A0E1A; }
  .smo-head{ text-align:center; margin-bottom:8px; }
  .smo-eyebrow{ font-family:'JetBrains Mono',monospace; font-size:12px; letter-spacing:.1em; text-transform:uppercase; color:#9a9a93; margin-bottom:16px; }
  .smo-h1{ font-family:'Fraunces',Georgia,serif; font-weight:500; font-size:clamp(2rem,5vw,3rem); line-height:1.12; letter-spacing:-.02em; margin:0 0 14px; }
  .smo-sub{ font-family:'Fraunces',Georgia,serif; font-style:italic; font-size:18px; color:#6b6b63; margin:0 auto 8px; max-width:560px; }
  .smo-video-cta{ text-align:center; font-family:'IBM Plex Sans',system-ui,sans-serif; font-size:15px; color:#6b6b63; margin:26px auto 0; max-width:560px; }
  .smo-video-cta a{ color:#0A0E1A; text-decoration:underline; text-underline-offset:2px; }
  .smo-video-cta a:hover{ opacity:.7; }
  .smo-video{ max-width:480px; margin:12px auto 6px; border-radius:18px; overflow:hidden; background:#0A0E1A; box-shadow:0 18px 50px rgba(10,14,26,.22); }
  .smo-video-el{ width:100%; height:auto; display:block; }
  .smo-tier{ display:flex; align-items:center; gap:14px; margin:42px 0 18px; }
  .smo-tier-line{ flex:1; height:1px; background:#e2e2da; }
  .smo-tier-label{ font-family:'JetBrains Mono',monospace; font-size:11.5px; letter-spacing:.12em; text-transform:uppercase; color:#9a9a93; white-space:nowrap; }
  .smo-grid{ display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px; }
  @media(max-width:760px){ .smo-grid{ grid-template-columns:1fr 1fr; } }
  @media(max-width:480px){ .smo-grid{ grid-template-columns:1fr; } }
  .smo-card{ display:flex; flex-direction:column; align-items:flex-start; gap:6px; text-align:left; border:1.5px solid #d9d9d1; border-radius:18px; padding:24px 24px 20px; background:#fff; cursor:pointer; transition:border-color .15s ease, box-shadow .18s ease, transform .08s ease; font-family:inherit; }
  .smo-card:hover{ border-color:#0A0E1A; box-shadow:0 16px 40px rgba(10,14,26,.13); transform:translateY(-2px); }
  .smo-card h2{ font-family:'Fraunces',Georgia,serif; font-weight:500; font-size:21px; margin:0; }
  .smo-card p{ font-size:13.5px; line-height:1.45; color:#6b6b63; margin:0; }
  .smo-start{ margin-top:4px; font-family:'JetBrains Mono',monospace; font-size:12.5px; color:#1845D6; }
  .smo-pill{ display:inline-flex; align-items:center; gap:6px; margin-top:10px; padding:5px 11px; border-radius:99px; background:#eef7ee; color:#2E7D32; font-size:11px; font-weight:600; line-height:1.2; }
  .smo-pill svg{ width:12px; height:12px; flex:0 0 auto; }
  .smo-note{ text-align:center; font-size:14px; color:#7a7a72; line-height:1.6; max-width:620px; margin:20px auto 0; }
  .smo-fullapp{ margin-top:18px; border-radius:20px; padding:30px 32px; text-align:left; background:linear-gradient(135deg,#0A0E1A 0%,#16204a 100%); color:#fff; position:relative; overflow:hidden; display:flex; align-items:center; justify-content:space-between; gap:28px; flex-wrap:wrap; box-shadow:0 22px 60px rgba(10,14,26,.30); }
  .smo-fullapp-copy{ flex:1 1 320px; }
  .smo-fa-eyebrow{ font-family:'JetBrains Mono',monospace; font-size:11.5px; letter-spacing:.12em; text-transform:uppercase; color:#8ea2ff; margin-bottom:10px; }
  .smo-fullapp h3{ font-family:'Fraunces',Georgia,serif; font-weight:500; font-size:25px; line-height:1.2; margin:0 0 10px; color:#fff; }
  .smo-fullapp p{ font-size:14.5px; line-height:1.6; color:#c5cbe0; margin:0; max-width:440px; }
  .smo-hardnote{ margin-top:12px; font-size:12.5px; color:#9aa6cf; }
  .smo-fa-btn{ flex:0 0 auto; display:inline-flex; align-items:center; gap:10px; background:#fff; color:#0A0E1A; border-radius:99px; padding:18px 34px; font-size:16px; font-weight:600; text-decoration:none; white-space:nowrap; transition:transform .08s ease, box-shadow .15s ease; box-shadow:0 8px 24px rgba(0,0,0,.25); }
  .smo-fa-btn:hover{ transform:translateY(-2px); box-shadow:0 14px 34px rgba(0,0,0,.34); }
  .smo-fa-btn::after{ content:'\2192'; }
</style>
