---
import Layout from '../../../layouts/Layout.astro';
import RealReverseForm from '../../../components/RealReverseForm.astro';
---

<Layout title="Reverse Mortgage — See My Options | Stairway Mortgage" description="See your reverse mortgage options. Income from your home, age 55+ — no credit pull, guided by Jim Blackburn (NMLS #1072866).">
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">See My Options · Reverse Mortgage</span>
        <h1 class="display-xl mt-6 mb-6">Income from your <em class="not-italic text-[var(--color-blue)]">home</em>.</h1>
        <p class="lede max-w-xl mx-auto mb-8">Answer a few questions about your property and goals. Our team will walk you through reverse mortgage options — no pressure, no obligation.</p>
        <div class="flex flex-wrap gap-3 justify-center mt-10">
          <button data-rm-open class="btn btn-blue btn-arrow text-base px-6 py-3.5">See My Options</button>
          <a href="tel:+19549931625" class="btn btn-ghost text-base px-6 py-3.5">Call (954) 993-1625</a>
        </div>
        <p class="mono text-[11px] text-[var(--color-mute)] mt-4">NMLS #1072866 · Not a commitment to lend.</p>
      </div>
    </div>
  </section>
  <RealReverseForm />
</Layout>
