---
import Layout from '../layouts/Layout.astro';
import DiscoveryQuizForm from '../components/forms/DiscoveryQuizForm.astro';
---
<Layout title="Discovery Quiz — Stairway Mortgage" description="Discover where you are on your financial journey and what smart step to take next. A short conversational quiz that matches you with the right tools, experts, and strategies.">

  <section class="section relative overflow-hidden dq-hero">
    <div class="container-page">
      <div class="max-w-2xl mx-auto text-center">
        <span class="eyebrow eyebrow-blue mb-6">Find Your Path</span>
        <h1 class="display-lg mt-6 mb-4">Which step is <em class="not-italic text-[var(--color-blue)]">yours</em>?</h1>
        <p class="lede max-w-xl mx-auto mb-10">Discover where you are on your financial journey — and what smart step to take next. We'll help you identify opportunities, avoid costly mistakes, and connect you with the right tools, experts, and strategies to grow wealth with confidence.</p>

        <div class="dq-launch">
          <button type="button" data-open-discovery-quiz class="btn btn-blue btn-arrow text-base px-7 py-3.5">Take the Discovery Quiz</button>
          <p class="dq-launch__meta mono">Live · 3–5 minutes · No login</p>
        </div>
      </div>

      <p class="mono text-[11px] text-[var(--color-mute)] text-center mt-12">NMLS #1072866</p>
    </div>
  </section>

  <DiscoveryQuizForm />

</Layout>

<style>
  .dq-hero{position:relative;}.dq-hero::before{content:'';position:absolute;top:0;left:0;right:0;height:200px;background:linear-gradient(180deg,var(--color-blue-tint) 0%,transparent 100%);opacity:0.3;pointer-events:none;z-index:0;}
  .dq-launch{display:flex;flex-direction:column;align-items:center;gap:14px;}
  .dq-launch__meta{font-size:12px;color:var(--color-mute);letter-spacing:0.04em;}
</style>
