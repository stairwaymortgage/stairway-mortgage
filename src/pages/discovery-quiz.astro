---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Discovery Quiz — Stairway Mortgage" description="Find your top financial priorities. Quick quiz to match you with the right path.">
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">Tools</span>
        <h1 class="display-xl mt-6 mb-6">Find your <em class="italic text-[var(--color-blue)]">path</em>.</h1>
        <p class="lede max-w-xl mx-auto mb-8">Answer a few quick questions and we match you with the right mortgage path.</p>
        <div class="card max-w-lg mx-auto p-8 text-center">
          <p class="font-display text-xl mb-4">Quiz launching soon</p>
          <p class="text-[14px] text-[var(--color-mute)]"><!-- TODO: Build interactive quiz --></p>
        </div>
        <div class="flex flex-wrap gap-3 justify-center mt-10">
          <a href="/the-8-steps/" class="btn btn-blue btn-arrow text-base px-6 py-3.5">See the 8 Steps</a>
          <a href="/contact-us/" class="btn btn-ghost text-base px-6 py-3.5">Talk to Our Team</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
