---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Blog — Stairway Mortgage" description="Market updates, mortgage tips, and real estate insights.">
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">Learn · Blog</span>
        <h1 class="display-xl mt-6 mb-6">Market updates and <em class="italic text-[var(--color-blue)]">insights</em>.</h1>
        <p class="lede max-w-xl mx-auto mb-8">Articles and market updates from the Stairway team. Coming soon.</p>
        <div class="card max-w-lg mx-auto p-8 text-center">
          <p class="text-[14px] text-[var(--color-mute)]"><!-- TODO: Wire blog CMS --> Blog launching soon.</p>
        </div>
        <div class="flex flex-wrap gap-3 justify-center mt-10">
          <a href="/contact-us/" class="btn btn-ghost text-base px-6 py-3.5">Talk to Our Team</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
