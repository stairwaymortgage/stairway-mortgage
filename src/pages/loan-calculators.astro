---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Loan Calculators — Stairway Mortgage" description="Mortgage payment, refinance savings, and affordability calculators.">
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">Tools & Rates · Calculators</span>
        <h1 class="display-xl mt-6 mb-6">Run the <em class="italic text-[var(--color-blue)]">numbers</em>.</h1>
        <p class="lede max-w-xl mx-auto mb-8">Mortgage payment, refinance break-even, affordability, and investor cash-flow calculators.</p>
        <div class="grid sm:grid-cols-2 gap-4 max-w-2xl mx-auto text-left">
          <a href="/buy-a-house-journey/" class="card"><h3 class="font-display text-lg font-medium mb-1">Affordability</h3><p class="text-[14px] text-[var(--color-mute)]">See what you can buy.</p></a>
          <a href="/refinance-or-heloc-journey/" class="card"><h3 class="font-display text-lg font-medium mb-1">Refinance Break-Even</h3><p class="text-[14px] text-[var(--color-mute)]">See if a refi saves money.</p></a>
          <a href="/renovate-a-house-journey/" class="card"><h3 class="font-display text-lg font-medium mb-1">Renovation Value</h3><p class="text-[14px] text-[var(--color-mute)]">Before vs. after your reno.</p></a>
          <a href="/build-a-wealth-plan-journey/" class="card"><h3 class="font-display text-lg font-medium mb-1">Investor Leverage</h3><p class="text-[14px] text-[var(--color-mute)]">See how cash controls 4x its value.</p></a>
        </div>
        <div class="flex flex-wrap gap-3 justify-center mt-10">
          <a href="/same-day-approval/" class="btn btn-blue btn-arrow text-base px-6 py-3.5">See My Options</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
