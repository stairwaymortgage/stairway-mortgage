  .flip-card__inner {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.5s;
    transform-style: preserve-3d;
  }
  .flip-card:hover .flip-card__inner,
  .flip-card:focus .flip-card__inner {
    transform: rotateY(180deg);
  }
  .flip-card__front,
  .flip-card__back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
