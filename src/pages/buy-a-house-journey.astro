  .stepper__review {
    padding: 1.5rem !important;
  }

  /* ── Matcher / Program picker ── */
  .matcher-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: center;
    margin-bottom: 2rem;
  }
  .matcher-filter { text-align: center; }
  .matcher-filter__label {
    display: block;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-mute);
    margin-bottom: 0.5rem;
  }
  .matcher-filter__options { display: flex; gap: 4px; }
  .matcher-pill {
    padding: 0.4rem 0.9rem;
    font-size: 13px;
    font-weight: 500;
    border: 1px solid var(--color-bone);
    border-radius: 20px;
    background: var(--color-paper);
    cursor: pointer;
    transition: all 0.15s;
    color: var(--color-ink);
  }
  .matcher-pill.is-active {
    background: var(--color-blue);
    border-color: var(--color-blue);
    color: white;
  }
  .matcher-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }
  .matcher-card {
    position: relative;
    transition: all 0.3s;
  }
  .matcher-card.is-dimmed {
    opacity: 0.35;
    transform: scale(0.97);
  }
  .matcher-card__match {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-green);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .matcher-card:not(.is-dimmed) .matcher-card__match { opacity: 1; }

  /* ── Stat band ── */
  .stat-band {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 2rem;
  }
  .stat-band__item { text-align: center; flex: 1; min-width: 120px; }
  .stat-band__num {
    display: block;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-paper);
  }
  .stat-band__label {
    display: block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.5;
    margin-top: 0.4rem;
  }

  /* ── Flip cards ── */
  .flip-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }
  .flip-card {
    perspective: 600px;
    cursor: pointer;
    height: 180px;
  }
  .flip-card__inner {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.5s;
    transform-style: preserve-3d;
  }
  .flip-card:hover .flip-card__inner,
  .flip-card:focus .flip-card__inner {
    transform: rotateY(180deg);
  }
  .flip-card__front,
  .flip-card__back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    border: 1px solid var(--color-bone);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .flip-card__front { background: var(--color-paper); }
  .flip-card__back {
    background: var(--color-ink);
    color: var(--color-paper);
    transform: rotateY(180deg);
    gap: 0.5rem;
    align-items: center;
    text-align: center;
  }
  .flip-card__num {
    font-size: 11px;
    color: var(--color-rust);
    margin-bottom: 0.5rem;
  }

  /* ── Stairway graphic ── */
  .stairway-graphic {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 1.5rem;
    height: 220px;
  }
  .stairway-step {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .stairway-step__bar {
    width: 80px;
    border-radius: 10px 10px 0 0;
    transition: height 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .stairway-step--1 .stairway-step__bar { height: 0; background: var(--color-bone); }
  .stairway-step--2 .stairway-step__bar { height: 0; background: var(--color-blue); }
  .stairway-step--3 .stairway-step__bar { height: 0; background: var(--color-ink); }
  .stairway-graphic.in-view .stairway-step--1 .stairway-step__bar { height: 80px; }
  .stairway-graphic.in-view .stairway-step--2 .stairway-step__bar { height: 130px; }
  .stairway-graphic.in-view .stairway-step--3 .stairway-step__bar { height: 180px; }
  .stairway-step__label { font-size: 16px; font-weight: 500; }
  .stairway-step__sub { font-size: 12px; color: var(--color-mute); }

  /* ── Reviews carousel ── */
  .reviews-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 1rem;
  }
  .reviews-track {
    display: flex;
    gap: 1.25rem;
    animation: scroll-reviews 30s linear infinite;
    width: max-content;
  }
  @keyframes scroll-reviews {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .reviews-track:hover { animation-play-state: paused; }
  .review-card {
    flex-shrink: 0;
    width: 340px;
    border: 1px solid rgba(250, 250, 247, 0.15);
    border-radius: 16px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .review-card__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-blue-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .review-card__initials {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-paper);
  }
  .review-card__text {
    font-size: 15px;
    line-height: 1.45;
    color: var(--color-paper);
    font-weight: 400;
    flex: 1;
  }
  .review-card__meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-size: 12px;
    color: rgba(250, 250, 247, 0.6);
  }
  .review-card__meta strong { color: var(--color-paper); font-weight: 500; }
  .review-card__source {
    margin-left: auto;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.5;
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .reviews-track { animation: none; }
    .hero-strike { text-decoration: line-through; text-decoration-color: var(--color-rust); opacity: 0.4; }
    .hero-typed { opacity: 1; transform: none; }
    .stepper__pulse { animation: none; }
    .q-chart__bar { transition: none; }
    .stairway-step__bar { transition: none; }
    .donut-seg { transition: none; }
  }
</style>

<!-- ═══════════════════════════════════════════════════════════
     PAGE SCRIPT — animations, stepper, matcher
     ═══════════════════════════════════════════════════════════ -->
<script is:inline>
(function() {
  'use strict';
  var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ── Count-up on scroll ── */
  function countUp(el) {
    var target = parseFloat(el.dataset.countup);
    var suffix = el.dataset.suffix || '';
    var prefix = el.dataset.prefix || '';
    var decimals = parseInt(el.dataset.decimals) || 0;
    var duration = 1200;
    var start = performance.now();

    function tick(now) {
      var elapsed = now - start;
      var progress = Math.min(elapsed / duration, 1);
      var ease = 1 - Math.pow(1 - progress, 3);
      var current = ease * target;
      el.textContent = prefix + (decimals ? current.toFixed(decimals) : Math.round(current)) + suffix;
      if (progress < 1) requestAnimationFrame(tick);
    }
    if (prefersReduced) {
      el.textContent = prefix + (decimals ? target.toFixed(decimals) : target) + suffix;
    } else {
      requestAnimationFrame(tick);
    }
  }

  /* ── Scroll observer for everything ── */
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (!e.isIntersecting) return;
        e.target.classList.add('in-view');
        io.unobserve(e.target);

        // Count-ups
        e.target.querySelectorAll('[data-countup]').forEach(countUp);
        if (e.target.dataset.countup) countUp(e.target);

        // Bar chart grow
        e.target.querySelectorAll('[data-grow]').forEach(function(bar) {
          bar.style.height = bar.dataset.grow + '%';
        });

        // Donut segments
        e.target.querySelectorAll('[data-donut]').forEach(function(seg) {
          seg.style.strokeDashoffset = 314 - parseInt(seg.dataset.donut);
        });
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal, .reveal-right, .trust-ribbon, .stat-band, .stairway-graphic, .q-chart, .donut-wrap').forEach(function(el) {
      io.observe(el);
    });
    // Observe individual parent containers for the donut and chart
    document.querySelectorAll('.q-chart__bar-wrap').forEach(function(el) { io.observe(el); });
  }

  /* ── Hero reframe ── */
  var heroOld = document.getElementById('hero-old');
  var heroNew = document.getElementById('hero-new');
  if (heroOld && heroNew) {
    setTimeout(function() { heroOld.classList.add('done'); }, 800);
    setTimeout(function() { heroNew.classList.add('show'); heroNew.setAttribute('aria-hidden', 'false'); }, 1600);
  }

  /* ── Stepper — auto-advance ── */
  var stepper = document.getElementById('stepper');
  var panels = document.getElementById('stepper-panels');
  var fill = document.getElementById('stepper-fill');
  if (stepper && panels) {
    var tabs = stepper.querySelectorAll('.stepper__tab');
    var panelEls = panels.querySelectorAll('.stepper__panel');
    var current = 0;
    var total = tabs.length;
    var interval = 5000;
    var timer;

    function goTo(i) {
      current = i;
      tabs.forEach(function(t, idx) {
        t.classList.toggle('is-active', idx === i);
        t.setAttribute('aria-selected', idx === i ? 'true' : 'false');
      });
      panelEls.forEach(function(p, idx) {
        p.classList.toggle('is-active', idx === i);
      });
      fill.style.width = ((i + 1) / total * 100) + '%';
    }

    function advance() { goTo((current + 1) % total); }
    function startTimer() { timer = setInterval(advance, interval); }
    function stopTimer() { clearInterval(timer); }

    tabs.forEach(function(t, i) {
      t.addEventListener('click', function() { stopTimer(); goTo(i); startTimer(); });
    });

    stepper.addEventListener('mouseenter', stopTimer);
    stepper.addEventListener('mouseleave', startTimer);
    if (!prefersReduced) startTimer();
  }

  /* ── Program matcher ── */
  var filters = document.getElementById('matcher-filters');
  var grid = document.getElementById('matcher-grid');
  if (filters && grid) {
    var state = { income: 'w2', down: 'low', goal: 'live' };

    function updateMatcher() {
      var cards = grid.querySelectorAll('.matcher-card');
      cards.forEach(function(card) {
        var incomeList = JSON.parse(card.dataset.income);
        var downList = JSON.parse(card.dataset.down);
        var goalList = JSON.parse(card.dataset.goal);
        var match = incomeList.includes(state.income) && downList.includes(state.down) && goalList.includes(state.goal);
        card.classList.toggle('is-dimmed', !match);
      });
    }

    filters.addEventListener('click', function(e) {
      var pill = e.target.closest('.matcher-pill');
      if (!pill) return;
      var filterGroup = pill.parentElement;
      var filterType = filterGroup.dataset.filter;
      filterGroup.querySelectorAll('.matcher-pill').forEach(function(p) { p.classList.remove('is-active'); });
      pill.classList.add('is-active');
      state[filterType] = pill.dataset.val;
      updateMatcher();
    });

    updateMatcher();
  }

  /* ── Reviews: duplicate track for infinite scroll ── */
  var track = document.getElementById('reviews-track');
  if (track && !prefersReduced) {
    var clone = track.innerHTML;
    track.innerHTML += clone;
  }
})();
</script>
