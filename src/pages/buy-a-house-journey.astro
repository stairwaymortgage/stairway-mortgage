    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .proof-dart__name {
    font-family: var(--stw-mono, 'JetBrains Mono'), monospace;
    font-size: 11px;
    color: var(--color-mute);
  }
  .proof-dart__cta {
    font-family: var(--stw-mono, 'JetBrains Mono'), monospace;
    font-size: 11px;
    color: var(--color-blue);
    text-decoration: none;
    white-space: nowrap;
  }
  .proof-dart__cta:hover { text-decoration: underline; }

  /* ── Mobile sticky CTA bar ── */
  .mobile-cta-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--color-ink);
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    z-index: 45;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 -4px 20px rgba(10, 14, 26, 0.3);
  }
  .mobile-cta-bar.is-visible { transform: translateY(0); }
  @media (min-width: 980px) { .mobile-cta-bar { display: none !important; } }
  .mobile-cta-bar__btn { flex: 1; text-align: center; font-size: 14px !important; padding: 0.6rem 1rem !important; }
  .mobile-cta-bar__phone {
    color: var(--color-paper);
    text-decoration: none;
    font-size: 12px;
    opacity: 0.7;
    white-space: nowrap;
  }
  .mobile-cta-bar__close {
    color: var(--color-paper);
    background: none;
    border: none;
    font-size: 20px;
    cursor: pointer;
    opacity: 0.5;
    padding: 4px;
  }

  /* ── Hero gradient wash ── */
  .hero-wash::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 200px;
    background: linear-gradient(180deg, var(--color-blue-tint) 0%, transparent 100%);
    opacity: 0.3;
    pointer-events: none;
    z-index: 0;
  }

  /* ── Stepper dark overrides ── */
  .stepper-dark .stepper__tab {
    background: rgba(250, 250, 247, 0.08);
    border-color: rgba(250, 250, 247, 0.12);
    color: var(--color-paper);
  }
  .stepper-dark .stepper__tab.is-active {
    background: var(--color-paper);
    color: var(--color-ink);
    border-color: var(--color-paper);
  }
  .stepper-dark .stepper__tab:not(.is-active):hover {
    border-color: rgba(250, 250, 247, 0.3);
  }
  .stepper-dark .stepper-progress { background: rgba(250, 250, 247, 0.15); }
  .stepper-dark .stepper__review { background: rgba(250, 250, 247, 0.06); border-color: rgba(250, 250, 247, 0.1); }
  .stepper-dark .stepper__review p { color: var(--color-paper); }
  .stepper-dark .stepper__review .text-\[13px\] { color: rgba(250, 250, 247, 0.5); }

  /* ── Blue-wash stat band overrides ── */
  .stat-band-blue .stat-band__num { color: var(--color-ink); }
  .stat-band-blue .stat-band__label { color: var(--color-mute); opacity: 1; }

  /* ── Summit glow ── */
  .summit-glow {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .summit-glow__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
  }
  .summit-glow__blob--blue {
    width: 200px;
    height: 200px;
    background: var(--color-blue);
    opacity: 0.2;
    bottom: -40px;
    right: 10%;
  }
  .summit-glow__blob--rust {
    width: 160px;
    height: 160px;
    background: var(--color-rust);
    opacity: 0.15;
    top: -20px;
    left: 15%;
  }
</style>

<!-- ═══════════════════════════════════════════════════════════
     PAGE SCRIPT — animations, stepper, matcher
     ═══════════════════════════════════════════════════════════ -->
<script is:inline>
(function() {
  'use strict';
  var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ── Count-up on scroll ── */
  function countUp(el) {
    var target = parseFloat(el.dataset.countup);
    var suffix = el.dataset.suffix || '';
    var prefix = el.dataset.prefix || '';
    var decimals = parseInt(el.dataset.decimals) || 0;
    var duration = 1200;
    var start = performance.now();

    function tick(now) {
      var elapsed = now - start;
      var progress = Math.min(elapsed / duration, 1);
      var ease = 1 - Math.pow(1 - progress, 3);
      var current = ease * target;
      el.textContent = prefix + (decimals ? current.toFixed(decimals) : Math.round(current)) + suffix;
      if (progress < 1) requestAnimationFrame(tick);
    }
    if (prefersReduced) {
      el.textContent = prefix + (decimals ? target.toFixed(decimals) : target) + suffix;
    } else {
      requestAnimationFrame(tick);
    }
  }

  /* ── Scroll observer for everything ── */
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (!e.isIntersecting) return;
        e.target.classList.add('in-view');
        io.unobserve(e.target);

        // Count-ups
        e.target.querySelectorAll('[data-countup]').forEach(countUp);
        if (e.target.dataset.countup) countUp(e.target);

        // Donut segments
        e.target.querySelectorAll('[data-donut]').forEach(function(seg) {
          seg.style.strokeDashoffset = 314 - parseInt(seg.dataset.donut);
        });
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal, .reveal-right, .trust-ribbon, .stat-band, .stairway-graphic, .donut-wrap').forEach(function(el) {
      io.observe(el);
    });
  }

  /* ── Hero reframe ── */
  var heroOld = document.getElementById('hero-old');
  var heroNew = document.getElementById('hero-new');
  if (heroOld && heroNew) {
    setTimeout(function() { heroOld.classList.add('done'); }, 800);
    setTimeout(function() { heroNew.classList.add('show'); heroNew.setAttribute('aria-hidden', 'false'); }, 1600);
  }

  /* ── Stepper — click-only (static, no auto/scroll advance) ── */
  var stepper = document.getElementById('stepper');
  var panelsWrap = document.getElementById('stepper-panels');
  var fill = document.getElementById('stepper-fill');
  if (stepper && panelsWrap) {
    var tabs = stepper.querySelectorAll('.stepper__tab');
    var panelEls = panelsWrap.querySelectorAll('.stepper__panel');
    var currentStep = 0;
    var totalSteps = tabs.length;

    function goToStep(i) {
      currentStep = i;
      tabs.forEach(function(t, idx) {
        t.classList.toggle('is-active', idx === i);
        t.setAttribute('aria-selected', idx === i ? 'true' : 'false');
      });
      panelEls.forEach(function(p, idx) {
        p.classList.toggle('is-active', idx === i);
      });
      fill.style.width = ((i + 1) / totalSteps * 100) + '%';
    }

    tabs.forEach(function(t, i) {
      t.addEventListener('click', function() { goToStep(i); });
    });
  }

  /* ── Program matcher ── */
  var matcherFilters = document.getElementById('matcher-filters');
  var matcherGrid = document.getElementById('matcher-grid');
  if (matcherFilters && matcherGrid) {
    var mState = { income: 'w2', down: 'low', goal: 'live', prop: 'existing' };

    function updateMatcher() {
      var cards = matcherGrid.querySelectorAll('.matcher-card');
      cards.forEach(function(card) {
        var incomeList = JSON.parse(card.dataset.income);
        var downList = JSON.parse(card.dataset.down);
        var goalList = JSON.parse(card.dataset.goal);
        var propList = JSON.parse(card.dataset.prop || '["existing","new","reno"]');
        var match = incomeList.includes(mState.income)
          && downList.includes(mState.down)
          && goalList.includes(mState.goal)
          && propList.includes(mState.prop);
        card.classList.toggle('is-dimmed', !match);
      });
    }

    matcherFilters.addEventListener('click', function(e) {
      var pill = e.target.closest('.matcher-pill');
      if (!pill) return;
      var filterGroup = pill.parentElement;
      var filterType = filterGroup.dataset.filter;
      filterGroup.querySelectorAll('.matcher-pill').forEach(function(p) { p.classList.remove('is-active'); });
      pill.classList.add('is-active');
      mState[filterType] = pill.dataset.val;
      updateMatcher();
    });

    updateMatcher();
  }

  /* ── Reviews: duplicate track for infinite scroll ── */
  var track = document.getElementById('reviews-track');
  if (track && !prefersReduced) {
    var clone = track.innerHTML;
    track.innerHTML += clone;
  }

  /* ── The Climb (stops at summit, never enters footer) ── */
  var climbEl = document.querySelector('.climb');
  var climbNode = document.getElementById('climb-node');
  var climbFill = document.getElementById('climb-fill');
  var climbTicks = document.querySelectorAll('.climb__tick');
  var climbSections = document.querySelectorAll('[data-climb-section]');
  var climbTicking = false;
  var climbEnd = 0; /* absolute Y of the last section's bottom */

  function calcClimbBounds() {
    var lastSec = climbSections[climbSections.length - 1];
    if (lastSec) {
      climbEnd = lastSec.offsetTop + lastSec.offsetHeight;
    }
  }

  function updateClimb() {
    var scrollY = window.scrollY || window.pageYOffset;
    /* progress scoped to content above footer */
    var maxScroll = Math.max(1, climbEnd - window.innerHeight);
    var progress = Math.min(1, Math.max(0, scrollY / maxScroll));
    var viewH = window.innerHeight;

    /* Hide climb once we scroll past the summit into footer */
    var pastSummit = scrollY > climbEnd;
    if (climbEl) climbEl.style.opacity = pastSummit ? '0' : '1';

    if (climbNode) {
      climbNode.style.transform = 'translateY(' + (progress * viewH * 0.85 + viewH * 0.05) + 'px)';
    }
    if (climbFill) {
      climbFill.style.height = (progress * 100) + '%';
    }

    climbTicks.forEach(function(tick) {
      var tickPos = parseFloat(tick.dataset.pos || 0);
      tick.classList.toggle('is-passed', progress >= tickPos);
    });

    climbTicking = false;
  }

  if (climbNode) {
    function calcTicks() {
      calcClimbBounds();
      var maxScroll = Math.max(1, climbEnd - window.innerHeight);
      climbSections.forEach(function(sec, i) {
        var pos = sec.offsetTop / maxScroll;
        if (climbTicks[i]) {
          climbTicks[i].dataset.pos = Math.min(1, pos);
          climbTicks[i].style.top = (Math.min(1, pos) * 100) + '%';
        }
      });
    }
    calcTicks();
    window.addEventListener('resize', calcTicks);

    window.addEventListener('scroll', function() {
      if (!climbTicking) {
        requestAnimationFrame(updateClimb);
        climbTicking = true;
      }
    }, { passive: true });
    updateClimb();
  }

  /* ── Mobile sticky CTA bar ── */
  var mobileBar = document.getElementById('mobile-cta-bar');
  var mobileClose = document.getElementById('mobile-cta-close');
  var mobileDismissed = false;

  if (mobileBar) {
    window.addEventListener('scroll', function() {
      if (mobileDismissed) return;
      var scrollH = document.documentElement.scrollHeight - window.innerHeight;
      var progress = scrollH > 0 ? (window.scrollY / scrollH) : 0;
      if (progress > 0.6) {
        mobileBar.classList.add('is-visible');
        mobileBar.setAttribute('aria-hidden', 'false');
      }
    }, { passive: true });

    if (mobileClose) {
      mobileClose.addEventListener('click', function() {
        mobileDismissed = true;
        mobileBar.classList.remove('is-visible');
        mobileBar.setAttribute('aria-hidden', 'true');
      });
    }
  }
})();
</script>
