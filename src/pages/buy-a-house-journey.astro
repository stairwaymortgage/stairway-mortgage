---
import Layout from '../layouts/Layout.astro';

/* ── Data ─────────────────────────────────────────────────── */
const trustNumbers = [
  { value: 5.0,   suffix: '★',  label: 'Client rating' },
  { value: 624,   suffix: '',   label: 'Verified reviews' },
  { value: 300,   suffix: '+',  label: 'Lender network' },
  { value: 48,    suffix: '',   label: 'States (NEXA)' },
  { value: 19,    suffix: '',   label: 'Day fastest close' },
];

const steps = [
  {
    num: '01',
    title: 'Get pre-approved',
    line: '60 seconds online, answer in 24 hours.',
    review: { text: '"Got my approval letter same day."', name: 'Raman S.', loc: 'NJ' },
  },
  {
    num: '02',
    title: 'Explore your options',
    line: '300+ lenders bid — you pick the best fit.',
    review: { text: '"Jim found a rate nobody else could."', name: 'Holly F.', loc: 'MI' },
  },
  {
    num: '03',
    title: 'Partner up',
    line: 'We connect you with agents, inspectors, title.',
    review: { text: '"The whole team was coordinated perfectly."', name: 'Syed S.', loc: 'IL' },
  },
  {
    num: '04',
    title: 'Offer & inspect',
    line: 'Cash-backed offers that win bidding wars.',
    review: { text: '"We closed in under 30 days."', name: 'Andreea G.', loc: 'IL' },
  },
  {
    num: '05',
    title: 'Close & plan ahead',
    line: "Keys in hand — plus a roadmap for what\u2019s next.",
    review: { text: '"Already planning our second property."', name: 'Dwayne L.', loc: 'IL' },
  },
];

const programs = [
  { id: 'fha',    name: 'FHA',              line: 'Low down, flexible credit',      income: ['w2','self','mixed'], down: ['low'],       goal: ['live'] },
  { id: 'va',     name: 'VA',               line: 'Zero down for veterans',         income: ['w2'],               down: ['low','20'],   goal: ['live'] },
  { id: 'usda',   name: 'USDA',             line: 'Zero down, rural & suburban',    income: ['w2'],               down: ['low'],        goal: ['live'] },
  { id: 'conv',   name: 'Conventional',     line: 'Standard rates, flexible terms', income: ['w2','mixed'],       down: ['20'],         goal: ['live','invest'] },
  { id: 'jumbo',  name: 'Jumbo',            line: 'High-value properties',          income: ['w2','self','mixed'],down: ['20'],          goal: ['live','invest'] },
  { id: 'flex',   name: 'Flexible Income',  line: 'Bank statements, assets, 1099',  income: ['self','mixed'],     down: ['low','20'],   goal: ['live','invest'] },
];

const mistakes = [
  { front: 'Not getting pre-approved first',      back: 'Jim gets you approved before you shop' },
  { front: 'Only talking to one lender',           back: '300+ lenders compete for your rate' },
  { front: 'Ignoring the total monthly cost',      back: 'We show taxes, insurance, and upkeep upfront' },
  { front: 'Waiving the home inspection',          back: 'Our team coordinates fast, thorough inspections' },
  { front: 'Forgetting about closing costs',       back: 'We map every dollar before you sign' },
];

const reviews = [
  { text: "Raman and his wife were first-time buyers in New Jersey. Jim's team got them pre-approved the same day and found a rate that beat three other lenders.", name: 'Raman Sawhney', loc: 'New Jersey', source: 'Google', img: '/testimonials/raman-sawhney.jpg' },
  { text: "Holly bought her first home in Michigan. The portal was intuitive, the team proactive, and the whole process was wrapped up in under three weeks.", name: 'Holly Fontyn', loc: 'Michigan', source: 'Google', img: '/testimonials/holly-fontyn.jpg' },
  { text: "Syed closed on a multi-family in Illinois. Jim's knowledge of investor-friendly loans helped him structure the deal with maximum leverage.", name: 'Syed Saqib', loc: 'Illinois', source: 'Zillow', img: '/testimonials/syed-saqib.jpg' },
  { text: "Andreea needed to close fast — under 30 days. Jim's team delivered ahead of schedule, coordinating title, appraisal, and insurance seamlessly.", name: 'Andreea Grigorie', loc: 'Illinois', source: 'Google', img: '/testimonials/andreea-grigorie.jpg' },
  { text: "Dwayne has used Jim three times. Each transaction was smoother than the last. He now refers every friend and colleague to Stairway.", name: 'Dwayne Lee', loc: 'Illinois', source: 'Facebook', img: '/testimonials/dwayne-lee.jpg' },
  { text: "Carolina did a purchase and a refi within the same year. Jim found savings on both that added up to over $400/month.", name: 'Carolina Forsyth', loc: 'New Jersey', source: 'Google', img: '/testimonials/carolina-forsyth.jpg' },
];
---

<Layout title="Buy a Home — Stairway Mortgage" description="Your path to buying a home wisely. 300+ lenders competing for your loan. Pre-approved in as fast as 24 hours.">

  <!-- ═══════════════════════════════════════════════════════
       1. HERO — The Reframe
       ═══════════════════════════════════════════════════════ -->
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">How We Serve · Buy a Home</span>

        <!-- Animated reframe -->
        <h1 class="display-xl mt-6 mb-8" aria-label="How can I buy wisely?">
          <span class="hero-strike" id="hero-old">Can I buy a house?</span>
          <span class="hero-typed" id="hero-new" aria-hidden="true">
            How can I buy <em class="italic text-[var(--color-blue)]">wisely</em>?
          </span>
        </h1>

        <div class="flex flex-wrap gap-3 justify-center mb-12">
          <a href="/same-day-approval/" class="btn btn-blue btn-arrow text-base px-6 py-3.5">See My Options</a>
          <a href="/contact-us/" class="btn btn-ghost text-base px-6 py-3.5">Talk to Jim</a>
        </div>
      </div>

      <!-- Trust ribbon with count-up -->
      <div class="trust-ribbon reveal" style="transition-delay:200ms;">
        {trustNumbers.map((t) => (
          <div class="trust-ribbon__item">
            <span class="trust-ribbon__num font-display" data-countup={t.value} data-suffix={t.suffix}>0{t.suffix}</span>
            <span class="trust-ribbon__label">{t.label}</span>
          </div>
        ))}
        <div class="trust-ribbon__nmls">
          <span class="mono">Jim Blackburn · NMLS #1072866</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       2. THREE QUESTIONS — Mini infographics
       ═══════════════════════════════════════════════════════ -->
  <section class="section-tight border-y border-[var(--color-bone)]">
    <div class="container-page">
      <div class="grid md:grid-cols-3 gap-px bg-[var(--color-bone)] rounded-2xl overflow-hidden border border-[var(--color-bone)]">

        <!-- Q1: Now vs. future value -->
        <div class="bg-[var(--color-paper)] p-8 lg:p-10 reveal">
          <span class="eyebrow mb-6">Question 01</span>
          <h3 class="display-sm mt-4 mb-6">Today, or five years from now?</h3>
          <!-- Mini bar chart: now vs future -->
          <div class="q-chart" aria-label="Home values tend to rise over time">
            <div class="q-chart__bar-wrap">
              <div class="q-chart__bar q-chart__bar--now" data-grow="62" style="height:0%">
                <span class="q-chart__val font-display">$350K</span>
              </div>
              <span class="q-chart__label">Today</span>
            </div>
            <div class="q-chart__bar-wrap">
              <div class="q-chart__bar q-chart__bar--future" data-grow="88" style="height:0%">
                <span class="q-chart__val font-display">$497K</span>
              </div>
              <span class="q-chart__label">5 years</span>
            </div>
          </div>
          <p class="text-[13px] text-[var(--color-mute)] mt-4">National median, CoreLogic projection</p>
        </div>

        <!-- Q2: Credits & incentives -->
        <div class="bg-[var(--color-paper)] p-8 lg:p-10 reveal" style="transition-delay:80ms;">
          <span class="eyebrow mb-6">Question 02</span>
          <h3 class="display-sm mt-4 mb-6">Leaving money on the table?</h3>
          <!-- Stacked coins infographic -->
          <div class="coins-stack" aria-label="Credits and incentives can add up">
            <div class="coins-stack__row reveal-right" style="transition-delay:200ms;">
              <span class="coins-stack__bar coins-stack__bar--1"></span>
              <span class="coins-stack__text">Seller concessions <strong class="font-display">$8K</strong></span>
            </div>
            <div class="coins-stack__row reveal-right" style="transition-delay:300ms;">
              <span class="coins-stack__bar coins-stack__bar--2"></span>
              <span class="coins-stack__text">Lender credits <strong class="font-display">$4K</strong></span>
            </div>
            <div class="coins-stack__row reveal-right" style="transition-delay:400ms;">
              <span class="coins-stack__bar coins-stack__bar--3"></span>
              <span class="coins-stack__text">First-time buyer grants <strong class="font-display">$10K</strong></span>
            </div>
            <div class="coins-stack__total">
              <span class="font-display text-2xl text-[var(--color-green)]">Up to $22K</span>
              <span class="text-[13px] text-[var(--color-mute)]">in potential savings</span>
            </div>
          </div>
        </div>

        <!-- Q3: True cost donut -->
        <div class="bg-[var(--color-paper)] p-8 lg:p-10 reveal" style="transition-delay:160ms;">
          <span class="eyebrow mb-6">Question 03</span>
          <h3 class="display-sm mt-4 mb-6">The whole cost — not just the mortgage?</h3>
          <!-- Animated donut chart -->
          <div class="donut-wrap" aria-label="Monthly payment breakdown">
            <svg viewBox="0 0 120 120" class="donut-svg">
              <circle cx="60" cy="60" r="50" fill="none" stroke="var(--color-bone)" stroke-width="14"/>
              <circle cx="60" cy="60" r="50" fill="none" stroke="var(--color-blue)" stroke-width="14"
                stroke-dasharray="314" stroke-dashoffset="314" data-donut="157" class="donut-seg donut-seg--pi"/>
              <circle cx="60" cy="60" r="50" fill="none" stroke="var(--color-blue-deep)" stroke-width="14"
                stroke-dasharray="314" stroke-dashoffset="314" data-donut="78" class="donut-seg donut-seg--tax"
                transform="rotate(180 60 60)"/>
              <circle cx="60" cy="60" r="50" fill="none" stroke="var(--color-rust)" stroke-width="14"
                stroke-dasharray="314" stroke-dashoffset="314" data-donut="47" class="donut-seg donut-seg--ins"
                transform="rotate(270 60 60)"/>
              <circle cx="60" cy="60" r="50" fill="none" stroke="var(--color-mute)" stroke-width="14"
                stroke-dasharray="314" stroke-dashoffset="314" data-donut="32" class="donut-seg donut-seg--upk"
                transform="rotate(324 60 60)"/>
            </svg>
            <div class="donut-center font-display">
              <span class="text-2xl">$2,847</span>
              <span class="text-[11px] text-[var(--color-mute)]">/month</span>
            </div>
          </div>
          <div class="donut-legend">
            <span><i style="background:var(--color-blue)"></i> Principal & interest</span>
            <span><i style="background:var(--color-blue-deep)"></i> Taxes</span>
            <span><i style="background:var(--color-rust)"></i> Insurance</span>
            <span><i style="background:var(--color-mute)"></i> Upkeep</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       3. STEPPER — Application to Keys
       ═══════════════════════════════════════════════════════ -->
  <section class="section">
    <div class="container-page">
      <div class="text-center max-w-2xl mx-auto mb-14 reveal">
        <span class="eyebrow eyebrow-rust mb-5">From application to keys</span>
        <h2 class="display-lg mt-5">Five steps. <em class="italic font-light">One team.</em></h2>
      </div>

      <!-- Progress bar -->
      <div class="stepper-progress reveal" style="transition-delay:100ms;">
        <div class="stepper-progress__fill" id="stepper-fill" style="width:20%"></div>
      </div>

      <!-- Steps -->
      <div class="stepper" id="stepper" role="tablist">
        {steps.map((s, i) => (
          <button
            class={`stepper__tab ${i === 0 ? 'is-active' : ''}`}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            data-step={i}
          >
            <span class="stepper__num mono">{s.num}</span>
            <span class="stepper__title font-display">{s.title}</span>
          </button>
        ))}
      </div>

      <div class="stepper-panels" id="stepper-panels">
        {steps.map((s, i) => (
          <div
            class={`stepper__panel ${i === 0 ? 'is-active' : ''}`}
            role="tabpanel"
            data-panel={i}
          >
            <div class="stepper__panel-inner">
              <div class="stepper__content">
                <div class="stepper__pulse" aria-hidden="true"></div>
                <h3 class="display-md mb-3">{s.title}</h3>
                <p class="lede">{s.line}</p>
              </div>
              <div class="stepper__review card">
                <svg width="20" height="16" viewBox="0 0 32 24" class="text-[var(--color-blue)]/30 mb-3" aria-hidden="true">
                  <path fill="currentColor" d="M0 24V12.8C0 5.4 4.2 0 12 0v4.8c-3.6 0-6 2.4-6 6h6V24H0zm20 0V12.8C20 5.4 24.2 0 32 0v4.8c-3.6 0-6 2.4-6 6h6V24H20z"/>
                </svg>
                <p class="font-display text-lg leading-snug mb-3">{s.review.text}</p>
                <p class="text-[13px] text-[var(--color-mute)]">{s.review.name} · {s.review.loc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       4. MATCH ME — Program Picker
       ═══════════════════════════════════════════════════════ -->
  <section class="section bg-[var(--color-paper-tint)]">
    <div class="container-page">
      <div class="text-center max-w-2xl mx-auto mb-12 reveal">
        <span class="eyebrow eyebrow-blue mb-5">Find your fit</span>
        <h2 class="display-lg mt-5">Which loan is <em class="italic font-light">yours</em>?</h2>
      </div>

      <!-- Toggle filters -->
      <div class="matcher-filters reveal" style="transition-delay:100ms;" id="matcher-filters">
        <div class="matcher-filter">
          <label class="matcher-filter__label">Income</label>
          <div class="matcher-filter__options" data-filter="income">
            <button class="matcher-pill is-active" data-val="w2">W-2</button>
            <button class="matcher-pill" data-val="self">Self-employed</button>
            <button class="matcher-pill" data-val="mixed">Mixed</button>
          </div>
        </div>
        <div class="matcher-filter">
          <label class="matcher-filter__label">Down payment</label>
          <div class="matcher-filter__options" data-filter="down">
            <button class="matcher-pill is-active" data-val="low">Low / zero</button>
            <button class="matcher-pill" data-val="20">20%+</button>
          </div>
        </div>
        <div class="matcher-filter">
          <label class="matcher-filter__label">Goal</label>
          <div class="matcher-filter__options" data-filter="goal">
            <button class="matcher-pill is-active" data-val="live">Live in it</button>
            <button class="matcher-pill" data-val="invest">Invest</button>
          </div>
        </div>
      </div>

      <!-- Program cards -->
      <div class="matcher-grid" id="matcher-grid">
        {programs.map((p) => (
          <div class="matcher-card card reveal" data-program={p.id}
            data-income={JSON.stringify(p.income)}
            data-down={JSON.stringify(p.down)}
            data-goal={JSON.stringify(p.goal)}>
            <h4 class="font-display text-xl font-medium mb-1">{p.name}</h4>
            <p class="text-[14px] text-[var(--color-mute)]">{p.line}</p>
            <div class="matcher-card__match" aria-hidden="true">Match</div>
          </div>
        ))}
      </div>

      <div class="text-center mt-10 reveal">
        <a href="/same-day-approval/" class="btn btn-blue btn-arrow">See My Options</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       5. BY THE NUMBERS — Stat Band
       ═══════════════════════════════════════════════════════ -->
  <section class="section-dark section-tight">
    <div class="container-page">
      <div class="stat-band reveal">
        <div class="stat-band__item">
          <span class="stat-band__num font-display" data-countup="350" data-suffix="M+" data-prefix="$">$0</span>
          <span class="stat-band__label">Loans closed</span>
        </div>
        <div class="stat-band__item">
          <span class="stat-band__num font-display" data-countup="19" data-suffix="-day">0</span>
          <span class="stat-band__label">Fastest close</span>
        </div>
        <div class="stat-band__item">
          <span class="stat-band__num font-display" data-countup="300" data-suffix="+">0</span>
          <span class="stat-band__label">Lenders</span>
        </div>
        <div class="stat-band__item">
          <span class="stat-band__num font-display" data-countup="48">0</span>
          <span class="stat-band__label">States (NEXA)</span>
        </div>
        <div class="stat-band__item">
          <span class="stat-band__num font-display" data-countup="5.0" data-suffix="★" data-decimals="1">0</span>
          <span class="stat-band__label">624 reviews</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       6. TOP 5 MISTAKES — Flip Cards
       ═══════════════════════════════════════════════════════ -->
  <section class="section">
    <div class="container-page">
      <div class="text-center max-w-2xl mx-auto mb-12 reveal">
        <span class="eyebrow mb-5">Learn from others</span>
        <h2 class="display-lg mt-5">Five mistakes buyers make.</h2>
      </div>

      <div class="flip-grid">
        {mistakes.map((m, i) => (
          <div class="flip-card reveal" style={`transition-delay:${i * 80}ms;`} tabindex="0"
               role="button" aria-label={`Mistake: ${m.front}. Prevention: ${m.back}`}>
            <div class="flip-card__inner">
              <div class="flip-card__front">
                <span class="flip-card__num mono">0{i + 1}</span>
                <p class="font-display text-lg leading-snug">{m.front}</p>
              </div>
              <div class="flip-card__back">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="var(--color-green)" aria-hidden="true"><path d="M6.5 12L2 7.5l1.4-1.4L6.5 9.2l6.1-6.1L14 4.5z"/></svg>
                <p class="font-display text-lg leading-snug">{m.back}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       7. LIFE AFTER CLOSING — Stairway Graphic
       ═══════════════════════════════════════════════════════ -->
  <section class="section bg-[var(--color-paper-tint)]">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-rust mb-5">Life after closing</span>
        <h2 class="display-lg mt-5 mb-12">Closing day is step one.</h2>
      </div>

      <div class="stairway-graphic reveal" style="transition-delay:150ms;">
        <div class="stairway-step stairway-step--1">
          <div class="stairway-step__bar"></div>
          <span class="stairway-step__label font-display">Buy</span>
          <span class="stairway-step__sub">Keys in hand</span>
        </div>
        <div class="stairway-step stairway-step--2">
          <div class="stairway-step__bar"></div>
          <span class="stairway-step__label font-display">Build equity</span>
          <span class="stairway-step__sub">Grow your wealth</span>
        </div>
        <div class="stairway-step stairway-step--3">
          <div class="stairway-step__bar"></div>
          <span class="stairway-step__label font-display">Next move</span>
          <span class="stairway-step__sub">Invest or upgrade</span>
        </div>
      </div>

      <p class="text-center mt-10 font-display text-2xl italic font-light text-[var(--color-mute)] reveal" style="transition-delay:300ms;">
        Leverage wisely. Grow wealthy.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       8. THE RECEIPTS — Reviews Carousel
       ═══════════════════════════════════════════════════════ -->
  <section class="section-dark section">
    <div class="container-page">
      <div class="text-center max-w-2xl mx-auto mb-14 reveal">
        <span class="eyebrow mb-5">The receipts</span>
        <h2 class="display-lg mt-5 text-[var(--color-paper)]">Real buyers. <em class="italic font-light">Real closings.</em></h2>
      </div>

      <div class="reviews-scroll no-scrollbar" id="reviews-scroll">
        <div class="reviews-track" id="reviews-track">
          {reviews.map((r) => (
            <figure class="review-card">
              <div class="review-card__avatar" aria-hidden="true">
                <span class="review-card__initials">{r.name.split(' ').map(n => n[0]).join('')}</span>
              </div>
              <blockquote class="review-card__text font-display">{r.text}</blockquote>
              <figcaption class="review-card__meta">
                <strong>{r.name}</strong>
                <span>{r.loc}</span>
                <span class="review-card__source mono">{r.source}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       9. FINAL CTA
       ═══════════════════════════════════════════════════════ -->
  <section class="section">
    <div class="container-page">
      <div class="relative rounded-3xl overflow-hidden bg-[var(--color-ink)] text-[var(--color-paper)] p-10 lg:p-16 text-center">
        <div class="absolute right-0 top-0 bottom-0 w-1/2 opacity-20 pointer-events-none" aria-hidden="true">
          <div class="absolute bottom-10 right-10 w-40 h-40 bg-[var(--color-blue)] blur-3xl rounded-full"></div>
        </div>
        <div class="relative reveal">
          <h2 class="display-lg text-[var(--color-paper)] mb-4">
            Ready to buy <em class="italic font-light text-[var(--color-blue-tint)]">wisely</em>?
          </h2>
          <div class="flex flex-wrap gap-3 justify-center mt-8">
            <a href="/same-day-approval/" class="btn btn-blue btn-arrow text-base px-7 py-3.5">See My Options</a>
            <a href="/contact-us/" class="btn bg-transparent border border-[var(--color-paper)]/30 text-[var(--color-paper)] hover:bg-[var(--color-paper)] hover:text-[var(--color-ink)] text-base px-7 py-3.5">Talk to Jim</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<!-- ═══════════════════════════════════════════════════════════
     PAGE-SCOPED STYLES
     ═══════════════════════════════════════════════════════════ -->
<style>
  /* ── Hero reframe animation ── */
  .hero-strike {
    display: block;
    position: relative;
    color: var(--color-mute);
    transition: opacity 0.6s 1s;
  }
  .hero-strike.done {
    text-decoration: line-through;
    text-decoration-color: var(--color-rust);
    text-decoration-thickness: 3px;
    opacity: 0.4;
  }
  .hero-typed {
    display: block;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.5s, transform 0.5s;
  }
  .hero-typed.show {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Trust ribbon ── */
  .trust-ribbon {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
    padding: 1.5rem 2rem;
    background: var(--color-paper-tint);
    border: 1px solid var(--color-bone);
    border-radius: 16px;
    position: relative;
  }
  .trust-ribbon__item { text-align: center; }
  .trust-ribbon__num {
    display: block;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }
  .trust-ribbon__label {
    display: block;
