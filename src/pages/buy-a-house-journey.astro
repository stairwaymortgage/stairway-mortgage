  }
  .stepper__num { font-size: 11px; opacity: 0.6; }
  .stepper__title { font-size: 15px; font-weight: 500; }
  .stepper__panel { display: none; }
  .stepper__panel.is-active { display: block; }
  .stepper__panel-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: center;
  }
  @media (max-width: 768px) {
    .stepper__panel-inner { grid-template-columns: 1fr; }
  }
  .stepper__content { padding: 2rem 0; }
  .stepper__pulse {
    width: 12px;
    height: 12px;
    background: var(--color-green);
    border-radius: 50%;
    margin-bottom: 1rem;
