  .reveal-right.in-view { opacity: 1; transform: translateX(0); }

  /* ── Q3: Donut ── */
  .donut-wrap {
    position: relative;
    width: 160px;
    height: 160px;
    margin: 0 auto;
  }
  .donut-svg { width: 100%; height: 100%; transform: rotate(-90deg); }
  .donut-seg {
