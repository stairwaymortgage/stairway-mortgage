    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.5;
    margin-top: 0.4rem;
  }

  /* ── Flip cards ── */
  .flip-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }
  .flip-card {
    perspective: 600px;
    cursor: pointer;
    height: 180px;
