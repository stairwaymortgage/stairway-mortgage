    .stepper__pulse { animation: none; }
    .stepper__panel.is-active { animation: none; opacity: 1; transform: none; }
    .stairway-step__bar { transition: none; }
    .donut-seg { transition: none; }
  }

  /* ── The Climb (progress rail — stops at summit) ── */
  .climb {
    position: fixed;
    left: calc(6vw - 1px);
    top: 0;
    bottom: 0;
    width: 2px;
    z-index: 30;
    pointer-events: none;
    display: none;
    transition: opacity 0.3s;
  }
  @media (min-width: 768px) { .climb { display: block; } }
  .climb__rail {
    position: absolute;
    inset: 0;
