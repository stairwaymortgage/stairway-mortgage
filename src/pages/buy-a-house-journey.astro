  .stairway-step--2 .stairway-step__bar { height: 0; background: var(--color-blue); }
  .stairway-step--3 .stairway-step__bar { height: 0; background: var(--color-ink); }
  .stairway-graphic.in-view .stairway-step--1 .stairway-step__bar { height: 80px; }
  .stairway-graphic.in-view .stairway-step--2 .stairway-step__bar { height: 130px; }
