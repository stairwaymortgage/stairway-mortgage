  .matcher-pill.is-active {
    background: var(--color-blue);
    border-color: var(--color-blue);
    color: white;
  }
  .matcher-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }
  .matcher-card {
    position: relative;
    transition: all 0.3s;
  }
  .matcher-card.is-dimmed {
    opacity: 0.35;
    transform: scale(0.97);
  }
  .matcher-card__match {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-green);
    opacity: 0;
    transition: opacity 0.3s;
