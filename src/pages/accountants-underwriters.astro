<script>
(function(){
  var form=document.getElementById('adp-intro-form');
  if(!form)return;
  var thanks=document.getElementById('adp-thanks');
  var submitBtn=document.getElementById('adp-submit');
  var hp=document.getElementById('adp-website');
  var hpTouched=false;
  hp.addEventListener('focus',function(){hpTouched=true;});
  setTimeout(function(){if(hp.value&&!hpTouched){hp.value='';}},1200);
  var WEBHOOK='https://services.leadconnectorhq.com/hooks/ipRIuBMrlyPNaFSXDz3q/webhook-trigger/fd7a3b30-ddf9-4415-b751-bfa88beda702';
  form.addEventListener('keydown',function(e){if(e.key==='Enter'&&e.target.tagName==='INPUT'){e.preventDefault();submit();}});
  form.addEventListener('submit',function(e){e.preventDefault();submit();});
  function _getCookie(n){var m=document.cookie.match(new RegExp('(?:^|;\\s*)'+n+'=([^;]+)'));return m?decodeURIComponent(m[1]):'';}
  function _qs(n){try{return new URL(location.href).searchParams.get(n)||'';}catch(e){return '';}}
  function _cleanUmtid(v){return v?String(v).replace(/[^A-Za-z0-9_-]/g,'').slice(0,40):'';}
  function _resolveUmtid(){return _cleanUmtid(_qs('umtid'))||_cleanUmtid(_getCookie('umtid'))||'';}
  function _resolveLoid(){
    var raw = _qs('loid') || _qs('lo_id') || _qs('first_touch_loid') || _getCookie('first_touch_loid') || '';
    var m = String(raw).match(/(\d{3,})/);
    return m ? m[1] : '';
  }
  var submitting=false;
  function submit(){
    if(submitting)return;
    if(hp.value){showThanks();return;}
    var name=form.name.value.trim(),email=form.email.value.trim(),phone=form.phone.value.trim();
    if(!name||!email||!phone){if(!name)form.name.focus();else if(!email)form.email.focus();else form.phone.focus();return;}
    submitting=true;submitBtn.textContent='Sending\u2026';submitBtn.disabled=true;
    var payload={
      name:name,company:form.company.value.trim(),email:email,phone:phone,
      loan_purpose:'partner_introduction',partner_type:'accountant_underwriter',source_page:'accountants-underwriters',
      form_source:'accountants_underwriters',form_name:'Partner Introduction',
      page_url:window.location.href,submitted_at:new Date().toISOString(),
      umtid:_resolveUmtid(),loid:_resolveLoid(),
      utm_source:_qs('utm_source')||_getCookie('utm_source')||'',
      utm_medium:_qs('utm_medium')||_getCookie('utm_medium')||'',
      utm_campaign:_qs('utm_campaign')||_getCookie('utm_campaign')||'',
      utm_term:_qs('utm_term')||_getCookie('utm_term')||'',
      utm_content:_qs('utm_content')||_getCookie('utm_content')||'',
      source_url:_getCookie('first_touch_url')||location.href
    };
    fetch(WEBHOOK,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)}).then(function(){showThanks();}).catch(function(){showThanks();});
  }
  function showThanks(){form.style.display='none';thanks.style.display='block';}
})();
</script>
