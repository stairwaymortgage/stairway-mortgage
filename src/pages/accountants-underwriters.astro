---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Trusted Accountants & Underwriters | Stairway Partners" description="Buying, refinancing, or investing? Get introduced to vetted CPAs and underwriting pros who keep your numbers clean and your loan on track.">
<style is:global>
.adp-scope {
  --stw-ink:#0A0E1A; --stw-ink-soft:#161b2b; --stw-paper:#FAFAF7; --stw-paper-tint:#f0eee6;
  --stw-blue:#1845D6; --stw-blue-deep:#1238b4; --stw-rust:#8B2C2C; --stw-gold:#d8a13a;
  --stw-mute:#5d6470; --stw-line:#e2e0d7; --stw-card:#ffffff;
  --stw-display:'Fraunces',Georgia,serif; --stw-body:'IBM Plex Sans',system-ui,sans-serif; --stw-mono:'JetBrains Mono',ui-monospace,monospace;
  font-family:var(--stw-body); color:var(--stw-ink); background:var(--stw-paper); line-height:1.6;
  -webkit-font-smoothing:antialiased; text-rendering:optimizeLegibility;
}
.adp-scope *,.adp-scope *::before,.adp-scope *::after{box-sizing:border-box;}
.adp-scope img{max-width:100%;display:block;}
.adp-scope a{color:inherit;text-decoration:none;}
.adp-scope .adp-wrap{max-width:1140px;margin:0 auto;padding:0 24px;}
.adp-scope .adp-narrow{max-width:760px;margin-left:auto;margin-right:auto;}
.adp-scope section{padding:88px 0;}
@media(max-width:720px){.adp-scope section{padding:60px 0;}}
.adp-scope .adp-eyebrow{font-family:var(--stw-mono);font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--stw-blue);margin:0 0 18px;}
.adp-scope h1,.adp-scope h2,.adp-scope h3{font-family:var(--stw-display);font-weight:500;line-height:1.08;letter-spacing:-.01em;margin:0;}
.adp-scope h1{font-size:clamp(2.4rem,5.5vw,4rem);}
.adp-scope h2{font-size:clamp(1.9rem,4vw,2.9rem);}
.adp-scope h3{font-size:1.25rem;font-weight:600;}
.adp-scope .adp-lead{font-size:clamp(1.05rem,2vw,1.3rem);color:var(--stw-mute);line-height:1.55;}
.adp-scope em{font-style:normal;}
.adp-scope .adp-accent{font-style:normal;color:var(--stw-blue);}
.adp-scope .adp-btn{display:inline-flex;align-items:center;gap:10px;font-family:var(--stw-body);font-weight:600;font-size:1rem;padding:16px 30px;border-radius:6px;cursor:pointer;border:1.5px solid transparent;transition:transform .15s ease,background .15s ease,box-shadow .15s ease;}
.adp-scope .adp-btn--primary{background:var(--stw-blue);color:#fff;}
.adp-scope .adp-btn--primary:hover{transform:translateY(-2px);background:var(--stw-blue-deep);box-shadow:0 12px 28px rgba(24,69,214,.28);}
.adp-scope .adp-btn--ghost{background:transparent;color:var(--stw-paper);border-color:rgba(250,250,247,.4);}
.adp-scope .adp-btn--ghost:hover{background:rgba(250,250,247,.1);border-color:var(--stw-paper);}
.adp-scope .adp-btn--light{background:var(--stw-paper);color:var(--stw-ink);}
.adp-scope .adp-btn--light:hover{transform:translateY(-2px);box-shadow:0 12px 28px rgba(0,0,0,.25);}
.adp-scope .adp-hero{background:var(--stw-ink);color:var(--stw-paper);padding:96px 0 64px;overflow:hidden;}
.adp-scope .adp-hero__grid{display:grid;grid-template-columns:1.05fr .95fr;gap:56px;align-items:center;}
.adp-scope .adp-hero h1{color:var(--stw-paper);}
.adp-scope .adp-hero .adp-eyebrow{color:#6f8cf0;}
.adp-scope .adp-hero .adp-accent{color:#6f8cf0;}
.adp-scope .adp-hero__lead{color:rgba(250,250,247,.8);font-size:clamp(1.05rem,2vw,1.25rem);margin:22px 0 32px;max-width:30ch;}
.adp-scope .adp-hero__cta{display:flex;gap:14px;flex-wrap:wrap;}
.adp-scope .adp-hero__trust{margin-top:30px;font-family:var(--stw-mono);font-size:12.5px;letter-spacing:.04em;color:rgba(250,250,247,.55);}
.adp-scope .adp-hero__media{position:relative;aspect-ratio:4/5;min-height:480px;border-radius:14px;overflow:hidden;background:linear-gradient(160deg,#1b2236,#0A0E1A);}
.adp-scope .adp-hero__media img{width:100%;height:100%;object-fit:cover;object-position:50% 22%;display:block;}
@media(max-width:880px){.adp-scope .adp-hero{padding-top:64px;}.adp-scope .adp-hero__grid{grid-template-columns:1fr;gap:36px;}.adp-scope .adp-hero__media{min-height:300px;border-radius:12px;}}
.adp-scope .adp-questions{background:var(--stw-paper);}
.adp-scope .adp-qgrid{display:grid;grid-template-columns:1fr 1fr;gap:18px 40px;margin-top:40px;}
.adp-scope .adp-q{display:grid;grid-template-columns:auto 1fr;gap:16px;align-items:start;padding:22px 0;border-top:1px solid var(--stw-line);}
.adp-scope .adp-q__num{font-family:var(--stw-mono);font-size:13px;color:var(--stw-blue);padding-top:3px;}
.adp-scope .adp-q p{margin:0;font-size:1.05rem;}
@media(max-width:720px){.adp-scope .adp-qgrid{grid-template-columns:1fr;gap:0;}}
.adp-scope .adp-equity{background:var(--stw-paper-tint);}
.adp-scope .adp-equity__grid{display:grid;grid-template-columns:.95fr 1.05fr;gap:56px;align-items:center;}
.adp-scope .adp-equity__media{border-radius:14px;overflow:hidden;min-height:420px;background:linear-gradient(160deg,#e7e2d4,#d8d2c2);}
.adp-scope .adp-equity__media img{width:100%;height:100%;object-fit:cover;}
.adp-scope .adp-vlist{list-style:none;margin:28px 0 0;padding:0;}
.adp-scope .adp-vlist li{display:grid;grid-template-columns:auto 1fr;gap:14px;align-items:start;padding:14px 0;border-bottom:1px solid var(--stw-line);font-size:1.05rem;}
.adp-scope .adp-vlist li:last-child{border-bottom:0;}
.adp-scope .adp-check{width:22px;height:22px;flex:none;border-radius:50%;background:var(--stw-blue);display:grid;place-items:center;margin-top:2px;}
.adp-scope .adp-check svg{width:12px;height:12px;}
@media(max-width:880px){.adp-scope .adp-equity__grid{grid-template-columns:1fr;gap:36px;}.adp-scope .adp-equity__media{min-height:280px;}}
.adp-scope .adp-how{background:var(--stw-paper);text-align:center;}
.adp-scope .adp-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;margin-top:52px;text-align:left;}
.adp-scope .adp-step{background:var(--stw-card);border:1px solid var(--stw-line);border-radius:12px;padding:32px 28px;position:relative;}
.adp-scope .adp-step__num{font-family:var(--stw-display);font-size:2.6rem;font-weight:500;color:var(--stw-blue);line-height:1;margin-bottom:14px;display:block;}
.adp-scope .adp-step h3{margin-bottom:10px;}
.adp-scope .adp-step p{margin:0;color:var(--stw-mute);font-size:.98rem;}
@media(max-width:880px){.adp-scope .adp-steps{grid-template-columns:1fr;gap:18px;}}
.adp-scope .adp-reviews{background:var(--stw-ink);color:var(--stw-paper);}
.adp-scope .adp-reviews h2{color:var(--stw-paper);}
.adp-scope .adp-reviews .adp-eyebrow{color:#6f8cf0;}
.adp-scope .adp-reviews__head{text-align:center;max-width:640px;margin:0 auto 14px;}
.adp-scope .adp-rsummary{text-align:center;display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:44px;}
.adp-scope .adp-rsummary__stars{display:flex;gap:3px;}
.adp-scope .adp-rsummary__stars svg{width:18px;height:18px;}
.adp-scope .adp-rsummary__label{font-family:var(--stw-mono);font-size:12.5px;letter-spacing:.05em;color:rgba(250,250,247,.65);}
.adp-scope .adp-rscroll{display:grid;grid-auto-flow:column;grid-auto-columns:360px;gap:24px;overflow-x:auto;padding:6px 4px 24px;scroll-snap-type:x mandatory;}
.adp-scope .adp-rscroll::-webkit-scrollbar{height:6px;}
.adp-scope .adp-rscroll::-webkit-scrollbar-thumb{background:rgba(250,250,247,.2);border-radius:99px;}
.adp-scope .adp-tcard{scroll-snap-align:start;background:var(--stw-card);color:var(--stw-ink);border-radius:14px;padding:28px 26px 24px;position:relative;display:flex;flex-direction:column;box-shadow:0 14px 40px rgba(0,0,0,.22);border-top:3px solid var(--stw-blue);}
.adp-scope .adp-tcard__head{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.adp-scope .adp-tcard__stars{display:flex;gap:2px;}
.adp-scope .adp-tcard__stars svg{width:16px;height:16px;color:var(--stw-ink);}
.adp-scope .adp-tcard__source svg{width:18px;height:18px;display:block;}
.adp-scope .adp-tcard__quote{font-family:var(--stw-display);font-size:1.1rem;line-height:1.5;margin:0 0 18px;flex:1;color:#1c2230;}
.adp-scope .adp-tcard__quote::before{content:"\201C";color:var(--stw-blue);font-weight:600;margin-right:1px;}
.adp-scope .adp-tcard__tag{font-family:var(--stw-mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--stw-mute);padding-top:16px;border-top:1px solid var(--stw-line);margin-bottom:16px;}
.adp-scope .adp-tcard__author{display:flex;align-items:center;gap:12px;}
.adp-scope .adp-tcard__avatar{width:42px;height:42px;border-radius:50%;flex:none;overflow:hidden;background:linear-gradient(145deg,var(--stw-blue),#0e2a8c);display:grid;place-items:center;font-family:var(--stw-display);font-weight:600;color:#fff;font-size:.92rem;}
.adp-scope .adp-tcard__avatar img{width:100%;height:100%;object-fit:cover;}
.adp-scope .adp-tcard__name{font-weight:600;font-size:.96rem;font-family:var(--stw-body);}
.adp-scope .adp-tcard__meta{font-size:.8rem;color:var(--stw-mute);line-height:1.3;}
@media(max-width:720px){.adp-scope .adp-rscroll{grid-auto-columns:84vw;}}
.adp-scope .adp-form-sec{background:var(--stw-paper-tint);}
.adp-scope .adp-form-grid{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;}
.adp-scope .adp-form-copy h2{margin-bottom:18px;}
.adp-scope .adp-form-copy p{color:var(--stw-mute);font-size:1.08rem;margin:0 0 16px;}
.adp-scope .adp-form-copy .adp-microtrust{font-family:var(--stw-mono);font-size:12px;letter-spacing:.04em;color:var(--stw-blue);margin-top:24px;}
.adp-scope .adp-formcard{background:var(--stw-card);border:1px solid var(--stw-line);border-radius:16px;padding:36px;box-shadow:0 20px 50px rgba(10,14,26,.08);}
.adp-scope .adp-field{margin-bottom:18px;}
.adp-scope .adp-field label{display:block;font-size:.85rem;font-weight:600;margin-bottom:7px;color:var(--stw-ink);}
.adp-scope .adp-field input{width:100%;padding:13px 15px;font-family:var(--stw-body);font-size:1rem;border:1.5px solid var(--stw-line);border-radius:8px;background:var(--stw-paper);transition:border-color .15s ease,box-shadow .15s ease;}
.adp-scope .adp-field input:focus{outline:none;border-color:var(--stw-blue);box-shadow:0 0 0 3px rgba(24,69,214,.12);}
.adp-scope .adp-formcard .adp-btn--primary{width:100%;justify-content:center;margin-top:6px;}
.adp-scope .adp-hp{position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;}
.adp-scope .adp-form-note{text-align:center;font-size:.8rem;color:var(--stw-mute);margin-top:16px;}
.adp-scope .adp-thanks{text-align:center;padding:30px 10px;}
.adp-scope .adp-thanks__icon{width:56px;height:56px;border-radius:50%;background:var(--stw-blue);display:grid;place-items:center;margin:0 auto 18px;}
.adp-scope .adp-thanks h3{font-size:1.5rem;margin-bottom:10px;}
.adp-scope .adp-thanks p{color:var(--stw-mute);margin:0;}
@media(max-width:880px){.adp-scope .adp-form-grid{grid-template-columns:1fr;gap:36px;}}
.adp-scope .adp-partner{background:var(--stw-ink-soft);color:var(--stw-paper);text-align:center;}
.adp-scope .adp-partner h2{color:var(--stw-paper);margin-bottom:16px;}
.adp-scope .adp-partner .adp-eyebrow{color:#6f8cf0;}
.adp-scope .adp-partner p{color:rgba(250,250,247,.82);font-size:1.1rem;max-width:56ch;margin:0 auto 18px;}
.adp-scope .adp-partner__points{display:flex;justify-content:center;gap:34px;flex-wrap:wrap;margin:30px 0 38px;}
.adp-scope .adp-partner__point{font-family:var(--stw-mono);font-size:12.5px;letter-spacing:.04em;color:rgba(250,250,247,.7);display:flex;align-items:center;gap:8px;}
.adp-scope .adp-partner__point svg{width:14px;height:14px;color:var(--stw-gold);}
.adp-scope .adp-footer{background:var(--stw-ink);color:rgba(250,250,247,.6);padding:52px 0;font-size:.85rem;}
.adp-scope .adp-footer__inner{text-align:center;line-height:1.7;}
.adp-scope .adp-footer strong{color:rgba(250,250,247,.85);font-weight:600;}
.adp-scope .adp-footer a{color:#6f8cf0;}
@media(prefers-reduced-motion:reduce){.adp-scope *{transition:none !important;animation:none !important;}}
</style>

<div class="adp-scope">

  <!-- HERO -->
  <section class="adp-hero">
    <div class="adp-wrap">
      <div class="adp-hero__grid">
        <div>
          <p class="adp-eyebrow">For Buyers, Owners &amp; Investors</p>
          <h1>Your numbers,<br>working <em class="adp-accent">for</em> you.</h1>
          <p class="adp-hero__lead">The right CPA or underwriting pro doesn't just file your taxes — they structure your income so you qualify for more and keep more. We introduce you to vetted financial partners who think like lenders.</p>
          <div class="adp-hero__cta">
            <a href="#request-intro" class="adp-btn adp-btn--primary">Request a Partner Introduction</a>
            <a href="#how" class="adp-btn adp-btn--ghost">See how it works</a>
          </div>
          <p class="adp-hero__trust">Jim Blackburn &middot; NMLS #1072866 &middot; (954) 993-1625 &middot; $500M+ closed</p>
        </div>
        <div class="adp-hero__media">
          <!-- stw-img: Pexels 8297051. VERIFY IN BROWSER. -->
          <img src="https://images.pexels.com/photos/8297051/pexels-photo-8297051.jpeg?auto=compress&cs=tinysrgb&w=1280" alt="Accountant reviewing financial documents with a client" loading="eager" style="object-position:50% 30%;" onerror="this.onerror=null;this.src='https://placehold.co/720x540/0A0E1A/FAFAF7?text=Stairway';">
        </div>
      </div>
    </div>
  </section>

  <!-- QUESTIONS -->
  <section class="adp-questions">
    <div class="adp-wrap">
      <div class="adp-narrow" style="text-align:center;">
        <p class="adp-eyebrow">Before You Apply or Invest</p>
        <h2>Ask the questions that protect<br>your approval — not just your taxes.</h2>
        <p class="adp-lead" style="margin-top:18px;">How your income is documented can make or break a mortgage. A partner who understands both tax strategy and lending guidelines changes what you qualify for.</p>
      </div>
      <div class="adp-qgrid">
        <div class="adp-q"><span class="adp-q__num">01</span><p>Is your income documented in a way lenders actually accept?</p></div>
        <div class="adp-q"><span class="adp-q__num">02</span><p>Are your write-offs helping your taxes but hurting your loan approval?</p></div>
        <div class="adp-q"><span class="adp-q__num">03</span><p>Will your returns support the property or investment you want?</p></div>
        <div class="adp-q"><span class="adp-q__num">04</span><p>Are you structured to qualify as a self-employed or investor borrower?</p></div>
        <div class="adp-q"><span class="adp-q__num">05</span><p>Does your accountant talk to your lender — or work in a silo?</p></div>
        <div class="adp-q"><span class="adp-q__num">06</span><p>Is your financial picture audit-ready and underwriting-ready at once?</p></div>
      </div>
    </div>
  </section>

  <!-- EQUITY -->
  <section class="adp-equity">
    <div class="adp-wrap">
      <div class="adp-equity__grid">
        <div class="adp-equity__media">
          <!-- stw-img: Pexels 8439647. VERIFY IN BROWSER. -->
          <img src="https://images.pexels.com/photos/8439647/pexels-photo-8439647.jpeg?auto=compress&cs=tinysrgb&w=1280" alt="Accountant reviewing financial documents with a client" loading="lazy" onerror="this.onerror=null;this.src='https://placehold.co/640x520/f0eee6/0A0E1A?text=Stairway';">
        </div>
        <div>
          <p class="adp-eyebrow">Why Clean Numbers Build Wealth</p>
          <h2>Smart accounting is a<br><em class="adp-accent">qualifying engine</em>.</h2>
          <ul class="adp-vlist">
            <li><span class="adp-check"><svg viewBox="0 0 16 16" fill="#fff"><path d="M6.5 12L2 7.5l1.4-1.4L6.5 9.2l6.1-6.1L14 4.5z"/></svg></span>Document income so you qualify for the loan you actually want</li>
            <li><span class="adp-check"><svg viewBox="0 0 16 16" fill="#fff"><path d="M6.5 12L2 7.5l1.4-1.4L6.5 9.2l6.1-6.1L14 4.5z"/></svg></span>Balance tax savings against borrowing power — not one at the expense of the other</li>
            <li><span class="adp-check"><svg viewBox="0 0 16 16" fill="#fff"><path d="M6.5 12L2 7.5l1.4-1.4L6.5 9.2l6.1-6.1L14 4.5z"/></svg></span>Structure investor and self-employed income the way underwriters expect</li>
            <li><span class="adp-check"><svg viewBox="0 0 16 16" fill="#fff"><path d="M6.5 12L2 7.5l1.4-1.4L6.5 9.2l6.1-6.1L14 4.5z"/></svg></span>Keep returns clean, consistent, and ready for review</li>
            <li><span class="adp-check"><svg viewBox="0 0 16 16" fill="#fff"><path d="M6.5 12L2 7.5l1.4-1.4L6.5 9.2l6.1-6.1L14 4.5z"/></svg></span>Move from application to approval without surprise document requests</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="adp-how" id="how">
    <div class="adp-wrap">
      <div class="adp-narrow">
        <p class="adp-eyebrow">How a Partner Introduction Works</p>
        <h2>One request. The right pro.<br>Zero spam.</h2>
      </div>
      <div class="adp-steps">
        <div class="adp-step"><span class="adp-step__num">1</span><h3>Tell us your need</h3><p>Share what you're working on and where. It takes under a minute &mdash; name, company, and how to reach you.</p></div>
        <div class="adp-step"><span class="adp-step__num">2</span><h3>We match a vetted partner</h3><p>We hand-pick a CPA or underwriting pro from our directory who fits your situation, your area, and your loan.</p></div>
        <div class="adp-step"><span class="adp-step__num">3</span><h3>You move with confidence</h3><p>Your partner and our team stay aligned from first call to closing &mdash; so nothing falls through the cracks.</p></div>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="adp-reviews">
    <div class="adp-wrap">
      <div class="adp-reviews__head">
        <p class="adp-eyebrow">Real Clients &middot; Real Closings</p>
        <h2>The work speaks. So do they.</h2>
      </div>
      <div class="adp-rsummary">
        <span class="adp-rsummary__stars"><svg viewBox="0 0 24 24" fill="#0A0E1A"><path d="M12 2L14.85 8.62L22 9.41L16.5 14.32L18.06 21.5L12 17.77L5.94 21.5L7.5 14.32L2 9.41L9.15 8.62L12 2Z"/></svg><svg viewBox="0 0 24 24" fill="#0A0E1A"><path d="M12 2L14.85 8.62L22 9.41L16.5 14.32L18.06 21.5L12 17.77L5.94 21.5L7.5 14.32L2 9.41L9.15 8.62L12 2Z"/></svg><svg viewBox="0 0 24 24" fill="#0A0E1A"><path d="M12 2L14.85 8.62L22 9.41L16.5 14.32L18.06 21.5L12 17.77L5.94 21.5L7.5 14.32L2 9.41L9.15 8.62L12 2Z"/></svg><svg viewBox="0 0 24 24" fill="#0A0E1A"><path d="M12 2L14.85 8.62L22 9.41L16.5 14.32L18.06 21.5L12 17.77L5.94 21.5L7.5 14.32L2 9.41L9.15 8.62L12 2Z"/></svg><svg viewBox="0 0 24 24" fill="#0A0E1A"><path d="M12 2L14.85 8.62L22 9.41L16.5 14.32L18.06 21.5L12 17.77L5.94 21.5L7.5 14.32L2 9.41L9.15 8.62L12 2Z"/></svg></span>
        <span class="adp-rsummary__label">5.0 &middot; 624 reviews &middot; Past clients of our founder, Jim Blackburn</span>
      </div>
      <div class="adp-rscroll">
        <article class="adp-tcard">
          <div class="adp-tcard__head">
