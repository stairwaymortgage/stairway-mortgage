    .lec-label {
      font-size: var(--text-xs);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--ink-2);
    }
    .lec-input {
      width: 100%;
      padding: var(--s-3) var(--s-4);
      border: 1px solid var(--border-strong);
      border-radius: 4px;
      font-size: var(--text-base);
      font-family: var(--sans);
      color: var(--ink);
      background: var(--white);
      box-sizing: border-box;
      transition: border-color 0.15s;
    }
    .lec-input:focus {
      outline: none;
      border-color: var(--blue);
      box-shadow: 0 0 0 3px rgba(var(--blue-rgb, 30,80,220), 0.1);
    }
    .lec-textarea { resize: vertical; min-height: 96px; }
    .lec-file { padding: var(--s-3); font-size: var(--text-sm); cursor: pointer; line-height: 1.4; }
    .lec-file::file-selector-button {
      font-family: var(--sans);
      font-size: var(--text-xs);
      font-weight: 600;
      margin-right: var(--s-3);
      padding: var(--s-2) var(--s-3);
      border: 1px solid var(--border-strong);
      border-radius: 4px;
      background: var(--paper-2);
      color: var(--ink);
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s;
    }
    .lec-file::file-selector-button:hover { background: var(--paper-3); border-color: var(--ink); }
    .lec-error {
      font-size: var(--text-sm);
      color: #c0392b;
      margin: 0;
    }
    .lec-submit-btn { width: 100%; justify-content: center; }
    .lec-fine-inline {
      font-family: var(--mono);
      font-size: var(--text-2xs);
      letter-spacing: 0.04em;
      color: var(--ink-lighter);
      text-align: center;
      margin: 0;
    }

    /* ---------- SUCCESS STATE ---------- */
    .lec-success {
      text-align: center;
      padding: var(--s-7) var(--s-4);
    }
    .lec-success-icon {
      color: #2ecc71;
      margin: 0 auto var(--s-4);
      display: block;
    }
    .lec-success-title {
      font-family: var(--serif);
      font-size: var(--text-xl);
      font-variation-settings: "opsz" 30;
      margin-bottom: var(--s-3);
    }
    .lec-success-sub {
      font-size: var(--text-sm);
      color: var(--ink-2);
      max-width: 36ch;
      margin: 0 auto;
    }

    .le-upload-fine {
      font-size: var(--text-xs); color: var(--ink-lighter);
      margin-top: var(--s-4); line-height: 1.5;
    }

    /* ---------- COMPARE ---------- */
    .le-compare { padding: var(--s-9) 0; }
    .le-compare-lead { margin-top: var(--s-4); max-width: 50ch; }
    .le-compare-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--s-5);
      margin-top: var(--s-2);
    }
    .le-compare-row {
      display: flex; gap: var(--s-4);
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: var(--s-5);
    }
    .le-compare-check {
      flex-shrink: 0;
      width: 28px; height: 28px;
      border-radius: 50%;
      background: var(--le-gold-soft);
      color: var(--le-gold);
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: var(--text-sm);
    }
    .le-compare-row h4 { margin-bottom: var(--s-2); }

    /* ---------- PROOF ---------- */
    .le-proof { padding: var(--s-9) 0; background: var(--paper-2); }
    .le-proof-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--s-5);
      align-items: stretch;
    }
    .le-proof-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: var(--s-6);
      display: flex; flex-direction: column; gap: var(--s-5);
      margin: 0;
    }
    .le-proof-card--lead { border-top: 3px solid var(--le-gold); }
    .le-proof-avatar {
      width: 64px; height: 64px; border-radius: 50%;
      overflow: hidden; background: var(--ink-lighter); flex-shrink: 0;
    }
    .le-proof-avatar img {
      width: 100%; height: 100%; object-fit: cover;
      object-position: 50% 25%; display: block;
    }
    .le-proof-quote {
      font-family: var(--serif);
      font-size: var(--text-md);
      line-height: 1.5;
      color: var(--ink);
      margin: 0;
      font-variation-settings: "opsz" 30;
    }
    .le-proof-by { display: flex; flex-direction: column; gap: 2px; margin-top: auto; }
    .le-proof-by strong { font-size: var(--text-base); }
    .le-proof-by span { font-size: var(--text-xs); color: var(--ink-lighter); }
    .le-proof-credit { text-align: center; margin-top: var(--s-6); }

    /* ---------- FAQ ---------- */
    .le-faq { padding: var(--s-9) 0; }
    .faq-list { border-bottom: 1px solid var(--border); }
    .faq-item { border-top: 1px solid var(--border); }
    .faq-q {
      display: flex; gap: var(--s-4); align-items: flex-start;
      padding: var(--s-5) 0;
      font-family: var(--serif);
      font-size: var(--text-lg);
      color: var(--ink);
      cursor: pointer;
      list-style: none;
      font-variation-settings: "opsz" 30;
    }
    .faq-q::-webkit-details-marker { display: none; }
    .faq-q::after {
      content: '+'; margin-left: auto;
      font-family: var(--sans); color: var(--blue);
      font-size: var(--text-xl); line-height: 1;
    }
    details[open] .faq-q::after { content: '–'; }
    .faq-num { color: var(--le-gold); font-size: var(--text-sm); padding-top: 4px; }
    .faq-a { padding: 0 0 var(--s-5) calc(var(--s-4) + 2.5ch); max-width: 64ch; }

    /* ---------- FINAL CTA ---------- */
    .le-final { background: var(--ink); color: var(--paper); padding: var(--s-10) 0; }
    .le-final-inner { text-align: center; }
    .le-final-h { color: var(--paper); margin: var(--s-4) auto var(--s-5); max-width: 20ch; }
    .le-final-p { color: rgba(250,250,247,0.78); font-size: var(--text-lg); max-width: 52ch; margin: 0 auto var(--s-7); }
    .le-final-actions { display: flex; gap: var(--s-3); justify-content: center; flex-wrap: wrap; }
    .le-btn-ghost { background: transparent; color: var(--paper); border: 1px solid rgba(250,250,247,0.3); }
    .le-btn-ghost:hover { border-color: var(--paper); }
    .le-final-fine {
      font-size: var(--text-2xs); letter-spacing: 0.06em;
      color: rgba(250,250,247,0.5); margin-top: var(--s-6);
    }

    /* ---------- RESPONSIVE ---------- */
    @media (max-width: 900px) {
      .le-hero-grid,
      .le-challenge-grid { grid-template-columns: 1fr; gap: var(--s-7); }
      .le-steps-grid,
      .le-compare-grid,
      .le-proof-grid { grid-template-columns: 1fr; }
      .le-hero-card { order: 2; }
      .lec-field-grid { grid-template-columns: 1fr; }
    }
  </style>

<HomeReviews />
</Layout>

<script is:inline>
(function(){
  var form=document.getElementById('lec-form');
  if(!form)return;
  var ENDPOINT=form.getAttribute('data-ghl-endpoint')||'';
  var btn=document.getElementById('lec-submit');
  var errEl=document.getElementById('lec-error');
  var sending=false;

  function showErr(m){errEl.textContent=m;errEl.style.display='block';}
  function hideErr(){errEl.style.display='none';}

  btn.addEventListener('click',function(){
    if(sending)return;

    var gotcha=document.getElementById('lec-gotcha');
    if(gotcha&&gotcha.value.trim()!==''){
      document.getElementById('lec-form').style.display='none';
      document.getElementById('lec-success').style.display='block';
      return;
    }

    var first=document.getElementById('lec-first').value.trim();
    var last=document.getElementById('lec-last').value.trim();
    var email=document.getElementById('lec-email').value.trim();
    var phone=document.getElementById('lec-phone').value.trim();
    var message=document.getElementById('lec-message').value.trim();

    if(!first||!last)return showErr('Please enter your first and last name.');
    if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email))return showErr('Please enter a valid email address.');
    if(phone.replace(/\D/g,'').length<10)return showErr('Please enter a valid phone number.');
    hideErr();

    function _getCookie(n){var m=document.cookie.match(new RegExp('(?:^|;\\s*)'+n+'=([^;]+)'));return m?decodeURIComponent(m[1]):'';}
    function _qs(n){try{return new URL(location.href).searchParams.get(n)||'';}catch(e){return '';}}
    function _cleanUmtid(v){return v?String(v).replace(/[^A-Za-z0-9_-]/g,'').slice(0,40):'';}
    function _resolveUmtid(){return _cleanUmtid(_qs('umtid'))||_cleanUmtid(_getCookie('umtid'))||'';}
    function _resolveLoid(){
      var raw = _qs('loid') || _qs('lo_id') || _qs('first_touch_loid') || _getCookie('first_touch_loid') || '';
      var m = String(raw).match(/(\d{3,})/);
      return m ? m[1] : '';
    }
    var payload={
      first_name:first, last_name:last, full_name:(first+' '+last).trim(),
      email:email, phone:phone,
      message:message,
      form_source:'loan_estimate_challenge', form_name:'Loan Estimate Challenge',
      page_url:window.location.href, submitted_at:new Date().toISOString(),
      umtid: _resolveUmtid(),
      loid: _resolveLoid(),
      source_url: location.href,
      loan_estimate_url: ''
    };

    var UPLOAD_ENDPOINT='https://stairway-upload.jimb-3a9.workers.dev';
    var fileInput=document.getElementById('lec-file');
    var file=(fileInput&&fileInput.files&&fileInput.files[0])?fileInput.files[0]:null;

    sending=true; btn.disabled=true;

    function postLead(loanUrl){
      payload.loan_estimate_url=loanUrl||'';
      btn.textContent='Sending\u2026';
      fetch(ENDPOINT,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)})
        .then(function(){
          document.getElementById('lec-form').style.display='none';
          document.getElementById('lec-success').style.display='block';
        })
        .catch(function(){
          showErr('Something went wrong. Please try again or call us directly.');
        })
        .then(function(){
          sending=false; btn.disabled=false; btn.textContent='Submit My Loan Estimate';
        });
    }

    if(file){
      // Upload the document to the R2 Worker FIRST, then send the lead with its URL.
      // Note: do NOT set Content-Type \u2014 the browser sets the multipart boundary.
      btn.textContent='Uploading\u2026';
      var fd=new FormData();
      fd.append('file',file);
      fd.append('folder','loan-estimates');
      fd.append('email',email);
      fd.append('phone',phone);
      fd.append('first_name',first);
      fd.append('last_name',last);
      fd.append('field_key','loan_estimate_document');
      fetch(UPLOAD_ENDPOINT,{method:'POST',body:fd})
        .then(function(res){ if(!res.ok) throw new Error('upload '+res.status); return res.json(); })
        .then(function(data){ postLead(data&&data.url?data.url:''); })
        .catch(function(){
          // Upload failed: don't hard-block the lead. Let the user retry, or
          // remove the file and submit again to continue without it.
          sending=false; btn.disabled=false; btn.textContent='Submit My Loan Estimate';
          showErr('We couldn\u2019t upload that file \u2014 please try again, or remove it and submit without it.');
        });
    } else {
      postLead('');
    }
  });
})();
</script>
