<!-- ═══════════════════════════════════════════════════════════
     PAGE SCRIPT — timeline, reviews, count-up, mobile CTA
     ═══════════════════════════════════════════════════════════ -->
<script is:inline>
(function() {
  'use strict';
  var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ── Count-up on scroll ── */
  function countUp(el) {
    var target = parseFloat(el.dataset.countup);
    var suffix = el.dataset.suffix || '';
    var prefix = el.dataset.prefix || '';
    var decimals = parseInt(el.dataset.decimals) || 0;
    var duration = 1200;
    var start = performance.now();

    function tick(now) {
      var elapsed = now - start;
      var progress = Math.min(elapsed / duration, 1);
      var ease = 1 - Math.pow(1 - progress, 3);
      var current = ease * target;
      el.textContent = prefix + (decimals ? current.toFixed(decimals) : Math.round(current)) + suffix;
      if (progress < 1) requestAnimationFrame(tick);
    }
    if (prefersReduced) {
      el.textContent = prefix + (decimals ? target.toFixed(decimals) : target) + suffix;
    } else {
      requestAnimationFrame(tick);
    }
  }

  /* ── Scroll observer for reveals + count-ups ── */
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (!e.isIntersecting) return;
        e.target.classList.add('in-view');
        io.unobserve(e.target);
        e.target.querySelectorAll('[data-countup]').forEach(countUp);
        if (e.target.dataset && e.target.dataset.countup) countUp(e.target);
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal, .trust-ribbon, .stat-band').forEach(function(el) {
      io.observe(el);
    });
  }

  /* ── Timeline click handler ── */
  var stepper = document.getElementById('timeline-stepper');
  var panels = document.getElementById('timeline-panels');
  var fill = document.getElementById('timeline-fill');

  if (stepper && panels) {
    var nodes = stepper.querySelectorAll('.timeline-node');
    var allPanels = panels.querySelectorAll('.timeline-panel');
    var totalNodes = nodes.length;

    nodes.forEach(function(node) {
      node.addEventListener('click', function() {
        var idx = parseInt(node.dataset.phase);

        // Update nodes
        nodes.forEach(function(n, i) {
          if (i <= idx) {
            n.classList.add('is-active');
          } else {
            n.classList.remove('is-active');
          }
          n.setAttribute('aria-pressed', i === idx ? 'true' : 'false');
        });

        // Update panels
        allPanels.forEach(function(p, i) {
          if (i === idx) {
            p.style.display = '';
            p.classList.add('is-active');
          } else {
            p.style.display = 'none';
            p.classList.remove('is-active');
          }
        });

        // Update fill line
        if (fill) {
          var pct = totalNodes > 1 ? (idx / (totalNodes - 1)) * 100 : 0;
          fill.style.width = pct + '%';
        }
      });
    });
  }

  /* ── Reviews: duplicate track for infinite scroll ── */
  var track = document.getElementById('reviews-track');
  if (track && !prefersReduced) {
    var clone = track.innerHTML;
    track.innerHTML += clone;
  }

  /* ── Mobile sticky CTA bar ── */
  var mobileBar = document.getElementById('mobile-cta-bar');
  var mobileClose = document.getElementById('mobile-cta-close');
  var mobileDismissed = false;

  if (mobileBar) {
    window.addEventListener('scroll', function() {
      if (mobileDismissed) return;
      var scrollH = document.documentElement.scrollHeight - window.innerHeight;
      var progress = scrollH > 0 ? (window.scrollY / scrollH) : 0;
      if (progress > 0.6) {
        mobileBar.classList.add('is-visible');
        mobileBar.setAttribute('aria-hidden', 'false');
      }
    }, { passive: true });

    if (mobileClose) {
      mobileClose.addEventListener('click', function() {
        mobileDismissed = true;
        mobileBar.classList.remove('is-visible');
        mobileBar.setAttribute('aria-hidden', 'true');
      });
    }
  }
})();
</script>
