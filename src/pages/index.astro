<script>
(function() {
  const KEY = 'sw_visitor_v1';

  const SWMemory = {
    get() {
      try { return JSON.parse(localStorage.getItem(KEY)) || {}; }
      catch(e) { return {}; }
    },
    set(updates) {
      const current = this.get();
      const merged = { ...current, ...updates, last_updated: Date.now() };
      try { localStorage.setItem(KEY, JSON.stringify(merged)); } catch(e) {}
      window.dispatchEvent(new CustomEvent('sw:memory', { detail: merged }));
      return merged;
    },
    track(event, props) {
      const data = this.get();
      const events = data.events || [];
      events.push({ event, props: props || {}, at: Date.now() });
      // Cap at 100 events
      if (events.length > 100) events.shift();
      this.set({ events });
    },
    // Convert to URL params for any GHL form
    toParams() {
      const d = this.get();
      const out = [];
      const include = ['city', 'region', 'persona', 'intent', 'home_value', 'score_high', 'score_low', 'monthly_budget', 'timeline', 'first_visit_at'];
      for (const key of include) {
        if (d[key] !== undefined && d[key] !== null && d[key] !== '') {
          out.push(`${key}=${encodeURIComponent(d[key])}`);
        }
      }
      // Always include sw_session_id
      if (!d.session_id) {
        const sid = 'sw_' + Math.random().toString(36).slice(2, 11);
        this.set({ session_id: sid });
        out.push(`session_id=${sid}`);
      } else {
        out.push(`session_id=${d.session_id}`);
      }
      return out.join('&');
    },
    // Append memory to any URL as query params
    enrichUrl(url) {
      if (!url || url.startsWith('#') || url.startsWith('tel:') || url.startsWith('mailto:')) return url;
      const params = this.toParams();
      if (!params) return url;
      return url + (url.includes('?') ? '&' : '?') + params;
    }
  };

  // ─── INITIALIZE on first load ───
  if (!SWMemory.get().first_visit_at) {
    SWMemory.set({
      first_visit_at: Date.now(),
      first_landing_url: location.pathname + location.search,
      referrer: document.referrer || 'direct',
    });
  }

  // ─── IP DETECTION (cached after first call) ───
  if (!SWMemory.get().city) {
    fetch('https://ipapi.co/json/').then(r => r.json()).then(d => {
      if (d && d.city && !d.error) {
        SWMemory.set({
          city: d.city,
          region: d.region_code || d.region,
          country: d.country_code,
          ip_detected_at: Date.now(),
        });
      }
    }).catch(() => {});
  }

  // ─── URL PARAMS override (when arriving from a campaign) ───
  const urlParams = new URLSearchParams(location.search);
  const urlCity = urlParams.get('city');
  if (urlCity) {
    SWMemory.set({
      city: decodeURIComponent(urlCity).replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()),
      city_from_url: true,
    });
  }
  // Capture UTM params
  const utmKeys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content'];
  const utms = {};
  utmKeys.forEach(k => { if (urlParams.get(k)) utms[k] = urlParams.get(k); });
  if (Object.keys(utms).length) SWMemory.set(utms);

  // ─── AUTO-ENRICH all internal links with memory (on click) ───
  document.addEventListener('click', (e) => {
    const link = e.target.closest('a[href]');
    if (!link) return;
    const href = link.getAttribute('href');
    // Only enrich internal links going to /contact, /apply, schedule, etc.
    if (!/^(\/contact|\/apply|\/same-day-approval|\/purchase-inquiry|forms\.stairwaymortgage)/.test(href)) return;
    // Don't double-enrich
    if (link.dataset.swEnriched === '1') return;
    link.dataset.swEnriched = '1';
    link.href = SWMemory.enrichUrl(href);
  }, true);

  // ─── PAGE VIEW TRACK ───
  SWMemory.track('page_view', { path: location.pathname });

  // ─── Make globally available ───
  window.SWMemory = SWMemory;
})();
</script>

