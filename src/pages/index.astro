ve-investor" data-module="active-investor" data-idx="5" style="--card-color:#8B2C2C; --card-gradient:linear-gradient(135deg, #8B2C2C 0%, #3B0F0F 100%); --card-delay:350ms; --photo-url:url(https://images.pexels.com/photos/5439379/pexels-photo-5439379.jpeg?auto=compress&#38;cs=tinysrgb&#38;w=800);" aria-label="Open Active Investor interactive guide"> <div class="jcard__photo"></div> <div class="jcard__overlay"></div> <div class="jcard__accent"></div> <div class="jcard__top"> <span class="jcard__icon"><svg viewBox="0 0 24 24" fill="none"><path d="M14 4l4 4-4 4M10 12l-4 4 4 4M18 8H8M16 16H6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span> <span class="jcard__pulse" aria-hidden="true"> <svg viewBox="0 0 24 24" fill="none"> <path d="M12 2L13.5 9L20 10.5L13.5 12L12 19L10.5 12L4 10.5L10.5 9L12 2Z" fill="currentColor"></path> </svg> </span> </div> <div class="jcard__body"> <span class="jcard__num">06</span> <h3 class="jcard__title">Active Investor</h3> <div class="jcard__taglines" data-taglines="[&#34;Flip math in 30 seconds?&#34;,&#34;Need a fast pre-approval letter?&#34;,&#34;Fund purchase + 100% of rehab&#34;]"> <p class="jcard__tagline active">Flip and scale faster.</p> </div> </div> <div class="jcard__bottom"> <div class="jcard__ticker" data-tickers="[&#34;Carlos · funded purchase + rehab Day 3&#34;,&#34;Tia · 4 flips this year · $190K net&#34;,&#34;The Park brothers · 12-unit BRRRR&#34;]"> <span class="jcard__ticker-dot"></span> <span class="jcard__ticker-text">Carlos · funded purchase + rehab Day 3</span> </div> <span class="jcard__cta"> <span class="jcard__cta-label">I'm here</span> <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg> </span> </div> </button><button class="jcard" data-persona="passive-investor" data-module="passive-investor" data-idx="6" style="--card-color:#64748B; --card-gradient:linear-gradient(135deg, #475569 0%, #1E2632 100%); --card-delay:420ms; --photo-url:url(https://images.pexels.com/photos/4348404/pexels-photo-4348404.jpeg?auto=compress&#38;cs=tinysrgb&#38;w=800);" aria-label="Open Passive Investor interactive guide"> <div class="jcard__photo"></div> <div class="jcard__overlay"></div> <div class="jcard__accent"></div> <div class="jcard__top"> <span class="jcard__icon"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M12 7v5l3 2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></span> <span class="jcard__pulse" aria-hidden="true"> <svg viewBox="0 0 24 24" fill="none"> <path d="M12 2L13.5 9L20 10.5L13.5 12L12 19L10.5 12L4 10.5L10.5 9L12 2Z" fill="currentColor"></path> </svg> </span> </div> <div class="jcard__body"> <span class="jcard__num">07</span> <h3 class="jcard__title">Passive Investor</h3> <div class="jcard__taglines" data-taglines="[&#34;Cash earning 5%?&#34;,&#34;Could it be earning 12%?&#34;,&#34;Yield without the hassle&#34;]"> <p class="jcard__tagline active">Yield without the headaches.</p> </div> </div> <div class="jcard__bottom"> <div class="jcard__ticker" data-tickers="[&#34;Lin · $250K deployed · 12% blended&#34;,&#34;The Cohens · accredited · multifamily&#34;,&#34;Wei · passive, no toilets, no tenants&#34;]"> <span class="jcard__ticker-dot"></span> <span class="jcard__ticker-text">Lin · $250K deployed · 12% blended</span> </div> <span class="jcard__cta"> <span class="jcard__cta-label">I'm here</span> <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg> </span> </div> </button><button class="jcard" data-persona="legacy-angel" data-module="legacy-angel" data-idx="7" style="--card-color:#4F46E5; --card-gradient:linear-gradient(135deg, #4F46E5 0%, #1E1B4B 100%); --card-delay:490ms; --photo-url:url(https://images.pexels.com/photos/6995237/pexels-photo-6995237.jpeg?auto=compress&#38;cs=tinysrgb&#38;w=800);" aria-label="Open Legacy Angel interactive guide"> <div class="jcard__photo"></div> <div class="jcard__overlay"></div> <div class="jcard__accent"></div> <div class="jcard__top"> <span class="jcard__icon"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3l2.5 5L20 9l-4 4 1 6-5-3-5 3 1-6-4-4 5.5-1L12 3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg></span> <span class="jcard__pulse" aria-hidden="true"> <svg viewBox="0 0 24 24" fill="none"> <path d="M12 2L13.5 9L20 10.5L13.5 12L12 19L10.5 12L4 10.5L10.5 9L12 2Z" fill="currentColor"></path> </svg> </span> </div> <div class="jcard__body"> <span class="jcard__num">08</span> <h3 class="jcard__title">Legacy Angel</h3> <div class="jcard__taglines" data-taglines="[&#34;What will your money mean?&#34;,&#34;Leave more than wealth — leave impact&#34;,&#34;Structure beats accumulation&#34;]"> <p class="jcard__tagline active">Structure that protects your legacy.</p> </div> </div> <div class="jcard__bottom"> <div class="jcard__ticker" data-tickers="[&#34;The Hartman Foundation · structured at 58&#34;,&#34;Eleanor · 480K meals funded · forever&#34;,&#34;The Singh trust · 3 generations&#34;]"> <span class="jcard__ticker-dot"></span> <span class="jcard__ticker-text">The Hartman Foundation · structured at 58</span> </div> <span class="jcard__cta"> <span class="jcard__cta-label">I'm here</span> <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg> </span> </div> </button> </div> </div> </section> <!-- ═══════════════════════════════════════════════════════════════
     MODAL — contains all 8 interactive modules
     ═══════════════════════════════════════════════════════════════ --> <div class="jm" data-jm role="dialog" aria-hidden="true"> <div class="jm__backdrop" data-jm-backdrop></div> <div class="jm__panel" data-jm-panel> <button class="jm__close" data-jm-close aria-label="Close"> <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path></svg> </button> <!-- ═══ MODULE 01: SMART STEWARD ═══ --> <div class="jm__module" data-jm-module="smart-steward"> <div class="jm__head"> <span class="eyebrow eyebrow-blue">Smart Steward · Module 01</span> <h2 class="jm__title">The Four-Year Head Start</h2> <p class="jm__hook">Most haven't even thought about credit yet. Worth knowing what those years are actually worth?</p> </div> <div class="jm__body"> <div class="jm__step active" data-step="1"> <p class="m1__big-q">Are you <strong>18-25</strong> and just getting started?</p> <div class="m1__yn"> <button class="m1__yn-btn m1__yn-btn--yes" data-m1-answer="yes">Yes, that's me</button> <button class="m1__yn-btn" data-m1-answer="no">Not quite</button> </div> </div> <div class="jm__step" data-step="2-yes"> <div class="m1__output"> <p class="m1__time-line">You have ~<strong class="m1__years">11 years</strong> before typical first-home age.</p> <p class="m1__money-line">Smart credit work now =</p> <p class="m1__money-amount">$75,600 saved</p> <p class="m1__money-context">on your first mortgage.</p> </div> <div class="m1__breakdown"> <p class="m1__breakdown-label">The math behind it</p> <div class="m1__rate-compare"> <div class="m1__rate-side"> <p class="m1__rate-side-label">Smart-built credit</p> <p class="m1__rate-side-rate">~ 6.25%</p> </div> <div class="m1__rate-side m1__rate-side--alt"> <p class="m1__rate-side-label">Starting cold</p> <p class="m1__rate-side-rate">~ 7.20%</p> </div> </div> <p class="m1__breakdown-detail">On a $350K first home with 5% down: <strong>$210/mo</strong> more in payment × 360 months = $75,600 lifetime cost of waiting.</p> </div> <p class="jm__bridge">
The playbook has 4 paths: <strong>authorized user</strong> (the fastest), secured cards, credit builder loans, and rent reporting. We'll send the full guide.
</p> <div class="jm__cta-stack"> <a href="/contact-us/?utm_source=journey&utm_module=smart-steward" class="jm__cta jm__cta--primary" data-jm-cta="schedule"> <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="16" rx="2" stroke="currentColor" stroke-width="1.7"></rect><path d="M3 9h18M8 3v4M16 3v4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"></path></svg>
Schedule a 15-min call
</a> <a href="/smart-credit-playbook/?utm_source=journey&utm_module=smart-steward" class="jm__cta" data-jm-cta="playbook">
📘 Get the Smart Credit Playbook
</a> </div> <details class="jm__assumptions"><summary>See assumptions</summary><p class="jm__assumptions-text">Loan = home price × 0.95 (5% down). 30-year fixed. Rate bands illustrative: 6.25% reflects 740+ FICO band, 7.20% reflects 620-660 band. Difference = ~$210/mo × 360 months = $75,600. Actual rate quoted depends on full credit profile, DTI, property type, market conditions, and program eligibility.</p></details> <p class="jm__compliance">Illustrative example using hypothetical rates. Actual rates depend on full credit profile, market conditions, and program eligibility. This is not a loan commitment.</p> </div> <div class="jm__step" data-step="2-no"> <div class="m1__not-you"> <p class="m1__not-you-line">Cool — you might be at a different stage in the Journey.</p> <p class="m1__not-you-sub">Take a look at the other 7 cards and find the one that matches.</p> <button class="jm__cta jm__cta--primary" data-jm-close-btn>← Back to the Journey</button> </div> </div> </div> </div> <!-- ═══ MODULE 02: FIRST-TIME BUYER ═══ --> <div class="jm__module" data-jm-module="first-time-buyer"> <div class="jm__head"> <span class="eyebrow eyebrow-blue">First-Time Buyer · Module 02</span> <h2 class="jm__title">What Can I Actually Afford?</h2> <p class="jm__hook">Tell us what you're paying in rent. We'll show you what that same payment could buy.</p> </div> <div class="jm__body"> <div class="jm__step active" data-step="1"> <div class="jm__inputs"> <div class="jm__input"> <label class="jm__label">Your monthly rent right now</label> <div class="jm__num-wrap"><span class="jm__num-prefix">$</span> <input type="number" data-m2-rent class="jm__num jm__num--prefix" value="2400" min="500" max="15000" step="100"> <span class="jm__num-suffix">/mo</span> </div> </div> </div> <p class="m2__city-note" data-m2-city-note></p> <button class="jm__cta jm__cta--primary" data-m2-go>Show me what I could buy →</button> </div> <div class="jm__step" data-step="2"> <div class="m2__output"> <p class="m2__rent-label">Your <strong>$<span data-m2-rent-display>2,400</span>/mo</strong> rent could buy you a home worth</p> <p class="m2__price-big">$<span data-m2-price>385,000</span></p> <p class="m2__rent-sub">today. You're not priced out — you're paying someone else's mortgage.</p> </div> <div class="m2__breakdown"> <div class="m2__row"><span>Estimated rate</span><strong data-m2-rate>6.50%</strong></div> <div class="m2__row"><span>Down payment (5%)</span><strong>$<span data-m2-down>19,250</span></strong></div> <div class="m2__row"><span>Property tax (est.)</span><strong>$<span data-m2-tax>320</span>/mo</strong></div> <div class="m2__row"><span>Insurance (est.)</span><strong>$<span data-m2-ins>480</span>/mo</strong></div> <div class="m2__row"><span>PMI (est.)</span><strong>$<span data-m2-pmi>180</span>/mo</strong></div> </div> <div class="m2__soft-frame" data-m2-soft-frame style="display:none;"> <p>You're in the <strong>$<span data-m2-soft-min>185,000</span> range</strong> at this payment. Close to ownership — a pre-approval call can show you Hometown Heroes assistance + lower-down-payment programs that bridge the gap.</p> </div> <p class="m2__programs">FL Hometown Heroes · FHA (3.5% down) · USDA · VA · DPA programs may apply.</p> <div class="jm__cta-stack"> <a href="/purchase-inquiry/?utm_source=journey&utm_module=first-time-buyer" class="jm__cta jm__cta--primary" data-jm-cta="prequal">Get pre-approved (24 hrs)</a> <a href="/contact-us/?utm_source=journey&utm_module=first-time-buyer" class="jm__cta" data-jm-cta="talk">Talk to Our Team first</a> </div> <p class="jm__compliance">Illustrative based on detected location. Rate/tax/insurance vary by city, credit, property type. Not a loan commitment.</p> </div> </div> </div> <!-- ═══ MODULE 03: HOMEOWNER ═══ --> <div class="jm__module" data-jm-module="homeowner"> <div class="jm__head"> <span class="eyebrow eyebrow-blue">Homeowner · Module 03</span> <h2 class="jm__title">Wake Up Your Sleeping Equity</h2> <p class="jm__hook">You've been building something quietly. Let's see what it's worth.</p> </div> <div class="jm__body"> <div class="jm__step active" data-step="1"> <div class="m3__inputs-grid"> <div class="jm__input"> <label class="jm__label">Estimated home value today</label> <div class="jm__num-wrap"><span class="jm__num-prefix">$</span> <input type="number" data-m3-value class="jm__num jm__num--prefix" value="650000" min="50000" max="10000000" step="10000"> </div> </div> <div class="jm__input"> <label class="jm__label">Current mortgage balance</label> <div class="jm__num-wrap"><span class="jm__num-prefix">$</span> <input type="number" data-m3-balance class="jm__num jm__num--prefix" value="320000" min="0" max="10000000" step="10000"> </div> </div> </div> <button class="jm__cta jm__cta--primary" data-m3-go>Show my equity →</button> </div> <div class="jm__step" data-step="2"> <div class="m3__equity-display"> <div class="m3__equity-num"> <p class="m3__equity-label">Available to access today</p> <p class="m3__equity-big">$<span data-m3-usable>180,000</span></p> </div> <div class="m3__equity-num m3__equity-num--secondary"> <p class="m3__equity-label">Total equity built</p> <p class="m3__equity-mid">$<span data-m3-total>330,000</span></p> </div> </div> <p class="m3__what-could">Imagine what that could become…</p> <div class="m3__outcomes"> <button class="m3__outcome" data-m3-outcome="bath"> <span class="m3__outcome-icon"><svg viewBox="0 0 24 24"><path d="M4 12V6a2 2 0 012-2h2a2 2 0 012 2v6M4 12h16v4a3 3 0 01-3 3H7a3 3 0 01-3-3v-4zM7 19l-1 2M17 19l1 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg></span> <p class="m3__outcome-label">Renovate your bathroom</p> <p class="m3__outcome-sub">Modern finishes, your sanctuary</p> </button><button class="m3__outcome" data-m3-outcome="kitchen"> <span class="m3__outcome-icon"><svg viewBox="0 0 24 24"><rect x="3" y="9" width="18" height="12" rx="1" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M3 13h18M8 9V5a4 4 0 018 0v4M11 16h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span> <p class="m3__outcome-label">Renovate your kitchen</p> <p class="m3__outcome-sub">The room your family actually lives in</p> </button><button class="m3__outcome" data-m3-outcome="debt"> <span class="m3__outcome-icon"><svg viewBox="0 0 24 24"><rect x="3" y="6" width="18" height="13" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M3 10h18M7 15h3M14 15h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span> <p class="m3__outcome-label">Eliminate high-interest debt</p> <p class="m3__outcome-sub">Trade 24% credit cards for one lower payment</p> </button><button class="m3__outcome" data-m3-outcome="education"> <span class="m3__outcome-icon"><svg viewBox="0 0 24 24"><path d="M12 3L2 8l10 5 10-5-10-5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" fill="none"/><path d="M6 10.5v4c0 1.5 2.7 3 6 3s6-1.5 6-3v-4M22 8v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span> <p class="m3__outcome-label">Fund a child&#39;s education</p> <p class="m3__outcome-sub">Without touching retirement</p> </button><button class="m3__outcome" data-m3-outcome="second-home"> <span class="m3__outcome-icon"><svg viewBox="0 0 24 24"><path d="M3 11l9-8 9 8M5 9.5V20a1 1 0 001 1h12a1 1 0 001-1V9.5M9 21V14h6v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg></span> <p class="m3__outcome-label">Buy that second home</p> <p class="m3__outcome-sub">The cabin, the beach place, the dream</p> </button><button class="m3__outcome" data-m3-outcome="rental"> <span class="m3__outcome-icon"><svg viewBox="0 0 24 24"><path d="M3 21V8l5-3 5 3v13M14 21V12l4-2 3 2v9M3 21h18M7 14h2M7 18h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg></span> <p class="m3__outcome-label">Turn equity into income</p> <p class="m3__outcome-sub">Reposition into a rental property</p> </button> </div> <div class="jm__cta-stack"> <a href="/contact-us/?utm_source=journey&utm_module=homeowner" class="jm__cta jm__cta--primary" data-jm-cta="path">See which path fits me</a> <a href="/purchase-inquiry/?utm_source=journey&utm_module=homeowner" class="jm__cta" data-jm-cta="equity">Get my real equity number</a> </div> <p class="jm__compliance">Available = (home value × 80%) − mortgage balance. Actual cash-out limits vary by lender, credit, property type, and program. Not a loan commitment.</p> </div> </div> </div> <!-- ═══ MODULE 04: SENIOR 55+ ═══ --> <div class="jm__module" data-jm-module="senior-55"> <div class="jm__head"> <span class="eyebrow eyebrow-blue">Senior 55+ · Module 04</span> <h2 class="jm__title">Two Doors at 55+</h2> <p class="jm__hook">Curious how your home equity can fund the next chapter?</p> </div> <div class="jm__body"> <div class="jm__step active" data-step="1"> <label class="jm__label">How old are you?</label> <div class="m4__slider-wrap"> <input type="range" data-m4-age class="m4__slider" min="55" max="110" value="67" step="1"> <div class="m4__age-display"> <span data-m4-age-display>67</span> <span class="m4__age-suffix">years</span> </div> </div> <p class="m4__city-note" data-m4-city-note></p> <div class="jm__input"><label class="jm__label">Your mortgage balance</label><div class="jm__num-wrap"><span class="jm__num-prefix">$</span><input type="number" data-m4-mortgage-input class="jm__num jm__num--prefix" value="280000" min="0" max="5000000" step="10000"></div></div><div class="jm__input"><label class="jm__label">Estimated property value</label><div class="jm__num-wrap"><span class="jm__num-prefix">$</span><input type="number" data-m4-value-input class="jm__num jm__num--prefix" value="550000" min="50000" max="10000000" step="10000"></div></div><button class="jm__cta jm__cta--primary" data-m4-go>Show me both doors →</button> </div> <div class="jm__step" data-step="2"> <p class="m4__age-context" data-m4-age-context></p> <div class="m4__doors"> <div class="m4__door m4__door--stay"> <span class="m4__door-num">Door 1</span> <h3 class="m4__door-title">Stay & Eliminate Your Payment</h3> <p class="m4__door-stat">$<span data-m4-stay-payment>2,400</span><span class="m4__door-stat-unit">/mo</span></p> <p class="m4__door-stat-label">payment eliminated, for life</p> <p class="m4__door-detail">With ~$<span data-m4-equity>320,000</span> in equity, you may qualify for a reverse mortgage that eliminates your monthly mortgage payment for as long as you live in the home.</p> <p class="m4__door-compliance">⚠ You still pay taxes, insurance, and home maintenance. Balance grows over time.</p> <details class="m4__door-disclosure"> <summary>See full reverse-mortgage disclosure</summary> <p>Reverse mortgages require continued payment of property taxes, insurance, and home maintenance. The loan balance grows over time as interest accrues. Eligibility depends on age, equity, occupancy as primary residence, and program guidelines. Borrower must maintain the home. The lender may foreclose if these obligations are not met. This is an illustrative scenario, not a loan commitment.</p> </details> <button class="m4__adjust" data-m4-adjust>Adjust home value / mortgage balance</button> <div class="m4__adjust-fields" data-m4-adjust-fields style="display:none;"> <div class="jm__input"><label class="jm__label">Home value</label> <div class="jm__num-wrap"><span class="jm__num-prefix">$</span><input type="number" data-m4-home-val class="jm__num jm__num--prefix" value=""></div> </div> <div class="jm__input"><label class="jm__label">Mortgage balance</label> <div class="jm__num-wrap"><span class="jm__num-prefix">$</span><input type="number" data-m4-mortgage class="jm__num jm__num--prefix" value=""></div> </div> <button class="jm__cta" data-m4-recalc>Recalculate</button> </div> <a href="/contact-us/?utm_source=journey&utm_module=senior-55&path=stay" class="m4__door-cta" data-jm-cta="senior-stay">Talk through Door 1 with Jim →</a> </div> <div class="m4__door m4__door--move"> <span class="m4__door-num">Door 2</span> <h3 class="m4__door-title">Downsize & Pocket the Difference</h3> <p class="m4__door-stat">$<span data-m4-pocket>180,000</span></p> <p class="m4__door-stat-label">cash in your pocket</p> <p class="m4__door-detail">Sell, buy smaller, walk away with cash + a lower-cost lifestyle.</p> <div class="m4__sliders"> <label class="m4__mini-label">New home target: <span data-m4-newhome-display>55</span>% of current value</label> <input type="range" data-m4-newhome class="m4__mini-slider" min="35" max="80" value="55" step="5"> <label class="m4__mini-label">All-in selling costs: <span data-m4-cost-display>6.5</span>%</label> <input type="range" data-m4-cost class="m4__mini-slider" min="4" max="10" value="6.5" step="0.5"> </div> <a href="/contact-us/?utm_source=journey&utm_module=senior-55&path=downsize" class="m4__door-cta" data-jm-cta="senior-downsize">Talk through Door 2 with Jim →</a> </div> </div> <p class="jm__compliance">Illustrative based on city-median home values. Reverse mortgage eligibility depends on age (62+ for HECM, 55+ for proprietary), equity, occupancy, and program guidelines. Downsize estimate uses adjustable assumptions above. Not a loan commitment.</p> </div> </div> </div> <!-- ═══ MODULE 05: FIRST-TIME INVESTOR ═══ --> <div class="jm__module" data-jm-module="first-investor"> <div class="jm__head"> <span class="eyebrow eyebrow-blue">First-Time Investor · Module 05</span> <h2 class="jm__title">The Leverage Reveal</h2> <p class="jm__hook">See how cash controls 4× its value — and what that does over time.</p> </div> <div class="jm__body"> <div class="jm__step active" data-step="1"> <div class="jm__input"> <label class="jm__label">Cash you could invest</label> <div class="m5__slider-wrap"> <input type="range" data-m5-cash class="m5__slider" min="25000" max="500000" value="100000" step="5000"> <div class="m5__cash-display">$<span data-m5-cash-display>100,000</span></div> </div> </div> <div class="jm__input"> <label class="jm__label">How long can you hold?</label> <div class="m5__slider-wrap"> <input type="range" data-m5-years class="m5__slider" min="5" max="20" value="10" step="1"> <div class="m5__cash-display"><span data-m5-years-display>10</span> years</div> </div> </div> <button class="jm__cta jm__cta--primary" data-m5-go>Show me the math →</button> </div> <div class="jm__step" data-step="2"> <!-- Three-act animated reveal --> <div class="m5__act m5__act--1" data-m5-act="1"> <p class="m5__act-label">Your cash</p> <p class="m5__act-num">$<span data-m5-cash-show>100,000</span></p> <p class="m5__act-arrow">↓ controls</p> <p class="m5__act-asset-label">A property worth</p> <p class="m5__act-asset">$<span data-m5-asset>400,000</span></p> </div> <div class="m5__act m5__act--2" data-m5-act="2"> <p class="m5__act-label">After <span data-m5-years-show>10</span> years</p> <div class="m5__timeline"> <div class="m5__timeline-bar" data-m5-bar-1><span class="m5__bar-label">Year 0 equity</span><span class="m5__bar-val">$100K</span></div> <div class="m5__timeline-bar" data-m5-bar-2><span class="m5__bar-label">Year <span data-m5-years-show2>10</span> equity</span><span class="m5__bar-val">$<span data-m5-equity>305,500</span></span></div> </div> </div> <div class="m5__act m5__act--3" data-m5-act="3"> <p class="m5__breakdown-label">Where the equity came from</p> <div class="m5__breakdown"> <div class="m5__row"><span>Your tenant paid down</span><strong>$<span data-m5-paydown>68,000</span></strong></div> <div class="m5__row"><span>Market appreciation</span><strong>$<span data-m5-appreciation>137,500</span></strong></div> <div class="m5__row m5__row--total"><span>Your equity</span><strong>$<span data-m5-equity-2>305,500</span></strong></div> </div> <div class="m5__cashflow"> <label class="m5__cashflow-label">Plus typical cash flow: $<span data-m5-cf-display>250</span>/mo (adjust)</label> <input type="range" data-m5-cashflow class="m4__mini-slider" min="50" max="800" value="250" step="50"> </div> </div> <p class="jm__bridge">This is how real estate quietly compounds.</p> <div class="jm__cta-stack"> <a href="/contact-us/?utm_source=journey&utm_module=first-investor" class="jm__cta jm__cta--primary" data-jm-cta="strategy">Talk strategy with Jim</a> <a href="/purchase-inquiry/?utm_source=journey&utm_module=first-investor" class="jm__cta" data-jm-cta="investor-prequal">Get investor pre-approval</a> </div> <p class="jm__compliance">Illustrative. Assumes 25% down DSCR loan at 7.5%, <span data-m5-appr-rate>3</span>% annual appreciation (regional average). Real estate values and rental income not guaranteed. Past appreciation does not predict future results.</p> </div> </div> </div> <!-- ═══ MODULE 06: ACTIVE INVESTOR ═══ --> <div class="jm__module" data-jm-module="active-investor"> <div class="jm__head"> <span class="eyebrow eyebrow-rust">Active Investor · Module 06</span> <h2 class="jm__title">The Flip Profit Estimator</h2> <p class="jm__hook">Crunch a deal in 30 seconds.</p> </div> <div class="jm__body"> <div class="jm__step active" data-step="1"> <div class="m6__inputs-grid"> <div class="jm__input"> <label class="jm__label">Purchase price</label> <div class="jm__num-wrap"><span class="jm__num-prefix">$</span><input type="number" data-m6-purchase class="jm__num jm__num--prefix" value="210000" min="50000" max="5000000" step="5000"></div> </div> <div class="jm__input"> <label class="jm__label">Rehab budget</label> <div class="jm__num-wrap"><span class="jm__num-prefix">$</span><input type="number" data-m6-rehab class="jm__num jm__num--prefix" value="65000" min="5000" max="2000000" step="5000"></div> </div> <div class="jm__input"> <label class="jm__label">ARV (After-Repair Value)</label> <div class="jm__num-wrap"><span class="jm__num-prefix">$</span><input type="number" data-m6-arv class="jm__num jm__num--prefix" value="385000" min="50000" max="10000000" step="5000"></div> </div> </div> <details class="m6__assumptions"> <summary>Adjust my assumptions</summary> <div class="m6__assumptions-grid"> <label>Holding %: <span data-m6-hold-display>1.5</span>%/yr <input type="range" data-m6-hold class="m4__mini-slider" min="0.5" max="3" step="0.1" value="1.5"></label> <label>Selling cost: <span data-m6-sell-display>6</span>% <input type="range" data-m6-sell class="m4__mini-slider" min="3" max="10" step="0.5" value="6"></label> <label>Loan rate: <span data-m6-loan-display>11</span>% <input type="range" data-m6-loan class="m4__mini-slider" min="6" max="15" step="0.25" value="11"></label> <label>Closing: $<span data-m6-closing-display>5,000</span> <input type="range" data-m6-closing class="m4__mini-slider" min="2000" max="15000" step="500" value="5000"></label> </div> </details> <button class="jm__cta jm__cta--primary" data-m6-go>Estimate profit →</button> </div> <div class="jm__step" data-step="2"> <div class="m6__output"> <div class="m6__big-stat m6__big-stat--rust"> <p class="m6__big-stat-label">ROI on cash</p> <p class="m6__big-stat-num"><span data-m6-roi>32</span>%</p> </div> <div class="m6__big-stat"> <p class="m6__big-stat-label">Net profit</p> <p class="m6__big-stat-num">$<span data-m6-profit>47,500</span></p> </div> </div> <div class="m6__hold-slider"> <label class="m4__mini-label">Holding period: <span data-m6-months-display>6</span> months <input type="range" data-m6-months class="m4__mini-slider" min="2" max="18" step="1" value="6"></label> </div> <div class="m6__breakdown"> <div class="m6__row"><span>ARV (sale price)</span><strong>$<span data-m6-arv-disp>385,000</span></strong></div> <div class="m6__row"><span>Purchase</span><strong>−$<span data-m6-purch-disp>210,000</span></strong></div> <div class="m6__row"><span>Rehab</span><strong>−$<span data-m6-rehab-disp>65,000</span></strong></div> <div class="m6__row"><span>Holding costs (<span data-m6-mo-disp>6</span> mo)</span><strong>−$<span data-m6-holding>18,900</span></strong></div> <div class="m6__row"><span>Selling costs</span><strong>−$<span data-m6-selling>23,100</span></strong></div> <div class="m6__row"><span>Closing</span><strong>−$<span data-m6-clos-disp>5,000</span></strong></div> <div class="m6__row"><span>Loan interest</span><strong>−$<span data-m6-interest>15,500</span></strong></div> <div class="m6__row m6__row--total"><span>Net profit</span><strong>$<span data-m6-profit-2>47,500</span></strong></div> </div> <div class="jm__cta-stack"> <a href="/purchase-inquiry/?utm_source=journey&utm_module=active-investor" class="jm__cta jm__cta--primary" data-jm-cta="fix-flip-funding">Get 100% purchase + rehab financing →</a> </div> <p class="m6__deal-context">Your deal numbers travel with the application — we underwrite from your inputs, not a generic form.</p> <p class="jm__compliance">Estimates only. Actual profit depends on execution, market conditions, sale timing, and unforeseen costs. Not an offer of credit.</p> </div> </div> </div> <!-- ═══ MODULE 07: PASSIVE INVESTOR ═══ --> <div class="jm__module" data-jm-module="passive-investor"> <div class="jm__head"> <span class="eyebrow eyebrow-rust">Passive Investor · Module 07</span> <h2 class="jm__title">Your Cash, Working</h2> <p class="jm__hook">Pick a target yield. Pick a horizon. See what your money becomes.</p> </div> <div class="jm__body"> <div class="jm__step active" data-step="1"> <div class="m7__accredited-gate"> <p class="m7__gate-q">Are you an accredited investor?</p> <p class="m7__gate-def">(annual income &gt;$200K solo / $300K joint — <strong>OR</strong> — net worth &gt;$1M excluding primary home)</p> <div class="m1__yn"> <button class="m1__yn-btn m1__yn-btn--yes" data-m7-acc="yes">Yes</button> <button class="m1__yn-btn" data-m7-acc="no">No / Not sure</button> </div> </div> <div class="m7__inputs" data-m7-inputs style="display:none;"> <div class="jm__input"> <label class="jm__label">Cash sitting at low yield</label> <div class="jm__num-wrap"><span class="jm__num-prefix">$</span><input type="number" data-m7-cash class="jm__num jm__num--prefix" value="250000" min="50000" max="10000000" step="25000"></div> </div> <div class="jm__input"> <label class="jm__label">Target yield: <span data-m7-yield-display>10</span>%</label> <input type="range" data-m7-yield class="m4__mini-slider" min="6" max="15" step="0.5" value="10"> <p class="jm__hint">Baseline comparison: 4.5% (today's money market avg)</p> </div> <div class="jm__input"> <label class="jm__label">Time horizon: <span data-m7-years-display>10</span> years</label> <input type="range" data-m7-years class="m4__mini-slider" min="5" max="20" step="1" value="10"> </div> <button class="jm__cta jm__cta--primary" data-m7-go>Show me the numbers →</button> </div> </div> <div class="jm__step" data-step="2"> <p class="m7__intro">$<span data-m7-cash-display>250,000</span> today, compared:</p> <div class="m7__columns"> <div class="m7__col"> <p class="m7__col-label">At 4.5% (today's MM avg)</p> <div class="m7__col-row"><span>Year 5</span><strong>$<span data-m7-low-5>311,000</span></strong></div> <div class="m7__col-row"><span>Year <span data-m7-yr1>10</span></span><strong>$<span data-m7-low-mid>388,000</span></strong></div> <div class="m7__col-row"><span>Year 20</span><strong>$<span data-m7-low-20>603,000</span></strong></div> </div> <div class="m7__col m7__col--alt"> <p class="m7__col-label">At <span data-m7-yield-show>10</span>%*</p> <div class="m7__col-row"><span>Year 5</span><strong>$<span data-m7-high-5>402,000</span></strong></div> <div class="m7__col-row"><span>Year <span data-m7-yr2>10</span></span><strong>$<span data-m7-high-mid>648,000</span></strong></div> <div class="m7__col-row"><span>Year 20</span><strong>$<span data-m7-high-20>1,682,000</span></strong></div> </div> </div> <div class="m7__cta-block" data-m7-accredited-cta> <div class="jm__cta-stack"> <a href="/contact-us/?utm_source=journey&utm_module=passive-investor" class="jm__cta jm__cta--primary" data-jm-cta="passive-network">Join the Accredited Investor Network</a> <a href="/contact-us/?utm_source=journey&utm_module=passive-investor&type=discovery" class="jm__cta" data-jm-cta="passive-discovery">Schedule a Discovery Call</a> </div> </div> <div class="m7__cta-block" data-m7-non-accredited-cta style="display:none;"> <div class="m7__redirect"> <p>We focus our passive partnerships on accredited investors. Here are 3 other real estate income paths for you:</p> <div class="m7__alt-paths"> <a href="#" data-m7-redirect="first-investor" class="m7__alt-path">→ Your first rental property (Module 05)</a> <a href="#" data-m7-redirect="homeowner" class="m7__alt-path">→ House-hack: rent rooms while you own (Module 03)</a> <a href="/contact-us/" class="m7__alt-path">→ Or Talk to Our Team about getting to accredited</a> </div> </div> </div> <p class="m7__compliance">* The target yield is a hypothetical figure you selected for illustration. It is not a projection, guarantee, or offer of any specific investment. Real estate investments carry risk, including loss of principal. This is not an offer to sell securities. Investment opportunities are limited to accredited investors and subject to separate documentation and disclosures.</p> </div> </div> </div> <!-- ═══ MODULE 08: LEGACY ANGEL ═══ --> <div class="jm__module" data-jm-module="legacy-angel"> <div class="jm__head"> <span class="eyebrow eyebrow-rust">Legacy Angel · Module 08</span> <h2 class="jm__title">What Will Your Money Mean?</h2> <p class="jm__hook">You've built something. What's it for?</p> </div> <div class="jm__body"> <div class="jm__step active" data-step="1"> <p class="m8__step-label">Step 1 of 2 — Pick what moves you</p> <div class="m8__causes"> <button class="m8__cause" data-m8-cause="hunger" style="--cause-photo:url(https://images.pexels.com/photos/6995247/pexels-photo-6995247.jpeg?auto=compress&#38;cs=tinysrgb&#38;w=400)"> <div class="m8__cause-photo"></div> <div class="m8__cause-overlay"></div> <div class="m8__cause-check"><svg viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path></svg></div> <p class="m8__cause-label">End childhood hunger</p> </button><button class="m8__cause" data-m8-cause="orphans" style="--cause-photo:url(https://images.pexels.com/photos/8613091/pexels-photo-8613091.jpeg?auto=compress&#38;cs=tinysrgb&#38;w=400)"> <div class="m8__cause-photo"></div> <div class="m8__cause-overlay"></div> <div class="m8__cause-check"><svg viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path></svg></div> <p class="m8__cause-label">Support kids without parents</p> </button><button class="m8__cause" data-m8-cause="homeless" style="--cause-photo:url(https://images.pexels.com/photos/6646917/pexels-photo-6646917.jpeg?auto=compress&#38;cs=tinysrgb&#38;w=400)"> <div class="m8__cause-photo"></div> <div class="m8__cause-overlay"></div> <div class="m8__cause-check"><svg viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path></svg></div> <p class="m8__cause-label">Fight homelessness</p> </button><button class="m8__cause" data-m8-cause="disease" style="--cause-photo:url(https://images.pexels.com/photos/3825578/pexels-photo-3825578.jpeg?auto=compress&#38;cs=tinysrgb&#38;w=400)"> <div class="m8__cause-photo"></div> <div class="m8__cause-overlay"></div> <div class="m8__cause-check"><svg viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path></svg></div> <p class="m8__cause-label">Fund disease research</p> </button><button class="m8__cause" data-m8-cause="education" style="--cause-photo:url(https://images.pexels.com/photos/5212345/pexels-photo-5212345.jpeg?auto=compress&#38;cs=tinysrgb&#38;w=400)"> <div class="m8__cause-photo"></div> <div class="m8__cause-overlay"></div> <div class="m8__cause-check"><svg viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path></svg></div> <p class="m8__cause-label">Education access</p> </button><button class="m8__cause" data-m8-cause="faith" style="--cause-photo:url(https://images.pexels.com/photos/208315/pexels-photo-208315.jpeg?auto=compress&#38;cs=tinysrgb&#38;w=400)"> <div class="m8__cause-photo"></div> <div class="m8__cause-overlay"></div> <div class="m8__cause-check"><svg viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path></svg></div> <p class="m8__cause-label">Faith-based ministry</p> </button><button class="m8__cause" data-m8-cause="environment" style="--cause-photo:url(https://images.pexels.com/photos/3573382/pexels-photo-3573382.jpeg?auto=compress&#38;cs=tinysrgb&#38;w=400)"> <div class="m8__cause-photo"></div> <div class="m8__cause-overlay"></div> <div class="m8__cause-check"><svg viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path></svg></div> <p class="m8__cause-label">Environmental restoration</p> </button><button class="m8__cause" data-m8-cause="custom" style="--cause-photo:url(https://images.pexels.com/photos/6646744/pexels-photo-6646744.jpeg?auto=compress&#38;cs=tinysrgb&#38;w=400)"> <div class="m8__cause-photo"></div> <div class="m8__cause-overlay"></div> <div class="m8__cause-check"><svg viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path></svg></div> <p class="m8__cause-label">Your own cause</p> </button> </div> <button class="jm__cta jm__cta--primary" data-m8-step1-go disabled>Continue → (select at least one)</button> </div> <div class="jm__step" data-step="2"> <p class="m8__step-label">Step 2 of 2 — Tell us roughly what you're working with</p> <div class="jm__input"> <label class="jm__label">Approximate net worth</label> <div class="jm__num-wrap"><span class="jm__num-prefix">$</span><input type="number" data-m8-nw class="jm__num jm__num--prefix" value="2400000" min="100000" max="100000000" step="100000"></div> </div> <div class="m8__giving"> <p class="m8__giving-label">How much of your wealth would you direct to legacy giving?</p> <div class="m8__giving-presets"> <button class="m8__preset" data-m8-preset="10">Modest legacy<span>10%</span></button> <button class="m8__preset m8__preset--active" data-m8-preset="25">Balanced<span>25%</span></button> <button class="m8__preset" data-m8-preset="50">Transformational<span>50%</span></button> </div> <label class="m4__mini-label">Or set your own: <span data-m8-pct-display>25</span>%</label> <input type="range" data-m8-pct class="m4__mini-slider" min="5" max="80" step="5" value="25"> </div> <button class="jm__cta jm__cta--primary" data-m8-go>Show me the impact →</button> </div> <div class="jm__step" data-step="3"> <div class="m8__impact-intro"> <p>With $<span data-m8-nw-display>2,400,000</span> · <span data-m8-pct-show>25</span>% directed to legacy:</p> <p class="m8__giving-amount">$<span data-m8-giving>600,000</span> to causes that move you</p> <p class="m8__heirs">$<span data-m8-heirs>1,800,000</span> still preserved for heirs</p> </div> <div class="m8__impacts" data-m8-impacts></div> <p class="m8__bridge">The difference between leaving money behind and leaving a legacy is structure. The right trust setup, the right asset positioning, and the right team can multiply your impact — during your life and after.</p> <div class="jm__cta-stack"> <a href="/contact-us/?utm_source=journey&utm_module=legacy-angel" class="jm__cta jm__cta--primary" data-jm-cta="legacy-conversation">Schedule a Legacy Planning Conversation</a> <a href="/contact-us/?utm_source=journey&utm_module=legacy-angel&type=trust-attorney" class="jm__cta" data-jm-cta="legacy-attorney">Get Introduced to a Trust Attorney</a> </div> <p class="jm__compliance">Stairway Mortgage does not provide legal, tax, or estate planning advice. Impact estimates are illustrative based on average charitable program costs (Feeding America, Hope For Foster Children, National Alliance to End Homelessness, NIH, Nature Conservancy averages). Consult licensed professionals for legal and tax matters.</p> </div> </div> </div> </div> </div> <script>
(function() {
  // ─── Rotating taglines per card ───
  document.querySelectorAll('.jcard').forEach(card => {
    const wrap = card.querySelector('.jcard__taglines');
    if (!wrap) return;
    const taglines = JSON.parse(wrap.dataset.taglines || '[]');
    if (taglines.length < 2) return;
    let idx = 0;
    setInterval(() => {
      if (card.dataset.paused === '1') return;
      idx = (idx + 1) % taglines.length;
      const cur = wrap.querySelector('.jcard__tagline.active');
      const next = document.createElement('p');
      next.className = 'jcard__tagline';
      next.textContent = taglines[idx];
      wrap.appendChild(next);
      requestAnimationFrame(() => {
        cur?.classList.add('out');
        next.classList.add('active');
        setTimeout(() => cur?.remove(), 500);
      });
    }, 3500 + Math.random() * 700);
  });

  // ─── Rotating live tickers per card ───
  document.querySelectorAll('.jcard').forEach(card => {
    const tickerWrap = card.querySelector('.jcard__ticker');
    if (!tickerWrap) return;
    const textEl = tickerWrap.querySelector('.jcard__ticker-text');
    const tickers = JSON.parse(tickerWrap.dataset.tickers || '[]');
    if (tickers.length < 2) return;
    let idx = 0;
    setInterval(() => {
      if (card.dataset.paused === '1') return;
      idx = (idx + 1) % tickers.length;
      textEl.classList.add('out');
      setTimeout(() => {
        textEl.textContent = tickers[idx];
        textEl.classList.remove('out');
        textEl.classList.add('in');
        setTimeout(() => textEl.classList.remove('in'), 400);
      }, 250);
    }, 5500 + Math.random() * 1500);
  });

  // ─── AI attention pulse ───
  const cards = Array.from(document.querySelectorAll('.jcard'));
  let cycleIdx = 0, cycleTimer = null, cycleActive = false;
  function spotlight(idx) { cards.forEach((c, i) => c.classList.toggle('spotlighted', i === idx)); }
  function startCycle() {
    if (cycleTimer || !cycleActive) return;
    spotlight(cycleIdx);
    cycleTimer = setInterval(() => { cycleIdx = (cycleIdx + 1) % cards.length; spotlight(cycleIdx); }, 2400);
  }
  function stopCycle() { if (cycleTimer) clearInterval(cycleTimer); cycleTimer = null; }
  cards.forEach((card, idx) => {
    card.addEventListener('mouseenter', () => {
      card.dataset.paused = '1'; stopCycle();
      cards.forEach(c => c.classList.remove('spotlighted')); card.classList.add('spotlighted');
    });
    card.addEventListener('mouseleave', () => { card.dataset.paused = '0'; cycleIdx = idx; if (cycleActive) startCycle(); });
  });
  const section = document.querySelector('.journey-section');
  if (section && 'IntersectionObserver' in window) {
    new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { cycleActive = true; startCycle(); }
        else { cycleActive = false; stopCycle(); cards.forEach(c => c.classList.remove('spotlighted')); }
      });
    }, { threshold: 0.15 }).observe(section);
  }
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) { cycleActive = false; stopCycle(); }

  const exploreEl = document.querySelector('[data-explore-count]');
  if (exploreEl) {
    exploreEl.textContent = 175 + Math.floor(Math.random() * 30);
    setInterval(() => {
      const cur = parseInt(exploreEl.textContent);
      const next = Math.max(140, Math.min(220, cur + Math.floor(Math.random() * 5) - 2));
      exploreEl.classList.add('flash'); exploreEl.textContent = next;
      setTimeout(() => exploreEl.classList.remove('flash'), 400);
    }, 6000 + Math.random() * 4000);
  }

  // ═══════════ MODAL ═══════════
  const modal = document.querySelector('[data-jm]');
  const panel = document.querySelector('[data-jm-panel]');
  const backdrop = document.querySelector('[data-jm-backdrop]');
  const closeBtn = document.querySelector('[data-jm-close]');
  if (!modal) return;

  // Modal width per module (some need wider for visual payoffs)
  const moduleWidths = {
    'homeowner': 'wide', 'senior-55': 'extra-wide', 'legacy-angel': 'wide', 'passive-investor': 'wide', 'active-investor': 'wide'
  };

  function openModule(persona, moduleKey) {
    modal.querySelectorAll('.jm__module').forEach(m => m.style.display = 'none');
    const moduleEl = modal.querySelector(`[data-jm-module="${moduleKey}"]`);
    if (moduleEl) {
      moduleEl.style.display = '';
      // Reset to first step
      moduleEl.querySelectorAll('.jm__step').forEach(s => s.classList.remove('active'));
      const firstStep = moduleEl.querySelector('.jm__step');
      if (firstStep) firstStep.classList.add('active');
    }

    // Apply modal width
    panel.classList.remove('jm__panel--wide', 'jm__panel--extra-wide');
    const w = moduleWidths[moduleKey];
    if (w) panel.classList.add(`jm__panel--${w}`);

    // Memory
    if (window.SWMemory) {
      window.SWMemory.set({ persona, last_module_opened: moduleKey });
      window.SWMemory.track('journey_card_opened', { persona, module: moduleKey });
    }
    modal.classList.add('jm--open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeModule() {
    modal.classList.remove('jm--open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }
  cards.forEach(card => card.addEventListener('click', () => openModule(card.dataset.persona, card.dataset.module)));
  closeBtn.addEventListener('click', closeModule);
  backdrop.addEventListener('click', closeModule);
  document.querySelectorAll('[data-jm-close-btn]').forEach(b => b.addEventListener('click', closeModule));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && modal.classList.contains('jm--open')) closeModule(); });

  function fmt(n) { return Math.round(n).toLocaleString('en-US'); }
  function showStep(moduleKey, stepKey) {
    const m = modal.querySelector(`[data-jm-module="${moduleKey}"]`);
    m.querySelectorAll('.jm__step').forEach(s => s.classList.remove('active'));
    m.querySelector(`[data-step="${stepKey}"]`).classList.add('active');
  }
  function isFL() {
    const mem = window.SWMemory?.get() || {};
    return (mem.region === 'FL' || mem.region === 'Florida' || /florida/i.test(mem.region || ''));
  }

  // ═══════════ MODULE 01: Smart Steward ═══════════
  document.querySelectorAll('[data-m1-answer]').forEach(btn => {
    btn.addEventListener('click', () => {
      const ans = btn.dataset.m1Answer;
      showStep('smart-steward', `2-${ans}`);
      if (window.SWMemory) {
        window.SWMemory.set({ smart_steward_qualifies: ans === 'yes' });
        window.SWMemory.track('smart_steward_answer', { answer: ans });
      }
    });
  });

  // ═══════════ MODULE 02: First-Time Buyer ═══════════
  const m2RentInput = document.querySelector('[data-m2-rent]');
  const m2CityNote = document.querySelector('[data-m2-city-note]');

  function updateM2CityNote() {
    const mem = window.SWMemory?.get() || {};
    if (mem.city && isFL()) {
      m2CityNote.innerHTML = `📍 Math tuned for <strong>${mem.city}, FL</strong> (higher insurance + tax than national avg)`;
    } else if (mem.city) {
      m2CityNote.innerHTML = `📍 Math tuned for <strong>${mem.city}, ${mem.region || ''}</strong> (national defaults)`;
    } else {
      m2CityNote.innerHTML = `📍 Using national averages (we'll refine on the call)`;
    }
  }
  if (m2CityNote) { updateM2CityNote(); window.addEventListener('sw:memory', updateM2CityNote); }

  function calcPayment(p, r, y) { const m = r/100/12, n = y*12; return r === 0 ? p/n : p * (m * Math.pow(1+m,n)) / (Math.pow(1+m,n)-1); }

  document.querySelector('[data-m2-go]')?.addEventListener('click', () => {
    const rent = parseInt(m2RentInput.value) || 2400;
    const fl = isFL();
    const rate = fl ? 6.50 : 6.00;
    const taxPct = fl ? 1.0 : 1.0;
    const insPct = fl ? 1.5 : 0.5;
    const pmiPct = 0.6;
    const dpPct = 0.05;
    // Solve for max price where total payment = rent
    // total = pi + (price*tax/12) + (price*ins/12) + (loan*pmi/12)
    // loan = price * 0.95
    // Iterative search
    let lo = 50000, hi = 3000000, best = lo;
    for (let i = 0; i < 40; i++) {
      const mid = (lo + hi) / 2;
      const loan = mid * (1 - dpPct);
      const pi = calcPayment(loan, rate, 30);
      const tax = mid * taxPct / 100 / 12;
      const ins = mid * insPct / 100 / 12;
      const pmi = loan * pmiPct / 100 / 12;
      const total = pi + tax + ins + pmi;
      if (total < rent) { best = mid; lo = mid; } else { hi = mid; }
    }
    const price = Math.round(best / 5000) * 5000;
    const loan = price * 0.95;
    const pi = calcPayment(loan, rate, 30);
    const tax = price * taxPct / 100 / 12;
    const ins = price * insPct / 100 / 12;
    const pmi = loan * pmiPct / 100 / 12;

    document.querySelector('[data-m2-rent-display]').textContent = fmt(rent);
    document.querySelector('[data-m2-price]').textContent = fmt(price);
    document.querySelector('[data-m2-rate]').textContent = rate.toFixed(2) + '%';
    document.querySelector('[data-m2-down]').textContent = fmt(price * 0.05);
    document.querySelector('[data-m2-tax]').textContent = fmt(tax);
    document.querySelector('[data-m2-ins]').textContent = fmt(ins);
    document.querySelector('[data-m2-pmi]').textContent = fmt(pmi);

    const softFrame = document.querySelector('[data-m2-soft-frame]');
    if (price < 200000) {
      softFrame.style.display = '';
      document.querySelector('[data-m2-soft-min]').textContent = fmt(price);
    } else { softFrame.style.display = 'none'; }

    showStep('first-time-buyer', '2');
    if (window.SWMemory) {
      window.SWMemory.set({ monthly_budget: rent, home_value_estimated: price });
      window.SWMemory.track('first_time_buyer_calculated', { rent, price, rate, fl });
    }
  });

  // ═══════════ MODULE 03: Homeowner ═══════════
  document.querySelector('[data-m3-go]')?.addEventListener('click', () => {
    const val = parseInt(document.querySelector('[data-m3-value]').value);
    const bal = parseInt(document.querySelector('[data-m3-balance]').value);
    const total = Math.max(0, val - bal);
    const usable = Math.max(0, (val * 0.80) - bal);
    document.querySelector('[data-m3-total]').textContent = fmt(total);
    document.querySelector('[data-m3-usable]').textContent = fmt(usable);
    showStep('homeowner', '2');
    panel.classList.add('jm__panel--extra-wide'); // Two-stage expansion
    if (window.SWMemory) {
      window.SWMemory.set({ home_value: val, mortgage_balance: bal, total_equity: total, usable_equity: usable });
      window.SWMemory.track('homeowner_equity_calculated', { val, bal, total, usable });
    }
  });
  // Outcome card click → write to memory and enrich CTA URLs
  document.querySelectorAll('[data-m3-outcome]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const outcome = btn.dataset.m3Outcome;
      document.querySelectorAll('[data-m3-outcome]').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      if (window.SWMemory) {
        window.SWMemory.set({ homeowner_outcome_interest: outcome });
        window.SWMemory.track('homeowner_outcome_clicked', { outcome });
      }
    });
  });

  // ═══════════ MODULE 04: Senior 55+ ═══════════
  const m4Age = document.querySelector('[data-m4-age]');
  const m4AgeDisp = document.querySelector('[data-m4-age-display]');
  const m4CityNote = document.querySelector('[data-m4-city-note]');
  m4Age?.addEventListener('input', () => m4AgeDisp.textContent = m4Age.value);

  function updateM4CityNote() {
    const mem = window.SWMemory?.get() || {};
    if (mem.city) {
      m4CityNote.innerHTML = `📍 We'll estimate from <strong>${mem.city}</strong> medians — adjust if needed on Door 1`;
    } else {
      m4CityNote.innerHTML = `📍 Using national medians as starting estimate`;
    }
  }
  if (m4CityNote) { updateM4CityNote(); window.addEventListener('sw:memory', updateM4CityNote); }

  // Florida city median home values (rough)
  const cityMedians = {
    'Miami': 585000, 'Fort Lauderdale': 525000, 'Hialeah': 410000, 'Hollywood': 495000,
    'Tampa': 410000, 'Orlando': 385000, 'Jacksonville': 295000, 'St. Petersburg': 370000,
    'Naples': 695000, 'Sarasota': 465000, 'Cape Coral': 365000, 'Coral Gables': 1100000,
  };

  function m4Recalc() {
    const age = parseInt(m4Age.value);
    const mem = window.SWMemory?.get() || {};
    const adjustedVal = document.querySelector('[data-m4-home-val]')?.value;
    const adjustedMort = document.querySelector('[data-m4-mortgage]')?.value;
    const homeVal = adjustedVal ? parseInt(adjustedVal) : (cityMedians[mem.city] || 400000);
    const mortBal = adjustedMort ? parseInt(adjustedMort) : Math.round(homeVal * 0.20);
    const equity = Math.max(0, homeVal - mortBal);

    // Age-aware language
    const ageCtx = document.querySelector('[data-m4-age-context]');
    if (age < 62) {
      ageCtx.innerHTML = `At <strong>${age}</strong>, you may qualify for proprietary reverse mortgages (private/jumbo). If you can wait until 62, HECM (federal program) typically offers better terms.`;
    } else {
      ageCtx.innerHTML = `At <strong>${age}</strong>, you qualify for HECM (federally-insured reverse mortgage) plus all proprietary options.`;
    }

    // Stay path - eliminate payment (estimate current payment)
    const currentRate = 6.50; // legacy assumption
    const stayPayment = Math.round(calcPayment(mortBal, currentRate, 25)); // remaining ~25yr
    document.querySelector('[data-m4-stay-payment]').textContent = fmt(stayPayment);
    document.querySelector('[data-m4-equity]').textContent = fmt(equity);

    // Downsize path
    const newHomePct = parseInt(document.querySelector('[data-m4-newhome]').value) / 100;
    const costPct = parseFloat(document.querySelector('[data-m4-cost]').value) / 100;
    const sellingProceeds = homeVal * (1 - costPct);
    const newHome = homeVal * newHomePct;
    const pocketed = Math.max(0, sellingProceeds - mortBal - newHome);
    document.querySelector('[data-m4-pocket]').textContent = fmt(pocketed);

    if (window.SWMemory) {
      window.SWMemory.set({ senior_age: age, senior_home_val: homeVal, senior_mort_bal: mortBal, senior_equity: equity, senior_pocket: pocketed });
      window.SWMemory.track('senior_calculated', { age, homeVal, equity, pocketed });
    }
  }

  document.querySelector('[data-m4-go]')?.addEventListener('click', () => {
    showStep('senior-55', '2');
    m4Recalc();
  });
  document.querySelector('[data-m4-newhome]')?.addEventListener('input', (e) => {
    document.querySelector('[data-m4-newhome-display]').textContent = e.target.value;
    m4Recalc();
  });
  document.querySelector('[data-m4-cost]')?.addEventListener('input', (e) => {
    document.querySelector('[data-m4-cost-display]').textContent = e.target.value;
    m4Recalc();
  });
  document.querySelector('[data-m4-adjust]')?.addEventListener('click', () => {
    const fields = document.querySelector('[data-m4-adjust-fields]');
    const mem = window.SWMemory?.get() || {};
    const homeVal = cityMedians[mem.city] || 400000;
    document.querySelector('[data-m4-home-val]').value = homeVal;
    document.querySelector('[data-m4-mortgage]').value = Math.round(homeVal * 0.20);
    fields.style.display = fields.style.display === 'none' ? '' : 'none';
  });
  document.querySelector('[data-m4-recalc]')?.addEventListener('click', m4Recalc);

  // ═══════════ MODULE 05: First-Time Investor ═══════════
  const m5Cash = document.querySelector('[data-m5-cash]');
  const m5Years = document.querySelector('[data-m5-years]');
  m5Cash?.addEventListener('input', () => document.querySelector('[data-m5-cash-display]').textContent = fmt(parseInt(m5Cash.value)));
  m5Years?.addEventListener('input', () => document.querySelector('[data-m5-years-display]').textContent = m5Years.value);

  document.querySelector('[data-m5-go]')?.addEventListener('click', () => {
    const cash = parseInt(m5Cash.value);
    const years = parseInt(m5Years.value);
    const apprRate = isFL() ? 4 : 3;
    const asset = cash * 4; // 25% down DSCR
    const loan = asset * 0.75;
    const futureVal = asset * Math.pow(1 + apprRate/100, years);
    // Remaining loan balance after N years at 7.5% / 30yr
    const r = 0.075/12, n = 30*12, paid = years * 12;
    const payment = calcPayment(loan, 7.5, 30);
    let bal = loan;
    for (let i = 0; i < paid; i++) { const interest = bal * r; bal -= (payment - interest); }
    bal = Math.max(0, bal);
    const equity = futureVal - bal;
    const paydown = loan - bal;
    const appreciation = futureVal - asset;

    showStep('first-investor', '2');

    // Animate the three acts
    document.querySelectorAll('[data-m5-act]').forEach(a => a.style.opacity = '0');
    setTimeout(() => {
      document.querySelector('[data-m5-act="1"]').style.opacity = '1';
      document.querySelector('[data-m5-cash-show]').textContent = fmt(cash);
      document.querySelector('[data-m5-asset]').textContent = fmt(asset);
    }, 100);
    setTimeout(() => {
      document.querySelector('[data-m5-act="2"]').style.opacity = '1';
      document.querySelector('[data-m5-equity]').textContent = fmt(equity);
      document.querySelector('[data-m5-years-show]').textContent = years;
      document.querySelector('[data-m5-years-show2]').textContent = years;
    }, 1100);
    setTimeout(() => {
      document.querySelector('[data-m5-act="3"]').style.opacity = '1';
      document.querySelector('[data-m5-paydown]').textContent = fmt(paydown);
      document.querySelector('[data-m5-appreciation]').textContent = fmt(appreciation);
      document.querySelector('[data-m5-equity-2]').textContent = fmt(equity);
      document.querySelector('[data-m5-appr-rate]').textContent = apprRate;
    }, 2400);

    if (window.SWMemory) {
      window.SWMemory.set({ investor_cash: cash, investor_years: years, investor_projected_equity: Math.round(equity) });
      window.SWMemory.track('first_investor_calculated', { cash, years, equity: Math.round(equity) });
    }
  });
  document.querySelector('[data-m5-cashflow]')?.addEventListener('input', (e) => {
    document.querySelector('[data-m5-cf-display]').textContent = e.target.value;
  });

  // ═══════════ MODULE 06: Active Investor ═══════════
  // Live update assumption sliders
  ['hold', 'sell', 'loan', 'closing'].forEach(k => {
    const el = document.querySelector(`[data-m6-${k}]`);
    el?.addEventListener('input', (e) => {
      const dispEl = document.querySelector(`[data-m6-${k}-display]`);
      if (k === 'closing') dispEl.textContent = fmt(e.target.value);
      else dispEl.textContent = e.target.value;
    });
  });

  function m6Calc() {
    const purchase = parseInt(document.querySelector('[data-m6-purchase]').value);
    const rehab = parseInt(document.querySelector('[data-m6-rehab]').value);
    const arv = parseInt(document.querySelector('[data-m6-arv]').value);
    const months = parseInt(document.querySelector('[data-m6-months]')?.value || 6);
    const holdPct = parseFloat(document.querySelector('[data-m6-hold]').value);
    const sellPct = parseFloat(document.querySelector('[data-m6-sell]').value);
    const loanRate = parseFloat(document.querySelector('[data-m6-loan]').value);
    const closing = parseInt(document.querySelector('[data-m6-closing]').value);

    const holding = arv * (holdPct/100) * (months/12);
    const selling = arv * (sellPct/100);
    const loanInt = (purchase + rehab) * (loanRate/100) * (months/12);
    const profit = arv - purchase - rehab - holding - selling - closing - loanInt;
    const cashInvested = (purchase * 0.10) + closing; // 90% LTC fix-and-flip
    const roi = (profit / cashInvested) * 100;

    document.querySelector('[data-m6-roi]').textContent = Math.round(roi);
    document.querySelector('[data-m6-profit]').textContent = fmt(profit);
    document.querySelector('[data-m6-profit-2]').textContent = fmt(profit);
    document.querySelector('[data-m6-arv-disp]').textContent = fmt(arv);
    document.querySelector('[data-m6-purch-disp]').textContent = fmt(purchase);
    document.querySelector('[data-m6-rehab-disp]').textContent = fmt(rehab);
    document.querySelector('[data-m6-holding]').textContent = fmt(holding);
    document.querySelector('[data-m6-selling]').textContent = fmt(selling);
    document.querySelector('[data-m6-clos-disp]').textContent = fmt(closing);
    document.querySelector('[data-m6-interest]').textContent = fmt(loanInt);
    document.querySelector('[data-m6-mo-disp]').textContent = months;
    document.querySelector('[data-m6-months-display]').textContent = months;

    if (window.SWMemory) {
      window.SWMemory.set({ flip_purchase: purchase, flip_rehab: rehab, flip_arv: arv, flip_profit: Math.round(profit), flip_roi: Math.round(roi) });
      window.SWMemory.track('flip_deal_calculated', { purchase, rehab, arv, months, profit: Math.round(profit), roi: Math.round(roi) });
    }
  }
  document.querySelector('[data-m6-go]')?.addEventListener('click', () => { showStep('active-investor', '2'); m6Calc(); });
  document.querySelector('[data-m6-months]')?.addEventListener('input', m6Calc);
  ['hold', 'sell', 'loan', 'closing'].forEach(k => {
    const el = document.querySelector(`[data-m6-${k}]`);
    el?.addEventListener('input', () => {
      // Recalc only if on step 2
      const step2 = modal.querySelector('[data-jm-module="active-investor"] [data-step="2"]');
      if (step2.classList.contains('active')) m6Calc();
    });
  });

  // ═══════════ MODULE 07: Passive Investor ═══════════
  let m7Accredited = null;
  document.querySelectorAll('[data-m7-acc]').forEach(btn => {
    btn.addEventListener('click', () => {
      m7Accredited = btn.dataset.m7Acc;
      document.querySelector('.m7__accredited-gate').style.display = 'none';
      document.querySelector('[data-m7-inputs]').style.display = '';
      if (window.SWMemory) {
        window.SWMemory.set({ passive_accredited: m7Accredited });
        window.SWMemory.track('passive_accredited_answer', { answer: m7Accredited });
      }
    });
  });

  const m7Yield = document.querySelector('[data-m7-yield]');
  const m7Years = document.querySelector('[data-m7-years]');
  m7Yield?.addEventListener('input', () => document.querySelector('[data-m7-yield-display]').textContent = m7Yield.value);
  m7Years?.addEventListener('input', () => document.querySelector('[data-m7-years-display]').textContent = m7Years.value);

  document.querySelector('[data-m7-go]')?.addEventListener('click', () => {
    const cash = parseInt(document.querySelector('[data-m7-cash]').value);
    const targetYield = parseFloat(m7Yield.value);
    const years = parseInt(m7Years.value);
    const baseline = 4.5;

    document.querySelector('[data-m7-cash-display]').textContent = fmt(cash);
    document.querySelector('[data-m7-yield-show]').textContent = targetYield;
    document.querySelector('[data-m7-yr1]').textContent = years;
    document.querySelector('[data-m7-yr2]').textContent = years;

    document.querySelector('[data-m7-low-5]').textContent = fmt(cash * Math.pow(1 + baseline/100, 5));
    document.querySelector('[data-m7-low-mid]').textContent = fmt(cash * Math.pow(1 + baseline/100, years));
    document.querySelector('[data-m7-low-20]').textContent = fmt(cash * Math.pow(1 + baseline/100, 20));
    document.querySelector('[data-m7-high-5]').textContent = fmt(cash * Math.pow(1 + targetYield/100, 5));
    document.querySelector('[data-m7-high-mid]').textContent = fmt(cash * Math.pow(1 + targetYield/100, years));
    document.querySelector('[data-m7-high-20]').textContent = fmt(cash * Math.pow(1 + targetYield/100, 20));

    // Gate CTAs based on accredited
    if (m7Accredited === 'no') {
      document.querySelector('[data-m7-accredited-cta]').style.display = 'none';
      document.querySelector('[data-m7-non-accredited-cta]').style.display = '';
    } else {
      document.querySelector('[data-m7-accredited-cta]').style.display = '';
      document.querySelector('[data-m7-non-accredited-cta]').style.display = 'none';
    }

    showStep('passive-investor', '2');
    if (window.SWMemory) {
      window.SWMemory.set({ passive_cash: cash, passive_target_yield: targetYield, passive_years: years });
      window.SWMemory.track('passive_calculated', { cash, targetYield, years });
    }
  });
  // Redirect from non-accredited path
  document.querySelectorAll('[data-m7-redirect]').forEach(el => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      const target = el.dataset.m7Redirect;
      closeModule();
      setTimeout(() => {
        const targetCard = document.querySelector(`.jcard[data-persona="${target}"]`);
        if (targetCard) targetCard.click();
      }, 400);
    });
  });

  // ═══════════ MODULE 08: Legacy Angel ═══════════
  const selectedCauses = new Set();
  document.querySelectorAll('[data-m8-cause]').forEach(btn => {
    btn.addEventListener('click', () => {
      const cause = btn.dataset.m8Cause;
      if (selectedCauses.has(cause)) { selectedCauses.delete(cause); btn.classList.remove('selected'); }
      else { selectedCauses.add(cause); btn.classList.add('selected'); }
      const go = document.querySelector('[data-m8-step1-go]');
      go.disabled = selectedCauses.size === 0;
      go.textContent = selectedCauses.size === 0 ? 'Continue → (select at least one)' : `Continue with ${selectedCauses.size} selected →`;
    });
  });
  document.querySelector('[data-m8-step1-go]')?.addEventListener('click', () => {
    if (selectedCauses.size === 0) return;
    showStep('legacy-angel', '2');
    if (window.SWMemory) {
      window.SWMemory.set({ legacy_causes: Array.from(selectedCauses) });
      window.SWMemory.track('legacy_causes_selected', { causes: Array.from(selectedCauses) });
    }
  });

  // Giving presets
  const m8Pct = document.querySelector('[data-m8-pct]');
  document.querySelectorAll('[data-m8-preset]').forEach(btn => {
    btn.addEventListener('click', () => {
      const pct = parseInt(btn.dataset.m8Preset);
      m8Pct.value = pct;
      document.querySelector('[data-m8-pct-display]').textContent = pct;
      document.querySelectorAll('[data-m8-preset]').forEach(b => b.classList.remove('m8__preset--active'));
      btn.classList.add('m8__preset--active');
    });
  });
  m8Pct?.addEventListener('input', () => {
    document.querySelector('[data-m8-pct-display]').textContent = m8Pct.value;
    document.querySelectorAll('[data-m8-preset]').forEach(b => b.classList.remove('m8__preset--active'));
  });

  const causeData = {
    'hunger': { label: 'meals provided', unit: 1 },
    'orphans': { label: 'foster scholarships funded', unit: 25000 },
    'homeless': { label: 'family-years of housing', unit: 50000 },
    'disease': { label: 'researcher-years funded', unit: 120000 },
    'education': { label: 'college-years funded', unit: 20000 },
    'faith': { label: 'church-years sustained', unit: 50000 },
    'environment': { label: 'acres protected', unit: 1500 },
    'custom': { label: '— Jim translates on call', unit: 0 },
  };

  document.querySelector('[data-m8-go]')?.addEventListener('click', () => {
    const nw = parseInt(document.querySelector('[data-m8-nw]').value);
    const pct = parseInt(m8Pct.value);
    const giving = nw * (pct / 100);
    const heirs = nw - giving;
    const perCause = giving / selectedCauses.size;

    document.querySelector('[data-m8-nw-display]').textContent = fmt(nw);
    document.querySelector('[data-m8-pct-show]').textContent = pct;
    document.querySelector('[data-m8-giving]').textContent = fmt(giving);
    document.querySelector('[data-m8-heirs]').textContent = fmt(heirs);

    const impactsHtml = Array.from(selectedCauses).map(c => {
      const d = causeData[c];
      const units = d.unit > 0 ? fmt(perCause / d.unit) : '—';
      return `<div class="m8__impact-row"><strong>${units !== '—' ? units : 'Custom plan'}</strong><span>${d.label}</span></div>`;
    }).join('');
    document.querySelector('[data-m8-impacts]').innerHTML = impactsHtml;

    showStep('legacy-angel', '3');
    if (window.SWMemory) {
      window.SWMemory.set({ legacy_net_worth: nw, legacy_giving_pct: pct, legacy_giving_amount: Math.round(giving) });
      window.SWMemory.track('legacy_calculated', { nw, pct, giving: Math.round(giving), causes: Array.from(selectedCauses) });
    }
  });
})();
