---
import Layout from '../layouts/Layout.astro';

const stats = [
  { num: '$350M+', label: 'Closed Loans' },
  { num: '300+', label: 'Lender Network' },
  { num: '7×', label: 'Scotsman Guide Top Producer' },
  { num: '24hr', label: 'Same-Day Approval' },
];

const journeys = [
  { num: '01', title: 'Smart Stewards', desc: "Students or parents building credit while juggling tuition and wealth goals.", href: '/smart-stewards-journey/' },
  { num: '02', title: 'First-Time Home Buyer', desc: 'Buying your first home with confidence, clarity, and a plan.', href: '/first-time-buyers-journey/' },
  { num: '03', title: 'Homeowner', desc: "Already own a home? Make it work for growth, equity, or freedom.", href: '/homeowners-journey/' },
  { num: '04', title: 'Senior Homeowner 55+', desc: 'Nearing retirement, downsizing, or managing wealth from your home equity.', href: '/senior-homeowners-55-journey/' },
  { num: '05', title: 'First-Time Investor', desc: 'Turn income into assets — get your first rental property right.', href: '/first-time-investors-journey/' },
  { num: '06', title: 'Active Investor', desc: 'Maximize leverage, streamline cash flow, and scale smart across properties.', href: '/active-investors-journey/' },
  { num: '07', title: 'Passive Investor', desc: 'Real estate that works for you — no tenants, timelines, or taxes to manage.', href: '/passive-investors-journey/' },
  { num: '08', title: 'Legacy Angel', desc: 'Focused on family, faith, giving — your real estate becomes lasting impact.', href: '/legacy-angels-journey/' },
];

const testimonials = [
  {
    quote: "If you want to take advantage of the low rates, Jim is your man. His team got my refinance done in under 30 days, with rates beating every other company. I'd recommend him to anyone.",
    name: 'Chris Richardson',
    role: 'Former LT, U.S. Army',
    location: 'Nevada',
  },
  {
    quote: 'I was so pleased with how easy and quick the whole process was. Jim is very knowledgeable and helped me determine the best option for my family. He shaved 9 years off my mortgage.',
    name: 'Alexis Kulick',
    role: 'Executive Director, UBS',
    location: 'California',
  },
  {
    quote: "Did a refi as I've worked with Jim before. The process was very smooth. The portal is intuitive, and team members proactively reach out to clear up any issues.",
    name: 'Nilay Patel',
    role: 'Vice President, Permira',
    location: 'New York',
  },
  {
    quote: 'Jim is absolutely phenomenal. Extremely knowledgeable and patient — gives all parties peace of mind throughout the entire transaction. One of the best in the industry.',
    name: 'Karena Clarke',
    role: 'Realtor',
    location: 'Florida',
  },
];

const services = [
  { num: '01', title: 'Buy a Home', desc: 'First-time or move-up purchase', href: '/buy-a-house-journey/' },
  { num: '02', title: 'Refinance / HELOC', desc: 'Lower payment or unlock equity', href: '/refinance-or-heloc-journey/' },
  { num: '03', title: 'Reverse Mortgage', desc: 'Income for life, age 55+', href: '/reverse-mortgage-journey/' },
  { num: '04', title: 'Build a Home', desc: 'Construction-to-permanent financing', href: '/build-a-house-journey/' },
  { num: '05', title: 'Renovate', desc: 'Fund improvements, fix-and-flip', href: '/renovate-a-house-journey/' },
  { num: '06', title: 'Investor Loans', desc: 'DSCR, non-QM, scaling portfolios', href: '/active-investors-journey/' },
];
---

<Layout title="Stairway Mortgage — Leverage wisely. Grow wealthy. | Division of NEXA Mortgage LLC">

  <!-- ============================================
       HERO — Editorial Display Type
       Massive Fraunces, asymmetric grid, restrained
       ============================================ -->
  <section class="relative pt-16 lg:pt-24 pb-16 lg:pb-28 overflow-hidden">
    <!-- Subtle decorative grid -->
    <div class="absolute inset-0 pointer-events-none opacity-[0.025]" aria-hidden="true">
      <svg width="100%" height="100%" preserveAspectRatio="none">
        <defs>
          <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
            <path d="M 60 0 L 0 0 0 60" fill="none" stroke="currentColor" stroke-width="1"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)"/>
      </svg>
    </div>

    <div class="container-page relative">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-16 items-start">

        <!-- Left: copy -->
        <div class="lg:col-span-7 reveal">
          <div class="flex items-center gap-3 mb-8">
            <span class="eyebrow eyebrow-blue">Division of NEXA Mortgage · 300+ Lenders</span>
          </div>

          <h1 class="display-xl mb-6">
            <span class="block">Leverage</span>
            <span class="block italic font-light text-[var(--color-mute)]">wisely.</span>
            <span class="block">Grow</span>
            <span class="block italic font-light"><span class="bg-gradient-to-r from-[var(--color-blue)] to-[var(--color-blue-deep)] bg-clip-text text-transparent">wealthy.</span></span>
          </h1>

          <p class="lede max-w-xl mb-10">
            From first purchase to meaningful legacy — we guide you through buying, renovating, leveraging equity, and planning retirement with the precision of a wealth strategist and the heart of a neighbor.
          </p>

          <div class="flex flex-wrap gap-3 mb-10">
            <a href="/same-day-approval/" class="btn btn-primary btn-arrow text-base px-6 py-3.5">Get Pre-Approved</a>
            <a href="/contact-us/" class="btn btn-ghost text-base px-6 py-3.5">Schedule a Call</a>
          </div>

          <!-- Quote chips - 3 paths -->
          <div class="flex flex-wrap gap-x-6 gap-y-3 text-[14px]">
            <a href="/purchase-inquiry/" class="link-editorial">Purchase Quote</a>
            <span class="text-[var(--color-bone)]">·</span>
            <a href="/refinance-or-heloc-inquiry/" class="link-editorial">Refi or HELOC Quote</a>
            <span class="text-[var(--color-bone)]">·</span>
            <a href="/reverse-mortgage-inquiry/" class="link-editorial">Reverse Mortgage Quote</a>
          </div>
        </div>

        <!-- Right: editorial stat card -->
        <div class="lg:col-span-5 reveal" style="transition-delay:120ms;">
          <div class="relative">
            <!-- Backdrop tint -->
            <div class="absolute -inset-6 bg-[var(--color-paper-tint)] rounded-2xl -rotate-1 -z-10"></div>

            <div class="bg-[var(--color-ink)] text-[var(--color-paper)] rounded-2xl p-8 lg:p-10 relative">
              <div class="flex items-center gap-2 mb-6 text-[var(--color-paper)]/60 text-[11px] font-medium tracking-[0.14em] uppercase">
                <span class="mono">↦ 02 / 2026</span>
                <span class="opacity-50">·</span>
                <span>Track Record</span>
              </div>

              <p class="editorial-number-sm text-[var(--color-paper)] mb-1 leading-none">$350M+</p>
              <p class="text-[14px] opacity-72 mb-8">in closed loans · 7 years Scotsman Guide Top Producer</p>

              <div class="grid grid-cols-3 gap-4 pt-6 border-t border-[var(--color-paper)]/15">
                <div>
                  <p class="font-display text-3xl font-light leading-none mb-1">300+</p>
                  <p class="text-[11px] uppercase tracking-wider opacity-60">Lenders</p>
                </div>
                <div>
                  <p class="font-display text-3xl font-light leading-none mb-1">48</p>
                  <p class="text-[11px] uppercase tracking-wider opacity-60">States (NEXA)</p>
                </div>
                <div>
                  <p class="font-display text-3xl font-light leading-none mb-1">24hr</p>
                  <p class="text-[11px] uppercase tracking-wider opacity-60">Approval</p>
                </div>
              </div>

              <div class="mt-8 pt-6 border-t border-[var(--color-paper)]/15">
                <p class="text-[14px] italic opacity-80 leading-relaxed">
                  "Guiding your every step,"
                </p>
                <p class="mt-2 font-display text-lg">Jim Blackburn <span class="opacity-60 text-[14px] font-normal">& The Stairway Team</span></p>
                <p class="text-[12px] opacity-50 mono mt-1">NMLS #1072866</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       SERVICES STRIP — Editorial cards
       ============================================ -->
  <section class="section-tight border-y border-[var(--color-bone)]">
    <div class="container-page">
      <div class="flex flex-col lg:flex-row items-baseline justify-between gap-6 mb-10 reveal">
        <div>
          <span class="eyebrow mb-4">How we serve</span>
          <h2 class="display-md mt-3 max-w-2xl">
            Six paths to financing — <em class="italic font-light text-[var(--color-mute)]">one team.</em>
          </h2>
        </div>
        <a href="/loan-programs/" class="btn btn-link text-[14px]">See all loan programs →</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-[var(--color-bone)] border border-[var(--color-bone)] rounded-2xl overflow-hidden">
        {services.map((s) => (
          <a href={s.href} class="group bg-[var(--color-paper)] p-7 lg:p-8 hover:bg-[var(--color-paper-tint)] transition-colors duration-200 reveal">
            <div class="flex items-start justify-between mb-6">
              <span class="card-step-num">{s.num}</span>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="opacity-30 group-hover:opacity-100 group-hover:translate-x-1 group-hover:-translate-y-1 transition-all">
                <path d="M3 11L11 3M11 3H4M11 3V10" stroke="currentColor" stroke-width="1.4"/>
              </svg>
            </div>
            <h3 class="font-display text-2xl font-medium mb-2 leading-tight">{s.title}</h3>
            <p class="text-[14.5px] text-[var(--color-mute)] leading-relaxed">{s.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       STAIRWAY CLIENT SYSTEM™ — 8 Journey Cards
       The defining editorial moment
       ============================================ -->
  <section class="section">
    <div class="container-page">
      <div class="grid lg:grid-cols-12 gap-10 mb-16 items-end">
        <div class="lg:col-span-7 reveal">
          <span class="eyebrow eyebrow-rust mb-5">The Stairway Client System™</span>
          <h2 class="display-lg mt-5 mb-6">
            Eight chapters of a <em class="italic font-light">real estate life.</em>
            <br/>One path that knows yours.
          </h2>
          <p class="lede max-w-2xl">
            Whether you're 18 with a credit score to build or 75 with a portfolio to pass on — we meet you where you are and walk you to the next step.
          </p>
        </div>
        <div class="lg:col-span-5 lg:text-right reveal" style="transition-delay:100ms;">
          <p class="editorial-number text-[var(--color-rust)]">08</p>
          <p class="text-[14px] uppercase tracking-[0.14em] text-[var(--color-mute)] -mt-2">distinct journeys</p>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-5">
        {journeys.map((j, i) => (
          <a href={j.href} class="card group reveal flex flex-col" style={`transition-delay:${i * 60}ms;`}>
            <div class="flex items-start justify-between mb-8">
              <span class="card-step-num">{j.num}</span>
              <span class="w-7 h-7 rounded-full bg-[var(--color-paper-tint)] inline-flex items-center justify-center text-[var(--color-mute)] group-hover:bg-[var(--color-ink)] group-hover:text-[var(--color-paper)] transition-colors">
                <svg width="11" height="11" viewBox="0 0 12 12" fill="none">
                  <path d="M3 9L9 3M9 3H4M9 3V8" stroke="currentColor" stroke-width="1.4"/>
                </svg>
              </span>
            </div>
            <h3 class="font-display text-xl font-medium leading-tight mb-2">{j.title}</h3>
            <p class="text-[14px] text-[var(--color-mute)] leading-relaxed flex-1">{j.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       NEXA BACKING — Editorial Stat Moment
       ============================================ -->
  <section class="section bg-[var(--color-paper-tint)]">
    <div class="container-page">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-5 reveal">
          <span class="eyebrow eyebrow-blue mb-5">Backed by NEXA</span>
          <p class="editorial-number text-[var(--color-blue)] mb-2">300+</p>
          <p class="display-sm text-[var(--color-mute)] mt-2">lenders competing for your loan.</p>
        </div>
        <div class="lg:col-span-7 reveal" style="transition-delay:80ms;">
          <h2 class="display-md mb-5">
            We work for <em class="italic font-light">you</em>, not the bank.
          </h2>
          <p class="lede mb-8 max-w-xl">
            Stairway Mortgage is a division of NEXA — the #1 broker network in the U.S. with 3,000+ loan officers and unmatched bargaining power. Lenders bid for our business, you get wholesale pricing.
          </p>
          <div class="flex flex-wrap gap-4 items-center">
            <a href="/nexa-mortgage-partnership/" class="btn btn-primary btn-arrow">See why we chose NEXA</a>
            <a href="/current-rates/" class="btn btn-link text-[14px]">Today's rates →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       SAME-DAY APPROVAL
       ============================================ -->
  <section class="section">
    <div class="container-page">
      <div class="grid lg:grid-cols-12 gap-12 items-center">

        <div class="lg:col-span-6 order-2 lg:order-1 reveal">
          <span class="eyebrow eyebrow-rust mb-5">24-hour approval</span>
          <h2 class="display-lg mt-5 mb-6">
            Found a house. <br/>
            <em class="italic font-light">Need a letter — fast?</em>
          </h2>
          <p class="lede mb-8">
            Win competitive markets with cash-backed offers. Pre-approvals as fast as 24 hours, available 7 days a week.
          </p>

          <ul class="space-y-3.5 mb-9">
            {[
              'Turn your offer into a competitive cash-backed bid',
              'Stand out in multiple-offer situations',
              'Increase your odds of winning your dream home',
              'Get the edge in today\'s market',
            ].map(item => (
              <li class="flex items-start gap-3">
                <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[var(--color-green)] shrink-0"></span>
                <span class="text-[15.5px] text-[var(--color-ink-light)]">{item}</span>
              </li>
            ))}
          </ul>

          <div class="flex flex-wrap gap-3">
            <a href="/same-day-approval/" class="btn btn-green btn-arrow px-6 py-3.5">Apply for Same-Day Approval</a>
          </div>
        </div>

        <div class="lg:col-span-6 order-1 lg:order-2 reveal" style="transition-delay:100ms;">
          <div class="relative aspect-[4/5] rounded-2xl overflow-hidden bg-[var(--color-ink)]">
            <video
              autoplay
              muted
              loop
              playsinline
              class="w-full h-full object-cover opacity-90"
              poster=""
            >
              <source src="https://stairwaymortgage.com/wp-content/uploads/2025/06/New-Same-Day-Approval-720.mp4" type="video/mp4" />
            </video>
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-ink)] via-transparent to-transparent pointer-events-none"></div>
            <div class="absolute bottom-0 left-0 right-0 p-7 text-[var(--color-paper)]">
              <p class="mono text-[11px] opacity-70 mb-2">PROCESS · STEP 01</p>
              <p class="font-display text-2xl leading-tight">From inquiry to approval letter in <em class="italic font-light">a single day</em>.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       TESTIMONIALS — Dark Editorial Section
       ============================================ -->
  <section class="section-dark section">
    <div class="container-page">
      <div class="text-center max-w-3xl mx-auto mb-16 reveal">
        <span class="eyebrow mb-6">Built on trust · Backed by experience</span>
        <h2 class="display-lg mt-6 mb-4 text-[var(--color-paper)]">
          What clients say after <em class="italic font-light">closing day.</em>
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
        {testimonials.map((t, i) => (
          <figure class="border border-[var(--color-paper)]/15 rounded-2xl p-8 lg:p-10 reveal" style={`transition-delay:${i * 80}ms;`}>
            <svg width="32" height="24" viewBox="0 0 32 24" class="text-[var(--color-paper)]/30 mb-6">
              <path fill="currentColor" d="M0 24V12.8C0 5.4 4.2 0 12 0v4.8c-3.6 0-6 2.4-6 6h6V24H0zm20 0V12.8C20 5.4 24.2 0 32 0v4.8c-3.6 0-6 2.4-6 6h6V24H20z"/>
            </svg>
            <blockquote class="font-display text-xl lg:text-[1.45rem] leading-snug text-[var(--color-paper)] mb-7" style="font-variation-settings:'opsz' 48; font-weight: 400;">
              "{t.quote}"
            </blockquote>
            <figcaption class="flex items-center justify-between">
              <div>
                <p class="font-medium text-[15px] text-[var(--color-paper)]">{t.name}</p>
                <p class="text-[13px] opacity-65 mt-0.5">{t.role}</p>
              </div>
              <p class="mono text-[12px] opacity-50 uppercase tracking-wider">{t.location}</p>
            </figcaption>
          </figure>
        ))}
      </div>

      <div class="text-center mt-14 reveal">
        <a href="/case-studies/" class="btn btn-outline-white btn-ghost border-[var(--color-paper)] text-[var(--color-paper)] hover:bg-[var(--color-paper)] hover:text-[var(--color-ink)]">
          Read full case studies
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
       CTA BLOCK
       ============================================ -->
  <section class="section">
    <div class="container-page">
      <div class="relative rounded-3xl overflow-hidden bg-[var(--color-ink)] text-[var(--color-paper)] p-10 lg:p-16">
        <!-- Decorative stair gradient -->
        <div class="absolute right-0 top-0 bottom-0 w-1/2 opacity-30 pointer-events-none" aria-hidden="true">
          <div class="absolute bottom-0 right-0 w-32 h-32 bg-[var(--color-blue)] blur-3xl rounded-full"></div>
          <div class="absolute top-0 right-20 w-32 h-32 bg-[var(--color-rust)] blur-3xl rounded-full"></div>
        </div>

        <div class="relative grid lg:grid-cols-12 gap-8 items-end">
          <div class="lg:col-span-8 reveal">
            <span class="eyebrow mb-6 text-[var(--color-paper)]/70">
              <span style="background:rgba(250,250,247,0.5)" class="!w-7 !h-px !inline-block"></span>
              Let's talk
            </span>
            <h2 class="display-lg text-[var(--color-paper)] mt-5">
              Ready to climb? <em class="italic font-light">Let's plan your next step.</em>
            </h2>
          </div>
          <div class="lg:col-span-4 flex flex-wrap gap-3 lg:justify-end reveal" style="transition-delay:100ms;">
            <a href="/contact-us/" class="btn btn-green">Schedule a Call</a>
            <a href="/same-day-approval/" class="btn bg-transparent border border-[var(--color-paper)]/30 text-[var(--color-paper)] hover:bg-[var(--color-paper)] hover:text-[var(--color-ink)]">Apply Now</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
