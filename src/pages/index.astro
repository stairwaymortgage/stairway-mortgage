---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Stairway Mortgage — Leverage wisely. Grow wealthy. | Division of NEXA Mortgage LLC">
   <section class="relative pt-10 lg:pt-14 pb-14 lg:pb-20 overflow-hidden"> <div class="absolute inset-0 pointer-events-none opacity-[0.022]" aria-hidden="true"> <svg width="100%" height="100%" preserveAspectRatio="none"><defs><pattern id="grid" width="64" height="64" patternUnits="userSpaceOnUse"><path d="M 64 0 L 0 0 0 64" fill="none" stroke="currentColor" stroke-width="1"></path></pattern></defs><rect width="100%" height="100%" fill="url(#grid)"></rect></svg> </div> <div class="container-page relative"> <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-start"> <!-- Left: H1 + stats + trust signal --> <div class="lg:col-span-6 reveal pt-2 lg:pt-4"> <span class="eyebrow eyebrow-blue mb-7">A division of NEXA Mortgage</span> <h1 class="display-lg mb-3 max-w-2xl">
First-Time Buyers. Investors. Legacy Builders.
<span class="emph-blue">You belong here.</span> </h1> <p class="text-[var(--color-mute)] text-[15px] mb-7 font-medium"> <svg width="13" height="13" viewBox="0 0 24 24" fill="none" class="inline-block mr-1.5 -mt-0.5 align-middle opacity-70"> <path d="M12 22s-8-7.58-8-13a8 8 0 0116 0c0 5.42-8 13-8 13z" stroke="currentColor" stroke-width="1.5"></path> <circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.5"></circle> </svg>
Including buyers in <span data-personalize-city class="text-[var(--color-ink)] font-medium">your city</span> </p> <p class="lede max-w-xl mb-8">
From first purchase to lasting legacy — we guide you through buying, renovating, leveraging equity, and planning retirement with the precision of a wealth strategist and the heart of a neighbor.
</p> <div class="grid grid-cols-3 gap-6 pb-6 mb-7 border-b border-[var(--color-bone)]"> <div> <p class="font-display text-[2.25rem] lg:text-[2.75rem] text-[var(--color-ink)] leading-none mb-1.5 tracking-tight">$500M<span class="text-xl opacity-70 align-top">+</span></p> <p class="text-[11px] uppercase tracking-wider text-[var(--color-mute)]">closed loans</p> </div> <div> <p class="font-display text-[2.25rem] lg:text-[2.75rem] text-[var(--color-ink)] leading-none mb-1.5 tracking-tight">300<span class="text-xl opacity-70 align-top">+</span></p> <p class="text-[11px] uppercase tracking-wider text-[var(--color-mute)]">lenders compete</p> </div> <div> <p class="font-display text-[2.25rem] lg:text-[2.75rem] text-[var(--color-ink)] leading-none mb-1.5 tracking-tight">7<span class="text-xl opacity-70">×</span></p> <p class="text-[11px] uppercase tracking-wider text-[var(--color-mute)]">top producer</p> </div> </div> <!-- ─── Hero Reviews Badge (Batch 3) ─── --> <a href="#reviews" class="hero-reviews-badge group"> <span class="hero-reviews-badge__stars"> <svg viewBox="0 0 24 24" fill="currentColor" class="hero-reviews-badge__star"><path d="M12 2L14.85 8.62L22 9.41L16.5 14.32L18.06 21.5L12 17.77L5.94 21.5L7.5 14.32L2 9.41L9.15 8.62L12 2Z"></path></svg><svg viewBox="0 0 24 24" fill="currentColor" class="hero-reviews-badge__star"><path d="M12 2L14.85 8.62L22 9.41L16.5 14.32L18.06 21.5L12 17.77L5.94 21.5L7.5 14.32L2 9.41L9.15 8.62L12 2Z"></path></svg><svg viewBox="0 0 24 24" fill="currentColor" class="hero-reviews-badge__star"><path d="M12 2L14.85 8.62L22 9.41L16.5 14.32L18.06 21.5L12 17.77L5.94 21.5L7.5 14.32L2 9.41L9.15 8.62L12 2Z"></path></svg><svg viewBox="0 0 24 24" fill="currentColor" class="hero-reviews-badge__star"><path d="M12 2L14.85 8.62L22 9.41L16.5 14.32L18.06 21.5L12 17.77L5.94 21.5L7.5 14.32L2 9.41L9.15 8.62L12 2Z"></path></svg><svg viewBox="0 0 24 24" fill="currentColor" class="hero-reviews-badge__star"><path d="M12 2L14.85 8.62L22 9.41L16.5 14.32L18.06 21.5L12 17.77L5.94 21.5L7.5 14.32L2 9.41L9.15 8.62L12 2Z"></path></svg> </span> <span class="hero-reviews-badge__rating">5.0</span> <span class="hero-reviews-badge__divider"></span> <span class="hero-reviews-badge__count"><strong>624</strong> reviews</span> <span class="hero-reviews-badge__on">on</span> <span class="hero-reviews-badge__platforms"> <span class="hero-reviews-badge__plat" style="--plat-accent:#4285F4"> Google + </span><span class="hero-reviews-badge__plat" style="--plat-accent:#00B5AD"> Birdeye </span><span class="hero-reviews-badge__plat" style="--plat-accent:#1877F2"> Facebook </span> </span> <svg class="hero-reviews-badge__arrow" width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg> </a> <div class="flex items-center gap-3 mb-7"> <span class="relative inline-flex"> <span class="absolute inline-flex w-2 h-2 rounded-full bg-[var(--color-green)] opacity-80 animate-ping"></span> <span class="relative inline-flex w-2 h-2 rounded-full bg-[var(--color-green)]"></span> </span> <p class="text-[13.5px] text-[var(--color-ink-light)]"> <span class="font-medium" data-live-count>14</span> people in
<span class="mono text-[var(--color-ink)]" data-personalize-city>your area</span>
pre-approved this week
</p> </div> <div class="flex items-center gap-4"> <div class="portrait-frame bg-[var(--color-paper-tint)] shrink-0"> <img src="/wp-content/uploads/2025/06/JIM-BLACKBURN-217x300.png" alt="Jim Blackburn" width="48" height="48" class="w-12 h-12 rounded-full object-cover" style="object-position:50% 20%" loading="eager" onerror="this.src='https://placehold.co/48x48/1a2332/white?text=JB';this.onerror=null"> </div> <div> <p class="font-display text-base leading-tight">Jim Blackburn</p> <p class="text-[12px] text-[var(--color-mute)] mono">NMLS #1072866 · Founder</p> </div> </div> </div> <!-- Right: AI Chat --> <div class="lg:col-span-6 reveal" style="transition-delay:120ms;"> <div class="aic" data-aic> <!-- ─── Ambient AI aurora glow (the "AI" feeling) ─── --> <div class="aic__aurora" aria-hidden="true"> <span class="aic__aurora-blob aic__aurora-blob--1"></span> <span class="aic__aurora-blob aic__aurora-blob--2"></span> <span class="aic__aurora-blob aic__aurora-blob--3"></span> </div> <!-- ─── HEADER: AI brand bar ─── --> <div class="aic__header"> <div class="aic__brand"> <span class="aic__sparkle" aria-hidden="true"> <svg viewBox="0 0 24 24" fill="none"> <path d="M12 2L13.5 9L20 10.5L13.5 12L12 19L10.5 12L4 10.5L10.5 9L12 2Z" fill="currentColor"></path> <path d="M19 3L19.7 5.3L22 6L19.7 6.7L19 9L18.3 6.7L16 6L18.3 5.3L19 3Z" fill="currentColor" opacity="0.6"></path> <path d="M5 17L5.5 18.5L7 19L5.5 19.5L5 21L4.5 19.5L3 19L4.5 18.5L5 17Z" fill="currentColor" opacity="0.4"></path> </svg> </span> <div class="aic__brand-text"> <p class="aic__title"> <span>AI mortgage assistant</span> <span class="aic__badge">AI</span> </p> <p class="aic__sub"> <span class="aic__live-dot"></span>
Live · 300+ lenders connected
</p> </div> </div> <button class="aic__reset" data-reset aria-label="Start new conversation" title="New conversation"> <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M3 12a9 9 0 1015-6.7M21 4v5h-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg> </button> </div> <!-- ─── BODY: welcome OR conversation ─── --> <div class="aic__body"> <!-- Welcome state --> <div class="aic__welcome" data-welcome> <p class="aic__greet">
Hi <span class="aic__wave">👋</span> </p> <p class="aic__greet-line">
I can answer mortgage questions, run numbers, and connect you to <span class="aic__greet-em">Jim's team</span> when you're ready.
</p> <p class="aic__greet-prompt">What can I help you figure out?</p> </div> <!-- Conversation state (hidden until first message) --> <div class="aic__convo" data-convo></div> </div> <!-- ─── COMPOSER ─── --> <div class="aic__composer"> <form class="aic__form" data-form> <div class="aic__input-frame"> <span class="aic__input-prefix" data-prefix>I want to figure out</span> <input type="text" class="aic__input" data-input placeholder="my monthly payment…" autocomplete="off" aria-label="Ask about mortgages"> <button type="button" class="aic__icon-btn" data-mic aria-label="Voice input"> <svg width="15" height="15" viewBox="0 0 24 24" fill="none"> <rect x="9" y="3" width="6" height="11" rx="3" stroke="currentColor" stroke-width="1.7"></rect> <path d="M5 11a7 7 0 0014 0M12 18v3" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"></path> </svg> </button> <button type="submit" class="aic__send" data-send aria-label="Send"> <svg width="15" height="15" viewBox="0 0 24 24" fill="none"> <path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path> </svg> </button> </div> </form> <!-- Quick action chips (Better.com style) --> <div class="aic__chips" data-chips> <button class="aic__chip" data-q="What's my pre-approval amount and how fast can I get the letter?"> <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg>
Start pre-approval
</button> <button class="aic__chip" data-q="How can I lower my mortgage rate or refinance?"> <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M6 13l6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg>
Lower my rate
</button> <button class="aic__chip" data-q="How much house can I afford?"> <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M12 2v20M17 6H9a3 3 0 000 6h6a3 3 0 010 6H7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path></svg>
Affordability
</button> <button class="aic__chip" data-q="Can I get cash out of my home with a refinance or HELOC?"> <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><rect x="3" y="6" width="18" height="13" rx="2" stroke="currentColor" stroke-width="1.7"></rect><circle cx="12" cy="12.5" r="2.5" stroke="currentColor" stroke-width="1.7"></circle></svg>
Get cash out
</button> </div> </div> <!-- ─── FOOTER: trust + escape ─── --> <div class="aic__footer"> <div class="aic__creds"> <svg width="11" height="11" viewBox="0 0 24 24" fill="none"><path d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path></svg> <span>Direct broker · Fannie Mae · Freddie Mac · 300+ lenders</span> </div> <a href="/contact-us/" class="aic__schedule-link">Talk to Our Team →</a> </div> </div> <script>
(function() {
  const root = document.querySelector('[data-aic]');
  if (!root) return;

  const welcome = root.querySelector('[data-welcome]');
  const convo = root.querySelector('[data-convo]');
  const form = root.querySelector('[data-form]');
  const input = root.querySelector('[data-input]');
  const prefix = root.querySelector('[data-prefix]');
  const chipsWrap = root.querySelector('[data-chips]');
  const resetBtn = root.querySelector('[data-reset]');
  const micBtn = root.querySelector('[data-mic]');

  let conversationStarted = false;
  let detectedCity = null;

  // ─── Rotating placeholder for AI feel ───
  const placeholders = [
    'my monthly payment…',
    'if I can afford this house…',
    'how to lower my rate…',
    'my pre-approval amount…',
    'if I should refinance…',
    'cash-out options…',
    'self-employed loan programs…',
    'DSCR loans for investors…',
  ];
  let placeholderIdx = 0;
  let placeholderTimer = setInterval(() => {
    if (input === document.activeElement || input.value || conversationStarted) return;
    placeholderIdx = (placeholderIdx + 1) % placeholders.length;
    input.placeholder = placeholders[placeholderIdx];
  }, 3200);

  // ─── Location detection ───
  fetch('https://ipapi.co/json/').then(r => r.json()).then(d => {
    if (d && d.city && !d.error) detectedCity = d.city;
  }).catch(() => {});
  // URL override
  const urlCity = new URLSearchParams(location.search).get('city');
  if (urlCity) detectedCity = decodeURIComponent(urlCity).replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());

  // Read from site-wide memory if available (loads after this script in some cases)
  function syncFromMemory() {
    const mem = window.SWMemory?.get?.() || {};
    if (mem.city && !detectedCity) detectedCity = mem.city;
  }
  syncFromMemory();
  window.addEventListener('sw:memory', syncFromMemory);

  // ─── Market data for rate responses ───
  const marketData = {
    'Miami': '6.38%', 'Fort Lauderdale': '6.41%', 'Tampa': '6.40%', 'Orlando': '6.45%',
    'Jacksonville': '6.50%', 'Naples': '6.36%', 'Phoenix': '6.55%', 'Mesa': '6.52%',
    'Scottsdale': '6.48%', 'Los Angeles': '6.65%', 'San Francisco': '6.70%', 'San Diego': '6.62%',
    'New York': '6.60%', 'Chicago': '6.42%', 'Houston': '6.48%', 'Dallas': '6.49%',
    'Austin': '6.52%', 'Atlanta': '6.45%', 'Seattle': '6.58%', 'Denver': '6.52%',
    'Boston': '6.55%', 'Las Vegas': '6.50%', 'Nashville': '6.46%', 'Charlotte': '6.44%', 'Raleigh': '6.44%',
  };

  // ─── 15 mortgage intents ───
  const intents = [
    {
      keys: ['rate', 'interest', 'apr'],
      reply: () => {
        const r = (detectedCity && marketData[detectedCity]) || '6.48%';
        const cityLine = detectedCity ? ` in <strong>${detectedCity}</strong>` : '';
        return `<p>Today's wholesale rates${cityLine}:</p>
                <div class="aic-card">
                  <div><span>30-year fixed</span><strong>${r}</strong></div>
                  <div><span>15-year fixed</span><strong>${(parseFloat(r) - 0.66).toFixed(2)}%</strong></div>
                  <div><span>FHA 30yr</span><strong>${(parseFloat(r) - 0.15).toFixed(2)}%</strong></div>
                  <div><span>DSCR (investor)</span><strong>${(parseFloat(r) + 0.75).toFixed(2)}%</strong></div>
                </div>
                <p class="aic-note">Subject to credit approval. Real rate quote takes 60 seconds →</p>`;
      },
      follow: ['Lock my rate', 'How much can I afford?', 'Talk to Our Team'],
    },
    {
      keys: ['pre-approv', 'preapprov', 'pre approv', 'how fast', 'how long', 'how quick', 'how soon', '24 hour', 'speed'],
      reply: () => `<p><strong>Same-day pre-approvals</strong> — letter in your hands within <strong>24 hours</strong>, 7 days a week.</p>
                    <p>What I need to give you a real letter:</p>
                    <ul class="aic-list">
                      <li>2 recent pay stubs (or business returns if self-employed)</li>
                      <li>2 years of W-2s or 1099s</li>
                      <li>Last 2 months of bank statements</li>
                      <li>Photo ID</li>
                    </ul>
                    <p>Ready when you are.</p>`,
      follow: ['Start pre-approval now', 'What about self-employed?', 'Talk to Our Team'],
    },
    {
      keys: ['afford', 'how much', 'budget', 'qualify', 'income', 'salary', 'price range'],
      reply: () => `<p>Rule of thumb: most borrowers qualify for <strong>3-5× annual income</strong>, but it really depends on:</p>
                    <ul class="aic-list">
                      <li><strong>Credit score</strong> — drives the rate</li>
                      <li><strong>Debt-to-income</strong> — target under 43%</li>
                      <li><strong>Down payment</strong> — 3-20%+ depending on program</li>
                      <li><strong>Loan type</strong> — FHA, Conventional, Jumbo, DSCR all qualify differently</li>
                    </ul>
                    <p>Want a real number? Our 60-second pre-qual gives you an exact range to shop with.</p>`,
      follow: ['Get my exact number', 'Calculate payment', 'Talk to Our Team'],
    },
    {
      keys: ['credit', 'score', 'fico', 'low credit', 'bad credit'],
      reply: () => `<p>Minimum credit by program:</p>
                    <div class="aic-card">
                      <div><span>FHA</span><strong>580+</strong></div>
                      <div><span>Conventional</span><strong>620+</strong></div>
                      <div><span>VA</span><strong>580+</strong></div>
                      <div><span>Jumbo</span><strong>700+</strong></div>
                      <div><span>DSCR (investor)</span><strong>640+</strong></div>
                    </div>
                    <p>Lower than 580? We have <strong>non-QM</strong> programs for credit-challenged borrowers — let's talk through your scenario.</p>`,
      follow: ['My score is below 580', 'FHA details', 'Talk to Our Team'],
    },
    {
      keys: ['document', 'paperwork', 'paper work', 'need to provide', 'what do i need', 'docs'],
      reply: () => `<p><strong>W-2 borrowers:</strong></p>
                    <ul class="aic-list">
                      <li>2 years W-2s + 30 days of pay stubs</li>
                      <li>2 months of bank statements</li>
                      <li>Photo ID + SSN</li>
                    </ul>
                    <p><strong>Self-employed:</strong></p>
                    <ul class="aic-list">
                      <li>2 years business + personal tax returns</li>
                      <li>YTD profit & loss statement</li>
                      <li>12 months of business bank statements</li>
                    </ul>
                    <p>Or use our <strong>bank-statement-only</strong> program — no tax returns required.</p>`,
      follow: ['Bank statement loan', 'Start pre-approval', 'Talk to Our Team'],
    },
    {
      keys: ['dscr', 'debt service', 'rental', 'investor loan', 'investment property'],
      reply: () => `<p><strong>DSCR loans</strong> (Debt Service Coverage Ratio) are built for real estate investors — no W-2, no tax returns needed.</p>
                    <p>You qualify based on the <strong>property's rental income</strong> covering the mortgage payment.</p>
                    <div class="aic-card">
                      <div><span>Min DSCR ratio</span><strong>1.0</strong></div>
                      <div><span>Min credit</span><strong>640</strong></div>
                      <div><span>Down payment</span><strong>20-25%</strong></div>
                      <div><span>Properties allowed</span><strong>Unlimited</strong></div>
                    </div>
                    <p>Perfect for scaling a portfolio without W-2 income caps.</p>`,
      follow: ['Get DSCR rates', 'Multi-property strategy', 'Talk to Our Team'],
    },
    {
      keys: ['reverse', '55+', 'senior', 'retirement', 'hecm', 'age 55', 'age 62'],
      reply: () => `<p><strong>Reverse mortgages</strong> let homeowners 55+ tap home equity — no monthly payments required.</p>
                    <p>Use the funds for:</p>
                    <ul class="aic-list">
                      <li>Tax-free retirement income</li>
                      <li>Paying off your existing mortgage</li>
                      <li>Healthcare or in-home care costs</li>
                      <li>Buying a new home (HECM for Purchase)</li>
                    </ul>
                    <p>You retain ownership and can stay in the home for life.</p>`,
      follow: ['Eligibility check', 'How much can I unlock?', 'Talk to Our Team'],
    },
    {
      keys: ['self-employ', 'self employ', '1099', 'freelance', 'business owner', 'entrepreneur', 'gig', 'no w2', 'no w-2'],
      reply: () => `<p>Self-employed is our <strong>specialty</strong>. We have programs that don't require tax returns:</p>
                    <ul class="aic-list">
                      <li><strong>Bank Statement Loans</strong> — qualify on 12-24 months of deposits</li>
                      <li><strong>P&L-Only Loans</strong> — CPA-prepared P&L is enough</li>
                      <li><strong>Asset Depletion</strong> — qualify on assets, zero income docs</li>
                      <li><strong>1099-Only loans</strong> — qualify on 1099 income alone</li>
                    </ul>
                    <p>If banks have said no, we likely can say yes.</p>`,
      follow: ['Bank statement loan details', 'Pre-qualify me', 'Talk to Our Team'],
    },
    {
      keys: ['refinance', 'refi', 'lower payment', 'lower rate', 'cash out', 'cash-out', 'heloc'],
      reply: () => `<p>Refinancing makes sense if:</p>
                    <ul class="aic-list">
                      <li>Rates have dropped 0.5%+ since you closed</li>
                      <li>You want to remove PMI (have 20%+ equity now)</li>
                      <li>You want cash out for renovation, investment, or debt consolidation</li>
                      <li>You want a HELOC for flexibility without resetting your first mortgage</li>
                    </ul>
                    <p>I'll run your numbers honestly — if it doesn't save you money, I'll tell you to wait.</p>`,
      follow: ['Run my refi math', 'HELOC vs cash-out', 'Talk to Our Team'],
    },
    {
      keys: ['fha', 'first time', 'first-time', 'low down', 'first home'],
      reply: () => `<p><strong>FHA loans</strong> — best for first-time buyers and lower credit scores:</p>
                    <ul class="aic-list">
                      <li><strong>3.5% down</strong> minimum</li>
                      <li><strong>580 credit</strong> minimum (compensating factors can go lower)</li>
                      <li>More flexible DTI requirements</li>
                      <li>Gift funds allowed for down payment</li>
                    </ul>
                    <p>Florida buyers: the <strong>Hometown Heroes</strong> program adds down-payment assistance for teachers, healthcare, first responders.</p>`,
      follow: ['Hometown Heroes', 'FHA vs Conventional', 'Talk to Our Team'],
    },
    {
      keys: ['closing cost', 'closing fee', 'fees', 'cost to close'],
      reply: () => `<p>Closing costs run <strong>2-5% of the loan amount</strong>, including:</p>
                    <ul class="aic-list">
                      <li>Origination + processing fees</li>
                      <li>Appraisal ($500-700)</li>
                      <li>Title insurance + settlement</li>
                      <li>Prepaid taxes & insurance (escrow)</li>
                      <li>Recording fees</li>
                    </ul>
                    <p>You get a full <strong>Loan Estimate</strong> within 3 days of application — no surprises at closing.</p>`,
      follow: ['Reduce closing costs', 'Seller credits explained', 'Talk to Our Team'],
    },
    {
      keys: ['cash offer', 'compete', 'bidding war', 'multiple offer', 'cash buyer', 'all cash'],
      reply: () => `<p>Yes — our <strong>Cash-Like Offers</strong> compete head-to-head with all-cash buyers:</p>
                    <ul class="aic-list">
                      <li>Pre-underwritten approval (not just pre-qualified)</li>
                      <li>24-hour close commitment letter</li>
                      <li>Sellers see your offer as cash-equivalent</li>
                      <li>Win bidding wars without overpaying</li>
                    </ul>
                    <p>Critical in today's market — let's set you up.</p>`,
      follow: ['Set up cash offer', 'Same-day approval', 'Talk to Our Team'],
    },
    {
      keys: ['schedule', 'talk', 'call', 'speak', 'jim', 'human', 'agent', 'person', 'expert', 'real person'],
      reply: () => `<p>Absolutely — Jim's team is available <strong>7 days a week</strong>, including evenings.</p>
                    <div class="aic-cta-stack">
                      <a href="/contact-us/" class="aic-cta aic-cta--primary"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="16" rx="2" stroke="currentColor" stroke-width="1.7"/><path d="M3 9h18M8 3v4M16 3v4" stroke="currentColor" stroke-width="1.7"/></svg> Schedule a call</a>
                      <a href="tel:+19549931625" class="aic-cta"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.36 1.9.69 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.33 1.85.56 2.81.69A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg> (954) 993-1625</a>
                      <a href="/same-day-approval/" class="aic-cta"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg> Start pre-approval</a>
                    </div>`,
      follow: [],
    },
    {
      keys: ['hello', 'hi ', 'hey', 'good morning', 'good afternoon', 'good evening', 'yo'],
      reply: () => `<p>Hey 👋 I'm here to help with anything mortgage-related.</p><p>What's on your mind?</p>`,
      follow: ['Today\'s rates', 'How much can I afford?', 'Talk to Our Team'],
    },
    {
      keys: ['thank', 'thanks', 'great', 'awesome', 'cool', 'nice'],
      reply: () => `<p>You're welcome! Anything else I can help with?</p><p>When you're ready for the next step, Jim's team is one click away.</p>`,
      follow: ['Schedule a call', 'Start pre-approval'],
    },
  ];

  const fallback = `<p>That's a great question — I want to get it right for your specific situation.</p>
                    <p>Let me connect you with Jim's team directly:</p>
                    <div class="aic-cta-stack">
                      <a href="/contact-us/" class="aic-cta aic-cta--primary">Schedule a call</a>
                      <a href="tel:+19549931625" class="aic-cta">(954) 993-1625</a>
                    </div>`;

  // ─── Intent matcher ───
  function findIntent(text) {
    const t = text.toLowerCase();
    let best = null, bestScore = 0;
    for (const it of intents) {
      const score = it.keys.filter(k => t.includes(k.toLowerCase())).length;
      if (score > bestScore) { bestScore = score; best = it; }
    }
    return best;
  }

  // ─── Conversation transition ───
  function ensureConvoMode() {
    if (conversationStarted) return;
    conversationStarted = true;
    welcome.classList.add('aic__welcome--gone');
    chipsWrap.classList.add('aic__chips--gone');
    setTimeout(() => {
      welcome.style.display = 'none';
      chipsWrap.style.display = 'none';
    }, 250);
    prefix.classList.add('aic__input-prefix--small');
    input.placeholder = 'Ask anything else…';
  }

  function resetConvo() {
    convo.innerHTML = '';
    conversationStarted = false;
    welcome.style.display = '';
    chipsWrap.style.display = '';
    welcome.classList.remove('aic__welcome--gone');
    chipsWrap.classList.remove('aic__chips--gone');
    prefix.classList.remove('aic__input-prefix--small');
    input.placeholder = placeholders[placeholderIdx];
    input.value = '';
  }

  // ─── Render messages ───
  function addMsg(html, who) {
    const m = document.createElement('div');
    m.className = `aic-msg aic-msg--${who}`;
    m.innerHTML = `<div class="aic-msg__b">${html}</div>`;
    convo.appendChild(m);
    convo.scrollTop = convo.scrollHeight;
    return m;
  }

  function addTyping() {
    const m = document.createElement('div');
    m.className = 'aic-msg aic-msg--bot aic-msg--typing';
    m.innerHTML = '<div class="aic-msg__b"><div class="aic-typing"><span></span><span></span><span></span></div></div>';
    convo.appendChild(m);
    convo.scrollTop = convo.scrollHeight;
    return m;
  }

  function renderReplies(replies) {
    if (!replies || !replies.length) return;
    const wrap = document.createElement('div');
    wrap.className = 'aic-replies';
    replies.forEach(r => {
      const b = document.createElement('button');
      b.className = 'aic-reply';
      b.textContent = r;
      b.dataset.q = r;
      wrap.appendChild(b);
    });
    convo.appendChild(wrap);
    convo.scrollTop = convo.scrollHeight;
  }

  function esc(s) { return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }

  // ─── Send handler ───
  async function send(text) {
    if (!text.trim()) return;
    ensureConvoMode();
    // remove any old reply chips
    convo.querySelectorAll('.aic-replies').forEach(r => r.remove());

    addMsg(esc(text), 'user');
    input.value = '';

    // ─── Write to site memory (silent data capture for GHL handoff) ───
    if (window.SWMemory) {
      const intentText = text.length > 200 ? text.slice(0, 200) : text;
      window.SWMemory.set({
        intent: intentText,
        ai_chat_engaged: true,
      });
      window.SWMemory.track('ai_chat_message', { text: intentText });
    }

    const t = addTyping();
    await new Promise(r => setTimeout(r, 650 + Math.random() * 350));
    t.remove();

    const intent = findIntent(text);
    if (intent) {
      addMsg(intent.reply(), 'bot');
      renderReplies(intent.follow);
    } else {
      addMsg(fallback, 'bot');
    }
  }

  // ─── Wire up ───
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    send(input.value);
  });

  chipsWrap.addEventListener('click', (e) => {
    const c = e.target.closest('.aic__chip');
    if (c && c.dataset.q) send(c.dataset.q);
  });

  convo.addEventListener('click', (e) => {
    const r = e.target.closest('.aic-reply');
    if (r && r.dataset.q) send(r.dataset.q);
  });

  resetBtn.addEventListener('click', resetConvo);

  // Mic button placeholder (visual only for now)
  micBtn.addEventListener('click', () => {
    micBtn.classList.toggle('aic__icon-btn--active');
    setTimeout(() => micBtn.classList.remove('aic__icon-btn--active'), 800);
  });

  // Input prefix shrinks when user focuses / types
  input.addEventListener('focus', () => { if (!conversationStarted) prefix.classList.add('aic__input-prefix--active'); });
  input.addEventListener('blur', () => { if (!input.value) prefix.classList.remove('aic__input-prefix--active'); });
})();
