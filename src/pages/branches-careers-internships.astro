---
import Layout from '../layouts/Layout.astro';
import CareerApplyForm from '../components/CareerApplyForm.astro';

const breadcrumbSchema = {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://stairwaymortgage.com/"},{"@type":"ListItem","position":2,"name":"Join the Stairway Team"}]};

const twoRoads = [
  {
    title: "Sales-Oriented Professionals",
    points: [
      "Build relationships, network, and close deals",
      "Thrive on challenge, persuasion, and performance",
      "High risk, high reward — six-figure potential",
    ],
  },
  {
    title: "Operations-Oriented Professionals",
    points: [
      "System-focused, organized, detail-oriented",
      "Enjoy consistency, precision, and behind-the-scenes mastery",
      "Career security with strong income potential",
    ],
  },
];

const whyJoin = [
  { title: "Uncapped Earning Potential", desc: "You control your income. With our competitive model, your success determines your paycheck — no caps, no limits." },
  { title: "Elite-Level Training", desc: "Access high-performance training that turns ambition into results. Learn from top producers and real-world experts." },
  { title: "Leadership Growth Paths", desc: "Whether you're new or seasoned, we offer defined tracks to help you grow into leadership roles and expand your influence." },
  { title: "Supportive Culture & Flexibility", desc: "Join a team that values collaboration, support, and the freedom to work from anywhere — with a community that's always got your back." },
];

const remote = {
  intro: "Whether you're in the field or working from a café, we believe in results over hours.",
  points: [
    "Work remotely and control your schedule",
    "Collaborate in your city through networking and outreach",
    "Focus on performance — not micromanagement",
  ],
};

const roleTiers = [
  {
    name: "Internships",
    meta: "No experience · Part-time",
    roles: [
      { title: "Telemarketing", desc: "Learn persuasive calling skills and client outreach basics." },
      { title: "Social Media Marketing", desc: "Assist with posting and campaign content creation." },
      { title: "Loan Processing", desc: "Support file prep, document review, and checklist tracking." },
    ],
  },
  {
    name: "Entry-Level",
    meta: "0–2 years",
    roles: [
      { title: "Junior Telemarketer", desc: "Call warm leads and log initial inquiries." },
      { title: "Junior Social Media Marketer", desc: "Manage comments, stories, and growth tactics." },
      { title: "Junior Loan Officer", desc: "Learn guidelines while assisting with client preapprovals." },
      { title: "Junior Loan Processor", desc: "Help gather documents and complete application files." },
    ],
  },
  {
    name: "Senior-Level",
    meta: "5+ years",
    roles: [
      { title: "Senior Telemarketer", desc: "Lead campaigns and mentor junior phone reps." },
      { title: "Senior Social Media Marketer", desc: "Strategize brand presence and campaign performance." },
      { title: "Senior Loan Officer", desc: "Manage complex files and high-volume closings." },
      { title: "Senior Loan Processor", desc: "Lead high-efficiency processing for top producers." },
      { title: "Senior Business Development Manager", desc: "Oversee growth strategy and major partnerships." },
    ],
  },
  {
    name: "Regional Support Team",
    meta: "Cross-market roles",
    roles: [
      { title: "Telemarketer", desc: "Drive lead generation with persuasive outreach techniques." },
      { title: "Social Media Marketer", desc: "Manage content calendar, strategy, and ad insights." },
      { title: "Loan Officer", desc: "Advise borrowers and structure deals start-to-finish." },
      { title: "Loan Processor", desc: "Oversee file flow and communicate with underwriters." },
      { title: "Business Development Manager", desc: "Grow partnerships and expand referral networks." },
    ],
  },
];

const producingTiers = [
  {
    q: "Producing less than $12M annually?",
    headline: "Apply for a Loan Officer position with Stairway",
    tagline: "Connect. Learn. Grow.",
    receiveLabel: "What you receive as a Loan Officer",
    benefits: [
      "Uncapped earning potential",
      "Warm leads",
      "Remote flexibility",
      "#1 AI CRM in the space",
      "Growth paths to leadership",
      "Jim's sales & accountability coaching",
    ],
    cta: "Apply For Loan Officer",
  },
  {
    q: "Already producing $12M+ annually?",
    headline: "Apply to launch a Stairway branch in your market.",
    tagline: "Leverage. Scale. Evolve.",
    receiveLabel: "What you receive as a Branch Owner",
    benefits: [
      "Powerful brand that adds value & attracts",
      "Local website with strong SEO presence",
      "Branded materials for your local market",
      "Educational content for lead generation",
      "Streamlined operations & processing",
      "Jim's leadership & accountability coaching",
    ],
    cta: "Apply For Branch",
  },
  {
    q: "Already producing $50M+ with a brand you love?",
    headline: "Apply to bring your brand to the NEXA ecosphere.",
    tagline: "",
    receiveLabel: "What you receive as a Brand Owner",
    benefits: [
      "250+ wholesale lender relationships",
      'NEXA proprietary system "LOS"',
      "National network of professionals",
      "Discounted third party vendors",
      "Regularly planned NEXA events",
      "Access to Jim's personal brand coaching",
    ],
    cta: "Apply to Plug In",
  },
];
---

<Layout title="Mortgage Careers & Branch Opportunities | Stairway" description="Build your mortgage career with training support and unlimited earning potential. Branch opportunities for experienced loan officers and teams." canonical="https://stairwaymortgage.com/branches-careers-internships/">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="bci-scope">
    <nav class="container-page bci-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a> <span>/</span> <span>Join the Stairway Team</span>
    </nav>

    <!-- HERO -->
    <header class="bci-hero">
      <div class="container-page bci-hero__inner">
        <span class="eyebrow eyebrow-blue">Careers · Branches · Internships</span>
        <h1 class="display-md bci-hero__title">Join the Stairway Team</h1>
        <p class="bci-hero__sub">A high-performance culture for ambitious professionals.</p>
        <p class="lede bci-hero__lede">At Stairway Mortgage, we don't just hire — we grow leaders. Our team is made up of driven, goal-oriented people who thrive under pressure and overcome challenges with grit. We value character, accountability, and discipline over experience — skills can be taught. If you're committed to growth and excellence, you'll feel right at home.</p>
        <div class="bci-hero__cta">
          <button type="button" data-caf-open class="btn btn-blue btn-arrow">Apply Now</button>
          <a href="#open-roles" class="btn btn-ghost">See Open Roles</a>
        </div>
      </div>
    </header>

    <!-- TWO ROADS -->
    <section class="bci-section">
      <div class="container-page">
        <div class="bci-section__head">
          <span class="eyebrow eyebrow-blue">Two paths</span>
          <h2 class="bci-section__title">Two Roads. One Destination: Success.</h2>
          <p class="bci-section__lede">Whether you close deals or run the systems behind them, there's a track built for how you work.</p>
        </div>
        <div class="bci-grid bci-grid--2">
          {twoRoads.map((road) => (
            <div class="bci-card">
              <h3 class="bci-card__title">{road.title}</h3>
              <ul class="bci-card__list">
                {road.points.map((p) => <li>{p}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- WHY JOIN -->
    <section class="bci-section bci-section--tint">
      <div class="container-page">
        <div class="bci-section__head">
          <span class="eyebrow eyebrow-blue">Why Stairway</span>
          <h2 class="bci-section__title">Why Join Stairway Mortgage?</h2>
        </div>
        <div class="bci-grid bci-grid--2">
          {whyJoin.map((item) => (
            <div class="bci-card">
              <h3 class="bci-card__title">{item.title}</h3>
              <p class="bci-card__desc">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- REMOTE -->
    <section class="bci-section">
      <div class="container-page">
        <div class="bci-section__head">
          <span class="eyebrow eyebrow-blue">How we work</span>
          <h2 class="bci-section__title">Flexible &amp; Remote Work Opportunities</h2>
          <p class="bci-section__lede">{remote.intro}</p>
        </div>
        <ul class="bci-card__list bci-remote-list">
          {remote.points.map((p) => <li>{p}</li>)}
        </ul>
      </div>
    </section>

    <!-- OPEN ROLES -->
    <section id="open-roles" class="bci-section bci-section--tint">
      <div class="container-page">
        <div class="bci-section__head">
          <span class="eyebrow eyebrow-blue">Open roles</span>
          <h2 class="bci-section__title">Career Opportunities at Stairway Mortgage</h2>
          <p class="bci-section__lede">Explore roles by experience level. Every role opens the same quick application — apply to the track that fits you.</p>
        </div>
        {roleTiers.map((tier) => (
          <div class="bci-tier">
            <div class="bci-tier__head">
              <h3 class="bci-tier__name">{tier.name}</h3>
              <span class="bci-tier__meta">{tier.meta}</span>
            </div>
            <div class="bci-grid bci-grid--3">
              {tier.roles.map((role) => (
                <div class="bci-role">
                  <h4 class="bci-role__title">{role.title}</h4>
                  <p class="bci-role__desc">{role.desc}</p>
                  <button type="button" data-caf-open class="bci-role__apply">Apply &rarr;</button>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- PRODUCING TIERS -->
    <section class="bci-section">
      <div class="container-page">
        <div class="bci-section__head">
          <span class="eyebrow eyebrow-blue">Grow with us</span>
          <h2 class="bci-section__title">Loan Officer, Branch, or Brand — Find Your Level</h2>
          <p class="bci-section__lede">Wherever you are in your career, there's a way to plug into the Stairway ecosystem.</p>
        </div>
        <div class="bci-grid bci-grid--3">
          {producingTiers.map((tier) => (
            <div class="bci-producing">
              <span class="bci-producing__q">{tier.q}</span>
              <h3 class="bci-producing__h">{tier.headline}</h3>
              {tier.tagline && <p class="bci-producing__tag">{tier.tagline}</p>}
              <p class="bci-producing__label">{tier.receiveLabel}</p>
              <ul class="bci-card__list">
                {tier.benefits.map((b) => <li>{b}</li>)}
              </ul>
              <div class="bci-producing__cta">
                <button type="button" data-caf-open class="btn btn-blue btn-arrow">{tier.cta}</button>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="bci-section bci-section--tint">
      <div class="container-page bci-cta-band">
        <h2 class="bci-section__title">Ready to take the next step?</h2>
        <p class="bci-section__lede bci-cta-band__lede">Apply once and our team will point you to the right track.</p>
        <button type="button" data-caf-open class="btn btn-blue btn-arrow">Apply Now</button>
      </div>
    </section>
  </div>

  <CareerApplyForm />
</Layout>

<style>
  .bci-breadcrumb { font-family:var(--stw-mono,'JetBrains Mono'),monospace; font-size:12px; color:var(--color-mute); padding-top:2rem; padding-bottom:1.25rem; }
  .bci-breadcrumb a { color:var(--color-mute); text-decoration:none; }
  .bci-breadcrumb a:hover { color:var(--color-blue); }
  .bci-breadcrumb span { margin-inline:.4rem; opacity:.5; }

  .bci-hero { padding: clamp(2.5rem,6vw,4.5rem) 0 clamp(2rem,4vw,3rem); background:linear-gradient(180deg,var(--color-paper-tint),var(--color-paper)); border-bottom:1px solid var(--color-bone); }
  .bci-hero__title { margin:.5rem 0 .9rem; }
  .bci-hero__sub { font-family:var(--stw-display,'Fraunces'),Georgia,serif; font-weight:500; font-size:clamp(1.2rem,2.2vw,1.5rem); color:var(--color-ink); margin-bottom:1rem; }
  .bci-hero__lede { max-width:64ch; margin-bottom:1.75rem; }
  .bci-hero__cta { display:flex; flex-wrap:wrap; gap:.75rem; }

  .bci-section { padding: clamp(2.5rem,5vw,4rem) 0; }
  .bci-section--tint { background:var(--color-paper-tint); border-top:1px solid var(--color-bone); border-bottom:1px solid var(--color-bone); }
  .bci-section__head { max-width:62ch; margin-bottom:2rem; }
  .bci-section__title { font-family:var(--stw-display,'Fraunces'),Georgia,serif; font-weight:500; font-size:clamp(1.5rem,3vw,2.1rem); margin:.4rem 0 .6rem; color:var(--color-ink); }
  .bci-section__lede { font-size:16px; line-height:1.65; color:var(--color-mute); }

  .bci-grid { display:grid; gap:1rem; }
  .bci-grid--2 { grid-template-columns:repeat(2,1fr); }
  .bci-grid--3 { grid-template-columns:repeat(3,1fr); }
  @media(max-width:900px){ .bci-grid--3 { grid-template-columns:1fr 1fr; } }
  @media(max-width:640px){ .bci-grid--2,.bci-grid--3 { grid-template-columns:1fr; } }

  .bci-card { background:var(--color-paper); border:1px solid var(--color-bone); border-radius:14px; padding:1.5rem 1.6rem; display:flex; flex-direction:column; gap:.65rem; }
  .bci-card__title { font-family:var(--stw-display,'Fraunces'),Georgia,serif; font-weight:500; font-size:1.2rem; color:var(--color-ink); }
  .bci-card__desc { font-size:15px; line-height:1.6; color:var(--color-ink-light); }

  .bci-card__list { list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:.5rem; }
  .bci-card__list li { position:relative; padding-left:1.15rem; font-size:15px; line-height:1.55; color:var(--color-ink-light); }
  .bci-card__list li::before { content:''; position:absolute; left:0; top:.55em; width:5px; height:5px; border-radius:50%; background:var(--color-blue); }
  .bci-remote-list { max-width:42rem; }

  .bci-tier { margin-top:2.25rem; }
  .bci-tier:first-of-type { margin-top:0; }
  .bci-tier__head { display:flex; align-items:baseline; gap:.85rem; flex-wrap:wrap; margin-bottom:1.1rem; padding-bottom:.6rem; border-bottom:1px solid var(--color-bone); }
  .bci-tier__name { font-family:var(--stw-display,'Fraunces'),Georgia,serif; font-weight:500; font-size:1.35rem; color:var(--color-ink); }
  .bci-tier__meta { font-family:var(--stw-mono,'JetBrains Mono'),monospace; font-size:11px; letter-spacing:.06em; text-transform:uppercase; color:var(--color-mute); }

  .bci-role { background:var(--color-paper); border:1px solid var(--color-bone); border-radius:12px; padding:1.25rem 1.35rem; display:flex; flex-direction:column; gap:.5rem; }
  .bci-role__title { font-family:var(--stw-display,'Fraunces'),Georgia,serif; font-weight:500; font-size:1.05rem; color:var(--color-ink); }
  .bci-role__desc { font-size:14px; line-height:1.55; color:var(--color-ink-light); flex:1; }
  .bci-role__apply { align-self:flex-start; margin-top:.35rem; font-family:var(--stw-mono,'JetBrains Mono'),monospace; font-size:12px; letter-spacing:.04em; color:var(--color-blue); text-decoration:none; background:none; border:0; padding:0; cursor:pointer; }
  .bci-role__apply:hover { text-decoration:underline; text-underline-offset:2px; }

  .bci-producing { background:var(--color-paper); border:1px solid var(--color-bone); border-radius:16px; padding:1.75rem; display:flex; flex-direction:column; gap:.7rem; }
  .bci-producing__q { font-family:var(--stw-mono,'JetBrains Mono'),monospace; font-size:11px; letter-spacing:.06em; text-transform:uppercase; color:var(--color-blue); }
  .bci-producing__h { font-family:var(--stw-display,'Fraunces'),Georgia,serif; font-weight:500; font-size:1.25rem; line-height:1.25; color:var(--color-ink); }
  .bci-producing__tag { font-family:var(--stw-mono,'JetBrains Mono'),monospace; font-size:12px; color:var(--color-mute); }
  .bci-producing__label { font-size:11px; text-transform:uppercase; letter-spacing:.06em; color:var(--color-mute); margin-top:.4rem; }
  .bci-producing__cta { margin-top:auto; padding-top:.6rem; }

  .bci-cta-band { text-align:center; }
  .bci-cta-band .bci-section__title { margin-bottom:.75rem; }
  .bci-cta-band__lede { margin:0 auto 1.5rem; max-width:46ch; }
</style>
