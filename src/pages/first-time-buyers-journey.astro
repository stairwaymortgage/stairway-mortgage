---
import Layout from '../layouts/Layout.astro';
---
<Layout title="First-Time Home Buyer — Stairway Mortgage" description="Buying your first home with confidence. Pre-approved in as fast as 24 hours.">
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">Your Situation · First-Time Buyer</span>
        <h1 class="display-xl mt-6 mb-6">Your first home starts with <em class="not-italic text-[var(--color-blue)]">the right team</em>.</h1>
        <p class="lede max-w-xl mx-auto mb-6">From pre-approval to keys in hand — we walk first-time buyers through every step with 300+ lenders competing for your rate.</p>
        <p class="mono text-[11px] text-[var(--color-mute)] mt-6">NMLS #1072866</p>
        <div class="flex flex-wrap gap-3 justify-center mt-10">
          <a href="/see-my-options/" class="btn btn-blue btn-arrow text-base px-6 py-3.5">See My Options</a>
          <a href="/contact-us/" class="btn btn-ghost text-base px-6 py-3.5">Talk to Our Team</a>
        </div>
      </div>

      <!-- stw-img: Pexels 4247768 -->
      <figure class="hero-photo" style="max-width:1040px;margin:2.5rem auto 0;border-radius:20px;overflow:hidden;box-shadow:0 30px 70px -28px rgba(10,14,26,.45);aspect-ratio:16/9;">
        <img src="https://images.pexels.com/photos/4247768/pexels-photo-4247768.jpeg?auto=compress&cs=tinysrgb&w=1200"
             alt="Excited young first-time buyers unpacking moving boxes in their new home" loading="eager"
             style="width:100%;height:100%;object-fit:cover;object-position:center 30%;display:block;"
             onerror="this.onerror=null;this.src='https://placehold.co/1000x1100/16335B/FAFAF9?text=Stairway';">
      </figure>
    </div>
  </section>

  <!-- LIFE GALLERY — real people, real milestones -->
  <section class="section-tight bg-[var(--color-paper-tint)]">
    <div class="container-page">
      <div class="text-center max-w-2xl mx-auto mb-8 reveal">
        <span class="eyebrow eyebrow-blue mb-4">Your first chapter</span>
        <h2 class="display-lg mt-4">From keys to <em class="not-italic font-light">home</em>.</h2>
      </div>
      <div class="grid sm:grid-cols-3 gap-5">
        <figure class="reveal" style="margin:0;">
          <!-- stw-img: Pexels 8293700 -->
          <div style="border-radius:16px;overflow:hidden;aspect-ratio:4/3;box-shadow:0 20px 45px -22px rgba(10,14,26,.4);">
            <img src="https://images.pexels.com/photos/8293700/pexels-photo-8293700.jpeg?auto=compress&cs=tinysrgb&w=800"
                 alt="Excited young couple holding the keys to their first home" loading="lazy"
                 style="width:100%;height:100%;object-fit:cover;object-position:center 35%;display:block;"
                 onerror="this.onerror=null;this.src='https://placehold.co/600x450/16335B/FAFAF9?text=Stairway';">
          </div>
          <figcaption style="text-align:center;font-size:12.5px;color:var(--color-mute);margin-top:0.6rem;">The moment the keys are finally yours</figcaption>
        </figure>
        <figure class="reveal" style="margin:0;transition-delay:80ms;">
          <!-- stw-img: Pexels 8120623 -->
          <div style="border-radius:16px;overflow:hidden;aspect-ratio:4/3;box-shadow:0 20px 45px -22px rgba(10,14,26,.4);">
            <img src="https://images.pexels.com/photos/8120623/pexels-photo-8120623.jpeg?auto=compress&cs=tinysrgb&w=800"
                 alt="Young family relaxing together in the living room of their new home" loading="lazy"
                 style="width:100%;height:100%;object-fit:cover;object-position:center 35%;display:block;"
                 onerror="this.onerror=null;this.src='https://placehold.co/600x450/16335B/FAFAF9?text=Stairway';">
          </div>
          <figcaption style="text-align:center;font-size:12.5px;color:var(--color-mute);margin-top:0.6rem;">Settling into a place that's truly yours</figcaption>
        </figure>
        <figure class="reveal" style="margin:0;transition-delay:160ms;">
          <!-- stw-img: Pexels 9869388 -->
          <div style="border-radius:16px;overflow:hidden;aspect-ratio:4/3;box-shadow:0 20px 45px -22px rgba(10,14,26,.4);">
            <img src="https://images.pexels.com/photos/9869388/pexels-photo-9869388.jpeg?auto=compress&cs=tinysrgb&w=800"
                 alt="First-time buyers planning their budget with a team in their corner" loading="lazy"
                 style="width:100%;height:100%;object-fit:cover;object-position:center 35%;display:block;"
                 onerror="this.onerror=null;this.src='https://placehold.co/600x450/16335B/FAFAF9?text=Stairway';">
          </div>
          <figcaption style="text-align:center;font-size:12.5px;color:var(--color-mute);margin-top:0.6rem;">Planning your budget with a team in your corner</figcaption>
        </figure>
      </div>
    </div>
  </section>
</Layout>
