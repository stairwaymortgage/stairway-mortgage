---
import Layout from '../layouts/Layout.astro';
---
<Layout title="First-Time Home Buyer — Stairway Mortgage" description="Buying your first home with confidence. Pre-approved in as fast as 24 hours.">
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">Your Situation · First-Time Buyer</span>
        <h1 class="display-xl mt-6 mb-6">Your first home starts with <em class="not-italic text-[var(--color-blue)]">the right team</em>.</h1>
        <p class="lede max-w-xl mx-auto mb-6">From pre-approval to keys in hand — we walk first-time buyers through every step with 300+ lenders competing for your rate.</p>
        <p class="mono text-[11px] text-[var(--color-mute)] mt-6">NMLS #1072866</p>
        <div class="flex flex-wrap gap-3 justify-center mt-10">
          <a href="/see-my-options/" class="btn btn-blue btn-arrow text-base px-6 py-3.5">See My Options</a>
          <a href="/contact-us/" class="btn btn-ghost text-base px-6 py-3.5">Talk to Our Team</a>
        </div>
      </div>

      <!-- stw-img: Pexels 4247768 -->
      <figure class="hero-photo" style="max-width:1040px;margin:2.5rem auto 0;border-radius:20px;overflow:hidden;box-shadow:0 30px 70px -28px rgba(10,14,26,.45);aspect-ratio:16/9;">
        <img src="https://images.pexels.com/photos/4247768/pexels-photo-4247768.jpeg?auto=compress&cs=tinysrgb&w=1200"
             alt="Excited young first-time buyers unpacking moving boxes in their new home" loading="eager"
             style="width:100%;height:100%;object-fit:cover;object-position:center 30%;display:block;"
             onerror="this.onerror=null;this.src='https://placehold.co/1000x1100/16335B/FAFAF9?text=Stairway';">
      </figure>
    </div>
  </section>
</Layout>
