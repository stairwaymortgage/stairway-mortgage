---
// reverse-mortgage.astro  →  route: /reverse-mortgage/
// Standalone page matching the Outgrow intro hero + Get Started trigger.
import ReverseMortgageForm from "../components/ReverseMortgageForm.astro";
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Reverse Mortgage The Smart Way | Stairway Mortgage</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,500;1,400&family=IBM+Plex+Sans:wght@400;500;600&family=JetBrains+Mono&display=swap" rel="stylesheet" />
  <style>
    body{ margin:0; font-family:'IBM Plex Sans',system-ui,sans-serif; color:#0A0E1A; background:#FAFAF7; }
    .rm-hero{ max-width:900px; margin:0 auto; padding:90px 24px 120px; text-align:center; }
    .rm-hero h1{ font-family:'Fraunces',Georgia,serif; font-weight:400; font-size:clamp(34px,6vw,56px); margin:0 0 18px; }
    .rm-hero p{ font-family:'Fraunces',Georgia,serif; font-style:italic; font-size:clamp(16px,2.4vw,22px); color:#555; margin:0 0 44px; }
    .rm-start{ border:0; cursor:pointer; background:#0A0E1A; color:#fff; border-radius:8px; padding:18px 40px; font-size:17px; font-family:'IBM Plex Sans',sans-serif; }
    .rm-start:hover{ background:#2d2350; }
  </style>
</head>
<body>
  <section class="rm-hero">
    <h1>Reverse Mortgage The Smart Way</h1>
    <p>Flexible equity solutions, expert guidance, and wealth-building strategies—built around you.</p>
    <button class="rm-start" data-rm-open>Get Started</button>
  </section>

  <ReverseMortgageForm />
</body>
</html>
