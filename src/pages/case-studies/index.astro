  <script is:inline>
    (function(){
      var grid=document.getElementById('csGrid'), tabs=document.getElementById('csTabs'), search=document.getElementById('csSearch'), empty=document.getElementById('csEmpty');
      var cards=Array.prototype.slice.call(grid.querySelectorAll('.cs-card'));
      var activeCat='all', q='';
      function render(){
        var shown=0;
        cards.forEach(function(c){
          var okCat=activeCat==='all'||c.getAttribute('data-cat')===activeCat;
          var okQ=!q||c.getAttribute('data-search').indexOf(q)>-1;
          var show=okCat&&okQ; c.style.display=show?'':'none'; if(show)shown++;
        });
        empty.hidden=shown>0;
      }
      tabs.addEventListener('click',function(e){var b=e.target.closest('.cs-tab');if(!b)return;tabs.querySelectorAll('.cs-tab').forEach(function(x){x.classList.remove('is-active');});b.classList.add('is-active');activeCat=b.getAttribute('data-cat');render();});
      search.addEventListener('input',function(){q=search.value.toLowerCase().trim();render();});
    })();
  </script>

