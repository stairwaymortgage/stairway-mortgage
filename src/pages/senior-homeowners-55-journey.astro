---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Senior Homeowner 55+ — Stairway Mortgage" description="Turn your home equity into retirement income. Reverse mortgage and downsizing options.">
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">Your Situation · Senior Homeowner 55+</span>
        <h1 class="display-xl mt-6 mb-6">Turn equity into <em class="not-italic text-[var(--color-blue)]">income</em>.</h1>
        <p class="lede max-w-xl mx-auto mb-6">Reverse mortgages, downsizing strategies, and retirement planning. HECM available at 62+; some proprietary programs at 55+.</p>
        <p class="mono text-[11px] text-[var(--color-mute)] mt-6">NMLS #1072866</p>
        <div class="flex flex-wrap gap-3 justify-center mt-10">
          <a href="/reverse-mortgage-journey/" class="btn btn-blue btn-arrow text-base px-6 py-3.5">See My Options</a>
          <a href="/contact-us/" class="btn btn-ghost text-base px-6 py-3.5">Talk to Our Team</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
