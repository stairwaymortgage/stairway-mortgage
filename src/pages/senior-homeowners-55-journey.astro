---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Senior Homeowner 55+ — Stairway Mortgage" description="Turn your home equity into retirement income. Reverse mortgage and downsizing options.">
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">Your Situation · Senior Homeowner 55+</span>
        <h1 class="display-xl mt-6 mb-6">Turn equity into <em class="not-italic text-[var(--color-blue)]">income</em>.</h1>
        <p class="lede max-w-xl mx-auto mb-6">Reverse mortgages, downsizing strategies, and retirement planning. HECM available at 62+; some proprietary programs at 55+.</p>
        <p class="mono text-[11px] text-[var(--color-mute)] mt-6">NMLS #1072866</p>
        <!-- stw-img: Pexels 6975211 -->
        <figure class="hero-photo" style="max-width:900px;margin:1.75rem auto 2.25rem;border-radius:20px;overflow:hidden;box-shadow:0 30px 70px -28px rgba(10,14,26,.45);aspect-ratio:3/2;">
          <img src="https://images.pexels.com/photos/6975211/pexels-photo-6975211.jpeg?auto=compress&cs=tinysrgb&w=1280"
               alt="Happy senior couple sharing a warm moment in their kitchen" loading="eager"
               style="width:100%;height:100%;object-fit:cover;object-position:center 22%;display:block;"
               onerror="this.onerror=null;this.src='https://placehold.co/1000x667/16335B/FAFAF9?text=Stairway';">
        </figure>

        <div class="flex flex-wrap gap-3 justify-center mt-10">
          <a href="/see-my-options/" class="btn btn-blue btn-arrow text-base px-6 py-3.5">See My Options</a>
          <a href="/contact-us/" class="btn btn-ghost text-base px-6 py-3.5">Talk to Our Team</a>
        </div>
      </div>
    </div>
  </section>

  <!-- People image -->
  <div style="max-width:1140px;margin:0 auto;padding:0 1.5rem;">
    <figure style="margin:0;border-radius:12px;overflow:hidden;aspect-ratio:21/9;">
      <img src="https://images.pexels.com/photos/5257526/pexels-photo-5257526.jpeg?auto=compress&cs=tinysrgb&w=1800" alt="Senior couple enjoying retirement in their home" loading="lazy" style="width:100%;height:100%;object-fit:cover;object-position:center 35%;display:block;" onerror="this.onerror=null;this.parentElement.style.display='none';">
    </figure>
  </div>

  <!-- People image -->
  <div style="max-width:1140px;margin:0 auto;padding:0 1.5rem;margin-top:2rem;">
    <figure style="margin:0;border-radius:12px;overflow:hidden;aspect-ratio:21/9;">
      <img src="https://images.pexels.com/photos/7551617/pexels-photo-7551617.jpeg?auto=compress&cs=tinysrgb&w=1800" alt="Senior homeowner discussing options with a trusted advisor" loading="lazy" style="width:100%;height:100%;object-fit:cover;object-position:center 35%;display:block;" onerror="this.onerror=null;this.parentElement.style.display='none';">
    </figure>
  </div>
</Layout>
