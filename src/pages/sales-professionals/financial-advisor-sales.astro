  <!-- ============ H2 #13: FINAL CTA ============ -->
  <section class="final-cta final-cta--bg" style="background-image: url('https://images.pexels.com/photos/590016/pexels-photo-590016.jpeg?auto=compress&cs=tinysrgb&w=1800');">
    <div class="container">
      <div class="final-cta-inner">
        <div class="eyebrow eyebrow-light">Talk to a financial advisor mortgage specialist</div>
        <h2 style="color: var(--paper);">Get a financial advisor mortgage from a lender who reads wirehouse W-2 grid commission, independent RIA AUM-based fees, RSU stock awards, forgivable loan recruiting structures, S-corp K-1 distributions, and practice valuation as one file.</h2>
