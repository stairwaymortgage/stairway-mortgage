      letter-spacing: 0.08em;
      color: var(--ink-lighter);
      text-transform: uppercase;
      margin-bottom: var(--s-7);
    }.realtor-scope .breadcrumb a{ color: var(--ink-lighter); }.realtor-scope .breadcrumb a:hover{ color: var(--blue); }.realtor-scope .breadcrumb span:last-child{ color: var(--ink); }.realtor-scope .hero-eyebrow{ margin-bottom: var(--s-5); }.realtor-scope .hero h1{ margin-bottom: var(--s-6); max-width: 18ch; }.realtor-scope .hero-subtitle{
