      font-size: var(--text-sm); font-weight: 500;
    }.realtor-scope .nav-links a{ color: var(--ink-2); transition: color 0.15s; }.realtor-scope .nav-links a:hover{ color: var(--blue); }.realtor-scope .nav-cta{
