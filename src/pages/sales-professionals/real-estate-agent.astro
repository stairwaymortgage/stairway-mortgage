    }
    @media (max-width: 900px) {.realtor-scope .nav-links{ display: none; }.realtor-scope .nav-cta .btn-secondary{ display: none; }
    }.realtor-scope .btn{
      display: inline-flex;
      align-items: center;
      gap: var(--s-2);
