    }.realtor-scope, .realtor-scope *::before, .realtor-scope *::after{ box-sizing: border-box; margin: 0; padding: 0; }.realtor-scope{ scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }.realtor-scope{
