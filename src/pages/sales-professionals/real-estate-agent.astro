      line-height: 1.4;
    }
    @media (max-width: 720px) {.realtor-scope .stats-grid{ grid-template-columns: repeat(2, 1fr); gap: var(--s-7) var(--s-4); }.realtor-scope .stat:nth-child(3){ border-left: 0; padding-left: 0; }
    }.realtor-scope .section{
      padding: var(--s-10) 0;
    }.realtor-scope .section-tinted{ background: var(--paper-2); }.realtor-scope .section-dark{ background: var(--ink); color: var(--paper); }.realtor-scope .section-header{
      max-width: 720px;
      margin-bottom: var(--s-8);
    }.realtor-scope .section-header .eyebrow{ margin-bottom: var(--s-4); }.realtor-scope .section-header h2{ margin-bottom: var(--s-5); }.realtor-scope .section-header p{ font-size: var(--text-lg); color: var(--ink-2); }.realtor-scope .lede-section{ padding: var(--s-9) 0; }.realtor-scope .lede-section .lede + .lede{ margin-top: var(--s-5); }.realtor-scope .data-table{
      width: 100%;
      border-collapse: collapse;
      font-size: var(--text-sm);
      font-feature-settings: 'tnum' 1;
    }.realtor-scope .data-table thead th{
      font-family: var(--mono);
      font-size: var(--text-xs);
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--ink-lighter);
      font-weight: 500;
      text-align: left;
      padding: var(--s-3) var(--s-4);
