      color: var(--ink);
      margin-bottom: var(--s-3);
      letter-spacing: -0.005em;
    }.realtor-scope p{ margin-bottom: var(--s-4); }.realtor-scope p:last-child{ margin-bottom: 0; }.realtor-scope p.lead{
      font-size: var(--text-lg);
