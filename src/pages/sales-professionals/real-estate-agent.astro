    }.realtor-scope img, .realtor-scope svg{ display: block; max-width: 100%; }.realtor-scope a{ color: inherit; text-decoration: none; }.realtor-scope button{ font: inherit; cursor: pointer; border: 0; background: none; }.realtor-scope .container{ max-width: 1200px; margin: 0 auto; padding: 0 var(--s-6); }.realtor-scope .container-narrow{ max-width: 760px; margin: 0 auto; padding: 0 var(--s-6); }.realtor-scope .container-wide{ max-width: 1340px; margin: 0 auto; padding: 0 var(--s-6); }.realtor-scope .eyebrow{
