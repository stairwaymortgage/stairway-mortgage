      line-height: 1.45;
      color: var(--ink);
      font-weight: 350;
      font-variation-settings: "opsz" 30;
    }.realtor-scope .body-text{ color: var(--ink-2); }.realtor-scope .text-muted{ color: var(--ink-lighter); }.realtor-scope .text-small{ font-size: var(--text-sm); }.realtor-scope .text-mono{ font-family: var(--mono); font-feature-settings: 'tnum' 1; }.realtor-scope strong, .realtor-scope b{ font-weight: 600; color: var(--ink); }.realtor-scope em, .realtor-scope i{ font-style: italic; }.realtor-scope .nav{
