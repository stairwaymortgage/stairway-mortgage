  <section class="section">
    <div class="container">
      <div class="section-header" style="text-align: center; max-width: 720px; margin: 0 auto var(--s-8);">
        <div class="eyebrow">09 &middot; Musician mortgage FAQs</div>
        <h2>Musician and songwriter mortgage questions, answered.</h2>
      </div>

      <div class="faq-list">

        <div class="faq-cross-links" style="margin-bottom: var(--s-10); padding: var(--s-6); background: var(--paper-warm); border-left: 3px solid var(--blue);">
          <p style="margin: 0 0 var(--s-3) 0; font-family: var(--serif); font-size: var(--text-md); font-weight: 500;">More <a href="https://stairwaymortgage.com/creative-earners/" style="color: inherit; text-decoration: underline;">musician mortgage</a> resources at Stairway</p>
          <ul style="margin: 0; padding-left: var(--s-5); font-size: var(--text-sm); line-height: 1.7; list-style: none;">
