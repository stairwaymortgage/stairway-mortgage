---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Today's Rates — Stairway Mortgage" description="Live wholesale rate check. 300+ lenders competing for your loan.">
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">Tools & Rates · Current Rates</span>
        <h1 class="display-xl mt-6 mb-6">Today's <em class="italic text-[var(--color-blue)]">rates</em>.</h1>
        <p class="lede max-w-xl mx-auto mb-8">Rates change daily. Get a personalized rate quote from 300+ lenders — no credit pull required.</p>
        <div class="card max-w-lg mx-auto p-8 text-center">
          <p class="font-display text-xl mb-4">Get your personalized rate</p>
          <p class="text-[14px] text-[var(--color-mute)]"><!-- TODO: Connect live rate feed API --> For now, talk to our team for a real-time quote.</p>
        </div>
        <div class="flex flex-wrap gap-3 justify-center mt-10">
          <a href="/same-day-approval/" class="btn btn-blue btn-arrow text-base px-6 py-3.5">See My Options</a>
          <a href="tel:+19549931625" class="btn btn-ghost text-base px-6 py-3.5">Call (954) 993-1625</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
