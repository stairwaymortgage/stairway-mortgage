---
// src/pages/current-rates.astro — rebuilt from WP XML. Optimal Blue OBMMI widget
// (re-themed to forest/cream) + 5 FRED rate charts. Iframes responsive on mobile.
import Layout from '../layouts/Layout.astro';

const FRED = [
  { id: '1M5nF', label: '15-Year Fixed Rate Mortgage Average' },
  { id: '1M5nL', label: '30-Year Fixed Rate Mortgage Average' },
  { id: '1M5nP', label: '30-Year Fixed Rate FHA Mortgage Index' },
  { id: '1M5nT', label: '30-Year Fixed Rate USDA Mortgage Index' },
  { id: '1M5nR', label: '30-Year Fixed Rate Jumbo Mortgage Index' },
];
const OB_SRC = `https://www2.optimalblue.com/OBMMI/widgetConfig.php?actbg=1f3d34&actcolor=f7f5ef&inactbg=15302a&hoverBG=2e5648&cell=ffffff&borders=e3e0d6&text=1a2420&rate=1a2420&pos=2E9E2E&neg=8B2C2C&footer=6b7770&graph1=2f47c9&graph2=1f3d34&graph3=6b7770&graph4=2E9E2E&graph5=8B2C2C&graph6=E0A96D&chartRange=90`;
---
<Layout
  title="Current Mortgage Rate Trends | Stairway Mortgage"
  description="Track live mortgage rate trends — 15-year, 30-year fixed, FHA, USDA, and jumbo — with data from Optimal Blue and the Federal Reserve. Lock in strategically.">
  <main class="rates">
    <section class="r-hero">
      <div class="r-hero__inner">
        <p class="r-eyebrow">Market Data &middot; Updated Daily</p>
        <h1 class="r-hero__title">Current mortgage rate trends.</h1>
        <p class="r-hero__lead">Serious questions deserve smart answers. Track where rates are heading with live market data — then lock in strategically, not emotionally. Rates shown are market averages, not personalized quotes.</p>
        <a class="r-btn r-btn--lg" href="/discovery-quiz/">See My Options &rarr;</a>
      </div>
    </section>

    <section class="r-section">
      <div class="r-section__head">
        <h2 class="r-h2">Live rate index</h2>
        <p class="r-note">Real-time mortgage market index from Optimal Blue, themed to our palette.</p>
      </div>
      <div class="r-embed r-embed--ob">
        <iframe src={OB_SRC} title="Optimal Blue mortgage rate index" loading="lazy" frameborder="0"></iframe>
      </div>
    </section>

    <section class="r-section">
      <div class="r-section__head">
        <h2 class="r-h2">Historical rate charts</h2>
        <p class="r-note">Federal Reserve (FRED) data across loan types. Hover any chart for detail.</p>
      </div>
      <div class="r-grid">
        {FRED.map(f => (
          <figure class="r-chart">
            <figcaption class="r-chart__cap">{f.label}</figcaption>
            <div class="r-embed">
              <iframe src={`https://fred.stlouisfed.org/graph/graph-landing.php?g=${f.id}&width=670&height=475`}
                title={f.label} scrolling="no" frameborder="0"
                style="overflow:hidden; border:0;"
                loading="lazy" allowtransparency="true"></iframe>
            </div>
          </figure>
        ))}
      </div>
    </section>

    <section class="r-alert">
      <div class="r-alert__inner">
        <p class="r-eyebrow r-eyebrow--royal">Rate alerts</p>
        <h2 class="r-h2">Track the exact rate you want.</h2>
        <p class="r-note">Tell us your target rate and we will let you know the moment the market hits it — so you lock in strategically, not emotionally.</p>
        <div class="r-cta__actions">
          <a class="r-btn r-btn--lg" href="/discovery-quiz/">Get My Rate</a>
          <a class="r-btn r-btn--ghost" href="/schedule-call/">Talk to Our Team</a>
        </div>
      </div>
    </section>
  </main>
  <style is:global>
    .rates { background: var(--color-cream,#f7f5ef); color: var(--color-ink,#1a2420); }
    .r-eyebrow { font-family:var(--stw-mono,'JetBrains Mono'),monospace; font-size:.66rem; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#9db8ad; margin:0 0 .8rem; }
    .r-eyebrow--royal { color:var(--color-royal,#2f47c9); }
    .r-hero { background:var(--color-forest,#1f3d34); color:#f4f5ef; padding:clamp(3rem,7vw,5rem) 1.25rem; }
    .r-hero__inner { max-width:1040px; margin:0 auto; }
    .r-hero__title { font-family:var(--stw-display,'Fraunces'),Georgia,serif; font-weight:600; font-size:clamp(2.2rem,5vw,3.6rem); line-height:1.05; letter-spacing:-.02em; margin:0 0 1rem; color:#f4f5ef; max-width:16ch; }
    .r-hero__lead { font-size:clamp(1rem,1.6vw,1.18rem); line-height:1.6; color:#c9d6cf; max-width:60ch; margin:0 0 2rem; }
    .r-section { max-width:1180px; margin:0 auto; padding:clamp(2.5rem,5vw,4rem) 1.25rem; }
    .r-section__head { margin-bottom:1.8rem; }
    .r-h2 { font-family:var(--stw-display,'Fraunces'),serif; font-weight:600; font-size:clamp(1.6rem,3.5vw,2.3rem); margin:0 0 .4rem; }
    .r-note { color:var(--color-muted,#6b7770); line-height:1.55; max-width:56ch; }
    /* Responsive iframe wrapper — never overflows mobile */
    .r-embed { position:relative; width:100%; max-width:100%; background:#fff; border:1px solid var(--color-line,#e3e0d6); border-radius:14px; overflow:hidden; }
    .r-embed iframe { display:block; width:100%; border:0; }
    .r-embed--ob { aspect-ratio:16/10; }
    .r-embed--ob iframe { width:100%; height:100%; position:absolute; inset:0; }
    .r-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:1.5rem; }
    .r-chart { margin:0; background:#fff; border:1px solid var(--color-line,#e3e0d6); border-radius:14px; padding:1.2rem; }
    .r-chart__cap { font-family:var(--stw-display,'Fraunces'),serif; font-weight:500; font-size:1.05rem; margin-bottom:.8rem; }
    .r-chart .r-embed { position:relative; width:100%; max-width:670px; margin:0 auto; border:0; }
    .r-chart .r-embed iframe { width:100%; height:525px; display:block; }
    .r-alert { background:var(--color-forest,#1f3d34); color:#f4f5ef; padding:clamp(3rem,6vw,4.5rem) 1.25rem; text-align:center; }
    .r-alert__inner { max-width:640px; margin:0 auto; }
    .r-alert .r-h2, .r-alert .r-eyebrow { color:#f4f5ef; }
    .r-alert .r-note { color:#c9d6cf; margin:0 auto 1.8rem; }
    .r-cta__actions { display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; }
    .r-btn { display:inline-flex; align-items:center; background:var(--color-royal,#2f47c9); color:#fff; text-decoration:none; font-family:var(--stw-body,'Inter'),sans-serif; font-weight:600; font-size:.95rem; padding:.85rem 1.7rem; border-radius:999px; transition:transform .15s, box-shadow .15s; }
    .r-btn:hover { transform:translateY(-2px); box-shadow:0 10px 24px rgba(47,71,201,.28); }
    .r-btn--ghost { background:transparent; border:1.5px solid #f4f5ef; }
    @media (max-width:760px){ .r-grid { grid-template-columns:1fr; } }
    @media (max-width:700px){ .r-chart .r-embed iframe { height:460px; } }
  </style>
  <script is:inline src="https://fred.stlouisfed.org/graph/js/embed.js"></script>
</Layout>
