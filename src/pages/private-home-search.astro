---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Private Home Search — Stairway Mortgage" description="MLS access, no spam. Search homes privately.">
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">Tools · Private Home Search</span>
        <h1 class="display-xl mt-6 mb-6">Search homes <em class="italic text-[var(--color-blue)]">privately</em>.</h1>
        <p class="lede max-w-xl mx-auto mb-8">Full MLS access without the spam. Get pre-approved so you are ready when you find the right home.</p>
        <div class="card max-w-lg mx-auto p-8 text-center">
          <p class="text-[14px] text-[var(--color-mute)]"><!-- TODO: Wire MLS search --> Private search coming soon. Get pre-approved in the meantime.</p>
        </div>
        <div class="flex flex-wrap gap-3 justify-center mt-10">
          <a href="/same-day-approval/" class="btn btn-blue btn-arrow text-base px-6 py-3.5">Get Pre-Approved First</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
