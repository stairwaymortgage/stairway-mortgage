---
import Layout from '../layouts/Layout.astro';
import { GHL_WEBHOOK_URL } from '../lib/ghl';
---

<Layout title="Private Home Search — Stairway Mortgage" description="Search homes privately on a professional-grade portal — no spam, no agents turned loose on you. Plus a hand-picked shortlist of top local agents, matched to you. Free, no obligation.">

<div class="phs-scope" id="phs-top">

  <!-- ============================================================
       HERO
  ============================================================ -->
  <section class="phs-hero">
    <div class="phs-hero-inner phs-container">

      <!-- LEFT COPY -->
      <div class="phs-hero-copy">
        <p class="phs-eyebrow">Free Tools &middot; Home Search</p>
        <h1 class="phs-h1">Search homes<br><em>privately.</em></h1>
        <p class="phs-lede">A professional-grade home search portal — the real MLS, 3D tours, and instant alerts — with no spam and no agents turned loose on you. Plus a hand-picked shortlist of top local agents, matched to you. All free.</p>
        <ul class="phs-bullets">
          <li>
            <span class="phs-bullet-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="#1B4FD8"/><path d="M5 9.5L7.5 12L13 6.5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            Private portal access — no ads, no lead-selling, no spam calls
          </li>
          <li>
            <span class="phs-bullet-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="#1B4FD8"/><path d="M5 9.5L7.5 12L13 6.5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            A shortlist of vetted local agents, chosen for your criteria
          </li>
          <li>
            <span class="phs-bullet-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="#1B4FD8"/><path d="M5 9.5L7.5 12L13 6.5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            Pre-approval ready, so the home you love becomes an offer you win
          </li>
        </ul>
        <p class="phs-trust-line">Jim Blackburn &middot; NMLS&nbsp;#1072866 &middot; 5.0&#9733; &middot; Free, no obligation</p>
      </div>

      <!-- RIGHT FORM CARD -->
      <div class="phs-formcard">
        <h2 class="phs-formcard-heading">Get private search access</h2>
        <p class="phs-formcard-sub">Tell us where you're looking. We'll set up your private portal and prepare your agent shortlist.</p>

        <div id="phs-form" data-ghl-endpoint={GHL_WEBHOOK_URL}>
          <div class="phs-field-row">
            <div class="phs-field">
              <label class="phs-label" for="phs-first">First Name</label>
              <input class="phs-input" id="phs-first" name="first_name" type="text" placeholder="Jane" autocomplete="given-name" />
            </div>
            <div class="phs-field">
              <label class="phs-label" for="phs-last">Last Name</label>
              <input class="phs-input" id="phs-last" name="last_name" type="text" placeholder="Smith" autocomplete="family-name" />
            </div>
          </div>
          <div class="phs-field">
            <label class="phs-label" for="phs-email">Email</label>
            <input class="phs-input" id="phs-email" name="email" type="email" placeholder="jane@example.com" autocomplete="email" />
          </div>
          <div class="phs-field">
            <label class="phs-label" for="phs-location">Where are you looking?</label>
            <input class="phs-input" id="phs-location" name="location" type="text" placeholder="City, neighborhood, or ZIP" />
          </div>
          <div class="phs-field">
            <label class="phs-label" for="phs-phone">Phone <span class="phs-optional">(Optional)</span></label>
            <input class="phs-input" id="phs-phone" name="phone" type="tel" placeholder="(555) 000-0000" autocomplete="tel" />
            <p class="phs-field-note">We will not call you unless you want us to.</p>
          </div>

          <p id="phs-error" class="phs-error phs-hidden" role="alert"></p>

          <!-- Honeypot -->
          <input type="text" id="phs-gotcha" name="gotcha" aria-hidden="true" tabindex="-1" autocomplete="off" style="display:none;" />

          <button id="phs-submit" class="phs-btn-primary phs-btn-full" type="button">
            Set Up My Search
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M3.75 9h10.5M9.75 4.5L14.25 9l-4.5 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>

        <!-- SUCCESS STATE -->
        <div id="phs-success" class="phs-success phs-hidden" role="status">
          <div class="phs-success-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none"><circle cx="20" cy="20" r="20" fill="#1B4FD8"/><path d="M11 21L16.5 26.5L29 13.5" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="phs-success-heading">You're in.</h3>
          <p class="phs-success-body">Here's what happens next:</p>
          <ol class="phs-success-steps">
            <li><strong>Portal setup</strong> — We configure your private home search with your criteria. No ads, no lead brokers.</li>
            <li><strong>Agent shortlist</strong> — We hand-pick 2–3 local agents matched to your area and goals.</li>
            <li><strong>You're in control</strong> — Browse on your schedule. Reach out when you're ready.</li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       WHAT YOU UNLOCK — split section
  ============================================================ -->
  <section class="phs-section phs-unlock">
    <div class="phs-container phs-split">
      <div class="phs-split-copy">
        <p class="phs-eyebrow phs-eyebrow-dark">What you unlock</p>
        <h2 class="phs-h2">A private portal built for serious buyers.</h2>
        <p class="phs-body-text">Public search sites sell your information the moment you register. Your private portal does the opposite — it's built on a professional MLS feed and configured just for you, with no ads, no data brokering, and no flood of agent calls.</p>
        <ul class="phs-deliver">
          <li>
            <span class="phs-deliver-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill="#1B4FD8"/><path d="M6 10.5L8.5 13L14 7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            Real MLS data — the same listings agents see, updated every few minutes
          </li>
          <li>
            <span class="phs-deliver-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill="#1B4FD8"/><path d="M6 10.5L8.5 13L14 7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            3D tours, floor plans, and detailed photos without a showing commitment
          </li>
          <li>
            <span class="phs-deliver-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill="#1B4FD8"/><path d="M6 10.5L8.5 13L14 7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            Instant alerts the moment a matching home hits the market
          </li>
          <li>
            <span class="phs-deliver-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill="#1B4FD8"/><path d="M6 10.5L8.5 13L14 7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            Neighborhood insights, school data, and walkability scores
          </li>
          <li>
            <span class="phs-deliver-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill="#1B4FD8"/><path d="M6 10.5L8.5 13L14 7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            Your information stays private — we never sell or share your data
          </li>
        </ul>
      </div>
      <!-- Dark portal mockup -->
      <div class="phs-split-visual">
        <div class="phs-dash" role="img" aria-label="Private home search portal mockup">
          <div class="phs-dash-topbar">
            <span class="phs-dash-dot phs-dot-red"></span>
            <span class="phs-dash-dot phs-dot-yellow"></span>
            <span class="phs-dash-dot phs-dot-green"></span>
            <span class="phs-dash-title">My Private Search</span>
          </div>
          <div class="phs-dash-body">
            <div class="phs-dash-listings">
              <div class="phs-dash-listing" style="background-image:url('https://images.pexels.com/photos/106399/pexels-photo-106399.jpeg?auto=compress&cs=tinysrgb&w=600')">
                <span class="phs-dash-price">$489,000</span>
                <span class="phs-dash-badge">New</span>
              </div>
              <div class="phs-dash-listing" style="background-image:url('https://images.pexels.com/photos/1396122/pexels-photo-1396122.jpeg?auto=compress&cs=tinysrgb&w=600')">
                <span class="phs-dash-price">$562,500</span>
              </div>
              <div class="phs-dash-listing" style="background-image:url('https://images.pexels.com/photos/1029599/pexels-photo-1029599.jpeg?auto=compress&cs=tinysrgb&w=600')">
                <span class="phs-dash-price">$374,900</span>
              </div>
            </div>
            <div class="phs-dash-map">
              <div class="phs-map-pin phs-pin-1" aria-hidden="true">
                <svg width="14" height="18" viewBox="0 0 14 18" fill="none"><path d="M7 0C3.13 0 0 3.13 0 7c0 5.25 7 11 7 11s7-5.75 7-11c0-3.87-3.13-7-7-7z" fill="#1B4FD8"/><circle cx="7" cy="7" r="2.5" fill="#fff"/></svg>
              </div>
              <div class="phs-map-pin phs-pin-2" aria-hidden="true">
                <svg width="14" height="18" viewBox="0 0 14 18" fill="none"><path d="M7 0C3.13 0 0 3.13 0 7c0 5.25 7 11 7 11s7-5.75 7-11c0-3.87-3.13-7-7-7z" fill="#1B4FD8"/><circle cx="7" cy="7" r="2.5" fill="#fff"/></svg>
              </div>
              <div class="phs-map-pin phs-pin-3" aria-hidden="true">
                <svg width="14" height="18" viewBox="0 0 14 18" fill="none"><path d="M7 0C3.13 0 0 3.13 0 7c0 5.25 7 11 7 11s7-5.75 7-11c0-3.87-3.13-7-7-7z" fill="#1B4FD8"/><circle cx="7" cy="7" r="2.5" fill="#fff"/></svg>
              </div>
              <div class="phs-dash-ai-chip">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><rect x="3" y="3" width="6" height="6" rx="1" fill="#1B4FD8"/><path d="M1 4h1M1 8h1M10 4h1M10 8h1M4 1v1M8 1v1M4 10v1M8 10v1" stroke="#1B4FD8" stroke-width="1" stroke-linecap="round"/></svg>
                AI match
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       INSIDE YOUR PORTAL — 6-card feature grid
  ============================================================ -->
  <section class="phs-section phs-section-tint phs-features">
    <div class="phs-container">
      <p class="phs-eyebrow phs-eyebrow-center">Inside your portal</p>
      <h2 class="phs-h2 phs-center">Everything serious buyers actually need.</h2>
      <div class="phs-fcard-grid">
        <div class="phs-fcard">
          <div class="phs-fcard-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="2" y="4" width="24" height="20" rx="3" stroke="#1B4FD8" stroke-width="2"/><path d="M2 10h24" stroke="#1B4FD8" stroke-width="2"/><path d="M8 7V2M20 7V2" stroke="#1B4FD8" stroke-width="2" stroke-linecap="round"/><rect x="7" y="14" width="4" height="4" rx="1" fill="#1B4FD8"/><rect x="13" y="14" width="4" height="4" rx="1" fill="#1B4FD8"/></svg>
          </div>
          <h3 class="phs-fcard-title">Real MLS Feed</h3>
          <p class="phs-fcard-body">The same listings your agent sees — updated every few minutes, not hours. No Zillow delay, no missing listings.</p>
        </div>
        <div class="phs-fcard">
          <div class="phs-fcard-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="10" stroke="#1B4FD8" stroke-width="2"/><path d="M14 8v6l4 2" stroke="#1B4FD8" stroke-width="2" stroke-linecap="round"/></svg>
          </div>
          <h3 class="phs-fcard-title">Instant Alerts</h3>
          <p class="phs-fcard-body">Be notified the moment a matching home hits the market. In competitive markets, hours matter.</p>
        </div>
        <div class="phs-fcard">
          <div class="phs-fcard-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="4" y="4" width="20" height="20" rx="3" stroke="#1B4FD8" stroke-width="2"/><path d="M9 10h10M9 14h10M9 18h6" stroke="#1B4FD8" stroke-width="2" stroke-linecap="round"/></svg>
          </div>
          <h3 class="phs-fcard-title">3D Tours &amp; Floor Plans</h3>
          <p class="phs-fcard-body">Walk through homes virtually before scheduling a showing. Save your time for the homes that truly fit.</p>
        </div>
        <div class="phs-fcard">
          <div class="phs-fcard-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 3L17.09 9.26L24 10.27L19 15.14L20.18 22.02L14 18.77L7.82 22.02L9 15.14L4 10.27L10.91 9.26L14 3Z" stroke="#1B4FD8" stroke-width="2" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="phs-fcard-title">Saved Favorites</h3>
          <p class="phs-fcard-body">Bookmark and compare homes privately. Your list, your timeline — no agent pressure to move faster than you want.</p>
        </div>
        <div class="phs-fcard">
          <div class="phs-fcard-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 4C9.58 4 6 7.58 6 12c0 6 8 14 8 14s8-8 8-14c0-4.42-3.58-8-8-8z" stroke="#1B4FD8" stroke-width="2"/><circle cx="14" cy="12" r="3" stroke="#1B4FD8" stroke-width="2"/></svg>
          </div>
          <h3 class="phs-fcard-title">Neighborhood Insights</h3>
          <p class="phs-fcard-body">School ratings, walkability, commute times, and local market trends — all in one place, before you ever schedule a visit.</p>
        </div>
        <div class="phs-fcard">
          <div class="phs-fcard-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="4" y="6" width="14" height="18" rx="2" stroke="#1B4FD8" stroke-width="2"/><path d="M18 8h4a2 2 0 012 2v12a2 2 0 01-2 2h-4" stroke="#1B4FD8" stroke-width="2"/><path d="M8 11h6M8 15h6M8 19h4" stroke="#1B4FD8" stroke-width="2" stroke-linecap="round"/></svg>
          </div>
          <h3 class="phs-fcard-title">Market Reports</h3>
          <p class="phs-fcard-body">Median prices, days on market, list-to-sale ratios — the data you need to make a confident offer, not an emotional one.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PRIVACY DARK CARD
  ============================================================ -->
  <section class="phs-section phs-privacy">
    <div class="phs-container">
      <div class="phs-privacy-card">
        <div class="phs-privacy-copy">
          <p class="phs-eyebrow phs-eyebrow-light">Your privacy</p>
          <h2 class="phs-h2 phs-light">Search in peace.</h2>
          <p class="phs-body-text phs-light-muted">When you register on public sites, your information is sold as a lead. Within hours you're fielding calls from agents who know nothing about you except that you clicked on a house. Your private portal works differently.</p>
          <p class="phs-privacy-trust">Jim Blackburn &middot; NMLS&nbsp;#1072866 &middot; Your info stays with us, full stop.</p>
        </div>
        <div class="phs-privacy-noise">
          <div class="phs-noise-heading">What you'll never get from us</div>
          <div class="phs-noise-row phs-noise-row--crossed">
            <svg class="phs-noise-x" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 4l8 8M12 4l-8 8" stroke="#e53e3e" stroke-width="2" stroke-linecap="round"/></svg>
            Cold calls from agents you never contacted
          </div>
          <div class="phs-noise-row phs-noise-row--crossed">
            <svg class="phs-noise-x" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 4l8 8M12 4l-8 8" stroke="#e53e3e" stroke-width="2" stroke-linecap="round"/></svg>
            Your email sold to listing alert services
          </div>
          <div class="phs-noise-row phs-noise-row--crossed">
            <svg class="phs-noise-x" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 4l8 8M12 4l-8 8" stroke="#e53e3e" stroke-width="2" stroke-linecap="round"/></svg>
            Retargeting ads following you across the internet
          </div>
          <div class="phs-noise-row phs-noise-row--crossed">
            <svg class="phs-noise-x" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 4l8 8M12 4l-8 8" stroke="#e53e3e" stroke-width="2" stroke-linecap="round"/></svg>
            "Just checking in" texts from strangers
          </div>
          <div class="phs-noise-row phs-noise-row--crossed">
            <svg class="phs-noise-x" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 4l8 8M12 4l-8 8" stroke="#e53e3e" stroke-width="2" stroke-linecap="round"/></svg>
            Your data brokered to anyone, ever
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       THE QUIET ADVANTAGE — 3-step
  ============================================================ -->
  <section class="phs-section phs-section-tint phs-quiet">
    <div class="phs-container phs-split phs-split-reverse">
      <div class="phs-split-visual phs-quiet-visual">
        <img
          src="https://images.pexels.com/photos/1370704/pexels-photo-1370704.jpeg?auto=compress&cs=tinysrgb&w=800"
          alt="Couple reviewing home details on a laptop, quietly, without pressure"
          class="phs-quiet-img"
          loading="lazy"
          onerror="this.src='https://placehold.co/600x420/e2e8f0/64748b?text=Home+Search'"
        />
      </div>
      <div class="phs-split-copy">
        <p class="phs-eyebrow phs-eyebrow-dark">The quiet advantage</p>
        <h2 class="phs-h2">Shop on your schedule. Move when you're ready.</h2>
        <p class="phs-body-text">The biggest mistake buyers make is rushing because they feel watched. Your private portal removes that pressure. Browse freely, save what you love, and reach out only when you have a real question.</p>
        <ol class="phs-deliver phs-deliver-numbered">
          <li>
            <span class="phs-deliver-num">1</span>
            <div>
              <strong>Set your criteria</strong> — bedrooms, budget, neighborhood, must-haves. We configure the portal to match.
            </div>
          </li>
          <li>
            <span class="phs-deliver-num">2</span>
            <div>
              <strong>Browse in private</strong> — no one is watching what you save, how many times you view a listing, or when you log in.
            </div>
          </li>
          <li>
            <span class="phs-deliver-num">3</span>
            <div>
              <strong>Reach out on your terms</strong> — when you find something you love, we introduce you to a vetted local agent who already knows your criteria.
            </div>
          </li>
        </ol>
      </div>
    </div>
  </section>

  <!-- ============================================================
       AGENT SHORTLIST REPORT CARD
  ============================================================ -->
  <section class="phs-section phs-agent-section">
    <div class="phs-container phs-split">
      <div class="phs-split-copy">
        <p class="phs-eyebrow phs-eyebrow-dark">Agent shortlist</p>
        <h2 class="phs-h2">The right agent. Chosen for you. No auditions.</h2>
        <p class="phs-body-text">Finding a good buyer's agent is harder than it looks. We maintain relationships with top local agents in markets across the country — and we match you to the right one based on your area, price range, and transaction type.</p>
        <ol class="phs-deliver phs-deliver-numbered">
          <li>
            <span class="phs-deliver-num">1</span>
            <div><strong>Tell us your criteria</strong> — area, budget, timeline, any special circumstances (investor, relocation, first-time buyer).</div>
          </li>
          <li>
            <span class="phs-deliver-num">2</span>
            <div><strong>We vet the field</strong> — transaction volume, local knowledge, communication style, buyer reviews.</div>
          </li>
          <li>
            <span class="phs-deliver-num">3</span>
            <div><strong>You get a shortlist</strong> — 2–3 agents who meet the bar, with a brief on each. You choose, or ask us who we'd pick.</div>
          </li>
          <li>
            <span class="phs-deliver-num">4</span>
            <div><strong>Introduction on your schedule</strong> — when you're ready to connect, not before.</div>
          </li>
        </ol>
      </div>
      <!-- Report card mockup -->
      <div class="phs-split-visual">
        <div class="phs-report-card">
          <div class="phs-rc-header">
            <span class="phs-rc-label">Your Agent Shortlist</span>
            <span class="phs-rc-badge">Confidential</span>
          </div>
          <div class="phs-rc-agent">
            <div class="phs-rc-avatar" aria-hidden="true">SR</div>
            <div class="phs-rc-info">
              <div class="phs-rc-name">Sarah R.</div>
              <div class="phs-rc-meta">127 transactions &middot; North Denver</div>
              <div class="phs-rc-stars" aria-label="5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            </div>
            <div class="phs-rc-match">Top Pick</div>
          </div>
          <div class="phs-rc-agent">
            <div class="phs-rc-avatar phs-rc-avatar-2" aria-hidden="true">MK</div>
            <div class="phs-rc-info">
              <div class="phs-rc-name">Marcus K.</div>
              <div class="phs-rc-meta">89 transactions &middot; Aurora / Stapleton</div>
              <div class="phs-rc-stars" aria-label="5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            </div>
            <div class="phs-rc-match phs-rc-match-2">Strong fit</div>
          </div>
          <div class="phs-rc-agent">
            <div class="phs-rc-avatar phs-rc-avatar-3" aria-hidden="true">TL</div>
            <div class="phs-rc-info">
