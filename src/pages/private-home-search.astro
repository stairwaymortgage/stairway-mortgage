<script is:inline>
(function(){
  var wrap=document.getElementById('phs-form');
  if(!wrap)return;
  var ENDPOINT=wrap.getAttribute('data-ghl-endpoint')||'';
  var errEl=document.getElementById('phs-error');
  var sending=false;

  function showErr(m){errEl.textContent=m;errEl.classList.remove('phs-hidden');}

  function _getCookie(n){var m=document.cookie.match(new RegExp('(?:^|;\\s*)'+n+'=([^;]+)'));return m?decodeURIComponent(m[1]):'';}
  function _qs(n){try{return new URL(location.href).searchParams.get(n)||'';}catch(e){return '';}}
  function _cleanUmtid(v){return v?String(v).replace(/[^A-Za-z0-9_-]/g,'').slice(0,40):'';}
  function _resolveUmtid(){return _cleanUmtid(_qs('umtid'))||_cleanUmtid(_getCookie('umtid'))||'';}
  function _resolveLoid(){
    var raw = _qs('loid') || _qs('lo_id') || _qs('first_touch_loid') || _getCookie('first_touch_loid') || '';
    var m = String(raw).match(/(\d{3,})/);
    return m ? m[1] : '';
  }

  function showSuccess(){
    var form=document.getElementById('phs-form');if(form)form.style.display='none';
    var s=document.getElementById('phs-success');if(s)s.classList.remove('phs-hidden');
    var top=document.getElementById('phs-top');if(top&&top.scrollIntoView)top.scrollIntoView({behavior:'smooth',block:'center'});
  }

  function submitForm(btn){
    if(sending)return;
    var gotcha=document.getElementById('phs-gotcha');
    if(gotcha&&gotcha.value.trim()!==''){showSuccess();return;}

    function val(id){var el=document.getElementById(id);return el&&el.value?el.value.trim():'';}
    var first=val('phs-first'),last=val('phs-last'),email=val('phs-email'),loc=val('phs-location'),phone=val('phs-phone');

    if(!first||!last)return showErr('Please enter your first and last name.');
    var _em=email.trim(); if(!/^[^\s@]{2,}@[^\s@]+\.[A-Za-z]{2,}$/.test(_em)||/\.\./.test(_em))return showErr('Please enter a valid email.');
    if(!loc)return showErr('Please tell us where you are looking.');
    if(phone){var _pd=phone.replace(/\D/g,''); if(_pd.length<10||_pd.length>15)return showErr('That phone number looks incomplete — leave it blank if you prefer not to share it.');}
    errEl.classList.add('phs-hidden');

    var payload={
      first_name:first, last_name:last, full_name:(first+' '+last).trim(),
      email:email, phone:phone,
      form_source:'private_home_search', form_name:'Private Home Search',
      page_url:window.location.href, submitted_at:new Date().toISOString(),
      notes:'Search location: '+loc+(phone?'':' | (no phone — opted out of call)'),
      umtid: _resolveUmtid(),
      loid: _resolveLoid(),
      utm_source: _qs('utm_source')||_getCookie('utm_source')||'',
      utm_medium: _qs('utm_medium')||_getCookie('utm_medium')||'',
      utm_campaign: _qs('utm_campaign')||_getCookie('utm_campaign')||'',
      utm_term: _qs('utm_term')||_getCookie('utm_term')||'',
      utm_content: _qs('utm_content')||_getCookie('utm_content')||'',
      source_url: _getCookie('first_touch_url')||location.href
    };

    sending=true;
    if(btn){btn.disabled=true;btn.dataset.label=btn.textContent;btn.textContent='Sending\u2026';}
    fetch(ENDPOINT,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)})
      .then(function(){showSuccess();})
      .catch(function(){showErr('Something went wrong. Please try again or call us.');})
      .then(function(){sending=false;if(btn){btn.disabled=false;btn.textContent=btn.dataset.label||'Set Up My Search';}});
  }

  var btn=document.getElementById('phs-submit');
  if(btn)btn.addEventListener('click',function(){submitForm(btn);});

  // Enter-key submit guard on all fields
  ['phs-first','phs-last','phs-email','phs-location','phs-phone'].forEach(function(id){
    var el=document.getElementById(id);
    if(el)el.addEventListener('keydown',function(e){if(e.key==='Enter'){e.preventDefault();submitForm(btn);}});
  });
})();
</script>
