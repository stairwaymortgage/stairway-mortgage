    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
  }

  .phs-scope .phs-split-reverse {
    direction: rtl;
  }

  .phs-scope .phs-split-reverse > * {
    direction: ltr;
  }

  /* ============================================================
