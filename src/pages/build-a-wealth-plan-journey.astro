---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Build a Wealth Plan — Stairway Mortgage" description="Use real estate as a wealth engine. Strategic planning from first property to legacy.">
  <section class="section">
    <div class="container-page text-center max-w-2xl mx-auto">
      <span class="eyebrow eyebrow-blue mb-5">How We Serve</span>
      <h1 class="display-lg mt-5 mb-6">Build a Wealth Plan</h1>
      <p class="lede mb-10">This page is being built. Talk to Jim to get started today.</p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/same-day-approval/" class="btn btn-blue btn-arrow">See My Options</a>
        <a href="/contact-us/" class="btn btn-ghost">Talk to Jim</a>
      </div>
    </div>
  </section>
</Layout>
