---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Refinance or HELOC Quote — Stairway Mortgage" description="See if lowering your rate or tapping equity makes sense.">
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">Quick Quote · Refinance or HELOC</span>
        <h1 class="display-xl mt-6 mb-6">Get your <em class="italic text-[var(--color-blue)]">refi quote</em>.</h1>
        <p class="lede max-w-xl mx-auto mb-8">Lower your rate, shorten your term, or access equity. We show you the numbers.</p>
        <div class="flex flex-wrap gap-3 justify-center mt-10">
          <a href="/refinance-or-heloc-journey/" class="btn btn-blue btn-arrow text-base px-6 py-3.5">See My Options</a>
          <a href="tel:+19549931625" class="btn btn-ghost text-base px-6 py-3.5">Call (954) 993-1625</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
