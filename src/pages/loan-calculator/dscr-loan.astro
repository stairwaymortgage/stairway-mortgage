---
import Layout from '../../layouts/Layout.astro';
import CalcLeadForm from '../../components/CalcLeadForm.astro';
const metaTitle = "DSCR Loan Calculator for Investment Purchase: Estimate Your Loan, Payment, Cash Flow & 15/30-Year ROI";
const metaDescription = "Calculate your DSCR loan amount, monthly payment, net cash flow, and projected 15- and 30-year equity, cash flow, tax savings, and ROI on an investment property.";
const canonical = "https://stairwaymortgage.com/loan-calculator/dscr-loan/";
const breadcrumbSchema = {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://stairwaymortgage.com/"},{"@type":"ListItem","position":2,"name":"Loan Calculators","item":"https://stairwaymortgage.com/all-loan-calculators/"},{"@type":"ListItem","position":3,"name":"DSCR Investment Loan Calculator","item":canonical}]};
const appSchema = {"@context":"https://schema.org","@type":"WebApplication","name":"DSCR Investment Purchase Loan Payment Calculator","applicationCategory":"FinanceApplication","operatingSystem":"All","url":canonical,"offers":{"@type":"Offer","price":"0","priceCurrency":"USD"},"description":metaDescription};
const faqSchema = {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is a DSCR loan?","acceptedAnswer":{"@type":"Answer","text":"A DSCR (debt-service coverage ratio) loan qualifies an investment property on its rental income rather than your personal income. The loan amount is sized so the rent covers the property's total payment at your target DSCR ratio."}},{"@type":"Question","name":"What DSCR ratio do I need?","acceptedAnswer":{"@type":"Answer","text":"Most DSCR lenders require a minimum ratio of 1.0, some as high as 1.35. A few allow as low as 0.75, often with a slightly higher rate."}},{"@type":"Question","name":"How much down payment is required?","acceptedAnswer":{"@type":"Answer","text":"Most DSCR lenders require 20% down, though some programs allow as little as 15%."}}]};
---
<Layout title={metaTitle} description={metaDescription} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
<main class="container-page">
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href="/">Home</a> <span>/</span>
    <a href="/all-loan-calculators/">Loan Calculators</a> <span>/</span>
    <span aria-current="page">DSCR Investment Loan Calculator</span>
  </nav>
  <header class="calc-head">
    <p class="eyebrow">Investor · DSCR · Purchase</p>
    <h1 class="display-lg">DSCR Investment Purchase Loan Payment Calculator</h1>
    <p class="lede">Qualify on rental income, not personal income. Estimate your loan, payment, monthly cash flow, and your projected 15- and 30-year equity, cash flow, tax savings, and ROI.</p>
    <p class="trust">Built by Jim Blackburn · NMLS #1072866 · $500M+ closed · 7× Scotsman Guide Top Producer</p>
  </header>
  <section class="calc" aria-label="DSCR Investment Purchase Calculator">
    <div class="calc-grid">
      <div class="calc-inputs">
        <div class="field"><label for="price">Purchase Price</label><div class="input-money"><span>$</span><input id="price" type="number" inputmode="numeric" value="400000" min="0" step="1000" /></div></div>
        <div class="field"><label for="down">Down Payment Percentage <span class="val" id="downVal">15%</span></label><input id="down" type="range" min="15" max="100" step="1" value="15" /><p class="hint hint--mute">Most DSCR lenders require 20%; some allow as little as 15%.</p></div>
        <div class="field"><label for="rent">Estimated Rental Income</label><div class="input-money"><span>$</span><input id="rent" type="number" inputmode="numeric" value="4000" min="0" step="50" /></div><p class="hint hint--mute">Check Zillow for comparable rentals.</p></div>
        <div class="field"><label for="dscr">DSCR Ratio</label><div class="input-pct"><input id="dscr" type="number" inputmode="numeric" value="1" min="0.5" max="2" step="0.05" /><span>×</span></div><p class="hint hint--mute">Rent ÷ total PITIA. Most lenders want ≥ 1.0; a few allow 0.75.</p></div>
        <div class="field"><label for="rate">Estimated Interest Rate <span class="val" id="rateVal">7.49%</span></label><input id="rate" type="range" min="5" max="10" step="0.1" value="7.49" /></div>
        <div class="field-row">
          <div class="field"><label for="ins">Annual Insurance</label><div class="input-money"><span>$</span><input id="ins" type="number" inputmode="numeric" value="2400" min="0" step="100" /></div></div>
          <div class="field"><label for="tax">Annual Taxes</label><div class="input-money"><span>$</span><input id="tax" type="number" inputmode="numeric" value="5000" min="0" step="100" /></div></div>
        </div>
        <div class="field"><label for="hoa">Monthly HOA</label><div class="input-money"><span>$</span><input id="hoa" type="number" inputmode="numeric" value="0" min="0" step="10" /></div></div>
        <div class="field"><label for="taxbr">Tax Bracket %</label><div class="input-pct"><input id="taxbr" type="number" inputmode="numeric" value="24" min="0" max="40" step="1" /><span>%</span></div><p class="hint hint--mute">Used to estimate your depreciation tax benefit.</p></div>
        <div class="field">
          <span class="lbl">Are you thinking about buying another home after this one to continue your wealth journey?</span>
          <div class="radios" role="radiogroup" aria-label="Buying another home">
            <label><input type="radio" name="wealth" value="1" /> Yes</label>
            <label><input type="radio" name="wealth" value="2" checked /> No</label>
          </div>
        </div>
      </div>
      <div class="calc-results" aria-live="polite">
        <p class="summary-title">Summary</p>
        <div class="result result--primary"><span class="result-label">Maximum Loan per Rent</span><span class="result-value" id="rMaxLoan">$484,350</span><span class="result-note">To increase, raise the rent or lower the DSCR ratio (note: at 0.75, raise the rate ~0.5%).</span></div>
        <div class="result result--primary"><span class="result-label">Desired Loan Amount</span><span class="result-value" id="rDesired">$364,000</span></div>
        <div class="result result--primary"><span class="result-label">Net Monthly Income (Cash Flow)</span><span class="result-value" id="rNet">$841</span></div>
        <p class="summary-sub">Payment Breakdown</p>
        <div class="result"><span class="result-label">Principal &amp; Interest Payment</span><span class="result-value" id="rPI">$2,543</span></div>
        <div class="result"><span class="result-label">Monthly Insurance</span><span class="result-value" id="rIns">$200</span></div>
        <div class="result"><span class="result-label">Monthly Taxes</span><span class="result-value" id="rTax">$417</span></div>
        <div class="result"><span class="result-label">HOA Paid Separately</span><span class="result-value" id="rHOA">$0</span></div>
        <div class="result"><span class="result-label">Total Monthly Housing Expense</span><span class="result-value" id="rTotal">$3,159</span></div>
        <p class="summary-sub">Cash to Close</p>
        <div class="result"><span class="result-label">Cash Out of Pocket — without seller credit</span><span class="result-value" id="rCashNo">$84,000</span><span class="result-note">Includes 6% estimated closing costs; varies by state. Not a Loan Estimate.</span></div>
        <div class="result"><span class="result-label">Cash Out of Pocket — with 3% seller credit</span><span class="result-value" id="rCashSC">$72,000</span></div>
        <p class="summary-sub">15-Year Growth</p>
        <div class="result"><span class="result-label">Estimated Value (15 yrs)</span><span class="result-value" id="rVal15">$623,187</span><span class="result-note">Assumes 3% annual appreciation.</span></div>
        <div class="result"><span class="result-label">Mortgage Balance (15 yrs)</span><span class="result-value" id="rBal15">$274,452</span></div>
        <div class="result"><span class="result-label">Equity (15 yrs)</span><span class="result-value" id="rEq15">$348,735</span></div>
        <div class="result"><span class="result-label">Cash Flow Collected (15 yrs)</span><span class="result-value" id="rCf15">$187,630</span></div>
        <div class="result"><span class="result-label">Income Tax Saved — Depreciation (15 yrs)</span><span class="result-value" id="rTax15">$41,891</span></div>
        <div class="result result--primary"><span class="result-label">Total Return (15 yrs)</span><span class="result-value" id="rTot15">$578,255</span></div>
        <div class="result result--primary"><span class="result-label">Annual ROI % (15 yrs)</span><span class="result-value" id="rRoi15">12.08%</span><span class="result-note">After ~25% business expenses (management, vacancy, capex).</span></div>
        <p class="summary-sub">30-Year Growth</p>
        <div class="result"><span class="result-label">Estimated Value (30 yrs)</span><span class="result-value" id="rVal30">$970,905</span><span class="result-note">Assumes 3% annual appreciation.</span></div>
        <div class="result"><span class="result-label">Equity (30 yrs)</span><span class="result-value" id="rEq30">$970,905</span><span class="result-note">Mortgage fully paid after 30 years.</span></div>
        <div class="result"><span class="result-label">Cash Flow Collected (30 yrs)</span><span class="result-value" id="rCf30">$479,951</span></div>
        <div class="result"><span class="result-label">Income Tax Saved — Depreciation (30 yrs)</span><span class="result-value" id="rTax30">$83,782</span></div>
        <div class="result result--primary"><span class="result-label">Total Return (30 yrs)</span><span class="result-value" id="rTot30">$1,534,638</span></div>
        <div class="result result--primary"><span class="result-label">Annual ROI % (30 yrs)</span><span class="result-value" id="rRoi30">9.75%</span></div>
        <a class="cta-primary" data-calc-cta data-calc-slug="dscr-loan">See My Options</a>
        <p class="micro">Estimates only — not a commitment to lend. Not tax advice.</p>
      </div>
    </div>
  </section>
  <section class="body-content">
    <figure class="author">
      <a href="http://www.mortgagemanjim.com/linkedin%20" target="_blank" rel="noopener">
        <img width="120" height="120" src="https://stairwaymortgage.com/wp-content/uploads/2025/10/Untitled-design-3.png" alt="Jim Blackburn" />
      </a>
      <h3><a href="http://www.mortgagemanjim.com/linkedin%20" target="_blank" rel="noopener">By Jim Blackburn</a></h3>
    </figure>
    <div class="cta-card">
      <h4>Ready to Take Your First Step?</h4>
      <p><strong>Skip the guesswork.</strong> Take our quick Discovery Quiz to uncover your top financial priorities, so we can guide you toward the wealth-building strategies that fit your life.</p>
      <ul><li>Takes just 5 minutes</li><li>Tailored results based on your answers</li><li>No credit check required</li></ul>
      <a href="https://stairwaymortgage.com/discovery-quiz">Take the Discovery Quiz</a>
    </div>
    <div class="cta-card">
      <h4>Need a Pre-Approval Letter—Fast?</h4>
      <p>Buying a home soon? Complete our short form and we'll connect you with the best loan options for your target property and financial situation—fast.</p>
      <ul><li>Only 2 minutes to complete</li><li>Quick turnaround on pre-approval</li><li>No credit score impact</li></ul>
      <a href="https://stairwaymortgage.com/purchase-inquiry">Get Pre-Approved Now</a>
    </div>
    <div class="cta-card">
      <h4>Got a Few Questions First?</h4>
      <p>Let's talk it through. Book a call and one of our friendly advisors will be in touch to guide you personally.</p>
      <a href="https://stairwaymortgage.com/schedule-call">Schedule a Call</a>
    </div>
    <h2>Important Disclaimer</h2>
    <p>This calculator is for illustrative purposes only and does not constitute financial, legal, investment, or tax advice. Results are based on general assumptions and may not reflect actual performance or eligibility. This is not a loan estimate or approval. Please consult with a licensed mortgage advisor and a tax professional before making decisions.</p>
    <h2>Related Posts</h2>
    <div class="related-placeholder">Related calculators module ([loan_calculator_box])</div>
  </section>
</main>
<script is:inline>
(function () {
  const $ = (id) => document.getElementById(id);
  const fmt0 = (n) => (n<0?'-$':'$') + Math.abs(Math.round(n)).toLocaleString('en-US');
  const fmtP = (n) => n.toFixed(2)+'%';
  function compute(){
    const price=+$('price').value||0, downpct=+$('down').value||0, rent=+$('rent').value||0,
          dscr=+$('dscr').value||1, rate=+$('rate').value||0, annIns=+$('ins').value||0,
          annTax=+$('tax').value||0, hoa=+$('hoa').value||0, taxbr=+$('taxbr').value||0;
    const mIns=annIns/12, mTax=annTax/12;
    const maxPI=(rent/dscr) - hoa - mIns - mTax;
    const r=rate/1200;
    const maxLoan = (r>0&&maxPI>0) ? Math.floor((maxPI*(Math.pow(1+r,360)-1))/(r*Math.pow(1+r,360))) : 0;
    const desired = Math.min(maxLoan, price + price*0.06 - price*downpct/100);
    const pi = r>0 ? (desired*r*Math.pow(1+r,360))/(Math.pow(1+r,360)-1) : desired/360;
    const total = pi + mIns + mTax;
    const cashNo = downpct*price*0.01 + 0.06*price;
    const cashSC = downpct*price*0.01 + 0.03*price;
    const net = rent - total;
    const val15 = price*Math.pow(1.03,15);
    const bal15 = r>0 ? desired*((Math.pow(1+r,360)-Math.pow(1+r,180))/(Math.pow(1+r,360)-1)) : desired/2;
    const eq15 = val15 - bal15;
    const cf15 = 12*net*((Math.pow(1.03,15)-1)/0.03);
    const tax15 = ((0.8*price)/27.5)*(taxbr/100)*15;
    const tot15 = eq15+cf15+tax15;
    const bexp15 = rent*180*0.25;
    const roi15 = cashSC>0 ? 100*(Math.pow((tot15-bexp15)/cashSC, 1/15)-1) : 0;
    const val30 = price*Math.pow(1.03,30);
    const eq30 = val30 - 0;
    const cf30 = 12*net*((Math.pow(1.03,30)-1)/0.03);
    const tax30 = ((0.8*price)/27.5)*(taxbr/100)*30;
    const tot30 = eq30+cf30+tax30;
    const bexp30 = rent*360*0.25;
    const roi30 = cashSC>0 ? 100*(Math.pow((tot30-bexp30)/cashSC, 1/30)-1) : 0;
    $('downVal').textContent=downpct+'%'; $('rateVal').textContent=rate.toFixed(2)+'%';
    $('rMaxLoan').textContent=fmt0(maxLoan); $('rDesired').textContent=fmt0(desired); $('rNet').textContent=fmt0(net);
    $('rPI').textContent=fmt0(pi); $('rIns').textContent=fmt0(mIns); $('rTax').textContent=fmt0(mTax);
    $('rHOA').textContent=fmt0(hoa); $('rTotal').textContent=fmt0(total);
    $('rCashNo').textContent=fmt0(cashNo); $('rCashSC').textContent=fmt0(cashSC);
    $('rVal15').textContent=fmt0(val15); $('rBal15').textContent=fmt0(bal15); $('rEq15').textContent=fmt0(eq15);
    $('rCf15').textContent=fmt0(cf15); $('rTax15').textContent=fmt0(tax15); $('rTot15').textContent=fmt0(tot15); $('rRoi15').textContent=fmtP(roi15);
    $('rVal30').textContent=fmt0(val30); $('rEq30').textContent=fmt0(eq30); $('rCf30').textContent=fmt0(cf30);
    $('rTax30').textContent=fmt0(tax30); $('rTot30').textContent=fmt0(tot30); $('rRoi30').textContent=fmtP(roi30);
  }
  document.querySelectorAll('input').forEach(el=>{el.addEventListener('input',compute);el.addEventListener('change',compute);});
  compute();
})();
</script>
<style>
.crumbs{font-family:'JetBrains Mono',monospace;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--color-mute);margin-bottom:28px;}
.crumbs a{color:var(--color-mute);text-decoration:none;} .crumbs a:hover{color:var(--color-blue);} .crumbs span{margin:0 6px;}
.eyebrow{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--color-blue);margin:0 0 10px;}
.display-lg{font-family:'Fraunces',Georgia,serif;font-weight:500;font-size:clamp(32px,5vw,52px);line-height:1.06;margin:0 0 18px;letter-spacing:-.01em;}
.lede{font-size:18px;color:#2b3140;max-width:62ch;margin:0 0 14px;}
.trust{font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--color-mute);border-top:1px solid var(--color-bone);padding-top:14px;margin:0;}
.calc{margin:40px 0 56px;border:1px solid var(--color-bone);border-radius:18px;overflow:hidden;background:#fff;box-shadow:0 1px 0 var(--color-bone),0 24px 48px -32px rgba(10,14,26,.25);}
.calc::before{content:"";display:block;height:4px;background:var(--color-blue);}
.calc-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:0;}
@media(max-width:780px){.calc-grid{grid-template-columns:1fr;}}
.calc-inputs{padding:30px 30px 32px;}
.calc-results{padding:30px;background:var(--color-ink);color:#fff;display:flex;flex-direction:column;gap:12px;}
.summary-title{font-family:'Fraunces',serif;font-weight:600;font-size:28px;margin:0 0 4px;color:#fff;}
.summary-sub{font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-size:11px;color:#aeb6c8;border-top:1px solid rgba(255,255,255,.15);padding-top:14px;margin:8px 0 0;}
.field{margin-bottom:20px;}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
@media(max-width:520px){.field-row{grid-template-columns:1fr;}}
.lbl,label{display:block;font-size:13.5px;font-weight:600;color:#384055;margin-bottom:8px;}
label .val{float:right;font-family:'JetBrains Mono',monospace;color:var(--color-blue);font-weight:600;}
.radios{display:flex;gap:20px;}
.radios label{font-weight:500;color:#2b3140;display:flex;align-items:center;gap:9px;margin:0;cursor:pointer;}
.radios input{accent-color:var(--color-blue);width:17px;height:17px;}
.input-money,.input-pct{display:flex;align-items:center;border:1px solid var(--color-bone);border-radius:10px;background:#fff;overflow:hidden;transition:border-color .15s,box-shadow .15s;}
.input-money:focus-within,.input-pct:focus-within{border-color:var(--color-blue);box-shadow:0 0 0 3px rgba(24,69,214,.12);}
.input-money span{padding:0 4px 0 14px;color:var(--color-mute);font-weight:600;}
.input-pct span{padding:0 14px 0 4px;color:var(--color-mute);font-weight:600;}
.input-money input,.input-pct input{flex:1;border:0;outline:0;padding:13px 14px 13px 4px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--color-ink);width:100%;}
.input-pct input{padding-left:14px;}
input[type=range]{width:100%;accent-color:var(--color-blue);height:4px;margin:6px 0;}
.hint{font-size:12px;margin:6px 0 0;} .hint--mute{color:var(--color-mute);}
.result{display:flex;flex-direction:column;gap:3px;padding:12px 16px;border-radius:10px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.10);}
.result--primary{background:#fff;border-color:#fff;}
.result--primary .result-label{color:#384055;} .result--primary .result-value{color:var(--color-ink);} .result--primary .result-note{color:#6B7280;}
.result-label{font-size:12.5px;color:#aeb6c8;font-weight:600;}
.result-value{font-family:'Fraunces',serif;font-weight:600;font-size:26px;letter-spacing:-.01em;color:#fff;}
.result-note{font-size:10.5px;line-height:1.45;color:#8b93a6;}
.cta-primary{display:block;text-align:center;background:var(--color-blue);color:#fff;text-decoration:none;font-weight:600;padding:14px;border-radius:10px;margin-top:6px;transition:background .15s;}
.cta-primary:hover{background:#2a57e6;}
.micro{font-size:11px;color:#8b93a6;text-align:center;margin:0;}
.body-content h2{font-family:'Fraunces',serif;font-weight:500;font-size:28px;margin:40px 0 12px;}
.body-content p{color:#2b3140;}
.author{display:flex;align-items:center;gap:16px;margin:0 0 32px;}
.author img{width:64px;height:64px;border-radius:50%;object-fit:cover;}
.author h3{font-family:'Fraunces',serif;font-weight:500;font-size:18px;margin:0;}
.author a{color:var(--color-ink);text-decoration:none;} .author a:hover{color:var(--color-blue);}
.cta-card{background:var(--color-paper-tint);border:1px solid var(--color-bone);border-radius:16px;padding:32px;text-align:center;margin:24px auto;max-width:760px;}
.cta-card h4{font-family:'Fraunces',serif;font-weight:500;font-size:24px;margin:0 0 12px;}
.cta-card p{max-width:620px;margin:0 auto 18px;}
.cta-card ul{list-style:none;padding:0;margin:18px 0;color:#384055;font-size:15px;}
.cta-card a{display:inline-block;background:var(--color-ink);color:#fff;padding:13px 26px;border-radius:9px;text-decoration:none;font-weight:600;}
.cta-card a:hover{background:var(--color-blue);}
.related-placeholder{border:1px dashed var(--color-bone);border-radius:10px;padding:20px;color:var(--color-mute);font-family:'JetBrains Mono',monospace;font-size:13px;text-align:center;}
</style>
  <CalcLeadForm />
</Layout>
