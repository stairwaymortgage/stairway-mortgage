---
import Layout from '../../layouts/Layout.astro';

const metaTitle = "Conventional Loan Calculator for Home Purchase: Estimate Your Costs, Monthly Payment & Cash Needed to Close";
const metaDescription = "Calculate your monthly payment, PMI, cash to close, and income needed for a conventional purchase loan. Estimate PITI and the down payment for your property type.";
const canonical = "https://stairwaymortgage.com/loan-calculator/conventional-loan/";
const breadcrumbSchema = {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://stairwaymortgage.com/"},{"@type":"ListItem","position":2,"name":"Loan Calculators","item":"https://stairwaymortgage.com/all-loan-calculators/"},{"@type":"ListItem","position":3,"name":"Conventional Loan Calculator","item":canonical}]};
const appSchema = {"@context":"https://schema.org","@type":"WebApplication","name":"Conventional Purchase Loan Payment Calculator","applicationCategory":"FinanceApplication","operatingSystem":"All","url":canonical,"offers":{"@type":"Offer","price":"0","priceCurrency":"USD"},"description":metaDescription};
const faqSchema = {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How much can I borrow with a conventional loan?","acceptedAnswer":{"@type":"Answer","text":"Your maximum loan-to-value depends on the property type per the Fannie Mae and Freddie Mac LTV matrices: up to 97% for a 1-unit primary residence, lower for additional units, second homes, and investment properties, and subject to conforming loan limits."}},{"@type":"Question","name":"When do I have to pay PMI on a conventional loan?","acceptedAnswer":{"@type":"Answer","text":"Private mortgage insurance generally applies when your loan-to-value is above 80%. The estimated monthly cost rises as your down payment shrinks, and PMI can typically be removed once you reach 20% equity."}},{"@type":"Question","name":"How much cash do I need to close?","acceptedAnswer":{"@type":"Answer","text":"Cash to close is roughly your down payment plus closing costs. This calculator shows three scenarios: without help, with a 3% seller credit, and with both a seller credit and down payment assistance."}}]};
---
<Layout title={metaTitle} description={metaDescription} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <section class="section">
    <div class="container-page">
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href="/">Home</a> <span>/</span>
    <a href="/all-loan-calculators/">Loan Calculators</a> <span>/</span>
    <span aria-current="page">Conventional Loan Calculator</span>
  </nav>

  <header class="calc-head">
    <p class="eyebrow">Conventional · Home Purchase</p>
    <h1 class="display-lg">Conventional Purchase Loan Payment Calculator</h1>
    <p class="lede">Estimate your monthly payment, PMI, cash needed to close, and the income you'd need to qualify — based on your property type, down payment, and rate.</p>
    <p class="trust">Built by Jim Blackburn · NMLS #1072866 · $500M+ closed · 7× Scotsman Guide Top Producer</p>
  </header>

  <section class="calc" aria-label="Conventional Purchase Loan Payment Calculator">
    <div class="calc-grid">
      <div class="calc-inputs">
        <div class="field">
          <label for="ptype">What type of home will this be?</label>
          <select id="ptype">
            <option value="1" selected>Primary Residence (1 unit)</option>
            <option value="2">Primary Residence (2 units)</option>
            <option value="3">Primary Residence (3-4 units)</option>
            <option value="4">Second Home (1 unit)</option>
            <option value="5">Investment Rental (1 unit)</option>
            <option value="6">Investment Rental (2-4 units)</option>
          </select>
        </div>
        <div class="field">
          <label for="price">Purchase Price</label>
          <div class="input-money"><span>$</span><input id="price" type="number" inputmode="numeric" value="500000" min="0" step="1000" /></div>
        </div>
        <div class="field">
          <label for="down">Down Payment Percentage <span class="val" id="downVal">3%</span></label>
          <input id="down" type="range" min="0" max="100" step="1" value="3" />
        </div>
        <div class="field">
          <label for="term">Term of Loan</label>
          <select id="term">
            <option value="15">15 years</option>
            <option value="20">20 years</option>
            <option value="30" selected>30 years</option>
          </select>
        </div>
        <div class="field-row">
          <div class="field">
            <label for="ins">Annual Insurance</label>
            <div class="input-money"><span>$</span><input id="ins" type="number" inputmode="numeric" value="2400" min="0" step="100" /></div>
          </div>
          <div class="field">
            <label for="tax">Annual Taxes</label>
            <div class="input-money"><span>$</span><input id="tax" type="number" inputmode="numeric" value="5000" min="0" step="100" /></div>
          </div>
        </div>
        <div class="field">
          <label for="hoa">Monthly HOA</label>
          <div class="input-money"><span>$</span><input id="hoa" type="number" inputmode="numeric" value="0" min="0" step="10" /></div>
        </div>
        <div class="field">
          <label for="rate">Estimated Interest Rate <span class="val" id="rateVal">6.99%</span></label>
          <input id="rate" type="range" min="5" max="10" step="0.1" value="6.99" />
        </div>
        <div class="field">
          <span class="lbl">Are you thinking about buying another home after this one to continue your wealth journey?</span>
          <div class="radios" role="radiogroup" aria-label="Buying another home">
            <label><input type="radio" name="wealth" value="1" /> Yes</label>
            <label><input type="radio" name="wealth" value="2" checked /> No</label>
          </div>
        </div>
      </div>

      <div class="calc-results" aria-live="polite">
        <p class="summary-title">Summary</p>
        <div class="result result--primary">
          <span class="result-label">Total Monthly Housing Expense</span>
          <span class="result-value" id="rTotal">$3,969.46</span>
          <span class="result-note">Principal &amp; interest, insurance, taxes, and PMI (PITI). HOA, if any, is paid separately.</span>
        </div>
        <div class="result">
          <span class="result-label">Maximum Loan Amount (property type)</span>
          <span class="result-value" id="rMaxLoan">$485,000</span>
          <span class="result-note">Per the Fannie Mae / Freddie Mac LTV matrix and conventional conforming loan limits.</span>
        </div>
        <p class="summary-sub">Payment Breakdown</p>
        <div class="result"><span class="result-label">Desired Loan Amount</span><span class="result-value" id="rDesired">$485,000</span></div>
        <div class="result"><span class="result-label">Principal &amp; Interest Payment</span><span class="result-value" id="rPI">$3,223.46</span></div>
        <div class="result"><span class="result-label">Monthly Insurance</span><span class="result-value" id="rIns">$200.00</span></div>
        <div class="result"><span class="result-label">Monthly Taxes</span><span class="result-value" id="rTax">$416.67</span></div>
        <div class="result"><span class="result-label">Monthly PMI</span><span class="result-value" id="rPMI">$129.33</span><span class="result-note">Estimated private mortgage insurance based on the down payment.</span></div>
        <div class="result"><span class="result-label">HOA Paid Separately</span><span class="result-value" id="rHOA">$0</span></div>
        <p class="summary-sub">Cash to Close</p>
        <div class="result"><span class="result-label">Cash Out of Pocket — without seller credit or DPA</span><span class="result-value" id="rCashNo">$45,000</span><span class="result-note">Includes 6% estimated closing costs and varies state to state. This is NOT a Loan Estimate.</span></div>
        <div class="result"><span class="result-label">Cash Out of Pocket — with 3% seller credit</span><span class="result-value" id="rCashSC">$30,000</span><span class="result-note">Assumes a 3% seller credit toward closing costs and prepaids.</span></div>
        <div class="result"><span class="result-label">Cash Out of Pocket — with seller credit + DPA</span><span class="result-value" id="rCashDPA">$15,000</span><span class="result-note">Assumes 3% down payment assistance + 3% seller credit. Note: many DPA programs require a refinance within 5 years.</span></div>
        <div class="result"><span class="result-label">Monthly Income Target to Qualify</span><span class="result-value" id="rIncome">$7,938.92</span><span class="result-note">Fannie Mae allows up to 50% DTI; Freddie Mac up to 45% with strong credit and reserves.</span></div>
        <a class="cta-primary" href="https://stairwaymortgage.com/purchase-inquiry">See My Options</a>
        <p class="micro">Estimates only — not a commitment to lend.</p>
      </div>
    </div>
  </section>

  <section class="body-content">
    <figure class="author">
      <a href="http://www.mortgagemanjim.com/linkedin%20" target="_blank" rel="noopener">
        <img width="120" height="120" src="https://stairwaymortgage.com/wp-content/uploads/2025/10/Untitled-design-3.png" alt="Jim Blackburn" />
      </a>
      <h3><a href="http://www.mortgagemanjim.com/linkedin%20" target="_blank" rel="noopener">By Jim Blackburn</a></h3>
    </figure>
    <div class="cta-card">
      <h4>Ready to Take Your First Step?</h4>
      <p><strong>Skip the guesswork.</strong> Take our quick Discovery Quiz to uncover your top financial priorities, so we can guide you toward the wealth-building strategies that fit your life.</p>
      <ul><li>Takes just 5 minutes</li><li>Tailored results based on your answers</li><li>No credit check required</li></ul>
      <a href="https://stairwaymortgage.com/discovery-quiz">Take the Discovery Quiz</a>
    </div>
    <div class="cta-card">
      <h4>Need a Pre-Approval Letter—Fast?</h4>
      <p>Buying a home soon? Complete our short form and we'll connect you with the best loan options for your target property and financial situation—fast.</p>
      <ul><li>Only 2 minutes to complete</li><li>Quick turnaround on pre-approval</li><li>No credit score impact</li></ul>
      <a href="https://stairwaymortgage.com/purchase-inquiry">Get Pre-Approved Now</a>
    </div>
    <div class="cta-card">
      <h4>Got a Few Questions First?</h4>
      <p>Let's talk it through. Book a call and one of our friendly advisors will be in touch to guide you personally.</p>
      <a href="https://stairwaymortgage.com/schedule-call">Schedule a Call</a>
    </div>
    <h2>Important Disclaimer</h2>
    <p>This calculator is for illustrative purposes only and does not constitute financial, legal, or investment advice. Results are based on general assumptions and may not reflect actual performance or eligibility. This is not a loan estimate or approval. Please consult with a licensed mortgage advisor before making financial decisions.</p>
    <h2>Related Posts</h2>
    <div class="related-placeholder">Related calculators module ([loan_calculator_box])</div>
  </section>
    </div>
  </section>
</Layout>

<script is:inline>
(function () {
  const $ = (id) => document.getElementById(id);
  const fmt0 = (n) => '$' + Math.round(n).toLocaleString('en-US');
  const fmt2 = (n) => '$' + n.toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2});
  function ltvFactor(p){return {1:0.97,2:0.85,3:0.80,4:0.90,5:0.85,6:0.75}[p] || 0;}
  function compute(){
    const ptype = +$('ptype').value;
    const price = +$('price').value || 0;
    const downpct = +$('down').value || 0;
    const term = +$('term').value;
    const annIns = +$('ins').value || 0;
    const annTax = +$('tax').value || 0;
    const hoa = +$('hoa').value || 0;
    const rate = +$('rate').value || 0;
    const maxLoan = ltvFactor(ptype) * price;
    const desired = Math.min(price - (price*downpct/100), maxLoan);
    const r = rate/1200;
    const n = (term === 30) ? 360 : 180;
    const pi = r > 0 ? desired * r / (1 - Math.pow(1+r, -n)) : desired/n;
    const mIns = annIns/12;
    const mTax = annTax/12;
    const l = price > 0 ? desired/price : 0;
    let pmi = 0;
    if (l > 0.801 && l <= 0.85) pmi = desired*0.0012/12;
    else if (l > 0.851 && l <= 0.90) pmi = desired*0.0017/12;
    else if (l > 0.901 && l <= 0.95) pmi = desired*0.0025/12;
    else if (l > 0.951 && l <= 0.97) pmi = desired*0.0032/12;
    const total = pi + mIns + mTax + pmi;
    const cashNo = downpct*price*0.01 + 0.06*price;
    const cashSC = downpct*price*0.01 + 0.03*price;
    const cashDPA = price*0.03;
    const income = (total + hoa) * 2;
    $('downVal').textContent = downpct + '%';
    $('rateVal').textContent = rate.toFixed(2) + '%';
    $('rTotal').textContent  = fmt2(total);
    $('rMaxLoan').textContent= fmt0(maxLoan);
    $('rDesired').textContent= fmt0(desired);
    $('rPI').textContent     = fmt2(pi);
    $('rIns').textContent    = fmt2(mIns);
    $('rTax').textContent    = fmt2(mTax);
    $('rPMI').textContent    = fmt2(pmi);
    $('rHOA').textContent    = fmt0(hoa);
    $('rCashNo').textContent = fmt0(cashNo);
    $('rCashSC').textContent = fmt0(cashSC);
    $('rCashDPA').textContent= fmt0(cashDPA);
    $('rIncome').textContent = fmt2(income);
  }
  document.querySelectorAll('input,select').forEach(el => { el.addEventListener('input', compute); el.addEventListener('change', compute); });
  compute();
})();
</script>

<style>
.crumbs{font-family:'JetBrains Mono',monospace;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--mute);margin-bottom:28px;}
.crumbs a{color:var(--mute);text-decoration:none;} .crumbs a:hover{color:var(--blue);} .crumbs span{margin:0 6px;}
.eyebrow{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--blue);margin:0 0 10px;}
.display-lg{font-family:'Fraunces',Georgia,serif;font-weight:500;font-size:clamp(32px,5vw,52px);line-height:1.06;margin:0 0 18px;letter-spacing:-.01em;}
.lede{font-size:18px;color:#2b3140;max-width:62ch;margin:0 0 14px;}
.trust{font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--mute);border-top:1px solid var(--bone);padding-top:14px;margin:0;}
.calc{margin:40px 0 56px;border:1px solid var(--bone);border-radius:18px;overflow:hidden;background:#fff;box-shadow:0 1px 0 var(--bone),0 24px 48px -32px rgba(10,14,26,.25);}
.calc::before{content:"";display:block;height:4px;background:var(--blue);}
.calc-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:0;}
@media(max-width:780px){.calc-grid{grid-template-columns:1fr;}}
.calc-inputs{padding:30px 30px 32px;}
.calc-results{padding:30px;background:var(--ink);color:#fff;display:flex;flex-direction:column;gap:12px;}
.summary-title{font-family:'Fraunces',serif;font-weight:600;font-size:28px;margin:0 0 4px;color:#fff;}
.summary-sub{font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-size:11px;color:#aeb6c8;border-top:1px solid rgba(255,255,255,.15);padding-top:14px;margin:8px 0 0;}
.field{margin-bottom:20px;}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
@media(max-width:520px){.field-row{grid-template-columns:1fr;}}
.lbl,label{display:block;font-size:13.5px;font-weight:600;color:#384055;margin-bottom:8px;}
label .val{float:right;font-family:'JetBrains Mono',monospace;color:var(--blue);font-weight:600;}
select{width:100%;padding:12px 14px;border:1px solid var(--bone);border-radius:10px;background:#fff;font-size:16px;font-family:'IBM Plex Sans',sans-serif;color:var(--ink);}
select:focus{outline:0;border-color:var(--blue);box-shadow:0 0 0 3px rgba(24,69,214,.12);}
.radios{display:flex;gap:20px;}
.radios label{font-weight:500;color:#2b3140;display:flex;align-items:center;gap:9px;margin:0;cursor:pointer;}
.radios input{accent-color:var(--blue);width:17px;height:17px;}
.input-money{display:flex;align-items:center;border:1px solid var(--bone);border-radius:10px;background:#fff;overflow:hidden;transition:border-color .15s,box-shadow .15s;}
.input-money:focus-within{border-color:var(--blue);box-shadow:0 0 0 3px rgba(24,69,214,.12);}
.input-money span{padding:0 4px 0 14px;color:var(--mute);font-weight:600;}
.input-money input{flex:1;border:0;outline:0;padding:13px 14px 13px 4px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--ink);width:100%;}
input[type=range]{width:100%;accent-color:var(--blue);height:4px;margin:6px 0;}
.result{display:flex;flex-direction:column;gap:3px;padding:12px 16px;border-radius:10px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.10);}
.result--primary{background:#fff;border-color:#fff;}
.result--primary .result-label{color:#384055;} .result--primary .result-value{color:var(--ink);} .result--primary .result-note{color:#6B7280;}
.result-label{font-size:12.5px;color:#aeb6c8;font-weight:600;}
.result-value{font-family:'Fraunces',serif;font-weight:600;font-size:26px;letter-spacing:-.01em;color:#fff;}
.result-note{font-size:10.5px;line-height:1.45;color:#8b93a6;}
.cta-primary{display:block;text-align:center;background:var(--blue);color:#fff;text-decoration:none;font-weight:600;padding:14px;border-radius:10px;margin-top:6px;transition:background .15s;}
.cta-primary:hover{background:#2a57e6;}
.micro{font-size:11px;color:#8b93a6;text-align:center;margin:0;}
.body-content h2{font-family:'Fraunces',serif;font-weight:500;font-size:28px;margin:40px 0 12px;}
.body-content p{color:#2b3140;}
.author{display:flex;align-items:center;gap:16px;margin:0 0 32px;}
.author img{width:64px;height:64px;border-radius:50%;object-fit:cover;}
.author h3{font-family:'Fraunces',serif;font-weight:500;font-size:18px;margin:0;}
.author a{color:var(--ink);text-decoration:none;} .author a:hover{color:var(--blue);}
.cta-card{background:var(--paper-tint);border:1px solid var(--bone);border-radius:16px;padding:32px;text-align:center;margin:24px auto;max-width:760px;}
.cta-card h4{font-family:'Fraunces',serif;font-weight:500;font-size:24px;margin:0 0 12px;}
.cta-card p{max-width:620px;margin:0 auto 18px;}
.cta-card ul{list-style:none;padding:0;margin:18px 0;color:#384055;font-size:15px;}
.cta-card a{display:inline-block;background:var(--ink);color:#fff;padding:13px 26px;border-radius:9px;text-decoration:none;font-weight:600;}
.cta-card a:hover{background:var(--blue);}
.related-placeholder{border:1px dashed var(--bone);border-radius:10px;padding:20px;color:var(--mute);font-family:'JetBrains Mono',monospace;font-size:13px;text-align:center;}
</style>
