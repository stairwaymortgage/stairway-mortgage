---
import Layout from '../../layouts/Layout.astro';
import CalcLeadForm from '../../components/CalcLeadForm.astro';
const metaTitle = "Your Real Impact on The World | Stairway Mortgage";
const metaDescription = "See how many lives you could touch by sharing God's love each week — today and for years to come. A reflection from Jim Blackburn, NMLS #1072866.";
const canonical = "https://stairwaymortgage.com/loan-calculator/spiritual-influence-calculator/";
const breadcrumbSchema = {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://stairwaymortgage.com/"},{"@type":"ListItem","position":2,"name":"Loan Calculators","item":"https://stairwaymortgage.com/loan-calculators/"},{"@type":"ListItem","position":3,"name":"Your Real Impact on The World","item":canonical}]};
const appSchema = {"@context":"https://schema.org","@type":"WebApplication","name":"Your Real Impact on The World","applicationCategory":"LifestyleApplication","operatingSystem":"All","url":canonical,"offers":{"@type":"Offer","price":"0","priceCurrency":"USD"},"description":metaDescription};
const faqSchema = {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How is my impact calculated?","acceptedAnswer":{"@type":"Answer","text":"It starts with the people you bless each week over your remaining years (assuming you live to 100), then adds the ripple of those who follow your example, multiplied across seven levels."}},{"@type":"Question","name":"What is the following percentage?","acceptedAnswer":{"@type":"Answer","text":"The share of people who, after being blessed, go on to bless others themselves — which is what makes your influence multiply over time."}},{"@type":"Question","name":"Is this a real prediction?","acceptedAnswer":{"@type":"Answer","text":"No. It's an inspirational what-if built on simple math and bold assumptions, not a guarantee. It's meant to spark reflection, not certainty."}}]};
---
<Layout title={metaTitle} description={metaDescription}>
  <link slot="head" rel="canonical" href={canonical} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <main class="container-page">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a> <span>/</span>
      <a href="/loan-calculators/">Loan Calculators</a> <span>/</span>
      <span aria-current="page">Your Real Impact on The World</span>
    </nav>
    <header class="calc-head">
      <p class="eyebrow">Legacy · Influence</p>
      <h1 class="display-lg">Your Real Impact on The World</h1>
      <p class="lede"><em>Calculate the number of lives touched by sharing God's love, today and for years to come.</em></p>
      <p class="trust">A reflection from Jim Blackburn · NMLS #1072866 · $500M+ closed · 7× Scotsman Guide Top Producer</p>
    </header>
    <section class="calc" aria-label="Your Real Impact on The World">
      <div class="calc-grid">
        <div class="calc-inputs">
          <p class="group-label">Your Reach</p>
          <div class="field">
            <label for="weekly">People Blessed Weekly: <span id="weeklyOut" class="slider-out">7</span></label>
            <input id="weekly" type="range" min="0" max="1000000" step="1" value="7" />
            <p class="hint hint--mute">How many people you'll bless verbally with God's love each week.</p>
          </div>
          <div class="field">
            <label for="following">Following Percentage: <span id="followingOut" class="slider-out">10%</span></label>
            <input id="following" type="range" min="0" max="100" step="1" value="10" />
            <p class="hint hint--mute">The percentage of people who follow your example and bless others too.</p>
          </div>
          <div class="field"><label for="age">Your Age</label><div class="input-plain"><input id="age" type="number" inputmode="numeric" value="25" min="0" step="1" /></div><p class="hint hint--mute">The calculator assumes we live until age 100 and never stop blessing.</p></div>
        </div>
        <div class="calc-results" aria-live="polite">
          <p class="summary-title">Share the Blessing</p>
          <p class="summary-sub">The Ripple Through Time</p>
          <div class="result"><span class="result-label">Total Direct Influence</span><span class="result-value" id="rDirect">27,300</span><span class="result-note">Every word of love you speak is a seed planted in someone's heart.</span></div>
          <div class="result"><span class="result-label">Level 2</span><span class="result-value" id="rL2">30,030</span><span class="result-note">One friend becomes two, two become four — love starts multiplying.</span></div>
          <div class="result"><span class="result-label">Level 3</span><span class="result-value" id="rL3">33,033</span></div>
          <div class="result"><span class="result-label">Level 4</span><span class="result-value" id="rL4">36,336</span></div>
          <div class="result"><span class="result-label">Level 5</span><span class="result-value" id="rL5">39,970</span></div>
          <div class="result"><span class="result-label">Level 6</span><span class="result-value" id="rL6">43,967</span></div>
          <div class="result"><span class="result-label">Level 7</span><span class="result-value" id="rL7">48,364</span><span class="result-note">You're shaping nations. Beyond this, only God Himself can count the true reach.</span></div>
          <p class="summary-sub">Your Legacy</p>
          <div class="result"><span class="result-label">Total Indirect Influence</span><span class="result-value" id="rIndirect">259,000</span><span class="result-note">Your influence flows into lives you may never even meet.</span></div>
          <div class="result result--primary"><span class="result-label">Total Spiritual Influence</span><span class="result-value" id="rTotal">286,300</span><span class="result-note">The unseen reach of words carried through time and people.</span></div>
          <a class="cta-primary" data-calc-cta data-calc-slug="spiritual-influence-calculator">Yes, I Want to Share</a>
          <p class="micro">For inspiration only — not prophecy, and definitely not a loan approval.</p>
        </div>
      </div>
    </section>
    <section class="body-content">
      <figure class="author">
        <a href="https://www.linkedin.com/company/nexa-mortgage-jim-blackburn-team" target="_blank" rel="noopener">
          <img width="120" height="120" src="https://stairwaymortgage.com/wp-content/uploads/2025/10/Untitled-design-3.png" alt="Jim Blackburn" />
        </a>
        <h3><a href="https://www.linkedin.com/company/nexa-mortgage-jim-blackburn-team" target="_blank" rel="noopener">By Jim Blackburn</a></h3>
      </figure>
      <div class="cta-card">
        <h4>Ready to Take Your First Step?</h4>
        <p><strong>Skip the guesswork.</strong> Take our quick Discovery Quiz to uncover your top financial priorities, so we can guide you toward the wealth-building strategies that fit your life.</p>
        <ul><li>Takes just 5 minutes</li><li>Tailored results based on your answers</li><li>No credit check required</li></ul>
        <a href="https://stairwaymortgage.com/discovery-quiz">Take the Discovery Quiz</a>
      </div>
      <div class="cta-card">
        <h4>Want to Leave a Lasting Legacy?</h4>
        <p>Let's talk about how the right financial moves today can free you to bless others for years to come.</p>
        <a href="https://stairwaymortgage.com/schedule-call">Schedule a Call</a>
      </div>
      <h2>Important Disclaimer</h2>
      <p>This calculator is purely for inspiration, not prophecy, and definitely not a loan approval. While Stairway Mortgage can help you finance a house, we cannot finance your eternal salvation (please consult God directly for that).</p>
      <p>Results shown here are based on simple math and bold assumptions: that everyone lives to 100, never stops blessing others, and always smiles back when you say "God loves you." Actual blessings may vary depending on free will, naps, grocery store small talk, kids interrupting, or your willingness to talk to strangers in line at Starbucks.</p>
      <p>Like any good mortgage disclosure, we must remind you: past performance of blessing others is not a guarantee of future results. Your spiritual APR may fluctuate depending on prayer, consistency, and the occasional bad hair day.</p>
      <p>This is a holy "what-if," not a heavenly guarantee. Eternity is real, but this calculator is hypothetical. Please consult a licensed mortgage professional for financial decisions, and the Author of Life for eternal ones.</p>
      <h2>Related Posts</h2>
      <div class="related-placeholder">Related calculators module ([loan_calculator_box])</div>
    </section>
  </main>

  <script is:inline>
  (function () {
    const $ = (id) => document.getElementById(id);
    const fmtN = (n) => { if(!isFinite(n)) return '—'; return Math.round(n).toLocaleString('en-US'); };
    function compute(){
      const weekly=+$('weekly').value||0, following=+$('following').value||0, age=+$('age').value||0;
      $('weeklyOut').textContent = fmtN(weekly);
      $('followingOut').textContent = following+'%';
      // Total Direct Influence = (100 - age) * weekly * 52  (hardcoded 100 life expectancy, 52 weeks)
      const direct = (100 - age) * weekly * 52;
      // Levels 2-7: each = prior * (1 + following/100)  (iterative geometric, NOT POWER)
      const f = following/100;
      const L2 = direct + (direct * f);
      const L3 = L2 + (L2 * f);
      const L4 = L3 + (L3 * f);
      const L5 = L4 + (L4 * f);
      const L6 = L5 + (L5 * f);
      const L7 = L6 + (L6 * f);
      // Total Indirect = SUM(direct, L2..L7)
      const indirect = direct + L2 + L3 + L4 + L5 + L6 + L7;
      // Total Spiritual = SUM(direct, indirect)
      const total = direct + indirect;
      $('rDirect').textContent=fmtN(direct);
      $('rL2').textContent=fmtN(L2); $('rL3').textContent=fmtN(L3); $('rL4').textContent=fmtN(L4);
      $('rL5').textContent=fmtN(L5); $('rL6').textContent=fmtN(L6); $('rL7').textContent=fmtN(L7);
      $('rIndirect').textContent=fmtN(indirect); $('rTotal').textContent=fmtN(total);
    }
    document.querySelectorAll('input').forEach(el=>{el.addEventListener('input',compute);el.addEventListener('change',compute);});
    compute();
  })();
  </script>

  <style>
  .crumbs{font-family:'JetBrains Mono',monospace;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--mute);margin-bottom:28px;}
  .crumbs a{color:var(--mute);text-decoration:none;} .crumbs a:hover{color:var(--blue);} .crumbs span{margin:0 6px;}
  .eyebrow{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--blue);margin:0 0 10px;}
  .display-lg{font-family:'Fraunces',Georgia,serif;font-weight:500;font-size:clamp(28px,4.4vw,46px);line-height:1.08;margin:0 0 18px;letter-spacing:-.01em;}
  .lede{font-size:18px;color:#2b3140;max-width:62ch;margin:0 0 14px;}
  .trust{font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--mute);border-top:1px solid var(--bone);padding-top:14px;margin:0;}
  .calc{margin:40px 0 56px;border:1px solid var(--bone);border-radius:18px;overflow:hidden;background:#fff;box-shadow:0 1px 0 var(--bone),0 24px 48px -32px rgba(10,14,26,.25);}
  .calc::before{content:"";display:block;height:4px;background:var(--blue);}
  .calc-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:0;}
  @media(max-width:780px){.calc-grid{grid-template-columns:1fr;}}
  .calc-inputs{padding:30px 30px 32px;}
  .group-label{font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-size:11px;color:var(--blue);font-weight:600;margin:22px 0 12px;}
  .group-label:first-child{margin-top:0;}
  .calc-results{padding:30px;background:var(--ink);color:#fff;display:flex;flex-direction:column;gap:12px;}
  .summary-title{font-family:'Fraunces',serif;font-weight:600;font-size:28px;margin:0 0 4px;color:#fff;}
  .summary-sub{font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-size:11px;color:#aeb6c8;border-top:1px solid rgba(255,255,255,.15);padding-top:14px;margin:8px 0 0;}
  .field{margin-bottom:20px;}
  .lbl,label{display:block;font-size:13.5px;font-weight:600;color:#384055;margin-bottom:8px;}
  .slider-out{color:var(--blue);font-family:'JetBrains Mono',monospace;font-weight:600;}
  input[type=range]{width:100%;accent-color:var(--blue);height:6px;}
  .input-plain{display:flex;align-items:center;border:1px solid var(--bone);border-radius:10px;background:#fff;overflow:hidden;transition:border-color .15s,box-shadow .15s;}
  .input-plain:focus-within{border-color:var(--blue);box-shadow:0 0 0 3px rgba(24,69,214,.12);}
  .input-plain input{flex:1;border:0;outline:0;padding:13px 14px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--ink);width:100%;}
  .hint{font-size:12px;margin:6px 0 0;color:var(--mute);} .hint--mute{color:var(--mute);}
  .result{display:flex;flex-direction:column;gap:3px;padding:12px 16px;border-radius:10px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.10);}
  .result--primary{background:#fff;border-color:#fff;}
  .result--primary .result-label{color:#384055;} .result--primary .result-value{color:var(--ink);} .result--primary .result-note{color:#6B7280;}
  .result-label{font-size:12.5px;color:#aeb6c8;font-weight:600;}
  .result-value{font-family:'Fraunces',serif;font-weight:600;font-size:24px;letter-spacing:-.01em;color:#fff;}
  .result-note{font-size:10.5px;line-height:1.45;color:#8b93a6;}
  .cta-primary{display:block;text-align:center;background:var(--blue);color:#fff;text-decoration:none;font-weight:600;padding:14px;border-radius:10px;margin-top:6px;transition:background .15s;}
  .cta-primary:hover{background:#2a57e6;}
  .micro{font-size:11px;color:#8b93a6;text-align:center;margin:0;}
  .body-content h2{font-family:'Fraunces',serif;font-weight:500;font-size:28px;margin:40px 0 12px;}
  .body-content p{color:#2b3140;}
  .author{display:flex;align-items:center;gap:16px;margin:0 0 32px;}
  .author img{width:64px;height:64px;border-radius:50%;object-fit:cover;}
  .author h3{font-family:'Fraunces',serif;font-weight:500;font-size:18px;margin:0;}
  .author a{color:var(--ink);text-decoration:none;} .author a:hover{color:var(--blue);}
  .cta-card{background:var(--paper-tint);border:1px solid var(--bone);border-radius:16px;padding:32px;text-align:center;margin:24px auto;max-width:760px;}
  .cta-card h4{font-family:'Fraunces',serif;font-weight:500;font-size:24px;margin:0 0 12px;}
  .cta-card p{max-width:620px;margin:0 auto 18px;}
  .cta-card ul{list-style:none;padding:0;margin:18px 0;color:#384055;font-size:15px;}
  .cta-card a{display:inline-block;background:var(--ink);color:#fff;padding:13px 26px;border-radius:9px;text-decoration:none;font-weight:600;}
  .cta-card a:hover{background:var(--blue);}
  .related-placeholder{border:1px dashed var(--bone);border-radius:10px;padding:20px;color:var(--mute);font-family:'JetBrains Mono',monospace;font-size:13px;text-align:center;}
  </style>
  <CalcLeadForm />
</Layout>
