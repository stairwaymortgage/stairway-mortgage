---
import Layout from '../../layouts/Layout.astro';

const metaTitle = "Compare 3 Rate/Payments (Points Only) | Stairway Mortgage";
const metaDescription = "Compare three rate and payment scenarios by discount points, see your monthly and annual savings, breakeven point, and total savings over the loan term. Built by Jim Blackburn, NMLS #1072866.";
const canonical = "https://stairwaymortgage.com/loan-calculator/compare-3-rate-payments-points-only/";
const breadcrumbSchema = {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://stairwaymortgage.com/"},{"@type":"ListItem","position":2,"name":"Loan Calculators","item":"https://stairwaymortgage.com/all-loan-calculators/"},{"@type":"ListItem","position":3,"name":"Compare 3 Rate/Payments (Points Only)","item":canonical}]};
const appSchema = {"@context":"https://schema.org","@type":"WebApplication","name":"Compare 3 Rate/Payments (Points Only)","applicationCategory":"FinanceApplication","operatingSystem":"All","url":canonical,"offers":{"@type":"Offer","price":"0","priceCurrency":"USD"},"description":metaDescription};
const faqSchema = {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What are discount points?","acceptedAnswer":{"@type":"Answer","text":"Discount points are an upfront fee paid to the lender to lower your interest rate. Paying more points lowers your rate and monthly payment; taking a lender credit raises your rate but reduces upfront cost."}},{"@type":"Question","name":"What is the breakeven point on buying points?","acceptedAnswer":{"@type":"Answer","text":"It is how long you must keep the loan for the monthly savings from a lower rate to recover the extra upfront cost of the points. Past breakeven, the savings are pure benefit."}},{"@type":"Question","name":"Which strategy should I choose?","acceptedAnswer":{"@type":"Answer","text":"If you will keep the loan past the breakeven period and can afford the upfront cash, the lowest-rate option wins. If you may sell, refinance, or pay off sooner, the lowest-cost (higher-rate) option is usually better."}}]};
---
<Layout title={metaTitle} description={metaDescription} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <main class="container-page">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a> <span>/</span>
      <a href="/all-loan-calculators/">Loan Calculators</a> <span>/</span>
      <span aria-current="page">Compare 3 Rate/Payments (Points Only)</span>
    </nav>
    <header class="calc-head">
      <p class="eyebrow">Comparison · Points Only</p>
      <h1 class="display-lg">Compare 3 Rate/Payments (Points Only)</h1>
      <p class="lede">Enter your rates and the price of each rate — lowest, middle road, and highest — to compare monthly payments, your breakeven point, and total savings.</p>
      <p class="trust">Built by Jim Blackburn · NMLS #1072866 · $500M+ closed · 7× Scotsman Guide Top Producer</p>
    </header>
    <section class="calc" aria-label="Compare 3 Rate/Payments (Points Only)">
      <div class="calc-grid">
        <div class="calc-inputs">
          <p class="group-label">Shared</p>
          <div class="field-row">
            <div class="field"><label for="loan">Loan Amount</label><div class="input-money"><span>$</span><input id="loan" type="number" inputmode="numeric" value="350000" min="0" step="1000" /></div></div>
            <div class="field"><label for="term">Term in Months</label><div class="input-plain"><input id="term" type="number" inputmode="numeric" value="360" min="1" step="12" /></div><p class="hint hint--mute">10 yr = 120 · 15 yr = 180 · 30 yr = 360.</p></div>
          </div>
          <p class="group-label">Strategy A — Lowest Rate</p>
          <div class="field-row">
            <div class="field"><label for="rA">Rate w/ 4 Points</label><div class="input-plain"><input id="rA" type="number" inputmode="decimal" value="5.375" min="0" step="0.001" /><span class="suffix">%</span></div></div>
            <div class="field"><label for="pA">Price of Rate w/ 4 Points</label><div class="input-money"><span>$</span><input id="pA" type="number" inputmode="numeric" value="14000" step="100" /></div></div>
          </div>
          <p class="group-label">Strategy B — Middle Road</p>
          <div class="field-row">
            <div class="field"><label for="rB">Rate w/ 1 Point</label><div class="input-plain"><input id="rB" type="number" inputmode="decimal" value="6.99" min="0" step="0.001" /><span class="suffix">%</span></div></div>
            <div class="field"><label for="pB">Price of Rate w/ 1 Point</label><div class="input-money"><span>$</span><input id="pB" type="number" inputmode="numeric" value="3500" step="100" /></div></div>
          </div>
          <p class="group-label">Strategy C — Lowest Cost Rate</p>
          <div class="field-row">
            <div class="field"><label for="rC">Highest Rate</label><div class="input-plain"><input id="rC" type="number" inputmode="decimal" value="8.125" min="0" step="0.001" /><span class="suffix">%</span></div></div>
            <div class="field"><label for="pC">Price of Highest Rate</label><div class="input-money"><span>$</span><input id="pC" type="number" inputmode="numeric" value="-5000" step="100" /></div><p class="hint hint--mute">Negative = lender credit.</p></div>
          </div>
        </div>
        <div class="calc-results" aria-live="polite">
          <p class="summary-title">Results</p>
          <p class="summary-sub">Strategy A — Lowest Rate</p>
          <div class="result"><span class="result-label">Rate</span><span class="result-value" id="rRateA">5.375%</span></div>
          <div class="result"><span class="result-label">P&amp;I Payment</span><span class="result-value" id="rPiA">$1,960</span></div>
          <div class="result"><span class="result-label">Discount Points</span><span class="result-value" id="rPtsA">$14,000</span></div>
          <p class="summary-sub">Strategy B — Middle Road</p>
          <div class="result"><span class="result-label">Rate</span><span class="result-value" id="rRateB">6.990%</span></div>
          <div class="result"><span class="result-label">P&amp;I Payment</span><span class="result-value" id="rPiB">$2,326</span></div>
          <div class="result"><span class="result-label">Discount Points</span><span class="result-value" id="rPtsB">$3,500</span></div>
          <p class="summary-sub">Strategy C — Lowest Cost Rate</p>
          <div class="result"><span class="result-label">Rate</span><span class="result-value" id="rRateC">8.125%</span></div>
          <div class="result"><span class="result-label">P&amp;I Payment</span><span class="result-value" id="rPiC">$2,599</span></div>
          <div class="result"><span class="result-label">Discount Points</span><span class="result-value" id="rPtsC">-$5,000</span></div>
          <p class="summary-sub">Breakeven Analysis</p>
          <div class="result"><span class="result-label">Monthly Savings (A vs C)</span><span class="result-value" id="rMSav">$639</span></div>
          <div class="result"><span class="result-label">Annual Savings (A vs C)</span><span class="result-value" id="rASav">$7,666</span></div>
          <div class="result"><span class="result-label">Difference In Upfront Investment</span><span class="result-value" id="rUpfront">$19,000</span></div>
          <div class="result result--primary"><span class="result-label">Years To Breakeven</span><span class="result-value" id="rBE">2.5</span><span class="result-note">Years to recover the upfront points investment.</span></div>
          <p class="summary-sub">Future Savings</p>
          <div class="result"><span class="result-label">Years To Save</span><span class="result-value" id="rYSave">27.5</span><span class="result-note">Years of savings remaining after breakeven.</span></div>
          <div class="result result--primary"><span class="result-label">Estimated Savings For Remaining Term</span><span class="result-value" id="rEstSav">$210,986</span><span class="result-note">Pure cashflow over the remaining loan term after breakeven.</span></div>
          <a class="cta-primary" href="https://stairwaymortgage.com/purchase-inquiry">See My Options</a>
          <p class="micro">Estimates only — not a commitment to lend.</p>
        </div>
      </div>
    </section>
    <section class="body-content">
      <div class="conclusion-card">
        <h3>Professional Recommendation</h3>
        <p>If you think you'll <strong>keep this loan past the breakeven years</strong> before selling, paying off, or refinancing — and you can <strong>comfortably come up with the cash to close</strong> — then <strong>Strategy A</strong> is your best choice.</p>
        <p>If you're more likely to <strong>pay off, refinance, or sell before the breakeven period</strong>, then <strong>Strategy C</strong> is your best choice.</p>
        <p>If you're <strong>uncertain</strong> and caught between the two, go with <strong>Strategy B</strong>.</p>
      </div>
      <figure class="author">
        <a href="http://www.mortgagemanjim.com/linkedin%20" target="_blank" rel="noopener">
          <img width="120" height="120" src="https://stairwaymortgage.com/wp-content/uploads/2025/10/Untitled-design-3.png" alt="Jim Blackburn" />
        </a>
        <h3><a href="http://www.mortgagemanjim.com/linkedin%20" target="_blank" rel="noopener">By Jim Blackburn</a></h3>
      </figure>
      <div class="cta-card">
        <h4>Ready to Take Your First Step?</h4>
        <p><strong>Skip the guesswork.</strong> Take our quick Discovery Quiz to uncover your top financial priorities, so we can guide you toward the wealth-building strategies that fit your life.</p>
        <ul><li>Takes just 5 minutes</li><li>Tailored results based on your answers</li><li>No credit check required</li></ul>
        <a href="https://stairwaymortgage.com/discovery-quiz">Take the Discovery Quiz</a>
      </div>
      <div class="cta-card">
        <h4>Want to Run This for Your Real Numbers?</h4>
        <p>Tell us about your scenario and we'll pull current pricing and run your points break-even—fast.</p>
        <ul><li>Only 2 minutes to complete</li><li>Quick turnaround</li><li>No credit score impact</li></ul>
        <a href="https://stairwaymortgage.com/purchase-inquiry">See My Options</a>
      </div>
      <div class="cta-card">
        <h4>Got a Few Questions First?</h4>
        <p>Let's talk it through. Book a call and one of our friendly advisors will be in touch to guide you personally.</p>
        <a href="https://stairwaymortgage.com/schedule-call">Schedule a Call</a>
      </div>
      <h2>Important Disclaimer</h2>
      <p>This calculator is for illustrative purposes only and does not constitute financial, legal, or investment advice. Results are based on general assumptions and may not reflect actual performance or eligibility. This is not a loan estimate or approval. Please consult with a licensed mortgage advisor before making financial decisions.</p>
      <h2>Related Posts</h2>
      <div class="related-placeholder">Related calculators module ([loan_calculator_box])</div>
    </section>
  </main>

  <script is:inline>
  (function () {
    const $ = (id) => document.getElementById(id);
    const fmt0 = (n) => { const r=Math.round(n); return (r<0?'-$':'$') + Math.abs(r).toLocaleString('en-US'); };
    const rounddown2 = (x) => Math.floor(x*100)/100;
    function pi(rate, loan, term){
      const r = rate/1200;
      if (r<=0 || term<=0) return term>0 ? loan/term : 0;
      return rounddown2( (r*loan) / (1 - Math.pow(1+r, -term)) );
    }
    function compute(){
      const loan=+$('loan').value||0, term=+$('term').value||0,
            rA=+$('rA').value||0, pA=+$('pA').value||0,
            rB=+$('rB').value||0, pB=+$('pB').value||0,
            rC=+$('rC').value||0, pC=+$('pC').value||0;
      const piA=pi(rA,loan,term), piB=pi(rB,loan,term), piC=pi(rC,loan,term);
      // Monthly Savings = piC - piA
      const mSav = piC - piA;
      // Annual = mSav*12
      const aSav = mSav*12;
      // Upfront diff = pA + (pC * -1)
      const upfront = pA + (pC*-1);
      // Years to breakeven = upfront / aSav
      const yBE = aSav !== 0 ? upfront/aSav : 0;
      // Years to save = term/12 - yBE
      const ySave = (term/12) - yBE;
      // Est savings remaining = ySave * aSav
      const estSav = ySave * aSav;
      $('rRateA').textContent=rA.toFixed(3)+'%'; $('rPiA').textContent=fmt0(piA); $('rPtsA').textContent=fmt0(pA);
      $('rRateB').textContent=rB.toFixed(3)+'%'; $('rPiB').textContent=fmt0(piB); $('rPtsB').textContent=fmt0(pB);
      $('rRateC').textContent=rC.toFixed(3)+'%'; $('rPiC').textContent=fmt0(piC); $('rPtsC').textContent=fmt0(pC);
      $('rMSav').textContent=fmt0(mSav); $('rASav').textContent=fmt0(aSav);
      $('rUpfront').textContent=fmt0(upfront);
      $('rBE').textContent=yBE.toFixed(1);
      $('rYSave').textContent=ySave.toFixed(1);
      $('rEstSav').textContent=fmt0(estSav);
    }
    document.querySelectorAll('input').forEach(el=>{el.addEventListener('input',compute);el.addEventListener('change',compute);});
    compute();
  })();
  </script>

  <style>
  .crumbs{font-family:'JetBrains Mono',monospace;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--mute);margin-bottom:28px;}
  .crumbs a{color:var(--mute);text-decoration:none;} .crumbs a:hover{color:var(--blue);} .crumbs span{margin:0 6px;}
  .eyebrow{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--blue);margin:0 0 10px;}
  .display-lg{font-family:'Fraunces',Georgia,serif;font-weight:500;font-size:clamp(28px,4.4vw,46px);line-height:1.08;margin:0 0 18px;letter-spacing:-.01em;}
  .lede{font-size:18px;color:#2b3140;max-width:62ch;margin:0 0 14px;}
  .trust{font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--mute);border-top:1px solid var(--bone);padding-top:14px;margin:0;}
  .calc{margin:40px 0 56px;border:1px solid var(--bone);border-radius:18px;overflow:hidden;background:#fff;box-shadow:0 1px 0 var(--bone),0 24px 48px -32px rgba(10,14,26,.25);}
  .calc::before{content:"";display:block;height:4px;background:var(--blue);}
  .calc-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:0;}
  @media(max-width:780px){.calc-grid{grid-template-columns:1fr;}}
  .calc-inputs{padding:30px 30px 32px;}
  .group-label{font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-size:11px;color:var(--blue);font-weight:600;margin:22px 0 12px;}
  .group-label:first-child{margin-top:0;}
  .calc-results{padding:30px;background:var(--ink);color:#fff;display:flex;flex-direction:column;gap:12px;}
  .summary-title{font-family:'Fraunces',serif;font-weight:600;font-size:28px;margin:0 0 4px;color:#fff;}
  .summary-sub{font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-size:11px;color:#aeb6c8;border-top:1px solid rgba(255,255,255,.15);padding-top:14px;margin:8px 0 0;}
  .field{margin-bottom:20px;}
  .field-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
  @media(max-width:520px){.field-row{grid-template-columns:1fr;}}
  .lbl,label{display:block;font-size:13.5px;font-weight:600;color:#384055;margin-bottom:8px;}
  .input-money,.input-plain{display:flex;align-items:center;border:1px solid var(--bone);border-radius:10px;background:#fff;overflow:hidden;transition:border-color .15s,box-shadow .15s;}
  .input-money:focus-within,.input-plain:focus-within{border-color:var(--blue);box-shadow:0 0 0 3px rgba(24,69,214,.12);}
  .input-money span{padding:0 4px 0 14px;color:var(--mute);font-weight:600;}
  .input-money input{flex:1;border:0;outline:0;padding:13px 14px 13px 4px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--ink);width:100%;}
  .input-plain input{flex:1;border:0;outline:0;padding:13px 6px 13px 14px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--ink);width:100%;}
  .input-plain .suffix{padding:0 14px 0 4px;color:var(--mute);font-weight:600;}
  .hint{font-size:12px;margin:6px 0 0;} .hint--mute{color:var(--mute);}
  .result{display:flex;flex-direction:column;gap:3px;padding:12px 16px;border-radius:10px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.10);}
  .result--primary{background:#fff;border-color:#fff;}
  .result--primary .result-label{color:#384055;} .result--primary .result-value{color:var(--ink);} .result--primary .result-note{color:#6B7280;}
  .result-label{font-size:12.5px;color:#aeb6c8;font-weight:600;}
  .result-value{font-family:'Fraunces',serif;font-weight:600;font-size:24px;letter-spacing:-.01em;color:#fff;}
  .result-note{font-size:10.5px;line-height:1.45;color:#8b93a6;}
  .cta-primary{display:block;text-align:center;background:var(--blue);color:#fff;text-decoration:none;font-weight:600;padding:14px;border-radius:10px;margin-top:6px;transition:background .15s;}
  .cta-primary:hover{background:#2a57e6;}
  .micro{font-size:11px;color:#8b93a6;text-align:center;margin:0;}
  .conclusion-card{background:var(--paper-tint);border:1px solid var(--bone);border-radius:16px;padding:28px 32px;margin:8px 0 32px;max-width:760px;}
  .conclusion-card h3{font-family:'Fraunces',serif;font-weight:600;font-size:22px;margin:0 0 12px;}
  .conclusion-card p{color:#2b3140;margin:0 0 12px;}
  .body-content h2{font-family:'Fraunces',serif;font-weight:500;font-size:28px;margin:40px 0 12px;}
  .body-content p{color:#2b3140;}
  .author{display:flex;align-items:center;gap:16px;margin:0 0 32px;}
  .author img{width:64px;height:64px;border-radius:50%;object-fit:cover;}
  .author h3{font-family:'Fraunces',serif;font-weight:500;font-size:18px;margin:0;}
  .author a{color:var(--ink);text-decoration:none;} .author a:hover{color:var(--blue);}
  .cta-card{background:var(--paper-tint);border:1px solid var(--bone);border-radius:16px;padding:32px;text-align:center;margin:24px auto;max-width:760px;}
  .cta-card h4{font-family:'Fraunces',serif;font-weight:500;font-size:24px;margin:0 0 12px;}
  .cta-card p{max-width:620px;margin:0 auto 18px;}
  .cta-card ul{list-style:none;padding:0;margin:18px 0;color:#384055;font-size:15px;}
  .cta-card a{display:inline-block;background:var(--ink);color:#fff;padding:13px 26px;border-radius:9px;text-decoration:none;font-weight:600;}
  .cta-card a:hover{background:var(--blue);}
  .related-placeholder{border:1px dashed var(--bone);border-radius:10px;padding:20px;color:var(--mute);font-family:'JetBrains Mono',monospace;font-size:13px;text-align:center;}
  </style>
</Layout>
</content>
