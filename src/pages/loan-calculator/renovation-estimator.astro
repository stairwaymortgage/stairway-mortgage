---
import Layout from '../../layouts/Layout.astro';
import CalcLeadForm from '../../components/CalcLeadForm.astro';
const metaTitle = "Renovation Estimator | Stairway Mortgage";
const metaDescription = "Enter your project scopes and finish level to get a ballpark total for your home renovation, including demo and contingency. Built by Jim Blackburn, NMLS #1072866.";
const canonical = "https://stairwaymortgage.com/loan-calculator/renovation-estimator/";
const breadcrumbSchema = {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://stairwaymortgage.com/"},{"@type":"ListItem","position":2,"name":"Loan Calculators","item":"https://stairwaymortgage.com/loan-calculators/"},{"@type":"ListItem","position":3,"name":"Renovation Estimator","item":canonical}]};
const appSchema = {"@context":"https://schema.org","@type":"WebApplication","name":"Renovation Estimator","applicationCategory":"FinanceApplication","operatingSystem":"All","url":canonical,"offers":{"@type":"Offer","price":"0","priceCurrency":"USD"},"description":metaDescription};
const faqSchema = {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How does the finish level affect the estimate?","acceptedAnswer":{"@type":"Answer","text":"Each finish level — Economy, Standard, or Premium — applies a different built-in unit cost for paint, flooring, windows, kitchens, and baths."}},{"@type":"Question","name":"What is included in the total?","acceptedAnswer":{"@type":"Answer","text":"Hard costs for each scope plus your appliances allowance, a demo and disposal percentage, and a contingency percentage."}},{"@type":"Question","name":"Is this an exact quote?","acceptedAnswer":{"@type":"Answer","text":"No. It's a ballpark estimate using typical unit costs. Actual pricing depends on your market, materials, and contractor."}}]};
---
<Layout title={metaTitle} description={metaDescription}>
  <link slot="head" rel="canonical" href={canonical} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <main class="container-page">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a> <span>/</span>
      <a href="/loan-calculators/">Loan Calculators</a> <span>/</span>
      <span aria-current="page">Renovation Estimator</span>
    </nav>
    <header class="calc-head">
      <p class="eyebrow">Renovation · Budget</p>
      <h1 class="display-lg">Renovation Estimator</h1>
      <p class="lede">Enter your project scopes and finish level to get a ballpark total for your home improvements.</p>
      <p class="trust">Built by Jim Blackburn · NMLS #1072866 · $500M+ closed · 7× Scotsman Guide Top Producer</p>
    </header>
    <section class="calc" aria-label="Renovation Estimator">
      <div class="calc-grid">
        <div class="calc-inputs">
          <p class="group-label">Finish &amp; Area</p>
          <div class="field">
            <label for="finish">Finish Level</label>
            <select id="finish"><option value="0" selected>Economy</option><option value="1">Standard</option><option value="2">Premium</option></select>
            <p class="hint hint--mute">Sets the built-in unit costs for each scope.</p>
          </div>
          <div class="field"><label for="projArea">Project Area (sq ft)</label><div class="input-plain"><input id="projArea" type="number" inputmode="numeric" value="2000" min="0" step="100" /></div><p class="hint hint--mute">Used only to compute cost per square foot.</p></div>
          <p class="group-label">Scopes — Enter Quantities (0 to skip)</p>
          <div class="field-row">
            <div class="field"><label for="kitchens">Kitchens</label><div class="input-plain"><input id="kitchens" type="number" inputmode="numeric" value="1" min="0" step="1" /></div></div>
            <div class="field"><label for="baths">Full Baths</label><div class="input-plain"><input id="baths" type="number" inputmode="numeric" value="2" min="0" step="1" /></div></div>
          </div>
          <div class="field"><label for="floor">Flooring Area to Replace (sq ft)</label><div class="input-plain"><input id="floor" type="number" inputmode="numeric" value="2000" min="0" step="50" /></div></div>
          <div class="field"><label for="paint">Interior Paint Area (sq ft)</label><div class="input-plain"><input id="paint" type="number" inputmode="numeric" value="2000" min="0" step="50" /></div></div>
          <div class="field"><label for="windows">Windows (replace)</label><div class="input-plain"><input id="windows" type="number" inputmode="numeric" value="10" min="0" step="1" /></div></div>
          <div class="field"><label for="appliances">Appliances Allowance</label><div class="input-money"><span>$</span><input id="appliances" type="number" inputmode="numeric" value="5000" min="0" step="500" /></div></div>
          <p class="group-label">Add-Ons</p>
          <div class="field-row">
            <div class="field"><label for="demo">Demo &amp; Disposal</label><div class="input-plain"><input id="demo" type="number" inputmode="decimal" value="10" min="0" step="1" /><span class="suffix">%</span></div></div>
            <div class="field"><label for="cont">Contingency</label><div class="input-plain"><input id="cont" type="number" inputmode="decimal" value="10" min="0" step="1" /><span class="suffix">%</span></div></div>
          </div>
        </div>
        <div class="calc-results" aria-live="polite">
          <p class="summary-title">Results</p>
          <p class="summary-sub">Scope Costs</p>
          <div class="result"><span class="result-label">Paint</span><span class="result-value" id="rPaint">$2,000</span></div>
          <div class="result"><span class="result-label">Flooring</span><span class="result-value" id="rFloor">$10,000</span></div>
          <div class="result"><span class="result-label">Windows</span><span class="result-value" id="rWindow">$1,000</span></div>
          <div class="result"><span class="result-label">Kitchens</span><span class="result-value" id="rKitchen">$20,000</span></div>
          <div class="result"><span class="result-label">Baths</span><span class="result-value" id="rBath">$2,000</span></div>
          <p class="summary-sub">Rollup</p>
          <div class="result"><span class="result-label">Hard Costs</span><span class="result-value" id="rHard">$40,000</span><span class="result-note">Scopes + appliances allowance.</span></div>
          <div class="result"><span class="result-label">Demo &amp; Disposal</span><span class="result-value" id="rDemo">$4,000</span></div>
          <div class="result"><span class="result-label">Subtotal</span><span class="result-value" id="rSub">$44,000</span></div>
          <div class="result"><span class="result-label">Contingency</span><span class="result-value" id="rCont">$4,400</span></div>
          <div class="result result--primary"><span class="result-label">Total Project Cost</span><span class="result-value" id="rTotal">$48,400</span></div>
          <div class="result result--primary"><span class="result-label">Cost per Sq Ft</span><span class="result-value" id="rCps">$24.20</span></div>
          <a class="cta-primary" data-calc-cta data-calc-slug="renovation-estimator">See My Options</a>
          <p class="micro">Estimates only — not a commitment to lend.</p>
        </div>
      </div>
    </section>
    <section class="body-content">
      <figure class="author">
        <a href="https://www.linkedin.com/company/nexa-mortgage-jim-blackburn-team" target="_blank" rel="noopener">
          <img width="120" height="120" src="/wp-content/uploads/2025/10/Untitled-design-3.png" alt="Jim Blackburn" />
        </a>
        <h3><a href="https://www.linkedin.com/company/nexa-mortgage-jim-blackburn-team" target="_blank" rel="noopener">By Jim Blackburn</a></h3>
      </figure>
      <div class="cta-card">
        <h4>Ready to Take Your First Step?</h4>
        <p><strong>Skip the guesswork.</strong> Take our quick Discovery Quiz to uncover your top financial priorities, so we can guide you toward the wealth-building strategies that fit your life.</p>
        <ul><li>Takes just 5 minutes</li><li>Tailored results based on your answers</li><li>No credit check required</li></ul>
        <a href="https://stairwaymortgage.com/discovery-quiz">Take the Discovery Quiz</a>
      </div>
      <div class="cta-card">
        <h4>Financing Your Renovation?</h4>
        <p>Tell us about your project and we'll show how a renovation loan or HELOC can fund it—fast.</p>
        <ul><li>Only 2 minutes to complete</li><li>Quick turnaround</li><li>No credit score impact</li></ul>
        <a href="https://stairwaymortgage.com/refinance-or-heloc-inquiry">See My Options</a>
      </div>
      <div class="cta-card">
        <h4>Got a Few Questions First?</h4>
        <p>Let's talk it through. Book a call and one of our friendly advisors will be in touch to guide you personally.</p>
        <a href="https://stairwaymortgage.com/schedule-call">Schedule a Call</a>
      </div>
      <h2>Important Disclaimer</h2>
      <p>This calculator is for illustrative purposes only and does not constitute financial, legal, or investment advice. Results are based on general assumptions and may not reflect actual performance or eligibility. This is not a loan estimate or approval. Please consult with a licensed contractor and mortgage advisor before making financial decisions.</p>
      <h2>Related Posts</h2>
      <div class="related-placeholder">Related calculators module ([loan_calculator_box])</div>
    </section>
  </main>

  <script is:inline>
  (function () {
    const $ = (id) => document.getElementById(id);
    const fmt0 = (n) => { if(!isFinite(n)) return '—'; const r=Math.round(n); return (r<0?'-$':'$') + Math.abs(r).toLocaleString('en-US'); };
    const fmt2 = (n) => { if(!isFinite(n)) return '—'; return (n<0?'-$':'$') + Math.abs(n).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}); };
    const tier = (f,e,s,p) => (f===0 ? e : (f===1 ? s : p));  // Economy/Standard/Premium (2+ => premium)
    function compute(){
      const f=+$('finish').value, projArea=+$('projArea').value||0,
            kitchens=+$('kitchens').value||0, baths=+$('baths').value||0,
            floor=+$('floor').value||0, paint=+$('paint').value||0, windows=+$('windows').value||0,
            appliances=+$('appliances').value||0, demoPct=+$('demo').value||0, contPct=+$('cont').value||0;
      // Scope costs: quantity × finish-tiered unit cost
      const paintCost  = paint   * tier(f, 1, 1.5, 2);     // $/sqft
      const floorCost  = floor   * tier(f, 5, 10, 15);     // $/sqft
      const windowCost = windows * tier(f, 100, 150, 200); // $/window
      const kitchenCost= kitchens* tier(f, 20000, 30000, 40000); // $/kitchen
      const bathCost   = baths   * tier(f, 1000, 2000, 3000);    // $/bath
      // Hard Costs = scopes + appliances allowance (field directly)
      const hard = paintCost + floorCost + windowCost + kitchenCost + bathCost + appliances;
      // Demo & Disposal = demo%/100 × hard
      const demo = demoPct/100 * hard;
      // Subtotal = hard + demo
      const sub = hard + demo;
      // Contingency = cont%/100 × subtotal
      const cont = contPct/100 * sub;
      // Total = subtotal + contingency
      const total = sub + cont;
      // Cost per Sq Ft = total / projArea (guard >0)
      const cps = projArea>0 ? total/projArea : 0;
      $('rPaint').textContent=fmt0(paintCost); $('rFloor').textContent=fmt0(floorCost);
      $('rWindow').textContent=fmt0(windowCost); $('rKitchen').textContent=fmt0(kitchenCost);
      $('rBath').textContent=fmt0(bathCost); $('rHard').textContent=fmt0(hard);
      $('rDemo').textContent=fmt0(demo); $('rSub').textContent=fmt0(sub);
      $('rCont').textContent=fmt0(cont); $('rTotal').textContent=fmt0(total);
      $('rCps').textContent=fmt2(cps);
    }
    document.querySelectorAll('input,select').forEach(el=>{el.addEventListener('input',compute);el.addEventListener('change',compute);});
    compute();
  })();
  </script>

  <style>
  .crumbs{font-family:'JetBrains Mono',monospace;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--mute);margin-bottom:28px;}
  .crumbs a{color:var(--mute);text-decoration:none;} .crumbs a:hover{color:var(--blue);} .crumbs span{margin:0 6px;}
  .eyebrow{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--blue);margin:0 0 10px;}
  .display-lg{font-family:'Fraunces',Georgia,serif;font-weight:500;font-size:clamp(28px,4.4vw,46px);line-height:1.08;margin:0 0 18px;letter-spacing:-.01em;}
  .lede{font-size:18px;color:#2b3140;max-width:62ch;margin:0 0 14px;}
  .trust{font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--mute);border-top:1px solid var(--bone);padding-top:14px;margin:0;}
  .calc{margin:40px 0 56px;border:1px solid var(--bone);border-radius:18px;overflow:hidden;background:#fff;box-shadow:0 1px 0 var(--bone),0 24px 48px -32px rgba(10,14,26,.25);}
  .calc::before{content:"";display:block;height:4px;background:var(--blue);}
  .calc-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:0;}
  @media(max-width:780px){.calc-grid{grid-template-columns:1fr;}}
  .calc-inputs{padding:30px 30px 32px;}
  .group-label{font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-size:11px;color:var(--blue);font-weight:600;margin:22px 0 12px;}
  .group-label:first-child{margin-top:0;}
  .calc-results{padding:30px;background:var(--ink);color:#fff;display:flex;flex-direction:column;gap:12px;}
  .summary-title{font-family:'Fraunces',serif;font-weight:600;font-size:28px;margin:0 0 4px;color:#fff;}
  .summary-sub{font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-size:11px;color:#aeb6c8;border-top:1px solid rgba(255,255,255,.15);padding-top:14px;margin:8px 0 0;}
  .field{margin-bottom:20px;}
  .field-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
  @media(max-width:520px){.field-row{grid-template-columns:1fr;}}
  .lbl,label{display:block;font-size:13.5px;font-weight:600;color:#384055;margin-bottom:8px;}
  .input-money,.input-plain{display:flex;align-items:center;border:1px solid var(--bone);border-radius:10px;background:#fff;overflow:hidden;transition:border-color .15s,box-shadow .15s;}
  .input-money:focus-within,.input-plain:focus-within{border-color:var(--blue);box-shadow:0 0 0 3px rgba(24,69,214,.12);}
  .input-money span{padding:0 4px 0 14px;color:var(--mute);font-weight:600;}
  .input-money input{flex:1;border:0;outline:0;padding:13px 14px 13px 4px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--ink);width:100%;}
  .input-plain input{flex:1;border:0;outline:0;padding:13px 6px 13px 14px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--ink);width:100%;}
  .input-plain .suffix{padding:0 14px 0 4px;color:var(--mute);font-weight:600;}
  select{width:100%;padding:13px 14px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;border:1px solid var(--bone);border-radius:10px;background:#fff;color:var(--ink);}
  select:focus{outline:0;border-color:var(--blue);box-shadow:0 0 0 3px rgba(24,69,214,.12);}
  .hint{font-size:12px;margin:6px 0 0;color:var(--mute);} .hint--mute{color:var(--mute);}
  .result{display:flex;flex-direction:column;gap:3px;padding:12px 16px;border-radius:10px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.10);}
  .result--primary{background:#fff;border-color:#fff;}
  .result--primary .result-label{color:#384055;} .result--primary .result-value{color:var(--ink);} .result--primary .result-note{color:#6B7280;}
  .result-label{font-size:12.5px;color:#aeb6c8;font-weight:600;}
  .result-value{font-family:'Fraunces',serif;font-weight:600;font-size:24px;letter-spacing:-.01em;color:#fff;}
  .result-note{font-size:10.5px;line-height:1.45;color:#8b93a6;}
  .cta-primary{display:block;text-align:center;background:var(--blue);color:#fff;text-decoration:none;font-weight:600;padding:14px;border-radius:10px;margin-top:6px;transition:background .15s;}
  .cta-primary:hover{background:#2a57e6;}
  .micro{font-size:11px;color:#8b93a6;text-align:center;margin:0;}
  .body-content h2{font-family:'Fraunces',serif;font-weight:500;font-size:28px;margin:40px 0 12px;}
  .body-content p{color:#2b3140;}
  .author{display:flex;align-items:center;gap:16px;margin:0 0 32px;}
  .author img{width:64px;height:64px;border-radius:50%;object-fit:cover;}
  .author h3{font-family:'Fraunces',serif;font-weight:500;font-size:18px;margin:0;}
  .author a{color:var(--ink);text-decoration:none;} .author a:hover{color:var(--blue);}
  .cta-card{background:var(--paper-tint);border:1px solid var(--bone);border-radius:16px;padding:32px;text-align:center;margin:24px auto;max-width:760px;}
  .cta-card h4{font-family:'Fraunces',serif;font-weight:500;font-size:24px;margin:0 0 12px;}
  .cta-card p{max-width:620px;margin:0 auto 18px;}
  .cta-card ul{list-style:none;padding:0;margin:18px 0;color:#384055;font-size:15px;}
  .cta-card a{display:inline-block;background:var(--ink);color:#fff;padding:13px 26px;border-radius:9px;text-decoration:none;font-weight:600;}
  .cta-card a:hover{background:var(--blue);}
  .related-placeholder{border:1px dashed var(--bone);border-radius:10px;padding:20px;color:var(--mute);font-family:'JetBrains Mono',monospace;font-size:13px;text-align:center;}
  </style>
  <CalcLeadForm />
</Layout>
