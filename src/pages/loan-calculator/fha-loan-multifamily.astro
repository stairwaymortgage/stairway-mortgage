---
import Layout from '../../layouts/Layout.astro';
import CalcLeadForm from '../../components/CalcLeadForm.astro';
const metaTitle = "FHA 2–4 Unit Home Purchase Cash Flow & Appreciation Calculator | Stairway Mortgage";
const metaDescription = "Estimate your monthly payment, cash to close, rental cash flow, and long-term appreciation on a 2–4 unit owner-occupied FHA purchase. Built by Jim Blackburn, NMLS #1072866.";
const canonical = "https://stairwaymortgage.com/loan-calculator/fha-loan-multifamily/";
const breadcrumbSchema = {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://stairwaymortgage.com/"},{"@type":"ListItem","position":2,"name":"Loan Calculators","item":"https://stairwaymortgage.com/loan-calculators/"},{"@type":"ListItem","position":3,"name":"FHA 2–4 Unit Home Purchase Cash Flow Appreciation Calculator","item":canonical}]};
const appSchema = {"@context":"https://schema.org","@type":"WebApplication","name":"FHA 2–4 Unit Home Purchase Cash Flow Appreciation Calculator","applicationCategory":"FinanceApplication","operatingSystem":"All","url":canonical,"offers":{"@type":"Offer","price":"0","priceCurrency":"USD"},"description":metaDescription};
const faqSchema = {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Can I buy a 2–4 unit with an FHA loan?","acceptedAnswer":{"@type":"Answer","text":"Yes. FHA allows as little as 3.5% down on a 2–4 unit property as long as you occupy one of the units as your primary residence. The other units can be rented."}},{"@type":"Question","name":"How does rental income help me qualify?","acceptedAnswer":{"@type":"Answer","text":"FHA typically lets you count about 75% of the market rent from the units you won't occupy toward qualifying, which can substantially lower the income you need."}},{"@type":"Question","name":"How is appreciation estimated here?","acceptedAnswer":{"@type":"Answer","text":"This tool assumes a conservative 3% annual appreciation and projects your property value, remaining mortgage balance, equity, and cumulative cash flow at 5, 15, and 30 years."}}]};
---
<Layout title={metaTitle} description={metaDescription}>
  <link slot="head" rel="canonical" href={canonical} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <main class="container-page">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a> <span>/</span>
      <a href="/loan-calculators/">Loan Calculators</a> <span>/</span>
      <span aria-current="page">FHA 2–4 Unit Cash Flow &amp; Appreciation</span>
    </nav>
    <header class="calc-head">
      <p class="eyebrow">FHA · 2–4 Unit · Owner-Occupied</p>
      <h1 class="display-lg">FHA 2–4 Unit Home Purchase Cash Flow &amp; Appreciation Calculator</h1>
      <p class="lede">Estimate your monthly payment, cash to close, rental cash flow, and long-term appreciation on a 2–4 unit home you'll live in while renting the other units with an FHA loan.</p>
      <p class="trust">Built by Jim Blackburn · NMLS #1072866 · $500M+ closed · 7× Scotsman Guide Top Producer</p>
    </header>
    <section class="calc" aria-label="FHA 2–4 Unit Cash Flow and Appreciation Calculator">
      <div class="calc-grid">
        <div class="calc-inputs">
          <p class="group-label">Your Scenario</p>
          <div class="field-row">
            <div class="field"><label for="ownHome">Do you own a home already?</label>
              <select id="ownHome"><option value="1" selected>Yes</option><option value="2">No</option></select>
            </div>
            <div class="field"><label for="units">How many units are you buying?</label>
              <select id="units"><option value="2" selected>2</option><option value="3">3</option><option value="4">4</option></select>
            </div>
          </div>
          <div class="field"><label for="rent">Total Current Rent on Non-Owner-Occupied Units (Monthly)</label><div class="input-money"><span>$</span><input id="rent" type="number" inputmode="numeric" value="9000" min="0" step="100" /></div><p class="hint hint--mute">Enter only the rent for the units you won't occupy.</p></div>
          <p class="group-label">Purchase &amp; Loan</p>
          <div class="field"><label for="price">Purchase Price</label><div class="input-money"><span>$</span><input id="price" type="number" inputmode="numeric" value="1000000" min="0" step="10000" /></div></div>
          <div class="field">
            <label for="dp">Down Payment Percentage: <span id="dpOut" class="slider-out">3.5%</span></label>
            <input id="dp" type="range" min="3.5" max="100" step="1" value="3.5" data-default="3.5" />
            <p class="hint hint--mute">3.5% is the minimum (down payment assistance and gift funds allowed).</p>
          </div>
          <div class="field">
            <label for="rate">Estimated Interest Rate: <span id="rateOut" class="slider-out">7.0%</span></label>
            <input id="rate" type="range" min="2.5" max="10" step="0.1" value="7" />
          </div>
          <p class="group-label">Housing Costs</p>
          <div class="field-row">
            <div class="field"><label for="ins">Annual Insurance</label><div class="input-money"><span>$</span><input id="ins" type="number" inputmode="numeric" value="2400" min="0" step="100" /></div></div>
            <div class="field"><label for="tax">Annual Taxes</label><div class="input-money"><span>$</span><input id="tax" type="number" inputmode="numeric" value="3600" min="0" step="100" /></div></div>
          </div>
          <div class="field"><label for="hoa">Monthly HOA</label><div class="input-money"><span>$</span><input id="hoa" type="number" inputmode="numeric" value="0" min="0" step="25" /></div><p class="hint hint--mute">Paid separately, outside the mortgage.</p></div>
        </div>
        <div class="calc-results" aria-live="polite">
          <p class="summary-title">Summary</p>
          <p class="summary-sub">Loan</p>
          <div class="result"><span class="result-label">Desired Loan Amount</span><span class="result-value" id="rBase">$965,000</span></div>
          <div class="result"><span class="result-label">UFMIP (1.75%)</span><span class="result-value" id="rUfmip">$16,888</span></div>
          <div class="result"><span class="result-label">Final Loan Amount</span><span class="result-value" id="rFinal">$981,888</span><span class="result-note">Base + UFMIP.</span></div>
          <p class="summary-sub">Monthly Payment</p>
          <div class="result"><span class="result-label">Principal &amp; Interest</span><span class="result-value" id="rPi">$6,533</span></div>
          <div class="result"><span class="result-label">Monthly Insurance</span><span class="result-value" id="rIns">$200</span></div>
          <div class="result"><span class="result-label">Monthly Taxes</span><span class="result-value" id="rTax">$300</span></div>
          <div class="result"><span class="result-label">Estimated Monthly MI</span><span class="result-value" id="rMI">$614</span></div>
          <div class="result result--primary"><span class="result-label">Total Monthly Housing Expense</span><span class="result-value" id="rTotal">$7,646</span><span class="result-note">P&amp;I + insurance + taxes + MI. HOA shown separately.</span></div>
          <div class="result"><span class="result-label">HOA Paid Separately</span><span class="result-value" id="rHoa">$0</span></div>
          <p class="summary-sub">Rental Cash Flow</p>
          <div class="result"><span class="result-label">Monthly Rent Collected</span><span class="result-value" id="rRent">$9,000</span></div>
          <div class="result result--primary"><span class="result-label">Monthly Cashflow</span><span class="result-value" id="rCf">$1,354</span><span class="result-note">Rent collected minus total housing expense.</span></div>
          <div class="result"><span class="result-label">Monthly Personal Cost of Living</span><span class="result-value" id="rPcol">-$1,354</span><span class="result-note">Your net housing cost after rental income.</span></div>
          <p class="summary-sub">Cash to Close</p>
          <div class="result"><span class="result-label">Without Seller Credit or DPA</span><span class="result-value" id="rCashNo">$95,000</span><span class="result-note">Down payment + ~6% estimated closing costs.</span></div>
          <div class="result"><span class="result-label">With Seller Credit</span><span class="result-value" id="rCashSC">$35,000</span><span class="result-note">Assumes seller covers ~6% closing costs.</span></div>
          <div class="result result--primary"><span class="result-label">With Seller Credit AND DPA</span><span class="result-value" id="rCashDPA">$0</span><span class="result-note">Assumes 3.5% DPA plus a 6% seller credit.</span></div>
          <p class="summary-sub">Qualifying</p>
          <div class="result"><span class="result-label">Monthly Income Target to Qualify</span><span class="result-value" id="rIncome">$8,542</span><span class="result-note">50% DTI with 75% rental credit.</span></div>
          <p class="summary-sub">Wealth Analysis (3% Annual Appreciation)</p>
          <div class="result"><span class="result-label">1st Year Appreciation</span><span class="result-value" id="rApp1">$30,000</span><span class="result-note">First-year dollar gain.</span></div>
          <div class="wealth-grid">
            <div class="wealth-col">
              <p class="wealth-year">5 Years</p>
              <div class="result"><span class="result-label">Property Value</span><span class="result-value" id="rApp5">$1,159,274</span></div>
              <div class="result"><span class="result-label">Mortgage Balance</span><span class="result-value" id="rBal5">$908,370</span></div>
              <div class="result result--primary"><span class="result-label">Equity</span><span class="result-value" id="rEq5">$250,904</span></div>
              <div class="result"><span class="result-label">Cash Flow Collected</span><span class="result-value" id="rCf5">$81,228</span></div>
            </div>
            <div class="wealth-col">
              <p class="wealth-year">15 Years</p>
              <div class="result"><span class="result-label">Property Value</span><span class="result-value" id="rApp15">$1,557,967</span></div>
              <div class="result"><span class="result-label">Mortgage Balance</span><span class="result-value" id="rBal15">$714,282</span></div>
              <div class="result result--primary"><span class="result-label">Equity</span><span class="result-value" id="rEq15">$843,685</span></div>
              <div class="result"><span class="result-label">Cash Flow Collected</span><span class="result-value" id="rCf15">$243,684</span></div>
            </div>
            <div class="wealth-col">
              <p class="wealth-year">30 Years</p>
              <div class="result"><span class="result-label">Property Value</span><span class="result-value" id="rApp30">$2,427,262</span></div>
              <div class="result"><span class="result-label">Mortgage Balance</span><span class="result-value" id="rBal30">$0</span></div>
              <div class="result result--primary"><span class="result-label">Equity</span><span class="result-value" id="rEq30">$2,427,262</span></div>
              <div class="result"><span class="result-label">Cash Flow Collected</span><span class="result-value" id="rCf30">$487,368</span></div>
            </div>
          </div>
          <a class="cta-primary" data-calc-cta data-calc-slug="fha-loan-multifamily">See My Options</a>
          <p class="micro">Estimates only — not a commitment to lend.</p>
        </div>
      </div>
    </section>
    <section class="body-content">
      <figure class="author">
        <a href="https://www.linkedin.com/company/nexa-mortgage-jim-blackburn-team" target="_blank" rel="noopener">
          <img width="120" height="120" src="/wp-content/uploads/2025/10/Untitled-design-3.png" alt="Jim Blackburn" />
        </a>
        <h3><a href="https://www.linkedin.com/company/nexa-mortgage-jim-blackburn-team" target="_blank" rel="noopener">By Jim Blackburn</a></h3>
      </figure>
      <div class="cta-card">
        <h4>Ready to Take Your First Step?</h4>
        <p><strong>Skip the guesswork.</strong> Take our quick Discovery Quiz to uncover your top financial priorities, so we can guide you toward the wealth-building strategies that fit your life.</p>
        <ul><li>Takes just 5 minutes</li><li>Tailored results based on your answers</li><li>No credit check required</li></ul>
        <a href="https://stairwaymortgage.com/discovery-quiz">Take the Discovery Quiz</a>
      </div>
      <div class="cta-card">
        <h4>House Hacking a 2–4 Unit?</h4>
        <p>Tell us about your scenario and we'll map out your real payment, qualifying income, and cash flow with the right strategy—fast.</p>
        <ul><li>Only 2 minutes to complete</li><li>Quick turnaround</li><li>No credit score impact</li></ul>
        <a href="https://stairwaymortgage.com/purchase-inquiry">See My Options</a>
      </div>
      <div class="cta-card">
        <h4>Got a Few Questions First?</h4>
        <p>Let's talk it through. Book a call and one of our friendly advisors will be in touch to guide you personally.</p>
        <a href="https://stairwaymortgage.com/schedule-call">Schedule a Call</a>
      </div>
      <h2>Important Disclaimer</h2>
      <p>This calculator is for illustrative purposes only and does not constitute financial, legal, or investment advice. Results are based on general assumptions and may not reflect actual performance or eligibility. This is not a loan estimate or approval. Please consult with a licensed mortgage advisor before making financial decisions.</p>
      <h2>Related Posts</h2>
      <div class="related-placeholder">Related calculators module ([loan_calculator_box])</div>
    </section>
  </main>

  <script is:inline>
  (function () {
    const $ = (id) => document.getElementById(id);
    const fmt0 = (n) => { if(!isFinite(n)) return '—'; const r=Math.round(n); return (r<0?'-$':'$') + Math.abs(r).toLocaleString('en-US'); };
    let dpTouched = false;
    function balAt(base, rate, n){
      const R = rate/100/12;
      const p360 = Math.pow(1+R,360), pn = Math.pow(1+R,n);
      const denom = p360 - 1;
      if (denom === 0) return 0;
      return base * ((p360 - pn) / denom);
    }
    function compute(){
      const ownHome=$('ownHome').value, units=$('units').value, rent=+$('rent').value||0,
            price=+$('price').value||0, rate=+$('rate').value||0,
            ins=+$('ins').value||0, tax=+$('tax').value||0, hoa=+$('hoa').value||0;
      // Down payment holds 3.5 until slider dragged (matches live widget)
      const dp = dpTouched ? (+$('dp').value||0) : 3.5;
      $('dpOut').textContent = dp+'%';
      $('rateOut').textContent = rate.toFixed(1)+'%';
      // Desired (base) loan = price - price*dp/100 + (dp/100)*0.0175 [near-zero artifact, replicated]
      const base = price - (price*dp/100) + (dp/100)*0.0175;
      // UFMIP = base*0.0175
      const ufmip = base*0.0175;
      // Final = base + ufmip
      const final = base + ufmip;
      // P&I = ROUND( final*(rate/100/12)/(1-(1+rate/100/12)^-360), 2)  -- uses FINAL loan, term hardcoded 360
      const r = rate/100/12;
      let pi = 0;
      if (r>0) pi = Math.round( (final*r/(1-Math.pow(1+r,-360)))*100 )/100;
      else pi = final/360;
      // Monthly Ins / Tax
      const mIns = ins/12, mTax = tax/12;
      // Monthly MI = final*0.0075/12
      const mMI = final*0.0075/12;
      // Total Housing = P&I + ins + tax + MI (HOA excluded)
      const totH = pi + mIns + mTax + mMI;
      // Monthly Rent Collected = rent (passthrough)
      const rentC = rent;
      // Monthly Cashflow = rent collected - total housing
      const cf = rentC - totH;
      // Monthly Personal Cost of Living = total housing - rent
      const pcol = totH - rent;
      // Cash WITHOUT = (dp*price)*.01 + 0.06*price
      const cashNo = (dp*price)*0.01 + 0.06*price;
      // Cash WITH SC = (dp*price)*.01
      const cashSC = (dp*price)*0.01;
      // Cash WITH SC+DPA = IF units==2(val1) OR units==3(val2): cashSC - 3.5%*price ELSE cashSC. 4-unit excluded.
      const dpaTriggers = (units==='2' || units==='3');
      const cashDPA = dpaTriggers ? (cashSC - (3.5/100*price)) : cashSC;
      // Income Target = (totH*2) - rent*0.75
      const incTarget = (totH*2) - rent*0.75;
      // Appreciation: 1yr SIMPLE gain = price*0.03 ; 5/15/30 COMPOUND future value = price*1.03^n
      const app1 = price*0.03;
      const app5 = price*Math.pow(1.03,5);
      const app15 = price*Math.pow(1.03,15);
      const app30 = price*Math.pow(1.03,30);
      // Mortgage balances (use BASE loan); 30yr hardcoded 0
      const bal5 = balAt(base, rate, 60);
      const bal15 = balAt(base, rate, 180);
      const bal30 = 0;
      // Equity = appreciation FV - balance
      const eq5 = app5 - bal5, eq15 = app15 - bal15, eq30 = app30 - bal30;
      // Cash flow collected = monthly cf * months
      const cf5 = cf*60, cf15 = cf*180, cf30 = cf*360;
      $('rBase').textContent=fmt0(base); $('rUfmip').textContent=fmt0(ufmip); $('rFinal').textContent=fmt0(final);
      $('rPi').textContent=fmt0(pi); $('rIns').textContent=fmt0(mIns); $('rTax').textContent=fmt0(mTax); $('rMI').textContent=fmt0(mMI);
      $('rTotal').textContent=fmt0(totH); $('rHoa').textContent=fmt0(hoa);
      $('rRent').textContent=fmt0(rentC); $('rCf').textContent=fmt0(cf); $('rPcol').textContent=fmt0(pcol);
      $('rCashNo').textContent=fmt0(cashNo); $('rCashSC').textContent=fmt0(cashSC); $('rCashDPA').textContent=fmt0(cashDPA);
      $('rIncome').textContent=fmt0(incTarget);
      $('rApp1').textContent=fmt0(app1);
      $('rApp5').textContent=fmt0(app5); $('rBal5').textContent=fmt0(bal5); $('rEq5').textContent=fmt0(eq5); $('rCf5').textContent=fmt0(cf5);
      $('rApp15').textContent=fmt0(app15); $('rBal15').textContent=fmt0(bal15); $('rEq15').textContent=fmt0(eq15); $('rCf15').textContent=fmt0(cf15);
      $('rApp30').textContent=fmt0(app30); $('rBal30').textContent=fmt0(bal30); $('rEq30').textContent=fmt0(eq30); $('rCf30').textContent=fmt0(cf30);
    }
    $('dp').addEventListener('input', ()=>{ dpTouched = true; });
    document.querySelectorAll('input,select').forEach(el=>{el.addEventListener('input',compute);el.addEventListener('change',compute);});
    compute();
  })();
  </script>

  <style>
  .crumbs{font-family:'JetBrains Mono',monospace;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--mute);margin-bottom:28px;}
  .crumbs a{color:var(--mute);text-decoration:none;} .crumbs a:hover{color:var(--blue);} .crumbs span{margin:0 6px;}
  .eyebrow{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--blue);margin:0 0 10px;}
  .display-lg{font-family:'Fraunces',Georgia,serif;font-weight:500;font-size:clamp(28px,4.4vw,46px);line-height:1.08;margin:0 0 18px;letter-spacing:-.01em;}
  .lede{font-size:18px;color:#2b3140;max-width:62ch;margin:0 0 14px;}
  .trust{font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--mute);border-top:1px solid var(--bone);padding-top:14px;margin:0;}
  .calc{margin:40px 0 56px;border:1px solid var(--bone);border-radius:18px;overflow:hidden;background:#fff;box-shadow:0 1px 0 var(--bone),0 24px 48px -32px rgba(10,14,26,.25);}
  .calc::before{content:"";display:block;height:4px;background:var(--blue);}
  .calc-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:0;}
  @media(max-width:780px){.calc-grid{grid-template-columns:1fr;}}
  .calc-inputs{padding:30px 30px 32px;}
  .group-label{font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-size:11px;color:var(--blue);font-weight:600;margin:22px 0 12px;}
  .group-label:first-child{margin-top:0;}
  .calc-results{padding:30px;background:var(--ink);color:#fff;display:flex;flex-direction:column;gap:12px;}
  .summary-title{font-family:'Fraunces',serif;font-weight:600;font-size:28px;margin:0 0 4px;color:#fff;}
  .summary-sub{font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-size:11px;color:#aeb6c8;border-top:1px solid rgba(255,255,255,.15);padding-top:14px;margin:8px 0 0;}
  .field{margin-bottom:20px;}
  .field-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
  @media(max-width:520px){.field-row{grid-template-columns:1fr;}}
  .lbl,label{display:block;font-size:13.5px;font-weight:600;color:#384055;margin-bottom:8px;}
  .slider-out{color:var(--blue);font-family:'JetBrains Mono',monospace;font-weight:600;}
  input[type=range]{width:100%;accent-color:var(--blue);height:6px;}
  .input-money{display:flex;align-items:center;border:1px solid var(--bone);border-radius:10px;background:#fff;overflow:hidden;transition:border-color .15s,box-shadow .15s;}
  .input-money:focus-within{border-color:var(--blue);box-shadow:0 0 0 3px rgba(24,69,214,.12);}
  .input-money span{padding:0 4px 0 14px;color:var(--mute);font-weight:600;}
  .input-money input{flex:1;border:0;outline:0;padding:13px 14px 13px 4px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--ink);width:100%;}
  select{width:100%;padding:13px 14px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;border:1px solid var(--bone);border-radius:10px;background:#fff;color:var(--ink);}
  select:focus{outline:0;border-color:var(--blue);box-shadow:0 0 0 3px rgba(24,69,214,.12);}
  .hint{font-size:12px;margin:6px 0 0;} .hint--mute{color:var(--mute);}
  .result{display:flex;flex-direction:column;gap:3px;padding:12px 16px;border-radius:10px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.10);}
  .result--primary{background:#fff;border-color:#fff;}
  .result--primary .result-label{color:#384055;} .result--primary .result-value{color:var(--ink);} .result--primary .result-note{color:#6B7280;}
  .result-label{font-size:12.5px;color:#aeb6c8;font-weight:600;}
  .result-value{font-family:'Fraunces',serif;font-weight:600;font-size:24px;letter-spacing:-.01em;color:#fff;}
  .result-note{font-size:10.5px;line-height:1.45;color:#8b93a6;}
  .wealth-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;}
  @media(max-width:620px){.wealth-grid{grid-template-columns:1fr;}}
  .wealth-col{display:flex;flex-direction:column;gap:8px;}
  .wealth-col .result-value{font-size:18px;}
  .wealth-year{font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.08em;font-size:11px;color:#fff;font-weight:600;margin:4px 0 2px;}
  .cta-primary{display:block;text-align:center;background:var(--blue);color:#fff;text-decoration:none;font-weight:600;padding:14px;border-radius:10px;margin-top:6px;transition:background .15s;}
  .cta-primary:hover{background:#2a57e6;}
  .micro{font-size:11px;color:#8b93a6;text-align:center;margin:0;}
  .body-content h2{font-family:'Fraunces',serif;font-weight:500;font-size:28px;margin:40px 0 12px;}
  .body-content p{color:#2b3140;}
  .author{display:flex;align-items:center;gap:16px;margin:0 0 32px;}
  .author img{width:64px;height:64px;border-radius:50%;object-fit:cover;}
  .author h3{font-family:'Fraunces',serif;font-weight:500;font-size:18px;margin:0;}
