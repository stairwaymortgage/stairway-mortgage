---
import Layout from '../../layouts/Layout.astro';
import CalcLeadForm from '../../components/CalcLeadForm.astro';
const metaTitle = "Fix and Flip Profit Calculator: Estimate Your Loan, Holding Costs, Net Profit & Cash-on-Cash ROI";
const metaDescription = "Calculate a fix-and-flip deal: maximum loan at 75% ARV, cash to close, property and holding costs, total project cost, net profit before tax, and cash-on-cash return.";
const canonical = "https://stairwaymortgage.com/loan-calculator/fix-and-flip-loan/";
const breadcrumbSchema = {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://stairwaymortgage.com/"},{"@type":"ListItem","position":2,"name":"Loan Calculators","item":"https://stairwaymortgage.com/loan-calculators/"},{"@type":"ListItem","position":3,"name":"Fix and Flip Profit Calculator","item":canonical}]};
const appSchema = {"@context":"https://schema.org","@type":"WebApplication","name":"Fix And Flip Profit Calculator (Buy/Sell)","applicationCategory":"FinanceApplication","operatingSystem":"All","url":canonical,"offers":{"@type":"Offer","price":"0","priceCurrency":"USD"},"description":metaDescription};
const faqSchema = {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How much can I borrow on a fix and flip?","acceptedAnswer":{"@type":"Answer","text":"Typically up to 75% of the after-repair value (ARV), with 100% of rehab funds available within that limit. A 10% minimum down payment on the purchase price applies."}},{"@type":"Question","name":"What is cash-on-cash ROI?","acceptedAnswer":{"@type":"Answer","text":"Cash-on-cash return measures your profit relative to the actual cash you invested, not the total project size or property value."}},{"@type":"Question","name":"What costs are included?","acceptedAnswer":{"@type":"Answer","text":"Purchase price, renovation plus a 10% contingency, holding costs (interest, taxes, insurance, HOA over the months held), and exit/selling costs."}}]};
---
<Layout title={metaTitle} description={metaDescription} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<main class="container-page">
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href="/">Home</a> <span>/</span>
    <a href="/loan-calculators/">Loan Calculators</a> <span>/</span>
    <span aria-current="page">Fix and Flip Profit Calculator</span>
  </nav>
  <header class="calc-head">
    <p class="eyebrow">Investor · Fix &amp; Flip</p>
    <h1 class="display-lg">Fix and Flip Profit Calculator (Buy/Sell)</h1>
    <p class="lede">Run the numbers on a flip. Estimate your loan at 75% ARV, cash to close, holding and project costs, net profit, and cash-on-cash return.</p>
    <p class="trust">Built by Jim Blackburn · NMLS #1072866 · $500M+ closed · 7× Scotsman Guide Top Producer</p>
  </header>
  <section class="calc" aria-label="Fix and Flip Profit Calculator">
    <div class="calc-grid">
      <div class="calc-inputs">
        <div class="field"><label for="price">Purchase Price</label><div class="input-money"><span>$</span><input id="price" type="number" inputmode="numeric" value="400000" min="0" step="1000" /></div></div>
        <div class="field"><label for="down">Down Payment Percentage <span class="val" id="downVal">10%</span></label><input id="down" type="range" min="10" max="100" step="1" value="10" /><p class="hint hint--mute">10% minimum; 100% of rehab funds up to 75% ARV. ~5% post-close reserves required.</p></div>
        <div class="field"><label for="reno">Renovation Costs</label><div class="input-money"><span>$</span><input id="reno" type="number" inputmode="numeric" value="60000" min="0" step="1000" /></div><p class="hint hint--mute">Estimate all labor and material costs.</p></div>
        <div class="field-row">
          <div class="field"><label for="asis">As-Is Value</label><div class="input-money"><span>$</span><input id="asis" type="number" inputmode="numeric" value="400000" min="0" step="1000" /></div></div>
          <div class="field"><label for="arv">Sales Price / ARV</label><div class="input-money"><span>$</span><input id="arv" type="number" inputmode="numeric" value="630000" min="0" step="1000" /></div></div>
        </div>
        <div class="field"><label for="months">Months Held</label><div class="input-plain"><input id="months" type="number" inputmode="numeric" value="6" min="0" step="1" /><span class="suffix">mo</span></div><p class="hint hint--mute">Time to renovate and sell.</p></div>
        <div class="field"><label for="exit">Estimated Exit Costs (% of sales price)</label><div class="input-plain"><input id="exit" type="number" inputmode="numeric" value="5" min="0" step="0.5" /><span class="suffix">%</span></div><p class="hint hint--mute">~6% with a Realtor, ~3% if you are the Realtor, +2% seller costs. Varies by state.</p></div>
        <div class="field-row">
          <div class="field"><label for="ins">Annual Insurance</label><div class="input-money"><span>$</span><input id="ins" type="number" inputmode="numeric" value="2400" min="0" step="100" /></div></div>
          <div class="field"><label for="tax">Annual Property Tax</label><div class="input-money"><span>$</span><input id="tax" type="number" inputmode="numeric" value="4800" min="0" step="100" /></div></div>
        </div>
        <div class="field"><label for="hoa">Monthly HOA</label><div class="input-money"><span>$</span><input id="hoa" type="number" inputmode="numeric" value="0" min="0" step="10" /></div></div>
        <div class="field"><label for="rate">Estimated New Interest Rate <span class="val" id="rateVal">7.99%</span></label><input id="rate" type="range" min="5" max="10" step="0.1" value="7.99" /></div>
        <div class="field">
          <span class="lbl">Are you thinking about buying another home after this one to continue your wealth journey?</span>
          <div class="radios" role="radiogroup" aria-label="Buying another home">
            <label><input type="radio" name="wealth" value="1" /> Yes</label>
            <label><input type="radio" name="wealth" value="2" checked /> No</label>
          </div>
        </div>
      </div>
      <div class="calc-results" aria-live="polite">
        <p class="summary-title">Summary</p>
        <p class="summary-sub">Financing</p>
        <div class="result"><span class="result-label">Maximum Loan Amount (75% ARV)</span><span class="result-value" id="rMaxLoan">$360,000</span><span class="result-note">Increase the ARV to increase the loan amount.</span></div>
        <div class="result"><span class="result-label">Desired Loan Amount</span><span class="result-value" id="rDesiredLoan">$360,000</span><span class="result-note">Cannot exceed the maximum loan amount.</span></div>
        <div class="result"><span class="result-label">Cash to Close — without seller credit</span><span class="result-value" id="rCashNo">$64,000</span><span class="result-note">Includes 6% estimated closing costs. Not a Loan Estimate.</span></div>
        <div class="result result--primary"><span class="result-label">Cash to Close — with 6% seller credit</span><span class="result-value" id="rCashSC">$40,000</span></div>
        <p class="summary-sub">Project Costs</p>
        <div class="result"><span class="result-label">Property Costs</span><span class="result-value" id="rPropCosts">$466,000</span><span class="result-note">Purchase + renovation + 10% contingency.</span></div>
        <div class="result"><span class="result-label">Holding Costs</span><span class="result-value" id="rHolding">$17,982</span><span class="result-note">Interest, taxes, insurance, HOA over the months held.</span></div>
        <div class="result"><span class="result-label">Estimated Exit Costs</span><span class="result-value" id="rExit">$31,500</span></div>
        <div class="result"><span class="result-label">Total Project Costs</span><span class="result-value" id="rTotalProj">$515,482</span></div>
        <p class="summary-sub">Profit</p>
        <div class="result result--primary"><span class="result-label">Profit Before Tax or 1031 Exchange</span><span class="result-value" id="rProfit">$114,518</span></div>
        <div class="result result--primary"><span class="result-label">Cash-on-Cash ROI Estimate</span><span class="result-value" id="rROI">286.30%</span><span class="result-note">Return on the actual cash you invested.</span></div>
        <a class="cta-primary" data-calc-cta data-calc-slug="fix-and-flip-loan">See My Options</a>
        <p class="micro">Estimates only — not a commitment to lend.</p>
      </div>
    </div>
  </section>
  <section class="body-content">
    <figure class="author">
      <a href="https://www.linkedin.com/company/nexa-mortgage-jim-blackburn-team" target="_blank" rel="noopener">
        <img width="120" height="120" src="https://stairwaymortgage.com/wp-content/uploads/2025/10/Untitled-design-3.png" alt="Jim Blackburn" />
      </a>
      <h3><a href="https://www.linkedin.com/company/nexa-mortgage-jim-blackburn-team" target="_blank" rel="noopener">By Jim Blackburn</a></h3>
    </figure>
    <div class="cta-card">
      <h4>Ready to Take Your First Step?</h4>
      <p><strong>Skip the guesswork.</strong> Take our quick Discovery Quiz to uncover your top financial priorities, so we can guide you toward the wealth-building strategies that fit your life.</p>
      <ul><li>Takes just 5 minutes</li><li>Tailored results based on your answers</li><li>No credit check required</li></ul>
      <a href="https://stairwaymortgage.com/discovery-quiz">Take the Discovery Quiz</a>
    </div>
    <div class="cta-card">
      <h4>Need a Pre-Approval Letter—Fast?</h4>
      <p>Buying a home soon? Complete our short form and we'll connect you with the best loan options for your target property and financial situation—fast.</p>
      <ul><li>Only 2 minutes to complete</li><li>Quick turnaround on pre-approval</li><li>No credit score impact</li></ul>
      <a href="https://stairwaymortgage.com/purchase-inquiry">Get Pre-Approved Now</a>
    </div>
    <div class="cta-card">
      <h4>Got a Few Questions First?</h4>
      <p>Let's talk it through. Book a call and one of our friendly advisors will be in touch to guide you personally.</p>
      <a href="https://stairwaymortgage.com/schedule-call">Schedule a Call</a>
    </div>
    <h2>Important Disclaimer</h2>
    <p>This calculator is for illustrative purposes only and does not constitute financial, legal, or investment advice. Results are based on general assumptions and may not reflect actual performance or eligibility. This is not a loan estimate or approval. Please consult with a licensed mortgage advisor before making financial decisions.</p>
    <h2>Related Posts</h2>
    <div class="related-placeholder">Related calculators module ([loan_calculator_box])</div>
  </section>
</main>
<script is:inline>
(function () {
  const $ = (id) => document.getElementById(id);
  const fmt0 = (n) => (n<0?'-$':'$') + Math.abs(Math.round(n)).toLocaleString('en-US');
  function compute(){
    const price=+$('price').value||0, downpct=+$('down').value||0, reno=+$('reno').value||0,
          asis=+$('asis').value||0, arv=+$('arv').value||0, months=+$('months').value||0,
          exitpct=+$('exit').value||0, annIns=+$('ins').value||0, annTax=+$('tax').value||0,
          hoa=+$('hoa').value||0, rate=+$('rate').value||0;
    const maxLoan = Math.min(arv*0.75, price - price*0.10);
    const desiredLoan = price - (price*downpct)/100;
    const cashNo = price*downpct/100 + price*0.06;
    const cashSC = cashNo - price*0.06;
    const propCosts = price + reno + 0.10*reno;
    const mHold = ((desiredLoan*rate/100) + annTax + annIns + hoa*12)/12;
    const holding = mHold*months;
    const exitC = exitpct*arv/100;
    const totalProj = propCosts + holding + exitC;
    const profit = arv - totalProj;
    const roi = cashSC ? (profit/cashSC)*100 : 0;
    $('downVal').textContent=downpct+'%'; $('rateVal').textContent=rate.toFixed(2)+'%';
    $('rMaxLoan').textContent=fmt0(maxLoan); $('rDesiredLoan').textContent=fmt0(desiredLoan);
    $('rCashNo').textContent=fmt0(cashNo); $('rCashSC').textContent=fmt0(cashSC);
    $('rPropCosts').textContent=fmt0(propCosts); $('rHolding').textContent=fmt0(holding);
    $('rExit').textContent=fmt0(exitC); $('rTotalProj').textContent=fmt0(totalProj);
    $('rProfit').textContent=fmt0(profit); $('rROI').textContent=roi.toFixed(2)+'%';
  }
  document.querySelectorAll('input').forEach(el=>{el.addEventListener('input',compute);el.addEventListener('change',compute);});
  compute();
})();
</script>
<style>
.crumbs{font-family:'JetBrains Mono',monospace;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--mute);margin-bottom:28px;}
.crumbs a{color:var(--mute);text-decoration:none;} .crumbs a:hover{color:var(--blue);} .crumbs span{margin:0 6px;}
.eyebrow{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--blue);margin:0 0 10px;}
.display-lg{font-family:'Fraunces',Georgia,serif;font-weight:500;font-size:clamp(32px,5vw,52px);line-height:1.06;margin:0 0 18px;letter-spacing:-.01em;}
.lede{font-size:18px;color:#2b3140;max-width:62ch;margin:0 0 14px;}
.trust{font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--mute);border-top:1px solid var(--bone);padding-top:14px;margin:0;}
.calc{margin:40px 0 56px;border:1px solid var(--bone);border-radius:18px;overflow:hidden;background:#fff;box-shadow:0 1px 0 var(--bone),0 24px 48px -32px rgba(10,14,26,.25);}
.calc::before{content:"";display:block;height:4px;background:var(--blue);}
.calc-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:0;}
@media(max-width:780px){.calc-grid{grid-template-columns:1fr;}}
.calc-inputs{padding:30px 30px 32px;}
.calc-results{padding:30px;background:var(--ink);color:#fff;display:flex;flex-direction:column;gap:12px;}
.summary-title{font-family:'Fraunces',serif;font-weight:600;font-size:28px;margin:0 0 4px;color:#fff;}
.summary-sub{font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-size:11px;color:#aeb6c8;border-top:1px solid rgba(255,255,255,.15);padding-top:14px;margin:8px 0 0;}
.field{margin-bottom:20px;}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
@media(max-width:520px){.field-row{grid-template-columns:1fr;}}
.lbl,label{display:block;font-size:13.5px;font-weight:600;color:#384055;margin-bottom:8px;}
label .val{float:right;font-family:'JetBrains Mono',monospace;color:var(--blue);font-weight:600;}
.radios{display:flex;gap:20px;}
.radios label{font-weight:500;color:#2b3140;display:flex;align-items:center;gap:9px;margin:0;cursor:pointer;}
.radios input{accent-color:var(--blue);width:17px;height:17px;}
.input-money,.input-plain{display:flex;align-items:center;border:1px solid var(--bone);border-radius:10px;background:#fff;overflow:hidden;transition:border-color .15s,box-shadow .15s;}
.input-money:focus-within,.input-plain:focus-within{border-color:var(--blue);box-shadow:0 0 0 3px rgba(24,69,214,.12);}
.input-money span{padding:0 4px 0 14px;color:var(--mute);font-weight:600;}
.input-money input{flex:1;border:0;outline:0;padding:13px 14px 13px 4px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--ink);width:100%;}
.input-plain input{flex:1;border:0;outline:0;padding:13px 6px 13px 14px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--ink);width:100%;}
.input-plain .suffix{padding:0 14px 0 4px;color:var(--mute);font-weight:600;}
input[type=range]{width:100%;accent-color:var(--blue);height:4px;margin:6px 0;}
.hint{font-size:12px;margin:6px 0 0;} .hint--mute{color:var(--mute);}
.result{display:flex;flex-direction:column;gap:3px;padding:12px 16px;border-radius:10px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.10);}
.result--primary{background:#fff;border-color:#fff;}
.result--primary .result-label{color:#384055;} .result--primary .result-value{color:var(--ink);} .result--primary .result-note{color:#6B7280;}
.result-label{font-size:12.5px;color:#aeb6c8;font-weight:600;}
.result-value{font-family:'Fraunces',serif;font-weight:600;font-size:26px;letter-spacing:-.01em;color:#fff;}
.result-note{font-size:10.5px;line-height:1.45;color:#8b93a6;}
.cta-primary{display:block;text-align:center;background:var(--blue);color:#fff;text-decoration:none;font-weight:600;padding:14px;border-radius:10px;margin-top:6px;transition:background .15s;}
.cta-primary:hover{background:#2a57e6;}
.micro{font-size:11px;color:#8b93a6;text-align:center;margin:0;}
.body-content h2{font-family:'Fraunces',serif;font-weight:500;font-size:28px;margin:40px 0 12px;}
.body-content p{color:#2b3140;}
.author{display:flex;align-items:center;gap:16px;margin:0 0 32px;}
.author img{width:64px;height:64px;border-radius:50%;object-fit:cover;}
.author h3{font-family:'Fraunces',serif;font-weight:500;font-size:18px;margin:0;}
.author a{color:var(--ink);text-decoration:none;} .author a:hover{color:var(--blue);}
.cta-card{background:var(--paper-tint);border:1px solid var(--bone);border-radius:16px;padding:32px;text-align:center;margin:24px auto;max-width:760px;}
.cta-card h4{font-family:'Fraunces',serif;font-weight:500;font-size:24px;margin:0 0 12px;}
.cta-card p{max-width:620px;margin:0 auto 18px;}
.cta-card ul{list-style:none;padding:0;margin:18px 0;color:#384055;font-size:15px;}
.cta-card a{display:inline-block;background:var(--ink);color:#fff;padding:13px 26px;border-radius:9px;text-decoration:none;font-weight:600;}
.cta-card a:hover{background:var(--blue);}
.related-placeholder{border:1px dashed var(--bone);border-radius:10px;padding:20px;color:var(--mute);font-family:'JetBrains Mono',monospace;font-size:13px;text-align:center;}
</style>
  <CalcLeadForm />
</Layout>
