---
import Layout from '../../layouts/Layout.astro';
import CalcLeadForm from '../../components/CalcLeadForm.astro';
const metaTitle = "Closing Cost Calculator for Buyer | Stairway Mortgage";
const metaDescription = "Enter your home loan amount and estimated fees to instantly see your expected cash needed to close, broken down by Loan Estimate section. Built by Jim Blackburn, NMLS #1072866.";
const canonical = "https://stairwaymortgage.com/loan-calculator/closing-costs-calculator-for-buyer/";
const breadcrumbSchema = {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://stairwaymortgage.com/"},{"@type":"ListItem","position":2,"name":"Loan Calculators","item":"https://stairwaymortgage.com/loan-calculators/"},{"@type":"ListItem","position":3,"name":"Closing Cost Calculator for Buyer","item":canonical}]};
const appSchema = {"@context":"https://schema.org","@type":"WebApplication","name":"Closing Cost Calculator for Buyer","applicationCategory":"FinanceApplication","operatingSystem":"All","url":canonical,"offers":{"@type":"Offer","price":"0","priceCurrency":"USD"},"description":metaDescription};
const faqSchema = {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What closing costs do buyers pay?","acceptedAnswer":{"@type":"Answer","text":"Buyer closing costs typically include origination charges, third-party services, taxes and government fees, prepaids, an initial escrow deposit, and other items, organized into Loan Estimate sections A through G."}},{"@type":"Question","name":"How much are buyer closing costs?","acceptedAnswer":{"@type":"Answer","text":"They vary by loan size, location, and loan type, but commonly run roughly 2% to 5% of the loan amount. Use the line items above to estimate your own total."}},{"@type":"Question","name":"Can the seller help pay closing costs?","acceptedAnswer":{"@type":"Answer","text":"Yes. Depending on loan type and down payment, sellers may contribute toward a buyer's closing costs and prepaids, often up to 6% on FHA, USDA, and VA loans."}}]};
---
<Layout title={metaTitle} description={metaDescription} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <main class="container-page">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a> <span>/</span>
      <a href="/loan-calculators/">Loan Calculators</a> <span>/</span>
      <span aria-current="page">Closing Cost Calculator for Buyer</span>
    </nav>
    <header class="calc-head">
      <p class="eyebrow">Buyer · Closing Costs</p>
      <h1 class="display-lg">Closing Cost Calculator for Buyer</h1>
      <p class="lede">Enter your loan amount and estimated fees so you can instantly see your expected cash needed to close.</p>
      <p class="trust">Built by Jim Blackburn · NMLS #1072866 · $500M+ closed · 7× Scotsman Guide Top Producer</p>
    </header>
    <section class="calc" aria-label="Closing Cost Calculator for Buyer">
      <div class="calc-grid">
        <div class="calc-inputs">
          <div class="field"><label for="loan">Enter Loan Amount</label><div class="input-money"><span>$</span><input id="loan" type="number" inputmode="numeric" value="500000" min="0" step="1000" /></div><p class="hint hint--mute">For reference — does not change the totals below.</p></div>
          <p class="group-label">Loan Costs (A + B + C)</p>
          <div class="field"><label for="orig">Origination Charges</label><div class="input-money"><span>$</span><input id="orig" type="number" inputmode="numeric" value="3" min="0" step="100" /></div><p class="hint hint--mute">Points/discount and underwriting (entered as a dollar amount).</p></div>
          <div class="field-row">
            <div class="field"><label for="cannot">Services You Cannot Shop For</label><div class="input-money"><span>$</span><input id="cannot" type="number" inputmode="numeric" value="1000" min="0" step="50" /></div><p class="hint hint--mute">Appraisal, credit, flood cert.</p></div>
            <div class="field"><label for="can">Services You Can Shop For</label><div class="input-money"><span>$</span><input id="can" type="number" inputmode="numeric" value="2500" min="0" step="50" /></div><p class="hint hint--mute">Title search, pest, survey.</p></div>
          </div>
          <p class="group-label">Other Costs (D + E + F + G)</p>
          <div class="field-row">
            <div class="field"><label for="taxes">Taxes &amp; Other Government Fees</label><div class="input-money"><span>$</span><input id="taxes" type="number" inputmode="numeric" value="1000" min="0" step="50" /></div><p class="hint hint--mute">Recording fees and transfer taxes.</p></div>
            <div class="field"><label for="prepaids">Prepaids</label><div class="input-money"><span>$</span><input id="prepaids" type="number" inputmode="numeric" value="2400" min="0" step="50" /></div><p class="hint hint--mute">Insurance, prepaid interest, initial taxes.</p></div>
          </div>
          <div class="field-row">
            <div class="field"><label for="escrow">Initial Escrow Payment at Closing</label><div class="input-money"><span>$</span><input id="escrow" type="number" inputmode="numeric" value="2000" min="0" step="50" /></div></div>
            <div class="field"><label for="other">Other</label><div class="input-money"><span>$</span><input id="other" type="number" inputmode="numeric" value="500" min="0" step="50" /></div><p class="hint hint--mute">Owner's title policy, home warranty, HOA setup.</p></div>
          </div>
        </div>
        <div class="calc-results" aria-live="polite">
          <p class="summary-title">Summary</p>
          <p class="summary-sub">Subtotals</p>
          <div class="result"><span class="result-label">Total Loan Costs (A+B+C)</span><span class="result-value" id="rLoanCosts">$3,503</span><span class="result-note">Origination + services you cannot shop for + services you can shop for.</span></div>
          <div class="result"><span class="result-label">Total Other Costs (D+E+F+G)</span><span class="result-value" id="rOtherCosts">$5,900</span><span class="result-note">Taxes &amp; government fees + prepaids + initial escrow + other.</span></div>
          <p class="summary-sub">Cash to Close</p>
          <div class="result result--primary"><span class="result-label">Estimated Total Closing Costs</span><span class="result-value" id="rTotal">$9,403</span><span class="result-note">Total Loan Costs + Total Other Costs.</span></div>
          <a class="cta-primary" data-calc-cta data-calc-slug="closing-costs-calculator-for-buyer">See My Options</a>
          <p class="micro">Estimates only — not a commitment to lend.</p>
        </div>
      </div>
    </section>
    <section class="body-content">
      <div class="conclusion-card">
        <h3>Seller Credits</h3>
        <p>Up to 6% seller credit toward a buyer's closing costs, prepaids, and rate buydown is allowed with FHA, USDA, and VA loans, and with conventional loans for a primary residence with 10%+ down.</p>
        <p>3% is typical with a conventional loan for a primary residence with less than 10% down, and for second homes and rental properties.</p>
      </div>
      <figure class="author">
        <a href="http://www.mortgagemanjim.com/linkedin%20" target="_blank" rel="noopener">
          <img width="120" height="120" src="https://stairwaymortgage.com/wp-content/uploads/2025/10/Untitled-design-3.png" alt="Jim Blackburn" />
        </a>
        <h3><a href="http://www.mortgagemanjim.com/linkedin%20" target="_blank" rel="noopener">By Jim Blackburn</a></h3>
      </figure>
      <div class="cta-card">
        <h4>Ready to Take Your First Step?</h4>
        <p><strong>Skip the guesswork.</strong> Take our quick Discovery Quiz to uncover your top financial priorities, so we can guide you toward the wealth-building strategies that fit your life.</p>
        <ul><li>Takes just 5 minutes</li><li>Tailored results based on your answers</li><li>No credit check required</li></ul>
        <a href="https://stairwaymortgage.com/discovery-quiz">Take the Discovery Quiz</a>
      </div>
      <div class="cta-card">
        <h4>Want a Real Estimate of Your Cash to Close?</h4>
        <p>Tell us about your purchase and we'll prepare accurate numbers and a strategy to reduce your closing costs—fast.</p>
        <ul><li>Only 2 minutes to complete</li><li>Quick turnaround</li><li>No credit score impact</li></ul>
        <a href="https://stairwaymortgage.com/purchase-inquiry">See My Options</a>
      </div>
      <div class="cta-card">
        <h4>Got a Few Questions First?</h4>
        <p>Let's talk it through. Book a call and one of our friendly advisors will be in touch to guide you personally.</p>
        <a href="https://stairwaymortgage.com/schedule-call">Schedule a Call</a>
      </div>
      <h2>Important Disclaimer</h2>
      <p>This calculator is for illustrative purposes only and does not constitute financial, legal, or investment advice. Results are based on general assumptions and may not reflect actual performance or eligibility. This is not a loan estimate or approval. Please consult with a licensed mortgage advisor before making financial decisions.</p>
      <h2>Related Posts</h2>
      <div class="related-placeholder">Related calculators module ([loan_calculator_box])</div>
    </section>
  </main>

  <script is:inline>
  (function () {
    const $ = (id) => document.getElementById(id);
    const fmt0 = (n) => { const r=Math.round(n); return (r<0?'-$':'$') + Math.abs(r).toLocaleString('en-US'); };
    function compute(){
      // Loan Amount is informational only — never used in any total
      const orig=+$('orig').value||0, cannot=+$('cannot').value||0, can=+$('can').value||0,
            taxes=+$('taxes').value||0, prepaids=+$('prepaids').value||0, escrow=+$('escrow').value||0, other=+$('other').value||0;
      // Total Loan Costs = SUM(orig, cannot, can) — orig used RAW (the '%' label in the widget is cosmetic)
      const loanCosts = orig + cannot + can;
      // Total Other Costs = SUM(taxes + prepaids + escrow + other)
      const otherCosts = taxes + prepaids + escrow + other;
      // Estimated Total = loanCosts + otherCosts
      const total = loanCosts + otherCosts;
      $('rLoanCosts').textContent = fmt0(loanCosts);
      $('rOtherCosts').textContent = fmt0(otherCosts);
      $('rTotal').textContent = fmt0(total);
    }
    document.querySelectorAll('input').forEach(el=>{el.addEventListener('input',compute);el.addEventListener('change',compute);});
    compute();
  })();
  </script>

  <style>
  .crumbs{font-family:'JetBrains Mono',monospace;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--mute);margin-bottom:28px;}
  .crumbs a{color:var(--mute);text-decoration:none;} .crumbs a:hover{color:var(--blue);} .crumbs span{margin:0 6px;}
  .eyebrow{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--blue);margin:0 0 10px;}
  .display-lg{font-family:'Fraunces',Georgia,serif;font-weight:500;font-size:clamp(28px,4.4vw,46px);line-height:1.08;margin:0 0 18px;letter-spacing:-.01em;}
  .lede{font-size:18px;color:#2b3140;max-width:62ch;margin:0 0 14px;}
  .trust{font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--mute);border-top:1px solid var(--bone);padding-top:14px;margin:0;}
  .calc{margin:40px 0 56px;border:1px solid var(--bone);border-radius:18px;overflow:hidden;background:#fff;box-shadow:0 1px 0 var(--bone),0 24px 48px -32px rgba(10,14,26,.25);}
  .calc::before{content:"";display:block;height:4px;background:var(--blue);}
  .calc-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:0;}
  @media(max-width:780px){.calc-grid{grid-template-columns:1fr;}}
  .calc-inputs{padding:30px 30px 32px;}
  .group-label{font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-size:11px;color:var(--blue);font-weight:600;margin:22px 0 12px;}
  .calc-results{padding:30px;background:var(--ink);color:#fff;display:flex;flex-direction:column;gap:12px;}
  .summary-title{font-family:'Fraunces',serif;font-weight:600;font-size:28px;margin:0 0 4px;color:#fff;}
  .summary-sub{font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-size:11px;color:#aeb6c8;border-top:1px solid rgba(255,255,255,.15);padding-top:14px;margin:8px 0 0;}
  .field{margin-bottom:20px;}
  .field-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
  @media(max-width:520px){.field-row{grid-template-columns:1fr;}}
  .lbl,label{display:block;font-size:13.5px;font-weight:600;color:#384055;margin-bottom:8px;}
  .input-money{display:flex;align-items:center;border:1px solid var(--bone);border-radius:10px;background:#fff;overflow:hidden;transition:border-color .15s,box-shadow .15s;}
  .input-money:focus-within{border-color:var(--blue);box-shadow:0 0 0 3px rgba(24,69,214,.12);}
  .input-money span{padding:0 4px 0 14px;color:var(--mute);font-weight:600;}
  .input-money input{flex:1;border:0;outline:0;padding:13px 14px 13px 4px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--ink);width:100%;}
  .hint{font-size:12px;margin:6px 0 0;} .hint--mute{color:var(--mute);}
  .result{display:flex;flex-direction:column;gap:3px;padding:12px 16px;border-radius:10px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.10);}
  .result--primary{background:#fff;border-color:#fff;}
  .result--primary .result-label{color:#384055;} .result--primary .result-value{color:var(--ink);} .result--primary .result-note{color:#6B7280;}
  .result-label{font-size:12.5px;color:#aeb6c8;font-weight:600;}
  .result-value{font-family:'Fraunces',serif;font-weight:600;font-size:24px;letter-spacing:-.01em;color:#fff;}
  .result-note{font-size:10.5px;line-height:1.45;color:#8b93a6;}
  .cta-primary{display:block;text-align:center;background:var(--blue);color:#fff;text-decoration:none;font-weight:600;padding:14px;border-radius:10px;margin-top:6px;transition:background .15s;}
  .cta-primary:hover{background:#2a57e6;}
  .micro{font-size:11px;color:#8b93a6;text-align:center;margin:0;}
  .conclusion-card{background:var(--paper-tint);border:1px solid var(--bone);border-radius:16px;padding:28px 32px;margin:8px 0 32px;max-width:760px;}
  .conclusion-card h3{font-family:'Fraunces',serif;font-weight:600;font-size:22px;margin:0 0 12px;}
  .conclusion-card p{color:#2b3140;margin:0 0 12px;}
  .body-content h2{font-family:'Fraunces',serif;font-weight:500;font-size:28px;margin:40px 0 12px;}
  .body-content p{color:#2b3140;}
  .author{display:flex;align-items:center;gap:16px;margin:0 0 32px;}
  .author img{width:64px;height:64px;border-radius:50%;object-fit:cover;}
  .author h3{font-family:'Fraunces',serif;font-weight:500;font-size:18px;margin:0;}
  .author a{color:var(--ink);text-decoration:none;} .author a:hover{color:var(--blue);}
  .cta-card{background:var(--paper-tint);border:1px solid var(--bone);border-radius:16px;padding:32px;text-align:center;margin:24px auto;max-width:760px;}
  .cta-card h4{font-family:'Fraunces',serif;font-weight:500;font-size:24px;margin:0 0 12px;}
  .cta-card p{max-width:620px;margin:0 auto 18px;}
  .cta-card ul{list-style:none;padding:0;margin:18px 0;color:#384055;font-size:15px;}
  .cta-card a{display:inline-block;background:var(--ink);color:#fff;padding:13px 26px;border-radius:9px;text-decoration:none;font-weight:600;}
  .cta-card a:hover{background:var(--blue);}
  .related-placeholder{border:1px dashed var(--bone);border-radius:10px;padding:20px;color:var(--mute);font-family:'JetBrains Mono',monospace;font-size:13px;text-align:center;}
  </style>
  <CalcLeadForm />
</Layout>
</content>
