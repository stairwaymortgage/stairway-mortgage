---
import Layout from '../../layouts/Layout.astro';
import CalcLeadForm from '../../components/CalcLeadForm.astro';
const metaTitle = "FHA Purchase Loan Payment Calculator | Stairway Mortgage";
const metaDescription = "Estimate your monthly payment and cash needed to close on a new FHA home purchase loan, with and without seller credit and down payment assistance. Built by Jim Blackburn, NMLS #1072866.";
const canonical = "https://stairwaymortgage.com/loan-calculator/down-payment-assistance/";
const breadcrumbSchema = {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://stairwaymortgage.com/"},{"@type":"ListItem","position":2,"name":"Loan Calculators","item":"https://stairwaymortgage.com/loan-calculators/"},{"@type":"ListItem","position":3,"name":"FHA Purchase Loan Payment Calculator","item":canonical}]};
const appSchema = {"@context":"https://schema.org","@type":"WebApplication","name":"FHA Purchase Loan Payment Calculator","applicationCategory":"FinanceApplication","operatingSystem":"All","url":canonical,"offers":{"@type":"Offer","price":"0","priceCurrency":"USD"},"description":metaDescription};
const faqSchema = {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is the minimum FHA down payment?","acceptedAnswer":{"@type":"Answer","text":"FHA loans allow as little as 3.5% down, and down payment assistance and gift funds are permitted toward that amount."}},{"@type":"Question","name":"What is UFMIP?","acceptedAnswer":{"@type":"Answer","text":"The FHA Up-Front Mortgage Insurance Premium is 1.75% of the base loan amount. It is typically financed into the loan rather than paid in cash."}},{"@type":"Question","name":"Should I use down payment assistance?","acceptedAnswer":{"@type":"Answer","text":"DPA programs can help you buy sooner, but many carry conditions such as repayment or an equity share if you sell or refinance within the first few years. If you can close without it, you keep more of your equity and flexibility."}}]};
---
<Layout title={metaTitle} description={metaDescription}>
  <link slot="head" rel="canonical" href={canonical} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <main class="container-page">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a> <span>/</span>
      <a href="/loan-calculators/">Loan Calculators</a> <span>/</span>
      <span aria-current="page">FHA Purchase Loan Payment Calculator</span>
    </nav>
    <header class="calc-head">
      <p class="eyebrow">FHA · Purchase</p>
      <h1 class="display-lg">FHA Purchase Loan Payment Calculator</h1>
      <p class="lede">Estimate your monthly payment and the cash needed to close on a new FHA home purchase loan.</p>
      <p class="trust">Built by Jim Blackburn · NMLS #1072866 · $500M+ closed · 7× Scotsman Guide Top Producer</p>
    </header>
    <section class="calc" aria-label="FHA Purchase Loan Payment Calculator">
      <div class="calc-grid">
        <div class="calc-inputs">
          <p class="group-label">Purchase</p>
          <div class="field"><label for="price">Purchase Price</label><div class="input-money"><span>$</span><input id="price" type="number" inputmode="numeric" value="300000" min="0" step="5000" /></div></div>
          <div class="field">
            <label for="dp">Down Payment Percentage: <span id="dpOut" class="slider-out">3.5%</span></label>
            <input id="dp" type="range" min="0" max="100" step="1" value="3.5" data-default="3.5" />
            <p class="hint hint--mute">3.5% is the minimum (down payment assistance and gift funds allowed).</p>
          </div>
          <div class="field-row">
            <div class="field"><label for="term">Term of Loan</label>
              <select id="term">
                <option value="30" selected>30 years</option>
                <option value="20">20 years</option>
                <option value="15">15 years</option>
              </select>
            </div>
            <div class="field"><label for="rate">Estimated Interest Rate: <span id="rateOut" class="slider-out">7.0%</span></label>
              <input id="rate" type="range" min="2.5" max="10" step="0.1" value="7" />
            </div>
          </div>
          <p class="group-label">Housing Costs</p>
          <div class="field-row">
            <div class="field"><label for="ins">Annual Insurance</label><div class="input-money"><span>$</span><input id="ins" type="number" inputmode="numeric" value="2400" min="0" step="100" /></div></div>
            <div class="field"><label for="tax">Annual Taxes</label><div class="input-money"><span>$</span><input id="tax" type="number" inputmode="numeric" value="3600" min="0" step="100" /></div></div>
          </div>
          <div class="field"><label for="hoa">Monthly HOA</label><div class="input-money"><span>$</span><input id="hoa" type="number" inputmode="numeric" value="0" min="0" step="25" /></div><p class="hint hint--mute">Paid separately, outside the mortgage.</p></div>
        </div>
        <div class="calc-results" aria-live="polite">
          <p class="summary-title">Summary</p>
          <p class="summary-sub">Loan</p>
          <div class="result"><span class="result-label">Base Loan Amount</span><span class="result-value" id="rBase">$289,500</span></div>
          <div class="result"><span class="result-label">UFMIP (1.75%)</span><span class="result-value" id="rUfmip">$5,066</span></div>
          <div class="result"><span class="result-label">Final Loan Amount</span><span class="result-value" id="rFinal">$294,566</span><span class="result-note">Base + UFMIP.</span></div>
          <p class="summary-sub">Monthly Payment</p>
          <div class="result"><span class="result-label">Principal &amp; Interest</span><span class="result-value" id="rPi">$1,926</span></div>
          <div class="result"><span class="result-label">Monthly Insurance</span><span class="result-value" id="rIns">$200</span></div>
          <div class="result"><span class="result-label">Monthly Taxes</span><span class="result-value" id="rTax">$300</span></div>
          <div class="result"><span class="result-label">Estimated Monthly MI</span><span class="result-value" id="rMI">$184</span></div>
          <div class="result result--primary"><span class="result-label">Total Monthly Housing Expense</span><span class="result-value" id="rTotal">$2,610</span><span class="result-note">P&amp;I + insurance + taxes + MI. HOA shown separately.</span></div>
          <div class="result"><span class="result-label">HOA Paid Separately</span><span class="result-value" id="rHoa">$0</span></div>
          <p class="summary-sub">Cash to Close</p>
          <div class="result"><span class="result-label">Without Seller Credit or DPA</span><span class="result-value" id="rCashNo">$28,500</span><span class="result-note">Down payment + ~6% estimated closing costs.</span></div>
          <div class="result"><span class="result-label">With Seller Credit</span><span class="result-value" id="rCashSC">$10,500</span><span class="result-note">Assumes seller covers ~6% closing costs.</span></div>
          <div class="result result--primary"><span class="result-label">With Seller Credit AND DPA</span><span class="result-value" id="rCashDPA">$0</span><span class="result-note">Assumes 3.5% DPA plus a 6% seller credit.</span></div>
          <p class="summary-sub">Qualifying</p>
          <div class="result"><span class="result-label">Monthly Income Target to Qualify</span><span class="result-value" id="rIncome">$5,220</span><span class="result-note">Based on a 50% DTI.</span></div>
          <a class="cta-primary" data-calc-cta data-calc-slug="down-payment-assistance">See My Options</a>
          <p class="micro">Estimates only — not a commitment to lend.</p>
        </div>
      </div>
    </section>
    <section class="body-content">
      <div class="conclusion-card">
        <h3>A Note on Down Payment Assistance</h3>
        <p>Many DPA programs come with strings attached. They can lock you into the property and may require repayment of fees or a share of your home's equity if you sell or refinance within the first five years. If you're able to close without DPA, you keep more of your equity gains, retain full control over future decisions, and are in a stronger position to make competitive offers and close quickly.</p>
      </div>
      <figure class="author">
        <a href="http://www.mortgagemanjim.com/linkedin%20" target="_blank" rel="noopener">
          <img width="120" height="120" src="https://stairwaymortgage.com/wp-content/uploads/2025/10/Untitled-design-3.png" alt="Jim Blackburn" />
        </a>
        <h3><a href="http://www.mortgagemanjim.com/linkedin%20" target="_blank" rel="noopener">By Jim Blackburn</a></h3>
      </figure>
      <div class="cta-card">
        <h4>Ready to Take Your First Step?</h4>
        <p><strong>Skip the guesswork.</strong> Take our quick Discovery Quiz to uncover your top financial priorities, so we can guide you toward the wealth-building strategies that fit your life.</p>
        <ul><li>Takes just 5 minutes</li><li>Tailored results based on your answers</li><li>No credit check required</li></ul>
        <a href="https://stairwaymortgage.com/discovery-quiz">Take the Discovery Quiz</a>
      </div>
      <div class="cta-card">
        <h4>Buying With an FHA Loan?</h4>
        <p>Tell us about your scenario and we'll map out your real payment and cash-to-close with the right strategy—fast.</p>
        <ul><li>Only 2 minutes to complete</li><li>Quick turnaround</li><li>No credit score impact</li></ul>
        <a href="https://stairwaymortgage.com/purchase-inquiry">See My Options</a>
      </div>
      <div class="cta-card">
        <h4>Got a Few Questions First?</h4>
        <p>Let's talk it through. Book a call and one of our friendly advisors will be in touch to guide you personally.</p>
        <a href="https://stairwaymortgage.com/schedule-call">Schedule a Call</a>
      </div>
      <h2>Important Disclaimer</h2>
      <p>This calculator is for illustrative purposes only and does not constitute financial, legal, or investment advice. Results are based on general assumptions and may not reflect actual performance or eligibility. This is not a loan estimate or approval. Please consult with a licensed mortgage advisor before making financial decisions.</p>
      <h2>Related Posts</h2>
      <div class="related-placeholder">Related calculators module ([loan_calculator_box])</div>
    </section>
  </main>

  <script is:inline>
  (function () {
    const $ = (id) => document.getElementById(id);
    const fmt0 = (n) => { if(!isFinite(n)) return '—'; const r=Math.round(n); return (r<0?'-$':'$') + Math.abs(r).toLocaleString('en-US'); };
    let dpTouched = false;
    function compute(){
      const price=+$('price').value||0, term=+$('term').value||0,
            rate=+$('rate').value||0, ins=+$('ins').value||0, tax=+$('tax').value||0, hoa=+$('hoa').value||0;
      // Down payment: hold the 3.5 default until the user drags the slider (matches live widget,
      // whose slider loads at 3.5 between integer steps).
      const dp = dpTouched ? (+$('dp').value||0) : 3.5;
      $('dpOut').textContent = dp+'%';
      $('rateOut').textContent = rate.toFixed(1)+'%';
      // Base Loan = price - (price*dp/100) + (dp/100)*0.0175  [the +artifact is a near-zero leftover, replicated]
      const base = price - (price*dp/100) + (dp/100)*0.0175;
      // UFMIP = base*0.0175
      const ufmip = base*0.0175;
      // Final = base + ufmip
      const final = base + ufmip;
      // P&I uses BASE loan; n=360 if term==30 else 180 (20yr falls into 180 branch — widget bug, replicated)
      const n = (term===30) ? 360 : 180;
      const r = rate/1200;
      let pi = 0;
      if (r>0) pi = base*r/(1-Math.pow(1+r,-n));
      else if (n>0) pi = base/n;
      // Monthly Ins / Tax
      const mIns = ins/12, mTax = tax/12;
      // Monthly MI = final*0.0075/12
      const mMI = final*0.0075/12;
      // Total Housing = P&I + mIns + mTax + mMI (HOA excluded)
      const totHousing = pi + mIns + mTax + mMI;
      // Cash WITHOUT = (dp*price)*.01 + 0.06*price
      const cashNo = (dp*price)*0.01 + 0.06*price;
      // Cash WITH seller credit = (dp*price)*.01
      const cashSC = (dp*price)*0.01;
      // Cash WITH SC AND DPA = 0 (hardcoded in widget)
      const cashDPA = 0;
      // Income target = (totHousing + hoa)/.50
      const incTarget = (totHousing + hoa)/0.50;
      $('rBase').textContent=fmt0(base); $('rUfmip').textContent=fmt0(ufmip); $('rFinal').textContent=fmt0(final);
      $('rPi').textContent=fmt0(pi); $('rIns').textContent=fmt0(mIns); $('rTax').textContent=fmt0(mTax); $('rMI').textContent=fmt0(mMI);
      $('rTotal').textContent=fmt0(totHousing); $('rHoa').textContent=fmt0(hoa);
      $('rCashNo').textContent=fmt0(cashNo); $('rCashSC').textContent=fmt0(cashSC); $('rCashDPA').textContent=fmt0(cashDPA);
      $('rIncome').textContent=fmt0(incTarget);
    }
    $('dp').addEventListener('input', ()=>{ dpTouched = true; });
    document.querySelectorAll('input,select').forEach(el=>{el.addEventListener('input',compute);el.addEventListener('change',compute);});
    compute();
  })();
  </script>

  <style>
  .crumbs{font-family:'JetBrains Mono',monospace;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--mute);margin-bottom:28px;}
  .crumbs a{color:var(--mute);text-decoration:none;} .crumbs a:hover{color:var(--blue);} .crumbs span{margin:0 6px;}
  .eyebrow{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--blue);margin:0 0 10px;}
  .display-lg{font-family:'Fraunces',Georgia,serif;font-weight:500;font-size:clamp(28px,4.4vw,46px);line-height:1.08;margin:0 0 18px;letter-spacing:-.01em;}
  .lede{font-size:18px;color:#2b3140;max-width:62ch;margin:0 0 14px;}
  .trust{font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--mute);border-top:1px solid var(--bone);padding-top:14px;margin:0;}
  .calc{margin:40px 0 56px;border:1px solid var(--bone);border-radius:18px;overflow:hidden;background:#fff;box-shadow:0 1px 0 var(--bone),0 24px 48px -32px rgba(10,14,26,.25);}
  .calc::before{content:"";display:block;height:4px;background:var(--blue);}
  .calc-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:0;}
  @media(max-width:780px){.calc-grid{grid-template-columns:1fr;}}
  .calc-inputs{padding:30px 30px 32px;}
  .group-label{font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-size:11px;color:var(--blue);font-weight:600;margin:22px 0 12px;}
  .group-label:first-child{margin-top:0;}
  .calc-results{padding:30px;background:var(--ink);color:#fff;display:flex;flex-direction:column;gap:12px;}
  .summary-title{font-family:'Fraunces',serif;font-weight:600;font-size:28px;margin:0 0 4px;color:#fff;}
  .summary-sub{font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-size:11px;color:#aeb6c8;border-top:1px solid rgba(255,255,255,.15);padding-top:14px;margin:8px 0 0;}
  .field{margin-bottom:20px;}
  .field-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
  @media(max-width:520px){.field-row{grid-template-columns:1fr;}}
  .lbl,label{display:block;font-size:13.5px;font-weight:600;color:#384055;margin-bottom:8px;}
  .slider-out{color:var(--blue);font-family:'JetBrains Mono',monospace;font-weight:600;}
  input[type=range]{width:100%;accent-color:var(--blue);height:6px;}
  .input-money,.input-plain{display:flex;align-items:center;border:1px solid var(--bone);border-radius:10px;background:#fff;overflow:hidden;transition:border-color .15s,box-shadow .15s;}
  .input-money:focus-within,.input-plain:focus-within{border-color:var(--blue);box-shadow:0 0 0 3px rgba(24,69,214,.12);}
  .input-money span{padding:0 4px 0 14px;color:var(--mute);font-weight:600;}
  .input-money input{flex:1;border:0;outline:0;padding:13px 14px 13px 4px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--ink);width:100%;}
  .input-plain input{flex:1;border:0;outline:0;padding:13px 6px 13px 14px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--ink);width:100%;}
  .input-plain .suffix{padding:0 14px 0 4px;color:var(--mute);font-weight:600;}
  select{width:100%;padding:13px 14px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;border:1px solid var(--bone);border-radius:10px;background:#fff;color:var(--ink);}
  select:focus{outline:0;border-color:var(--blue);box-shadow:0 0 0 3px rgba(24,69,214,.12);}
  .hint{font-size:12px;margin:6px 0 0;} .hint--mute{color:var(--mute);}
  .result{display:flex;flex-direction:column;gap:3px;padding:12px 16px;border-radius:10px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.10);}
  .result--primary{background:#fff;border-color:#fff;}
  .result--primary .result-label{color:#384055;} .result--primary .result-value{color:var(--ink);} .result--primary .result-note{color:#6B7280;}
  .result-label{font-size:12.5px;color:#aeb6c8;font-weight:600;}
  .result-value{font-family:'Fraunces',serif;font-weight:600;font-size:24px;letter-spacing:-.01em;color:#fff;}
  .result-note{font-size:10.5px;line-height:1.45;color:#8b93a6;}
  .cta-primary{display:block;text-align:center;background:var(--blue);color:#fff;text-decoration:none;font-weight:600;padding:14px;border-radius:10px;margin-top:6px;transition:background .15s;}
  .cta-primary:hover{background:#2a57e6;}
  .micro{font-size:11px;color:#8b93a6;text-align:center;margin:0;}
  .conclusion-card{background:var(--paper-tint);border:1px solid var(--bone);border-radius:16px;padding:28px 32px;margin:8px 0 32px;max-width:760px;}
  .conclusion-card h3{font-family:'Fraunces',serif;font-weight:600;font-size:22px;margin:0 0 12px;}
  .conclusion-card p{color:#2b3140;margin:0 0 12px;}
  .body-content h2{font-family:'Fraunces',serif;font-weight:500;font-size:28px;margin:40px 0 12px;}
  .body-content p{color:#2b3140;}
  .author{display:flex;align-items:center;gap:16px;margin:0 0 32px;}
  .author img{width:64px;height:64px;border-radius:50%;object-fit:cover;}
  .author h3{font-family:'Fraunces',serif;font-weight:500;font-size:18px;margin:0;}
  .author a{color:var(--ink);text-decoration:none;} .author a:hover{color:var(--blue);}
  .cta-card{background:var(--paper-tint);border:1px solid var(--bone);border-radius:16px;padding:32px;text-align:center;margin:24px auto;max-width:760px;}
  .cta-card h4{font-family:'Fraunces',serif;font-weight:500;font-size:24px;margin:0 0 12px;}
  .cta-card p{max-width:620px;margin:0 auto 18px;}
  .cta-card ul{list-style:none;padding:0;margin:18px 0;color:#384055;font-size:15px;}
  .cta-card a{display:inline-block;background:var(--ink);color:#fff;padding:13px 26px;border-radius:9px;text-decoration:none;font-weight:600;}
  .cta-card a:hover{background:var(--blue);}
  .related-placeholder{border:1px dashed var(--bone);border-radius:10px;padding:20px;color:var(--mute);font-family:'JetBrains Mono',monospace;font-size:13px;text-align:center;}
  </style>
  <CalcLeadForm />
</Layout>
