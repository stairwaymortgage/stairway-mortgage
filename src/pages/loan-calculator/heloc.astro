---
import Layout from '../../layouts/Layout.astro';

const metaTitle = "HELOC Calculator: Estimate Your Available Equity, Draw Amount & Monthly Payment";
const metaDescription = "Calculate available equity, draw amount, and monthly payment for HELOC line of credit. Estimate funds accessible without refinancing existing favorable mortgage rate.";
const canonical = "https://stairwaymortgage.com/loan-calculator/heloc/";

const breadcrumbSchema = {
  "@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[
    {"@type":"ListItem","position":1,"name":"Home","item":"https://stairwaymortgage.com/"},
    {"@type":"ListItem","position":2,"name":"Loan Calculators","item":"https://stairwaymortgage.com/all-loan-calculators/"},
    {"@type":"ListItem","position":3,"name":"HELOC Calculator","item":canonical}]};
const appSchema = {
  "@context":"https://schema.org","@type":"WebApplication","name":"HELOC Calculator",
  "applicationCategory":"FinanceApplication","operatingSystem":"All","url":canonical,
  "offers":{"@type":"Offer","price":"0","priceCurrency":"USD"},"description":metaDescription};
const faqSchema = {
  "@context":"https://schema.org","@type":"FAQPage","mainEntity":[
    {"@type":"Question","name":"How much can I borrow with a HELOC?","acceptedAnswer":{"@type":"Answer","text":"Most lenders allow a combined loan-to-value (CLTV) of 80-90%. Your available line equals your home value multiplied by the maximum CLTV, minus your current mortgage balance."}},
    {"@type":"Question","name":"What is the difference between the draw period and repayment period?","acceptedAnswer":{"@type":"Answer","text":"During the draw period you can borrow against the line and typically make interest-only payments. After it ends, the balance amortizes over the repayment period with principal-and-interest payments."}},
    {"@type":"Question","name":"Does a HELOC affect my existing mortgage rate?","acceptedAnswer":{"@type":"Answer","text":"No. A HELOC is a second lien that sits behind your first mortgage, so you keep your existing first-mortgage rate while accessing equity."}}]};
---
<Layout title={metaTitle} description={metaDescription} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <section class="section">
    <div class="container-page">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a> <span>/</span>
        <a href="/all-loan-calculators/">Loan Calculators</a> <span>/</span>
        <span aria-current="page">HELOC Calculator</span>
      </nav>

      <header class="calc-head">
        <p class="eyebrow">Home Equity Line of Credit</p>
        <h1 class="display-lg">HELOC Calculator</h1>
        <p class="lede">Estimate your available equity, draw amount, and monthly payment — and see how much cash you can access without refinancing your existing first-mortgage rate.</p>
        <p class="trust">Built by Jim Blackburn · NMLS #1072866 · $500M+ closed · 7× Scotsman Guide Top Producer</p>
      </header>

      <section class="calc" aria-label="HELOC Calculator">
        <div class="calc-grid">
          <div class="calc-inputs">
            <div class="field">
              <label for="homeValue">Estimated home value</label>
              <div class="input-money"><span>$</span><input id="homeValue" type="number" inputmode="numeric" value="600000" min="0" step="1000" /></div>
            </div>
            <div class="field">
              <label for="balance">Current mortgage balance</label>
              <div class="input-money"><span>$</span><input id="balance" type="number" inputmode="numeric" value="300000" min="0" step="1000" /></div>
            </div>
            <div class="field">
              <label for="cltv">Max combined loan-to-value (CLTV) <span class="val" id="cltvVal">85%</span></label>
              <input id="cltv" type="range" min="70" max="90" step="1" value="85" />
            </div>
            <div class="field">
              <label for="draw">Desired draw amount</label>
              <div class="input-money"><span>$</span><input id="draw" type="number" inputmode="numeric" value="150000" min="0" step="1000" /></div>
              <p class="hint" id="drawHint"></p>
            </div>
            <div class="field-row">
              <div class="field">
                <label for="apr">Interest rate (APR) <span class="val" id="aprVal">8.5%</span></label>
                <input id="apr" type="range" min="1" max="15" step="0.1" value="8.5" />
              </div>
              <div class="field">
                <label for="repay">Repayment period <span class="val" id="repayVal">20 yrs</span></label>
                <input id="repay" type="range" min="5" max="30" step="1" value="20" />
              </div>
            </div>
          </div>
          <div class="calc-results" aria-live="polite">
            <div class="result result--primary"><span class="result-label">Available equity</span><span class="result-value" id="rAvail">$210,000</span></div>
            <div class="result"><span class="result-label">Your draw amount</span><span class="result-value" id="rDraw">$150,000</span></div>
            <div class="result"><span class="result-label">Interest-only payment <em>(draw period)</em></span><span class="result-value" id="rIO">$1,062.50</span></div>
            <div class="result"><span class="result-label">Amortizing payment <em>(repayment period)</em></span><span class="result-value" id="rAmort">$1,301.73</span></div>
            <a class="cta-primary" href="https://stairwaymortgage.com/purchase-inquiry">See My Options</a>
            <p class="micro">Estimates only — not a commitment to lend.</p>
          </div>
        </div>
      </section>

      <section class="body-content">
        <figure class="author">
          <a href="http://www.mortgagemanjim.com/linkedin%20" target="_blank" rel="noopener">
            <img width="120" height="120" src="https://stairwaymortgage.com/wp-content/uploads/2025/10/Untitled-design-3.png" alt="Jim Blackburn" />
          </a>
          <h3><a href="http://www.mortgagemanjim.com/linkedin%20" target="_blank" rel="noopener">By Jim Blackburn</a></h3>
        </figure>

        <div class="cta-card">
          <h4>Ready to Take Your First Step?</h4>
          <p><strong>Skip the guesswork.</strong> Take our quick Discovery Quiz to uncover your top financial priorities, so we can guide you toward the wealth-building strategies that fit your life.</p>
          <ul><li>Takes just 5 minutes</li><li>Tailored results based on your answers</li><li>No credit check required</li></ul>
          <a href="https://stairwaymortgage.com/discovery-quiz">Take the Discovery Quiz</a>
        </div>
        <div class="cta-card">
          <h4>Need a Pre-Approval Letter—Fast?</h4>
          <p>Buying a home soon? Complete our short form and we’ll connect you with the best loan options for your target property and financial situation—fast.</p>
          <ul><li>Only 2 minutes to complete</li><li>Quick turnaround on pre-approval</li><li>No credit score impact</li></ul>
          <a href="https://stairwaymortgage.com/purchase-inquiry">Get Pre-Approved Now</a>
        </div>
        <div class="cta-card">
          <h4>Got a Few Questions First?</h4>
          <p>Let’s talk it through. Book a call and one of our friendly advisors will be in touch to guide you personally.</p>
          <a href="https://stairwaymortgage.com/schedule-call">Schedule a Call</a>
        </div>

        <h2>Important Disclaimer</h2>
        <p>This calculator is for illustrative purposes only and does not constitute financial, legal, or investment advice. Results are based on general assumptions and may not reflect actual performance or eligibility. This is not a loan estimate or approval. Please consult with a licensed mortgage advisor before making financial decisions.</p>

        <h2>Related Posts</h2>
        <!-- [loan_calculator_box] — render the related-calculators component here in the live build -->
        <div class="related-placeholder">Related calculators module ([loan_calculator_box])</div>
      </section>
    </div>
  </section>

  <script is:inline>
  (function () {
    const $ = (id) => document.getElementById(id);
    const fmt = (n) => '$' + Math.round(n).toLocaleString('en-US');
    const fmt2 = (n) => '$' + n.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
    const els = ['homeValue','balance','cltv','draw','apr','repay'].map($);
    function compute() {
      const homeValue = +$('homeValue').value || 0;
      const balance   = +$('balance').value || 0;
      const cltv      = (+$('cltv').value || 0) / 100;
      const apr       = (+$('apr').value || 0) / 100;
      const repayYrs  = +$('repay').value || 0;
      let draw        = +$('draw').value || 0;
      const avail = Math.max(0, homeValue * cltv - balance);
      const cappedDraw = Math.min(draw, avail);
      const io = cappedDraw * (apr / 12);
      const n = repayYrs * 12;
      const r = apr / 12;
      let amort;
      if (r > 0 && n > 0) amort = cappedDraw * (r * Math.pow(1+r, n)) / (Math.pow(1+r, n) - 1);
      else amort = n > 0 ? cappedDraw / n : 0;
      $('cltvVal').textContent = (cltv*100).toFixed(0) + '%';
      $('aprVal').textContent  = (apr*100).toFixed(1) + '%';
      $('repayVal').textContent = repayYrs + ' yrs';
      $('rAvail').textContent = fmt(avail);
      $('rDraw').textContent  = fmt(cappedDraw);
      $('rIO').textContent    = fmt2(io);
      $('rAmort').textContent = fmt2(amort);
      const hint = $('drawHint');
      hint.textContent = (draw > avail) ? ('Capped to your available equity of ' + fmt(avail) + '.') : '';
    }
    els.forEach((el) => el.addEventListener('input', compute));
    compute();
  })();
  </script>
</Layout>

<style>
.crumbs{font-family:'JetBrains Mono',monospace;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--color-mute);margin-bottom:28px;}
.crumbs a{color:var(--color-mute);text-decoration:none;} .crumbs a:hover{color:var(--color-blue);} .crumbs span{margin:0 6px;}
.eyebrow{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--color-blue);margin:0 0 10px;}
.display-lg{font-family:'Fraunces',Georgia,serif;font-weight:500;font-size:clamp(36px,6vw,60px);line-height:1.04;margin:0 0 18px;letter-spacing:-.01em;}
.lede{font-size:19px;color:#2b3140;max-width:60ch;margin:0 0 14px;}
.trust{font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--color-mute);border-top:1px solid var(--color-bone);padding-top:14px;margin:0;}
.calc{margin:40px 0 56px;border:1px solid var(--color-bone);border-radius:18px;overflow:hidden;background:#fff;box-shadow:0 1px 0 var(--color-bone),0 24px 48px -32px rgba(10,14,26,.25);}
.calc::before{content:"";display:block;height:4px;background:var(--color-blue);}
.calc-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:0;}
@media(max-width:760px){.calc-grid{grid-template-columns:1fr;}}
.calc-inputs{padding:28px 28px 30px;}
.calc-results{padding:28px;background:var(--color-paper-tint);border-left:1px solid var(--color-bone);display:flex;flex-direction:column;gap:14px;}
@media(max-width:760px){.calc-results{border-left:0;border-top:1px solid var(--color-bone);}}
.field{margin-bottom:20px;}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:18px;}
@media(max-width:520px){.field-row{grid-template-columns:1fr;}}
label{display:block;font-size:13px;font-weight:600;color:#384055;margin-bottom:8px;}
label .val{float:right;font-family:'JetBrains Mono',monospace;color:var(--color-blue);font-weight:600;}
.input-money{display:flex;align-items:center;border:1px solid var(--color-bone);border-radius:10px;background:#fff;overflow:hidden;transition:border-color .15s,box-shadow .15s;}
.input-money:focus-within{border-color:var(--color-blue);box-shadow:0 0 0 3px rgba(24,69,214,.12);}
.input-money span{padding:0 4px 0 14px;color:var(--color-mute);font-weight:600;}
.input-money input{flex:1;border:0;outline:0;padding:12px 14px 12px 4px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--color-ink);width:100%;}
input[type=range]{width:100%;accent-color:var(--color-blue);height:4px;margin:6px 0;}
.hint{font-size:12px;color:var(--color-rust);margin:6px 0 0;min-height:14px;}
.result{display:flex;flex-direction:column;gap:2px;padding:12px 16px;border-radius:10px;background:#fff;border:1px solid var(--color-bone);}
.result--primary{background:var(--color-ink);border-color:var(--color-ink);}
.result--primary .result-label{color:#aeb6c8;} .result--primary .result-value{color:#fff;}
.result-label{font-size:12px;color:var(--color-mute);font-weight:500;} .result-label em{font-style:normal;opacity:.7;}
.result-value{font-family:'Fraunces',serif;font-weight:600;font-size:26px;letter-spacing:-.01em;}
.cta-primary{display:block;text-align:center;background:var(--color-blue);color:#fff;text-decoration:none;font-weight:600;padding:14px;border-radius:10px;margin-top:4px;transition:background .15s;}
.cta-primary:hover{background:#1238b0;}
.micro{font-size:11px;color:var(--color-mute);text-align:center;margin:0;}
.body-content{margin-top:8px;}
.body-content h2{font-family:'Fraunces',serif;font-weight:500;font-size:28px;margin:40px 0 12px;}
.body-content p{color:#2b3140;}
.author{display:flex;align-items:center;gap:16px;margin:0 0 32px;}
.author img{width:64px;height:64px;border-radius:50%;object-fit:cover;}
.author h3{font-family:'Fraunces',serif;font-weight:500;font-size:18px;margin:0;}
.author a{color:var(--color-ink);text-decoration:none;} .author a:hover{color:var(--color-blue);}
.cta-card{background:var(--color-paper-tint);border:1px solid var(--color-bone);border-radius:16px;padding:32px;text-align:center;margin:24px auto;max-width:760px;}
.cta-card h4{font-family:'Fraunces',serif;font-weight:500;font-size:24px;margin:0 0 12px;}
.cta-card p{max-width:620px;margin:0 auto 18px;}
.cta-card ul{list-style:none;padding:0;margin:18px 0;color:#384055;font-size:15px;}
.cta-card a{display:inline-block;background:var(--color-ink);color:#fff;padding:13px 26px;border-radius:9px;text-decoration:none;font-weight:600;}
.cta-card a:hover{background:var(--color-blue);}
.related-placeholder{border:1px dashed var(--color-bone);border-radius:10px;padding:20px;color:var(--color-mute);font-family:'JetBrains Mono',monospace;font-size:13px;text-align:center;}
</style>
