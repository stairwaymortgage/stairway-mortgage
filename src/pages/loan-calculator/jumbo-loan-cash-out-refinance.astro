---
import Layout from '../../layouts/Layout.astro';
import CalcLeadForm from '../../components/CalcLeadForm.astro';
const metaTitle = "Jumbo Cash-Out Refinance Calculator: Estimate Your Max Loan, Cash Back, Payment & Income to Qualify";
const metaDescription = "Calculate a jumbo cash-out refinance: maximum loan at 80% (primary) or 75% LTV, cash back, new payment, interest-only option, and the income needed to qualify at a 43% DTI.";
const canonical = "https://stairwaymortgage.com/loan-calculator/jumbo-loan-cash-out-refinance/";
const breadcrumbSchema = {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://stairwaymortgage.com/"},{"@type":"ListItem","position":2,"name":"Loan Calculators","item":"https://stairwaymortgage.com/all-loan-calculators/"},{"@type":"ListItem","position":3,"name":"Jumbo Cash-Out Refinance Calculator","item":canonical}]};
const appSchema = {"@context":"https://schema.org","@type":"WebApplication","name":"Jumbo Cashout Refinance Loan Payment Calculator","applicationCategory":"FinanceApplication","operatingSystem":"All","url":canonical,"offers":{"@type":"Offer","price":"0","priceCurrency":"USD"},"description":metaDescription};
const faqSchema = {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How much can I cash out on a jumbo refinance?","acceptedAnswer":{"@type":"Answer","text":"Typically up to 80% of value on a primary residence or 75% on a second home, minus your current balance and closing costs."}},{"@type":"Question","name":"What DTI do jumbo lenders allow?","acceptedAnswer":{"@type":"Answer","text":"Most jumbo lenders cap debt-to-income at 43%, though up to 50% is possible with strong credit and reserves; the best rates are often near 37% DTI."}},{"@type":"Question","name":"Should I consider interest-only?","acceptedAnswer":{"@type":"Answer","text":"If you don't plan to stay long term, an interest-only payment can lower monthly cost and free up cash to invest. This calculator shows that option."}}]};
---
<Layout title={metaTitle} description={metaDescription} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<main class="container-page">
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href="/">Home</a> <span>/</span>
    <a href="/all-loan-calculators/">Loan Calculators</a> <span>/</span>
    <span aria-current="page">Jumbo Cash-Out Refinance Calculator</span>
  </nav>
  <header class="calc-head">
    <p class="eyebrow">Jumbo · Cash-Out Refinance</p>
    <h1 class="display-lg">Jumbo Cashout Refinance Loan Payment Calculator</h1>
    <p class="lede">Tap equity on a high-balance home. Estimate your maximum loan, cash back, new payment, interest-only option, and the income needed to qualify.</p>
    <p class="trust">Built by Jim Blackburn · NMLS #1072866 · $500M+ closed · 7× Scotsman Guide Top Producer</p>
  </header>
  <section class="calc" aria-label="Jumbo Cash-Out Refinance Calculator">
    <div class="calc-grid">
      <div class="calc-inputs">
        <div class="field">
          <span class="lbl">Is this your primary residence?</span>
          <div class="radios" role="radiogroup" aria-label="Primary residence">
            <label><input type="radio" name="primary" value="0.8" checked /> Yes</label>
            <label><input type="radio" name="primary" value="0.75" /> No</label>
          </div>
          <p class="hint hint--mute">Primary = up to 80% LTV; second/investment = 75%.</p>
        </div>
        <div class="field"><label for="bal">Current Loan Balance</label><div class="input-money"><span>$</span><input id="bal" type="number" inputmode="numeric" value="1000000" min="0" step="1000" /></div></div>
        <div class="field"><label for="home">Estimated Current Home Value</label><div class="input-money"><span>$</span><input id="home" type="number" inputmode="numeric" value="2000000" min="0" step="1000" /></div><p class="hint hint--mute">Use an appraisal, online estimate, or your best guess.</p></div>
        <div class="field"><label for="cash">Desired Cash Back</label><div class="input-money"><span>$</span><input id="cash" type="number" inputmode="numeric" value="500000" min="0" step="1000" /></div></div>
        <div class="field"><label for="curpi">Monthly Principal &amp; Interest Payment</label><div class="input-money"><span>$</span><input id="curpi" type="number" inputmode="numeric" value="7000" min="0" step="10" /></div><p class="hint hint--mute">Your current payment excluding taxes, insurance, and MI.</p></div>
        <div class="field-row">
          <div class="field"><label for="tax">Monthly Property Taxes</label><div class="input-money"><span>$</span><input id="tax" type="number" inputmode="numeric" value="1000" min="0" step="10" /></div></div>
          <div class="field"><label for="ins">Monthly Homeowners Insurance</label><div class="input-money"><span>$</span><input id="ins" type="number" inputmode="numeric" value="500" min="0" step="10" /></div></div>
        </div>
        <div class="field"><label for="hoa">Monthly HOA</label><div class="input-money"><span>$</span><input id="hoa" type="number" inputmode="numeric" value="0" min="0" step="10" /></div></div>
        <div class="field"><label for="rate">Estimated New Interest Rate</label><div class="input-plain"><input id="rate" type="number" inputmode="decimal" value="5.99" min="0" step="0.01" /><span class="suffix">%</span></div><p class="hint hint--mute">If unsure, assume ~0.5% lower than your current rate.</p></div>
      </div>
      <div class="calc-results" aria-live="polite">
        <p class="summary-title">Summary</p>
        <div class="result result--primary"><span class="result-label">Max Loan Amount</span><span class="result-value" id="rMaxLoan">$1,600,000</span><span class="result-note">Above the county conforming limit it's a jumbo loan with tighter guidelines.</span></div>
        <div class="result result--primary"><span class="result-label">Maximum Estimated Cash Back</span><span class="result-value" id="rMaxCash">$590,000</span></div>
        <p class="summary-sub">Your Scenario</p>
        <div class="result result--primary"><span class="result-label">Desired Loan Amount</span><span class="result-value" id="rDesired">$1,530,000</span><span class="result-note">Includes ~2% estimated closing costs. Not a Loan Estimate.</span></div>
        <div class="result result--primary"><span class="result-label">Estimated Cash Back</span><span class="result-value" id="rEstCash">$507,050</span></div>
        <p class="summary-sub">Payment Breakdown</p>
        <div class="result"><span class="result-label">Principal &amp; Interest Payment</span><span class="result-value" id="rPI">$9,163</span></div>
        <div class="result"><span class="result-label">Monthly Insurance</span><span class="result-value" id="rIns">$500</span></div>
        <div class="result"><span class="result-label">Monthly Taxes</span><span class="result-value" id="rTax">$1,000</span></div>
        <div class="result result--primary"><span class="result-label">Total Monthly Expense</span><span class="result-value" id="rTotal">$10,663</span></div>
        <div class="result"><span class="result-label">*Interest-Only Payment</span><span class="result-value" id="rIO">$7,637</span><span class="result-note">Lower monthly cost if you don't intend to pay it off — invest the difference.</span></div>
        <div class="result"><span class="result-label">Monthly Income Target to Qualify</span><span class="result-value" id="rIncome">$24,798</span><span class="result-note">Assumes a 43% jumbo DTI cap.</span></div>
        <a class="cta-primary" data-calc-cta data-calc-slug="jumbo-loan-cash-out-refinance">See My Options</a>
        <p class="micro">Estimates only — not a commitment to lend.</p>
      </div>
    </div>
  </section>
  <section class="body-content">
    <figure class="author">
      <a href="http://www.mortgagemanjim.com/linkedin%20" target="_blank" rel="noopener">
        <img width="120" height="120" src="https://stairwaymortgage.com/wp-content/uploads/2025/10/Untitled-design-3.png" alt="Jim Blackburn" />
      </a>
      <h3><a href="http://www.mortgagemanjim.com/linkedin%20" target="_blank" rel="noopener">By Jim Blackburn</a></h3>
    </figure>
    <div class="cta-card">
      <h4>Ready to Take Your First Step?</h4>
      <p><strong>Skip the guesswork.</strong> Take our quick Discovery Quiz to uncover your top financial priorities, so we can guide you toward the wealth-building strategies that fit your life.</p>
      <ul><li>Takes just 5 minutes</li><li>Tailored results based on your answers</li><li>No credit check required</li></ul>
      <a href="https://stairwaymortgage.com/discovery-quiz">Take the Discovery Quiz</a>
    </div>
    <div class="cta-card">
      <h4>Need a Pre-Approval Letter—Fast?</h4>
      <p>Buying a home soon? Complete our short form and we'll connect you with the best loan options for your target property and financial situation—fast.</p>
      <ul><li>Only 2 minutes to complete</li><li>Quick turnaround on pre-approval</li><li>No credit score impact</li></ul>
      <a href="https://stairwaymortgage.com/purchase-inquiry">Get Pre-Approved Now</a>
    </div>
    <div class="cta-card">
      <h4>Got a Few Questions First?</h4>
      <p>Let's talk it through. Book a call and one of our friendly advisors will be in touch to guide you personally.</p>
      <a href="https://stairwaymortgage.com/schedule-call">Schedule a Call</a>
    </div>
    <h2>Important Disclaimer</h2>
    <p>This calculator is for illustrative purposes only and does not constitute financial, legal, or investment advice. Results are based on general assumptions and may not reflect actual performance or eligibility. This is not a loan estimate or approval. Please consult with a licensed mortgage advisor before making financial decisions.</p>
    <h2>Related Posts</h2>
    <div class="related-placeholder">Related calculators module ([loan_calculator_box])</div>
  </section>
</main>
<script is:inline>
(function () {
  const $ = (id) => document.getElementById(id);
  const fmt0 = (n) => (n<0?'-$':'$') + Math.abs(Math.round(n)).toLocaleString('en-US');
  function radio(name){const e=document.querySelector('input[name="'+name+'"]:checked');return e?+e.value:0;}
  function compute(){
    const primary=radio('primary'), bal=+$('bal').value||0, home=+$('home').value||0,
          cash=+$('cash').value||0, curpi=+$('curpi').value||0, mtax=+$('tax').value||0,
          mins=+$('ins').value||0, hoa=+$('hoa').value||0, rate=+$('rate').value||0;
    const maxLoan = (primary===0.8) ? home*0.8 : home*0.75;
    const maxCash = home*0.8 - bal - 10000;
    const desiredLoan = Math.min(maxLoan, 0.02*(bal+cash) + bal + cash);
    const r=rate/100/12;
    const pi = r>0 ? Math.floor(desiredLoan*r*Math.pow(1+r,360)/(Math.pow(1+r,360)-1)) : Math.floor(desiredLoan/360);
    const estCash = desiredLoan - bal - 0.015*desiredLoan;
    const total = pi + mins + mtax;
    const io = (desiredLoan*(rate/100))/12;
    const income = (total + hoa)/0.43;
    $('rMaxLoan').textContent=fmt0(maxLoan); $('rMaxCash').textContent=fmt0(maxCash);
    $('rDesired').textContent=fmt0(desiredLoan); $('rEstCash').textContent=fmt0(estCash);
    $('rPI').textContent=fmt0(pi); $('rIns').textContent=fmt0(mins); $('rTax').textContent=fmt0(mtax);
    $('rTotal').textContent=fmt0(total); $('rIO').textContent=fmt0(io); $('rIncome').textContent=fmt0(income);
  }
  document.querySelectorAll('input').forEach(el=>{el.addEventListener('input',compute);el.addEventListener('change',compute);});
  compute();
})();
</script>
<style>
.crumbs{font-family:'JetBrains Mono',monospace;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--mute);margin-bottom:28px;}
.crumbs a{color:var(--mute);text-decoration:none;} .crumbs a:hover{color:var(--blue);} .crumbs span{margin:0 6px;}
.eyebrow{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--blue);margin:0 0 10px;}
.display-lg{font-family:'Fraunces',Georgia,serif;font-weight:500;font-size:clamp(30px,4.6vw,48px);line-height:1.06;margin:0 0 18px;letter-spacing:-.01em;}
.lede{font-size:18px;color:#2b3140;max-width:62ch;margin:0 0 14px;}
.trust{font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--mute);border-top:1px solid var(--bone);padding-top:14px;margin:0;}
.calc{margin:40px 0 56px;border:1px solid var(--bone);border-radius:18px;overflow:hidden;background:#fff;box-shadow:0 1px 0 var(--bone),0 24px 48px -32px rgba(10,14,26,.25);}
.calc::before{content:"";display:block;height:4px;background:var(--blue);}
.calc-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:0;}
@media(max-width:780px){.calc-grid{grid-template-columns:1fr;}}
.calc-inputs{padding:30px 30px 32px;}
.calc-results{padding:30px;background:var(--ink);color:#fff;display:flex;flex-direction:column;gap:12px;}
.summary-title{font-family:'Fraunces',serif;font-weight:600;font-size:28px;margin:0 0 4px;color:#fff;}
.summary-sub{font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-size:11px;color:#aeb6c8;border-top:1px solid rgba(255,255,255,.15);padding-top:14px;margin:8px 0 0;}
.field{margin-bottom:20px;}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
@media(max-width:520px){.field-row{grid-template-columns:1fr;}}
.lbl,label{display:block;font-size:13.5px;font-weight:600;color:#384055;margin-bottom:8px;}
.radios{display:flex;gap:20px;}
.radios label{font-weight:500;color:#2b3140;display:flex;align-items:center;gap:9px;margin:0;cursor:pointer;}
.radios input{accent-color:var(--blue);width:17px;height:17px;}
.input-money,.input-plain{display:flex;align-items:center;border:1px solid var(--bone);border-radius:10px;background:#fff;overflow:hidden;transition:border-color .15s,box-shadow .15s;}
.input-money:focus-within,.input-plain:focus-within{border-color:var(--blue);box-shadow:0 0 0 3px rgba(24,69,214,.12);}
.input-money span{padding:0 4px 0 14px;color:var(--mute);font-weight:600;}
.input-money input{flex:1;border:0;outline:0;padding:13px 14px 13px 4px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--ink);width:100%;}
.input-plain input{flex:1;border:0;outline:0;padding:13px 6px 13px 14px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--ink);width:100%;}
.input-plain .suffix{padding:0 14px 0 4px;color:var(--mute);font-weight:600;}
input[type=range]{width:100%;accent-color:var(--blue);height:4px;margin:6px 0;}
.hint{font-size:12px;margin:6px 0 0;} .hint--mute{color:var(--mute);}
.result{display:flex;flex-direction:column;gap:3px;padding:12px 16px;border-radius:10px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.10);}
.result--primary{background:#fff;border-color:#fff;}
.result--primary .result-label{color:#384055;} .result--primary .result-value{color:var(--ink);} .result--primary .result-note{color:#6B7280;}
.result-label{font-size:12.5px;color:#aeb6c8;font-weight:600;}
.result-value{font-family:'Fraunces',serif;font-weight:600;font-size:26px;letter-spacing:-.01em;color:#fff;}
.result-note{font-size:10.5px;line-height:1.45;color:#8b93a6;}
.cta-primary{display:block;text-align:center;background:var(--blue);color:#fff;text-decoration:none;font-weight:600;padding:14px;border-radius:10px;margin-top:6px;transition:background .15s;}
.cta-primary:hover{background:#2a57e6;}
.micro{font-size:11px;color:#8b93a6;text-align:center;margin:0;}
.body-content h2{font-family:'Fraunces',serif;font-weight:500;font-size:28px;margin:40px 0 12px;}
.body-content p{color:#2b3140;}
.author{display:flex;align-items:center;gap:16px;margin:0 0 32px;}
.author img{width:64px;height:64px;border-radius:50%;object-fit:cover;}
.author h3{font-family:'Fraunces',serif;font-weight:500;font-size:18px;margin:0;}
.author a{color:var(--ink);text-decoration:none;} .author a:hover{color:var(--blue);}
.cta-card{background:var(--paper-tint);border:1px solid var(--bone);border-radius:16px;padding:32px;text-align:center;margin:24px auto;max-width:760px;}
.cta-card h4{font-family:'Fraunces',serif;font-weight:500;font-size:24px;margin:0 0 12px;}
.cta-card p{max-width:620px;margin:0 auto 18px;}
.cta-card ul{list-style:none;padding:0;margin:18px 0;color:#384055;font-size:15px;}
.cta-card a{display:inline-block;background:var(--ink);color:#fff;padding:13px 26px;border-radius:9px;text-decoration:none;font-weight:600;}
.cta-card a:hover{background:var(--blue);}
.related-placeholder{border:1px dashed var(--bone);border-radius:10px;padding:20px;color:var(--mute);font-family:'JetBrains Mono',monospace;font-size:13px;text-align:center;}
</style>
  <CalcLeadForm />
</Layout>
