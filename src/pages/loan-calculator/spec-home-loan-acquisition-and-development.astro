---
import Layout from '../../layouts/Layout.astro';
import CalcLeadForm from '../../components/CalcLeadForm.astro';
const metaTitle = "Build To Sell Spec Home Calculator: Purchase, Teardown, Build, Sell, Profit | Stairway Mortgage";
const metaDescription = "Estimate cash to close, holding costs, and profit potential on a build-to-sell spec home you acquire, tear down, and build with one loan. Built by Jim Blackburn, NMLS #1072866.";
const canonical = "https://stairwaymortgage.com/loan-calculator/spec-home-loan-acquisition-and-development/";
const breadcrumbSchema = {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://stairwaymortgage.com/"},{"@type":"ListItem","position":2,"name":"Loan Calculators","item":"https://stairwaymortgage.com/all-loan-calculators/"},{"@type":"ListItem","position":3,"name":"Build To Sell Spec Home Calculator","item":canonical}]};
const appSchema = {"@context":"https://schema.org","@type":"WebApplication","name":"Build To Sell Spec Home Calculator: Purchase, Teardown, Build, Sell, Profit","applicationCategory":"FinanceApplication","operatingSystem":"All","url":canonical,"offers":{"@type":"Offer","price":"0","priceCurrency":"USD"},"description":metaDescription};
const faqSchema = {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What does this spec home calculator estimate?","acceptedAnswer":{"@type":"Answer","text":"It estimates your cash to close, the maximum and desired loan amount, holding costs over the build period, total project cost, and profit before tax on a build-to-sell spec home financed with a single acquisition-and-construction loan."}},{"@type":"Question","name":"How is the maximum loan determined?","acceptedAnswer":{"@type":"Answer","text":"It is the lesser of 75% of total allowable financeable costs or 75% of the after-repair value, reflecting typical construction loan underwriting."}},{"@type":"Question","name":"Is this a loan approval?","acceptedAnswer":{"@type":"Answer","text":"No. It's an illustrative estimate, not a loan estimate or approval. Always obtain an official Loan Estimate from a licensed mortgage originator."}}]};
---
<Layout title={metaTitle} description={metaDescription}>
  <link slot="head" rel="canonical" href={canonical} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <main class="container-page">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a> <span>/</span>
      <a href="/all-loan-calculators/">Loan Calculators</a> <span>/</span>
      <span aria-current="page">Build To Sell Spec Home</span>
    </nav>
    <header class="calc-head">
      <p class="eyebrow">Spec Home · Build to Sell</p>
      <h1 class="display-lg">Build To Sell Spec Home Calculator: Purchase, Teardown, Build, Sell, Profit</h1>
      <p class="lede">Estimate your cash to close, holding costs, and profit potential on a spec home you plan to acquire, tear down, and build — all with the same loan.</p>
      <p class="trust">Built by Jim Blackburn · NMLS #1072866 · $500M+ closed · 7× Scotsman Guide Top Producer</p>
    </header>
    <section class="calc" aria-label="Build To Sell Spec Home Calculator">
      <div class="calc-grid">
        <div class="calc-inputs">
          <p class="group-label">Costs</p>
          <div class="field"><label for="purchase">Purchase Price</label><div class="input-money"><span>$</span><input id="purchase" type="number" inputmode="numeric" value="500000" min="0" step="10000" /></div></div>
          <div class="field"><label for="hard">Hard Costs</label><div class="input-money"><span>$</span><input id="hard" type="number" inputmode="numeric" value="1000000" min="0" step="10000" /></div><p class="hint hint--mute">Estimate all labor and material costs.</p></div>
          <div class="field"><label for="soft">Soft Costs</label><div class="input-money"><span>$</span><input id="soft" type="number" inputmode="numeric" value="50000" min="0" step="5000" /></div><p class="hint hint--mute">Permits, architectural, and engineering fees.</p></div>
          <div class="field"><label for="addl">Additional Funds Beyond Minimum To Put Down</label><div class="input-money"><span>$</span><input id="addl" type="number" inputmode="numeric" value="0" min="0" step="5000" /></div><p class="hint hint--mute">25% is the minimum down; this reduces the loan dollar-for-dollar.</p></div>
          <p class="group-label">Sale &amp; Timeline</p>
          <div class="field"><label for="arv">Sales Price / After Repair Value (ARV)</label><div class="input-money"><span>$</span><input id="arv" type="number" inputmode="numeric" value="3000000" min="0" step="25000" /></div><p class="hint hint--mute">Estimate with sold comps in the last 6 months.</p></div>
          <div class="field-row">
            <div class="field"><label for="months">Months Held</label><div class="input-plain"><input id="months" type="number" inputmode="numeric" value="12" min="0" step="1" /></div></div>
            <div class="field"><label for="partners"># of Partners</label><div class="input-plain"><input id="partners" type="number" inputmode="numeric" value="5" min="1" step="1" /></div></div>
          </div>
          <div class="field"><label for="exitPct">Estimated Exit Costs (% of sales price)</label><div class="input-plain"><input id="exitPct" type="number" inputmode="decimal" value="8" min="0" step="0.5" /><span class="suffix">%</span></div><p class="hint hint--mute">~6% with a Realtor, ~3% if you are one; 2% for seller costs.</p></div>
          <p class="group-label">Carry &amp; Financing</p>
          <div class="field-row">
            <div class="field"><label for="ins">Annual Insurance</label><div class="input-money"><span>$</span><input id="ins" type="number" inputmode="numeric" value="6000" min="0" step="500" /></div></div>
            <div class="field"><label for="tax">Annual Taxes</label><div class="input-money"><span>$</span><input id="tax" type="number" inputmode="numeric" value="12000" min="0" step="500" /></div></div>
          </div>
          <div class="field"><label for="hoa">Monthly HOA</label><div class="input-money"><span>$</span><input id="hoa" type="number" inputmode="numeric" value="0" min="0" step="25" /></div></div>
          <div class="field">
            <label for="rate">Estimated Interest Rate: <span id="rateOut" class="slider-out">9.99%</span></label>
            <input id="rate" type="range" min="5" max="15" step="0.01" value="9.99" />
            <p class="hint hint--mute">Estimated permanent rate after the interest-only construction period.</p>
          </div>
        </div>
        <div class="calc-results" aria-live="polite">
          <p class="summary-title">Summary</p>
          <p class="summary-sub">Costs &amp; Financing</p>
          <div class="result"><span class="result-label">Property Costs</span><span class="result-value" id="rProp">$1,650,000</span><span class="result-note">Purchase + hard costs + 10% contingency + soft costs.</span></div>
          <div class="result"><span class="result-label">12 Months Interest Reserves</span><span class="result-value" id="rIntRes">$123,626</span></div>
          <div class="result"><span class="result-label">Maximum Loan Amount</span><span class="result-value" id="rMaxLoan">$1,330,220</span><span class="result-note">Lesser of 75% of costs or 75% of ARV.</span></div>
          <div class="result"><span class="result-label">Desired Loan Amount</span><span class="result-value" id="rDesLoan">$1,330,220</span></div>
          <div class="result result--primary"><span class="result-label">Estimated Cash Out of Pocket</span><span class="result-value" id="rCashOOP">$443,407</span></div>
          <p class="summary-sub">Holding &amp; Exit</p>
          <div class="result"><span class="result-label">Holding Costs</span><span class="result-value" id="rHolding">$141,626</span><span class="result-note">Interest, tax, insurance, HOA over months held.</span></div>
          <div class="result"><span class="result-label">Estimated Exit Cost</span><span class="result-value" id="rExit">$240,000</span></div>
          <div class="result"><span class="result-label">Total Project Costs</span><span class="result-value" id="rTotalProj">$2,531,626</span></div>
          <p class="summary-sub">Profit</p>
          <div class="result result--primary"><span class="result-label">Profit Before Tax or 1031 Exchange</span><span class="result-value" id="rProfit">$468,374</span></div>
          <div class="result"><span class="result-label">Profit Per Partner</span><span class="result-value" id="rPerPartner">$93,675</span></div>
          <div class="result result--primary"><span class="result-label">Cash on Cash ROI % Estimate</span><span class="result-value" id="rROI">105.6%</span><span class="result-note">Profit relative to cash invested.</span></div>
          <div class="result"><span class="result-label">Monthly Income Target to Qualify</span><span class="result-value" id="rIncomeTarget">$29,242</span></div>
          <a class="cta-primary" data-calc-cta data-calc-slug="spec-home-loan-acquisition-and-development">See My Options</a>
          <p class="micro">Estimates only — not a commitment to lend.</p>
        </div>
      </div>
    </section>
    <section class="body-content">
      <figure class="author">
        <a href="http://www.mortgagemanjim.com/linkedin%20" target="_blank" rel="noopener">
          <img width="120" height="120" src="https://stairwaymortgage.com/wp-content/uploads/2025/10/Untitled-design-3.png" alt="Jim Blackburn" />
        </a>
        <h3><a href="http://www.mortgagemanjim.com/linkedin%20" target="_blank" rel="noopener">By Jim Blackburn</a></h3>
      </figure>
      <div class="cta-card">
        <h4>Ready to Take Your First Step?</h4>
        <p><strong>Skip the guesswork.</strong> Take our quick Discovery Quiz to uncover your top financial priorities, so we can guide you toward the wealth-building strategies that fit your life.</p>
        <ul><li>Takes just 5 minutes</li><li>Tailored results based on your answers</li><li>No credit check required</li></ul>
        <a href="https://stairwaymortgage.com/discovery-quiz">Take the Discovery Quiz</a>
      </div>
      <div class="cta-card">
        <h4>Financing a Spec Build?</h4>
        <p>Tell us about your project and we'll structure the acquisition-and-construction loan for you—fast.</p>
        <ul><li>Only 2 minutes to complete</li><li>Quick turnaround</li><li>No credit score impact</li></ul>
        <a href="https://stairwaymortgage.com/purchase-inquiry">See My Options</a>
      </div>
      <div class="cta-card">
        <h4>Got a Few Questions First?</h4>
        <p>Let's talk it through. Book a call and one of our friendly advisors will be in touch to guide you personally.</p>
        <a href="https://stairwaymortgage.com/schedule-call">Schedule a Call</a>
      </div>
      <h2>Important Disclaimer</h2>
      <p>This calculator is for illustrative purposes only and does not constitute financial, legal, or investment advice. Results are based on general assumptions and hypothetical scenarios and may not reflect actual performance or eligibility. This is not a loan approval or loan estimate. All borrowers must qualify for financing based on credit, income, asset documentation, and property-specific guidelines. Please consult a licensed mortgage professional or financial advisor before making any financial decisions.</p>
      <h2>Related Posts</h2>
      <div class="related-placeholder">Related calculators module ([loan_calculator_box])</div>
    </section>
  </main>

  <script is:inline>
  (function () {
    const $ = (id) => document.getElementById(id);
    const fmt0 = (n) => { if(!isFinite(n)) return '—'; const r=Math.round(n); return (r<0?'-$':'$') + Math.abs(r).toLocaleString('en-US'); };
    const fmtPct = (n) => { if(!isFinite(n)) return '—'; return n.toFixed(1)+'%'; };
    function compute(){
      const purchase=+$('purchase').value||0, hard=+$('hard').value||0, soft=+$('soft').value||0,
            addl=+$('addl').value||0, arv=+$('arv').value||0, months=+$('months').value||0,
            partners=+$('partners').value||0, exitPct=+$('exitPct').value||0,
            ins=+$('ins').value||0, tax=+$('tax').value||0, hoa=+$('hoa').value||0, rate=+$('rate').value||0;
      $('rateOut').textContent = rate.toFixed(2)+'%';
      // Property Costs = 10%*hard + purchase + hard + soft  (10% contingency on hard costs)
      const propCosts = 0.10*hard + purchase + hard + soft;
      // 12 Months Interest Reserves = (propCosts*.75) * rate/100  (raw slider rate; no +3% despite hint)
      const intReserves = (propCosts*0.75) * rate/100;
      // Total Financeable Allowable (before closing) = propCosts + intReserves
      const allowable = propCosts + intReserves;
      // Maximum Loan = MIN(allowable*0.75, arv*0.75)
      const maxLoan = Math.min(allowable*0.75, arv*0.75);
      // Desired Loan = maxLoan - additionalFunds
      const desiredLoan = maxLoan - addl;
      // Estimated Cash Out of Pocket = allowable - desiredLoan
      const cashOOP = allowable - desiredLoan;
      // Monthly Holding = (annualInterest[=intReserves] + tax + ins + hoa*12)/12
      const monthlyHolding = (intReserves + tax + ins + hoa*12)/12;
      // Holding Costs = monthlyHolding * months
      const holding = monthlyHolding * months;
      // Estimated Exit Cost = exitPct * arv / 100
      const exitCost = exitPct * arv / 100;
      // Total Project Costs = propCosts + holding + exitCost + purchase  (purchase double-counted, verbatim)
      const totalProj = propCosts + holding + exitCost + purchase;
      // Profit Before Tax = arv - totalProj
      const profit = arv - totalProj;
      // Profit Per Partner = profit / partners
      const perPartner = partners>0 ? profit/partners : 0;
      // Cash on Cash ROI % = profit / cashOOP * 100  (no ÷0 guard in widget; we guard display only)
      const roi = cashOOP!==0 ? profit/cashOOP*100 : NaN;
      // Monthly Income Target = ((desiredLoan*(rate/100)/12) + hoa + tax/12 + ins/12) / 0.43
      const incomeTarget = ((desiredLoan*(rate/100)/12) + hoa + (tax/12) + (ins/12))/0.43;
      $('rProp').textContent=fmt0(propCosts); $('rIntRes').textContent=fmt0(intReserves);
      $('rMaxLoan').textContent=fmt0(maxLoan); $('rDesLoan').textContent=fmt0(desiredLoan);
      $('rCashOOP').textContent=fmt0(cashOOP); $('rHolding').textContent=fmt0(holding);
      $('rExit').textContent=fmt0(exitCost); $('rTotalProj').textContent=fmt0(totalProj);
      $('rProfit').textContent=fmt0(profit); $('rPerPartner').textContent=fmt0(perPartner);
      $('rROI').textContent=fmtPct(roi); $('rIncomeTarget').textContent=fmt0(incomeTarget);
    }
    document.querySelectorAll('input').forEach(el=>{el.addEventListener('input',compute);el.addEventListener('change',compute);});
    compute();
  })();
  </script>

  <style>
  .crumbs{font-family:'JetBrains Mono',monospace;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--mute);margin-bottom:28px;}
  .crumbs a{color:var(--mute);text-decoration:none;} .crumbs a:hover{color:var(--blue);} .crumbs span{margin:0 6px;}
  .eyebrow{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--blue);margin:0 0 10px;}
  .display-lg{font-family:'Fraunces',Georgia,serif;font-weight:500;font-size:clamp(26px,3.6vw,40px);line-height:1.1;margin:0 0 18px;letter-spacing:-.01em;}
  .lede{font-size:18px;color:#2b3140;max-width:62ch;margin:0 0 14px;}
  .trust{font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--mute);border-top:1px solid var(--bone);padding-top:14px;margin:0;}
  .calc{margin:40px 0 56px;border:1px solid var(--bone);border-radius:18px;overflow:hidden;background:#fff;box-shadow:0 1px 0 var(--bone),0 24px 48px -32px rgba(10,14,26,.25);}
  .calc::before{content:"";display:block;height:4px;background:var(--blue);}
  .calc-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:0;}
  @media(max-width:780px){.calc-grid{grid-template-columns:1fr;}}
  .calc-inputs{padding:30px 30px 32px;}
  .group-label{font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-size:11px;color:var(--blue);font-weight:600;margin:22px 0 12px;}
  .group-label:first-child{margin-top:0;}
  .calc-results{padding:30px;background:var(--ink);color:#fff;display:flex;flex-direction:column;gap:12px;}
  .summary-title{font-family:'Fraunces',serif;font-weight:600;font-size:28px;margin:0 0 4px;color:#fff;}
  .summary-sub{font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-size:11px;color:#aeb6c8;border-top:1px solid rgba(255,255,255,.15);padding-top:14px;margin:8px 0 0;}
  .field{margin-bottom:20px;}
  .field-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
  @media(max-width:520px){.field-row{grid-template-columns:1fr;}}
  .lbl,label{display:block;font-size:13.5px;font-weight:600;color:#384055;margin-bottom:8px;}
  .slider-out{color:var(--blue);font-family:'JetBrains Mono',monospace;font-weight:600;}
  input[type=range]{width:100%;accent-color:var(--blue);height:6px;}
  .input-money,.input-plain{display:flex;align-items:center;border:1px solid var(--bone);border-radius:10px;background:#fff;overflow:hidden;transition:border-color .15s,box-shadow .15s;}
  .input-money:focus-within,.input-plain:focus-within{border-color:var(--blue);box-shadow:0 0 0 3px rgba(24,69,214,.12);}
  .input-money span{padding:0 4px 0 14px;color:var(--mute);font-weight:600;}
  .input-money input{flex:1;border:0;outline:0;padding:13px 14px 13px 4px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--ink);width:100%;}
  .input-plain input{flex:1;border:0;outline:0;padding:13px 6px 13px 14px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--ink);width:100%;}
  .input-plain .suffix{padding:0 14px 0 4px;color:var(--mute);font-weight:600;}
  .hint{font-size:12px;margin:6px 0 0;color:var(--mute);} .hint--mute{color:var(--mute);}
  .result{display:flex;flex-direction:column;gap:3px;padding:12px 16px;border-radius:10px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.10);}
  .result--primary{background:#fff;border-color:#fff;}
  .result--primary .result-label{color:#384055;} .result--primary .result-value{color:var(--ink);} .result--primary .result-note{color:#6B7280;}
  .result-label{font-size:12.5px;color:#aeb6c8;font-weight:600;}
  .result-value{font-family:'Fraunces',serif;font-weight:600;font-size:24px;letter-spacing:-.01em;color:#fff;}
  .result-note{font-size:10.5px;line-height:1.45;color:#8b93a6;}
  .cta-primary{display:block;text-align:center;background:var(--blue);color:#fff;text-decoration:none;font-weight:600;padding:14px;border-radius:10px;margin-top:6px;transition:background .15s;}
  .cta-primary:hover{background:#2a57e6;}
  .micro{font-size:11px;color:#8b93a6;text-align:center;margin:0;}
  .body-content h2{font-family:'Fraunces',serif;font-weight:500;font-size:28px;margin:40px 0 12px;}
  .body-content p{color:#2b3140;}
  .author{display:flex;align-items:center;gap:16px;margin:0 0 32px;}
  .author img{width:64px;height:64px;border-radius:50%;object-fit:cover;}
  .author h3{font-family:'Fraunces',serif;font-weight:500;font-size:18px;margin:0;}
  .author a{color:var(--ink);text-decoration:none;} .author a:hover{color:var(--blue);}
  .cta-card{background:var(--paper-tint);border:1px solid var(--bone);border-radius:16px;padding:32px;text-align:center;margin:24px auto;max-width:760px;}
  .cta-card h4{font-family:'Fraunces',serif;font-weight:500;font-size:24px;margin:0 0 12px;}
  .cta-card p{max-width:620px;margin:0 auto 18px;}
  .cta-card ul{list-style:none;padding:0;margin:18px 0;color:#384055;font-size:15px;}
  .cta-card a{display:inline-block;background:var(--ink);color:#fff;padding:13px 26px;border-radius:9px;text-decoration:none;font-weight:600;}
  .cta-card a:hover{background:var(--blue);}
  .related-placeholder{border:1px dashed var(--bone);border-radius:10px;padding:20px;color:var(--mute);font-family:'JetBrains Mono',monospace;font-size:13px;text-align:center;}
  </style>
  <CalcLeadForm />
</Layout>
