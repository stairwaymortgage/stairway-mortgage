---
import Layout from '../../layouts/Layout.astro';
import CalcLeadForm from '../../components/CalcLeadForm.astro';
const metaTitle = "Reverse Mortgage Home Purchase Loan Calculator | Stairway Mortgage";
const metaDescription = "Estimate your reverse mortgage home purchase: principal limit by age, final loan amount, cash to close, and monthly housing expense — with no payment for life. Built by Jim Blackburn, NMLS #1072866.";
const canonical = "https://stairwaymortgage.com/loan-calculator/reverse-mortgage/";
const breadcrumbSchema = {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://stairwaymortgage.com/"},{"@type":"ListItem","position":2,"name":"Loan Calculators","item":"https://stairwaymortgage.com/loan-calculators/"},{"@type":"ListItem","position":3,"name":"Reverse Mortgage Home Purchase Loan Calculator","item":canonical}]};
const appSchema = {"@context":"https://schema.org","@type":"WebApplication","name":"Reverse Mortgage Home Purchase Loan Calculator","applicationCategory":"FinanceApplication","operatingSystem":"All","url":canonical,"offers":{"@type":"Offer","price":"0","priceCurrency":"USD"},"description":metaDescription};
const faqSchema = {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is a reverse mortgage for purchase (H4P)?","acceptedAnswer":{"@type":"Answer","text":"It lets a borrower aged 62+ (or 55+ on non-traditional programs) buy a home using reverse mortgage proceeds plus a down payment, with no required monthly principal and interest payment for life."}},{"@type":"Question","name":"How is the principal limit determined?","acceptedAnswer":{"@type":"Answer","text":"The principal limit is the purchase price multiplied by a Principal Limit Factor (PLF) based on the age of the oldest borrower and the expected interest rate."}},{"@type":"Question","name":"Do I still pay anything monthly?","acceptedAnswer":{"@type":"Answer","text":"There is no monthly principal and interest payment, but you remain responsible for property taxes, homeowners insurance, and any HOA dues."}}]};
---
<Layout title={metaTitle} description={metaDescription} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <main class="container-page">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a> <span>/</span>
      <a href="/loan-calculators/">Loan Calculators</a> <span>/</span>
      <span aria-current="page">Reverse Mortgage Home Purchase Calculator</span>
    </nav>
    <header class="calc-head">
      <p class="eyebrow">Reverse Mortgage · Home Purchase</p>
      <h1 class="display-lg">Reverse Mortgage Home Purchase Loan Calculator</h1>
      <p class="lede">Estimate your purchase price and the equity or cash needed to close with a reverse mortgage home purchase loan — and <strong>no payment for life</strong>.</p>
      <p class="trust">Built by Jim Blackburn · NMLS #1072866 · $500M+ closed · 7× Scotsman Guide Top Producer</p>
    </header>
    <section class="calc" aria-label="Reverse Mortgage Home Purchase Calculator">
      <div class="calc-grid">
        <div class="calc-inputs">
          <div class="field"><label for="age">How many years of age is the oldest borrower?</label><div class="input-plain"><input id="age" type="number" inputmode="numeric" value="72" min="0" step="1" /></div><p class="hint hint--mute">62 is the minimum for traditional FHA reverse mortgages; 55 for some non-traditional programs.</p></div>
          <div class="field"><label for="equity">Equity from Departing Residence</label><div class="input-money"><span>$</span><input id="equity" type="number" inputmode="numeric" value="300000" min="0" step="1000" /></div><p class="hint hint--mute">If selling a home, estimate the available equity you'll transfer to the new home.</p></div>
          <div class="field"><label for="price">Purchase Price of New Home</label><div class="input-money"><span>$</span><input id="price" type="number" inputmode="numeric" value="500000" min="0" step="1000" /></div></div>
          <div class="field-row">
            <div class="field"><label for="ins">Annual Insurance</label><div class="input-money"><span>$</span><input id="ins" type="number" inputmode="numeric" value="2400" min="0" step="100" /></div></div>
            <div class="field"><label for="tax">Annual Taxes</label><div class="input-money"><span>$</span><input id="tax" type="number" inputmode="numeric" value="3600" min="0" step="100" /></div></div>
          </div>
          <div class="field"><label for="hoa">Monthly HOA</label><div class="input-money"><span>$</span><input id="hoa" type="number" inputmode="numeric" value="0" min="0" step="10" /></div><p class="hint hint--mute">Paid separately, outside the mortgage.</p></div>
          <div class="field">
            <span class="lbl">Do you already have a living trust set up to ensure your legacy continues in a way that aligns with your heart?</span>
            <div class="radios" role="radiogroup" aria-label="Living trust set up">
              <label><input type="radio" name="trust" value="1" checked /> Yes</label>
              <label><input type="radio" name="trust" value="2" /> No</label>
            </div>
            <p class="hint hint--mute">You may consider meeting with one of our legacy partners to explore a smart estate plan.</p>
          </div>
        </div>
        <div class="calc-results" aria-live="polite">
          <p class="summary-title">Summary</p>
          <p class="summary-sub">Loan</p>
          <div class="result"><span class="result-label">Gap Needed For New Home</span><span class="result-value" id="rGap">$200,000</span></div>
          <div class="result"><span class="result-label">PLF Factor (at 6%)</span><span class="result-value" id="rPLF">0.453</span></div>
          <div class="result result--primary"><span class="result-label">Maximum Reverse Mortgage (Principal Limit)</span><span class="result-value" id="rMaxRM">$226,500</span><span class="result-note">Estimate based on borrower age and HUD reverse mortgage guidelines.</span></div>
          <div class="result"><span class="result-label">UFMIP</span><span class="result-value" id="rUFMIP">$3,964</span><span class="result-note">1.75% of base loan amount for FHA mortgage insurance.</span></div>
          <div class="result"><span class="result-label">Final Loan Amount</span><span class="result-value" id="rFinal">$230,464</span><span class="result-note">Base + UFMIP. Subject to HUD county loan limits.</span></div>
          <p class="summary-sub">Payment Breakdown</p>
          <div class="result"><span class="result-label">Principal &amp; Interest Payment</span><span class="result-value" id="rPI">$0</span><span class="result-note">No payment for life on a reverse mortgage.</span></div>
          <div class="result"><span class="result-label">Monthly Taxes</span><span class="result-value" id="rTax">$300</span></div>
          <div class="result"><span class="result-label">Monthly Insurance</span><span class="result-value" id="rIns">$200</span></div>
          <div class="result"><span class="result-label">HOA (paid separately)</span><span class="result-value" id="rHOA">$0</span></div>
          <div class="result result--primary"><span class="result-label">Total Monthly Housing Expense</span><span class="result-value" id="rTotal">$500</span></div>
          <p class="summary-sub">Cash to Close</p>
          <div class="result result--primary"><span class="result-label">Without Seller Credit</span><span class="result-value" id="rCashNo">$256,500</span><span class="result-note">Includes 6% estimated closing costs; varies by state. Not a Loan Estimate.</span></div>
          <div class="result"><span class="result-label">With 6% Seller Credit</span><span class="result-value" id="rCashSC">$226,500</span><span class="result-note">Assumes a 6% seller credit toward closing costs and prepaids.</span></div>
          <div class="result"><span class="result-label">Monthly Income Target to Qualify</span><span class="result-value" id="rIncome">$1,000</span><span class="result-note">Based on a 50% FHA DTI allowance with compensating factors.</span></div>
          <a class="cta-primary" data-calc-cta data-calc-slug="reverse-mortgage">See My Options</a>
          <p class="micro">Estimates only — not a commitment to lend.</p>
        </div>
      </div>
    </section>
    <section class="body-content">
      <figure class="author">
        <a href="http://www.mortgagemanjim.com/linkedin%20" target="_blank" rel="noopener">
          <img width="120" height="120" src="https://stairwaymortgage.com/wp-content/uploads/2025/10/Untitled-design-3.png" alt="Jim Blackburn" />
        </a>
        <h3><a href="http://www.mortgagemanjim.com/linkedin%20" target="_blank" rel="noopener">By Jim Blackburn</a></h3>
      </figure>
      <div class="cta-card">
        <h4>Ready to Take Your First Step?</h4>
        <p><strong>Skip the guesswork.</strong> Take our quick Discovery Quiz to uncover your top financial priorities, so we can guide you toward the wealth-building strategies that fit your life.</p>
        <ul><li>Takes just 5 minutes</li><li>Tailored results based on your answers</li><li>No credit check required</li></ul>
        <a href="https://stairwaymortgage.com/discovery-quiz">Take the Discovery Quiz</a>
      </div>
      <div class="cta-card">
        <h4>Thinking About a Reverse Mortgage Purchase?</h4>
        <p>Tell us about your goals and your departing residence, and we'll connect you with the best reverse mortgage options for your scenario—fast.</p>
        <ul><li>Only 2 minutes to complete</li><li>Quick turnaround</li><li>No credit score impact</li></ul>
        <a href="https://stairwaymortgage.com/reverse-mortgage-inquiry">See My Options</a>
      </div>
      <div class="cta-card">
        <h4>Got a Few Questions First?</h4>
        <p>Let's talk it through. Book a call and one of our friendly advisors will be in touch to guide you personally.</p>
        <a href="https://stairwaymortgage.com/schedule-call">Schedule a Call</a>
      </div>
      <h2>Important Disclaimer</h2>
      <p>This calculator is for illustrative purposes only and does not constitute financial, legal, or investment advice. Results are based on general assumptions and may not reflect actual performance or eligibility. This is not a loan estimate or approval. Please consult with a licensed mortgage advisor before making financial decisions.</p>
      <h2>Related Posts</h2>
      <div class="related-placeholder">Related calculators module ([loan_calculator_box])</div>
    </section>
  </main>

  <script is:inline>
  (function () {
    const $ = (id) => document.getElementById(id);
    const fmt0 = (n) => { const r=Math.round(n); return (r<0?'-$':'$') + Math.abs(r).toLocaleString('en-US'); };
    function plf6(a){
      if(a>=55&&a<=58) return 0.257;
      if(a>=59&&a<=61) return 0.307;
      if(a>=62&&a<=64) return 0.357;
      if(a>=65&&a<=71) return 0.403;
      if(a>=72&&a<=74) return 0.453;
      if(a>=75&&a<=81) return 0.467;
      if(a>=82&&a<=84) return 0.545;
      if(a>=85&&a<=91) return 0.570;
      if(a>=92&&a<=101) return 0.589;
      if(a>=102) return 0.606;
      return 0;
    }
    function compute(){
      const age=+$('age').value||0, equity=+$('equity').value||0, price=+$('price').value||0,
            ins=+$('ins').value||0, tax=+$('tax').value||0, hoa=+$('hoa').value||0;
      const gap = price - equity;
      const plf = plf6(age);
      const maxRM = plf * price;
      const ufmip = maxRM * 0.0175;
      const final = maxRM + ufmip;
      const pi = 0;
      const mtax = tax/12, mins = ins/12, mhoa = hoa;
      const total = mins + mtax;
      const cashNo = 0.06*price + maxRM;
      const cashSC = cashNo - 0.06*price;
      const income = (total + hoa)/0.50;
      $('rGap').textContent=fmt0(gap);
      $('rPLF').textContent=plf.toFixed(3);
      $('rMaxRM').textContent=fmt0(maxRM);
      $('rUFMIP').textContent=fmt0(ufmip);
      $('rFinal').textContent=fmt0(final);
      $('rPI').textContent=fmt0(pi);
      $('rTax').textContent=fmt0(mtax);
      $('rIns').textContent=fmt0(mins);
      $('rHOA').textContent=fmt0(mhoa);
      $('rTotal').textContent=fmt0(total);
      $('rCashNo').textContent=fmt0(cashNo);
      $('rCashSC').textContent=fmt0(cashSC);
      $('rIncome').textContent=fmt0(income);
    }
    document.querySelectorAll('input,select').forEach(el=>{el.addEventListener('input',compute);el.addEventListener('change',compute);});
    compute();
  })();
  </script>

  <style>
  .crumbs{font-family:'JetBrains Mono',monospace;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--mute);margin-bottom:28px;}
  .crumbs a{color:var(--mute);text-decoration:none;} .crumbs a:hover{color:var(--blue);} .crumbs span{margin:0 6px;}
  .eyebrow{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--blue);margin:0 0 10px;}
  .display-lg{font-family:'Fraunces',Georgia,serif;font-weight:500;font-size:clamp(28px,4.4vw,46px);line-height:1.08;margin:0 0 18px;letter-spacing:-.01em;}
  .lede{font-size:18px;color:#2b3140;max-width:62ch;margin:0 0 14px;}
  .trust{font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--mute);border-top:1px solid var(--bone);padding-top:14px;margin:0;}
  .calc{margin:40px 0 56px;border:1px solid var(--bone);border-radius:18px;overflow:hidden;background:#fff;box-shadow:0 1px 0 var(--bone),0 24px 48px -32px rgba(10,14,26,.25);}
  .calc::before{content:"";display:block;height:4px;background:var(--blue);}
  .calc-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:0;}
  @media(max-width:780px){.calc-grid{grid-template-columns:1fr;}}
  .calc-inputs{padding:30px 30px 32px;}
  .calc-results{padding:30px;background:var(--ink);color:#fff;display:flex;flex-direction:column;gap:12px;}
  .summary-title{font-family:'Fraunces',serif;font-weight:600;font-size:28px;margin:0 0 4px;color:#fff;}
  .summary-sub{font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-size:11px;color:#aeb6c8;border-top:1px solid rgba(255,255,255,.15);padding-top:14px;margin:8px 0 0;}
  .field{margin-bottom:20px;}
  .field-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
  @media(max-width:520px){.field-row{grid-template-columns:1fr;}}
  .lbl,label{display:block;font-size:13.5px;font-weight:600;color:#384055;margin-bottom:8px;}
  label .val{float:right;font-family:'JetBrains Mono',monospace;color:var(--blue);font-weight:600;}
  .radios{display:flex;gap:20px;}
  .radios label{font-weight:500;color:#2b3140;display:flex;align-items:center;gap:9px;margin:0;cursor:pointer;}
  .radios input{accent-color:var(--blue);width:17px;height:17px;}
  .input-money,.input-plain{display:flex;align-items:center;border:1px solid var(--bone);border-radius:10px;background:#fff;overflow:hidden;transition:border-color .15s,box-shadow .15s;}
  .input-money:focus-within,.input-plain:focus-within{border-color:var(--blue);box-shadow:0 0 0 3px rgba(24,69,214,.12);}
  .input-money span{padding:0 4px 0 14px;color:var(--mute);font-weight:600;}
  .input-money input{flex:1;border:0;outline:0;padding:13px 14px 13px 4px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--ink);width:100%;}
  .input-plain input{flex:1;border:0;outline:0;padding:13px 6px 13px 14px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--ink);width:100%;}
  input[type=range]{width:100%;accent-color:var(--blue);height:4px;margin:6px 0;}
  .hint{font-size:12px;margin:6px 0 0;} .hint--mute{color:var(--mute);}
  .result{display:flex;flex-direction:column;gap:3px;padding:12px 16px;border-radius:10px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.10);}
  .result--primary{background:#fff;border-color:#fff;}
  .result--primary .result-label{color:#384055;} .result--primary .result-value{color:var(--ink);} .result--primary .result-note{color:#6B7280;}
  .result-label{font-size:12.5px;color:#aeb6c8;font-weight:600;}
  .result-value{font-family:'Fraunces',serif;font-weight:600;font-size:24px;letter-spacing:-.01em;color:#fff;}
  .result-note{font-size:10.5px;line-height:1.45;color:#8b93a6;}
  .cta-primary{display:block;text-align:center;background:var(--blue);color:#fff;text-decoration:none;font-weight:600;padding:14px;border-radius:10px;margin-top:6px;transition:background .15s;}
  .cta-primary:hover{background:#2a57e6;}
  .micro{font-size:11px;color:#8b93a6;text-align:center;margin:0;}
  .body-content h2{font-family:'Fraunces',serif;font-weight:500;font-size:28px;margin:40px 0 12px;}
  .body-content p{color:#2b3140;}
  .author{display:flex;align-items:center;gap:16px;margin:0 0 32px;}
  .author img{width:64px;height:64px;border-radius:50%;object-fit:cover;}
  .author h3{font-family:'Fraunces',serif;font-weight:500;font-size:18px;margin:0;}
  .author a{color:var(--ink);text-decoration:none;} .author a:hover{color:var(--blue);}
  .cta-card{background:var(--paper-tint);border:1px solid var(--bone);border-radius:16px;padding:32px;text-align:center;margin:24px auto;max-width:760px;}
  .cta-card h4{font-family:'Fraunces',serif;font-weight:500;font-size:24px;margin:0 0 12px;}
  .cta-card p{max-width:620px;margin:0 auto 18px;}
  .cta-card ul{list-style:none;padding:0;margin:18px 0;color:#384055;font-size:15px;}
  .cta-card a{display:inline-block;background:var(--ink);color:#fff;padding:13px 26px;border-radius:9px;text-decoration:none;font-weight:600;}
  .cta-card a:hover{background:var(--blue);}
  .related-placeholder{border:1px dashed var(--bone);border-radius:10px;padding:20px;color:var(--mute);font-family:'JetBrains Mono',monospace;font-size:13px;text-align:center;}
  </style>
  <CalcLeadForm />
</Layout>
</content>
