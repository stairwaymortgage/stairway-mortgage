---
import Layout from '../../layouts/Layout.astro';
import CalcLeadForm from '../../components/CalcLeadForm.astro';
const metaTitle = "Jumbo Renovation Refinance Loan Payment Calculator | Stairway Mortgage";
const metaDescription = "Estimate your monthly payment and the cash needed to close on a jumbo refinance renovation loan: total project costs, interest reserves, max loan by LTV, payment, and income to qualify.";
const canonical = "https://stairwaymortgage.com/loan-calculator/jumbo-loan-renovation-refinance/";
const breadcrumbSchema = {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://stairwaymortgage.com/"},{"@type":"ListItem","position":2,"name":"Loan Calculators","item":"https://stairwaymortgage.com/loan-calculators/"},{"@type":"ListItem","position":3,"name":"Jumbo Renovation Refinance Loan Payment Calculator","item":canonical}]};
const appSchema = {"@context":"https://schema.org","@type":"WebApplication","name":"Jumbo Renovation Refinance Loan Payment Calculator","applicationCategory":"FinanceApplication","operatingSystem":"All","url":canonical,"offers":{"@type":"Offer","price":"0","priceCurrency":"USD"},"description":metaDescription};
const faqSchema = {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is a jumbo renovation refinance loan?","acceptedAnswer":{"@type":"Answer","text":"It refinances your existing jumbo balance and finances renovation costs into a single loan, sized against the after-repair value (ARV) of the home."}},{"@type":"Question","name":"How much can I borrow?","acceptedAnswer":{"@type":"Answer","text":"The max loan is the lesser of 75% of total financeable allowable costs or the maximum loan allowed per the ARV-based LTV cap."}},{"@type":"Question","name":"How are payments handled during construction?","acceptedAnswer":{"@type":"Answer","text":"Interest reserves cover roughly six months of interest during the build, so no payments are due while construction is underway."}}]};
---
<Layout title={metaTitle} description={metaDescription} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<main class="container-page">
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href="/">Home</a> <span>/</span>
    <a href="/loan-calculators/">Loan Calculators</a> <span>/</span>
    <span aria-current="page">Jumbo Renovation Refinance Loan Calculator</span>
  </nav>
  <header class="calc-head">
    <p class="eyebrow">Jumbo · Renovation Refinance</p>
    <h1 class="display-lg">Jumbo Renovation Refinance Loan Payment Calculator</h1>
    <p class="lede">Use this loan calculator to estimate your monthly payment and the cash needed to close on a jumbo refinance renovation loan.</p>
    <p class="trust">Built by Jim Blackburn · NMLS #1072866 · $500M+ closed · 7× Scotsman Guide Top Producer</p>
  </header>
  <section class="calc" aria-label="Jumbo Renovation Refinance Loan Calculator">
    <div class="calc-grid">
      <div class="calc-inputs">
        <div class="field"><label for="htype">What type of home will this be?</label><div class="input-plain"><select id="htype">
          <option value="1" selected>Primary Residence (1-unit)</option>
          <option value="2">Second Home (1-unit)</option>
          <option value="3">Spec Home / Rental Property</option>
        </select></div><p class="hint hint--mute">Primary 80% LTV, second home & spec/rental 75% — all capped at 75% ARV.</p></div>
        <div class="field"><label for="balance">Loan Balance</label><div class="input-money"><span>$</span><input id="balance" type="number" inputmode="numeric" value="900000" min="0" step="1000" /></div></div>
        <div class="field-row">
          <div class="field"><label for="soft">Soft Costs</label><div class="input-money"><span>$</span><input id="soft" type="number" inputmode="numeric" value="30000" min="0" step="1000" /></div><p class="hint hint--mute">Permits, architectural, engineering.</p></div>
          <div class="field"><label for="hard">Hard Costs</label><div class="input-money"><span>$</span><input id="hard" type="number" inputmode="numeric" value="500000" min="0" step="1000" /></div><p class="hint hint--mute">Labor and materials.</p></div>
        </div>
        <div class="field"><label for="arv">After Repair Value (ARV)</label><div class="input-money"><span>$</span><input id="arv" type="number" inputmode="numeric" value="3000000" min="0" step="10000" /></div><p class="hint hint--mute">Estimate with sold comps in last 6 months. Same BR, BA, SQ FT within a mile.</p></div>
        <div class="field-row">
          <div class="field"><label for="ins">Annual Insurance</label><div class="input-money"><span>$</span><input id="ins" type="number" inputmode="numeric" value="6000" min="0" step="100" /></div></div>
          <div class="field"><label for="tax">Annual Taxes</label><div class="input-money"><span>$</span><input id="tax" type="number" inputmode="numeric" value="12000" min="0" step="100" /></div></div>
        </div>
        <div class="field"><label for="hoa">Monthly HOA</label><div class="input-money"><span>$</span><input id="hoa" type="number" inputmode="numeric" value="0" min="0" step="10" /></div><p class="hint hint--mute">Paid separately, outside the mortgage.</p></div>
        <div class="field"><label for="rate">Estimated Interest Rate <span class="val" id="rateVal">6.99%</span></label><input id="rate" type="range" min="5" max="10" step="0.01" value="6.99" /><p class="hint hint--mute">Permanent rate after construction. Interest-only period runs ~3% higher during the build.</p></div>
      </div>
      <div class="calc-results" aria-live="polite">
        <p class="summary-title">Summary</p>
        <p class="summary-sub">Project Costs</p>
        <div class="result"><span class="result-label">Total Project Costs</span><span class="result-value" id="rTotalProj">$1,480,000</span><span class="result-note">Payoff + renovation costs + 10% hard contingency reserve.</span></div>
        <div class="result"><span class="result-label">Maximum Loan Amount (LTV)</span><span class="result-value" id="rMaxLTV">$2,250,000</span><span class="result-note">Max per ARV; final loan is the lesser of this or financeable costs.</span></div>
        <div class="result"><span class="result-label">6 Months Interest Reserves</span><span class="result-value" id="rReserves">$112,388</span></div>
        <div class="result"><span class="result-label">Total Financeable Allowable Costs</span><span class="result-value" id="rFinanceable">$1,636,788</span><span class="result-note">Property costs + interest reserves + ~3% closing. Not a Loan Estimate.</span></div>
        <p class="summary-sub">Loan</p>
        <div class="result result--primary"><span class="result-label">Max Loan Amount</span><span class="result-value" id="rMaxLoan">$1,227,591</span><span class="result-note">Lesser of 75% financeable or max per LTV.</span></div>
        <p class="summary-sub">Payment Breakdown</p>
        <div class="result"><span class="result-label">P&amp;I Payment (Post Construction)</span><span class="result-value" id="rPI">$8,159</span></div>
        <div class="result"><span class="result-label">Monthly Insurance</span><span class="result-value" id="rIns">$500</span></div>
        <div class="result"><span class="result-label">Monthly Taxes</span><span class="result-value" id="rTax">$1,000</span></div>
        <div class="result"><span class="result-label">HOA (paid separately)</span><span class="result-value" id="rHOA">$0</span></div>
        <div class="result result--primary"><span class="result-label">Total Monthly Housing Expense</span><span class="result-value" id="rTotal">$9,659</span></div>
        <p class="summary-sub">Cash &amp; Income</p>
        <div class="result result--primary"><span class="result-label">Estimated Cash Out of Pocket</span><span class="result-value" id="rCash">$409,197</span></div>
        <div class="result"><span class="result-label">Monthly Income Target to Qualify</span><span class="result-value" id="rIncome">$22,463</span><span class="result-note">Based on a 43% housing ratio.</span></div>
        <a class="cta-primary" data-calc-cta data-calc-slug="jumbo-loan-renovation-refinance">See My Options</a>
        <p class="micro">Estimates only — not a commitment to lend.</p>
      </div>
    </div>
  </section>
  <section class="body-content">
    <figure class="author">
      <a href="https://www.linkedin.com/company/nexa-mortgage-jim-blackburn-team" target="_blank" rel="noopener">
        <img width="120" height="120" src="https://stairwaymortgage.com/wp-content/uploads/2025/10/Untitled-design-3.png" alt="Jim Blackburn" />
      </a>
      <h3><a href="https://www.linkedin.com/company/nexa-mortgage-jim-blackburn-team" target="_blank" rel="noopener">By Jim Blackburn</a></h3>
    </figure>
    <div class="cta-card">
      <h4>Ready to Take Your First Step?</h4>
      <p><strong>Skip the guesswork.</strong> Take our quick Discovery Quiz to uncover your top financial priorities, so we can guide you toward the wealth-building strategies that fit your life.</p>
      <ul><li>Takes just 5 minutes</li><li>Tailored results based on your answers</li><li>No credit check required</li></ul>
      <a href="https://stairwaymortgage.com/discovery-quiz">Take the Discovery Quiz</a>
    </div>
    <div class="cta-card">
      <h4>Thinking About a Cash-Out Renovation Refi?</h4>
      <p>Tell us about your property and your renovation goals, and we'll connect you with the best loan options for your scenario—fast.</p>
      <ul><li>Only 2 minutes to complete</li><li>Quick turnaround</li><li>No credit score impact</li></ul>
      <a href="https://stairwaymortgage.com/refinance-or-heloc-inquiry">See My Options</a>
    </div>
    <div class="cta-card">
      <h4>Got a Few Questions First?</h4>
      <p>Let's talk it through. Book a call and one of our friendly advisors will be in touch to guide you personally.</p>
      <a href="https://stairwaymortgage.com/schedule-call">Schedule a Call</a>
    </div>
    <h2>Important Disclaimer</h2>
    <p>This calculator is for illustrative purposes only and does not constitute financial, legal, or investment advice. Results are based on general assumptions and may not reflect actual performance or eligibility. This is not a loan estimate or approval. Please consult with a licensed mortgage advisor before making financial decisions.</p>
    <h2>Related Posts</h2>
    <div class="related-placeholder">Related calculators module ([loan_calculator_box])</div>
  </section>
</main>
<script is:inline>
(function () {
  const $ = (id) => document.getElementById(id);
  const fmt0 = (n) => { const r=Math.round(n); return (r<0?'-$':'$') + Math.abs(r).toLocaleString('en-US'); };
  function compute(){
    const htype=+$('htype').value||1, balance=+$('balance').value||0, soft=+$('soft').value||0, hard=+$('hard').value||0,
          arv=+$('arv').value||0, annIns=+$('ins').value||0, annTax=+$('tax').value||0, hoa=+$('hoa').value||0, rate=+$('rate').value||0;
    // Total Project Costs = 10%*hard + balance + hard + soft
    const totalProj = 0.10*hard + balance + hard + soft;
    // Max Loan Per LTV = MIN( type1 0.80*ARV / type2,3 0.75*ARV / else 0 , 0.75*ARV )
    let ltvBranch;
    if(htype===1) ltvBranch = 0.80*arv;
    else if(htype===2) ltvBranch = 0.75*arv;
    else if(htype===3) ltvBranch = 0.75*arv;
    else ltvBranch = 0;
    const maxLTV = Math.min(ltvBranch, 0.75*arv);
    // 6 Months Interest Reserves = maxLTV * (rate/100 + 0.03) * 0.50
    const reserves = maxLTV * (rate/100 + 0.03) * 0.50;
    // Total Financeable = 3%*totalProj + totalProj + reserves
    const financeable = 0.03*totalProj + totalProj + reserves;
    // Max Loan = MIN(75%*financeable, maxLTV)
    const maxLoan = Math.min(0.75*financeable, maxLTV);
    // P&I always 30yr (360)
    const r=rate/1200;
    const pi = r>0 ? maxLoan*r/(1-Math.pow(1+r,-360)) : maxLoan/360;
    const mins=annIns/12, mtax=annTax/12;
    // Total Monthly Housing = SUM(pi, ins, tax, hoa, [Deleted]=0)
    const total = pi + mins + mtax + hoa + 0;
    // Cash Out of Pocket = financeable - maxLoan
    const cash = financeable - maxLoan;
    // Income Target = (total + hoa)/0.43
    const income = (total + hoa)/0.43;
    $('rateVal').textContent=rate.toFixed(2)+'%';
    $('rTotalProj').textContent=fmt0(totalProj); $('rMaxLTV').textContent=fmt0(maxLTV);
    $('rReserves').textContent=fmt0(reserves); $('rFinanceable').textContent=fmt0(financeable);
    $('rMaxLoan').textContent=fmt0(maxLoan); $('rPI').textContent=fmt0(pi);
    $('rIns').textContent=fmt0(mins); $('rTax').textContent=fmt0(mtax); $('rHOA').textContent=fmt0(hoa);
    $('rTotal').textContent=fmt0(total); $('rCash').textContent=fmt0(cash); $('rIncome').textContent=fmt0(income);
  }
  document.querySelectorAll('input,select').forEach(el=>{el.addEventListener('input',compute);el.addEventListener('change',compute);});
  compute();
})();
</script>
<style>
.crumbs{font-family:'JetBrains Mono',monospace;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--mute);margin-bottom:28px;}
.crumbs a{color:var(--mute);text-decoration:none;} .crumbs a:hover{color:var(--blue);} .crumbs span{margin:0 6px;}
.eyebrow{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--blue);margin:0 0 10px;}
.display-lg{font-family:'Fraunces',Georgia,serif;font-weight:500;font-size:clamp(28px,4.4vw,46px);line-height:1.08;margin:0 0 18px;letter-spacing:-.01em;}
.lede{font-size:18px;color:#2b3140;max-width:62ch;margin:0 0 14px;}
.trust{font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--mute);border-top:1px solid var(--bone);padding-top:14px;margin:0;}
.calc{margin:40px 0 56px;border:1px solid var(--bone);border-radius:18px;overflow:hidden;background:#fff;box-shadow:0 1px 0 var(--bone),0 24px 48px -32px rgba(10,14,26,.25);}
.calc::before{content:"";display:block;height:4px;background:var(--blue);}
.calc-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:0;}
@media(max-width:780px){.calc-grid{grid-template-columns:1fr;}}
.calc-inputs{padding:30px 30px 32px;}
.calc-results{padding:30px;background:var(--ink);color:#fff;display:flex;flex-direction:column;gap:12px;}
.summary-title{font-family:'Fraunces',serif;font-weight:600;font-size:28px;margin:0 0 4px;color:#fff;}
.summary-sub{font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-size:11px;color:#aeb6c8;border-top:1px solid rgba(255,255,255,.15);padding-top:14px;margin:8px 0 0;}
.field{margin-bottom:20px;}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
@media(max-width:520px){.field-row{grid-template-columns:1fr;}}
.lbl,label{display:block;font-size:13.5px;font-weight:600;color:#384055;margin-bottom:8px;}
label .val{float:right;font-family:'JetBrains Mono',monospace;color:var(--blue);font-weight:600;}
.input-money,.input-plain{display:flex;align-items:center;border:1px solid var(--bone);border-radius:10px;background:#fff;overflow:hidden;transition:border-color .15s,box-shadow .15s;}
.input-money:focus-within,.input-plain:focus-within{border-color:var(--blue);box-shadow:0 0 0 3px rgba(24,69,214,.12);}
.input-money span{padding:0 4px 0 14px;color:var(--mute);font-weight:600;}
.input-money input{flex:1;border:0;outline:0;padding:13px 14px 13px 4px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--ink);width:100%;}
.input-plain input,.input-plain select{flex:1;border:0;outline:0;padding:13px 6px 13px 14px;font-size:16px;font-family:'IBM Plex Sans',sans-serif;background:transparent;color:var(--ink);width:100%;}
input[type=range]{width:100%;accent-color:var(--blue);height:4px;margin:6px 0;}
.hint{font-size:12px;margin:6px 0 0;} .hint--mute{color:var(--mute);}
.result{display:flex;flex-direction:column;gap:3px;padding:12px 16px;border-radius:10px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.10);}
.result--primary{background:#fff;border-color:#fff;}
.result--primary .result-label{color:#384055;} .result--primary .result-value{color:var(--ink);} .result--primary .result-note{color:#6B7280;}
.result-label{font-size:12.5px;color:#aeb6c8;font-weight:600;}
.result-value{font-family:'Fraunces',serif;font-weight:600;font-size:24px;letter-spacing:-.01em;color:#fff;}
.result-note{font-size:10.5px;line-height:1.45;color:#8b93a6;}
.cta-primary{display:block;text-align:center;background:var(--blue);color:#fff;text-decoration:none;font-weight:600;padding:14px;border-radius:10px;margin-top:6px;transition:background .15s;}
.cta-primary:hover{background:#2a57e6;}
.micro{font-size:11px;color:#8b93a6;text-align:center;margin:0;}
.body-content h2{font-family:'Fraunces',serif;font-weight:500;font-size:28px;margin:40px 0 12px;}
.body-content p{color:#2b3140;}
.author{display:flex;align-items:center;gap:16px;margin:0 0 32px;}
.author img{width:64px;height:64px;border-radius:50%;object-fit:cover;}
.author h3{font-family:'Fraunces',serif;font-weight:500;font-size:18px;margin:0;}
.author a{color:var(--ink);text-decoration:none;} .author a:hover{color:var(--blue);}
.cta-card{background:var(--paper-tint);border:1px solid var(--bone);border-radius:16px;padding:32px;text-align:center;margin:24px auto;max-width:760px;}
.cta-card h4{font-family:'Fraunces',serif;font-weight:500;font-size:24px;margin:0 0 12px;}
.cta-card p{max-width:620px;margin:0 auto 18px;}
.cta-card ul{list-style:none;padding:0;margin:18px 0;color:#384055;font-size:15px;}
.cta-card a{display:inline-block;background:var(--ink);color:#fff;padding:13px 26px;border-radius:9px;text-decoration:none;font-weight:600;}
.cta-card a:hover{background:var(--blue);}
.related-placeholder{border:1px dashed var(--bone);border-radius:10px;padding:20px;color:var(--mute);font-family:'JetBrains Mono',monospace;font-size:13px;text-align:center;}
</style>
  <CalcLeadForm />
</Layout>
</content>
</invoke>
