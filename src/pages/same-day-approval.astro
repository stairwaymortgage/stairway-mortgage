---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Same-Day Approval — Stairway Mortgage" description="Pre-approved in as fast as 24 hours. 300+ lenders. No credit pull to start.">
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">Get Started</span>
        <h1 class="display-xl mt-6 mb-6">See your options in <em class="italic text-[var(--color-blue)]">about a minute</em>.</h1>
        <p class="lede max-w-xl mx-auto mb-8">Answer a few questions and our team matches you with the best programs from 300+ lenders.</p>
        <div class="card max-w-lg mx-auto p-8">
          <div class="mb-4"><label class="block text-[12px] font-semibold uppercase tracking-wider text-[var(--color-mute)] mb-2">First name</label><input type="text" placeholder="First" class="w-full p-3 border border-[var(--color-bone)] rounded-lg" /></div>
          <div class="mb-4"><label class="block text-[12px] font-semibold uppercase tracking-wider text-[var(--color-mute)] mb-2">Email</label><input type="email" placeholder="you@email.com" class="w-full p-3 border border-[var(--color-bone)] rounded-lg" /></div>
          <div class="mb-4"><label class="block text-[12px] font-semibold uppercase tracking-wider text-[var(--color-mute)] mb-2">Phone</label><input type="tel" placeholder="(555) 000-0000" class="w-full p-3 border border-[var(--color-bone)] rounded-lg" /></div>
          <button class="btn btn-blue w-full text-center" type="button">Get Pre-Approved</button>
          <p class="text-[11px] text-[var(--color-mute)] mt-3 text-center">No obligation. Not a commitment to lend. <!-- TODO: Wire to /api/lead --></p>
        </div>
        <p class="mono text-[11px] text-[var(--color-mute)] mt-6">NMLS #1072866</p>
        <div class="flex flex-wrap gap-3 justify-center mt-10">
          
        </div>
      </div>
    </div>
  </section>
</Layout>
