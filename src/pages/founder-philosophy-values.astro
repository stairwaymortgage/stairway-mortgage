---
import Layout from '../layouts/Layout.astro';
const breadcrumbSchema={"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://stairwaymortgage.com/"}, {"@type": "ListItem", "position": 2, "name": "Founder, Philosophy & Values"}]};
---

<Layout title="Meet Our Founder | Faith-Based Philosophy | Stairway" description="Meet our founder and discover the faith-based values that guide everything we do. Why we're different from traditional banks and mortgage companies." canonical="https://stairwaymortgage.com/founder-philosophy-values/">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Breadcrumb -->
  <nav class="container-page fp-breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a> <span>/</span> <span>Founder, Philosophy & Values</span>
  </nav>

  <!-- 1. HERO -->
  <header class="fp-hero">
    <div class="container-prose fp-hero__inner">
      <span class="eyebrow eyebrow-blue">Our Story</span>
      <h1 class="display-lg fp-hero__title">Our Commitment to Excellence</h1>
      <p class="lede fp-hero__lede">A personal mission. A clear philosophy. A lifelong partnership in wealth. Guided by Jim Blackburn, <span class="mono">NMLS #1072866</span>.</p>
    </div>
  </header>

  <!-- 2. JIM'S BIO -->
  <section class="fp-bio">
    <div class="container-page fp-bio__grid">
      <div class="fp-bio__images">
        <img src="/wp-content/uploads/2025/06/Jim-Olga-Blackburn-768x1060.png" alt="Jim and Olga Blackburn" width="768" height="1060" srcset="/wp-content/uploads/2025/06/Jim-Olga-Blackburn-768x1060.png 768w, /wp-content/uploads/2025/06/Jim-Olga-Blackburn-600x828.png 600w, /wp-content/uploads/2025/06/Jim-Olga-Blackburn-217x300.png 217w, /wp-content/uploads/2025/06/Jim-Olga-Blackburn-742x1024.png 742w, /wp-content/uploads/2025/06/Jim-Olga-Blackburn-1112x1536.png 1112w, /wp-content/uploads/2025/06/Jim-Olga-Blackburn-1483x2048.png 1483w, /wp-content/uploads/2025/06/Jim-Olga-Blackburn-514x710.png 514w, /wp-content/uploads/2025/06/Jim-Olga-Blackburn.png 1854w" sizes="(max-width: 768px) 100vw, 420px" loading="eager" class="fp-bio__portrait" />
        <img src="/wp-content/uploads/2025/06/Mortgage-Loan-Fort-Lauderdale-Florida-1024x803.jpg" alt="Stairway Mortgage Fort Lauderdale" width="1024" height="803" srcset="/wp-content/uploads/2025/06/Mortgage-Loan-Fort-Lauderdale-Florida-1024x803.jpg 1024w, /wp-content/uploads/2025/06/Mortgage-Loan-Fort-Lauderdale-Florida-600x471.jpg 600w, /wp-content/uploads/2025/06/Mortgage-Loan-Fort-Lauderdale-Florida-300x235.jpg 300w, /wp-content/uploads/2025/06/Mortgage-Loan-Fort-Lauderdale-Florida-768x603.jpg 768w, /wp-content/uploads/2025/06/Mortgage-Loan-Fort-Lauderdale-Florida-905x710.jpg 905w, /wp-content/uploads/2025/06/Mortgage-Loan-Fort-Lauderdale-Florida.jpg 1263w" sizes="(max-width: 768px) 100vw, 420px" loading="lazy" class="fp-bio__scene" />
      </div>
      <div class="fp-bio__text">
        <span class="eyebrow eyebrow-rust">Meet Our Founder</span>
        <h2 class="display-md">Jim Blackburn</h2>
        <p class="fp-bio__role mono">Founder of Stairway Mortgage</p>
        <p><a href="https://jamesjblackburn.com/jim-blackburn-fort-lauderdale/">Jim Blackburn residing in Fort Lauderdale</a>, is a mortgage strategist, real estate advisor, and financial educator with over two decades of experience helping individuals and families turn everyday real estate decisions into lasting wealth. Jim's approach isn't about transactions — it's about transformation. His mission is to guide people at every stage of their journey, using real estate as a tool to build legacy, purpose, and peace of mind — not just financially, but wholly: with clarity in their finances, confidence in their personal path, and alignment with their spiritual values.</p>
        <ul class="fp-bio__pillars">
          <li>Jim's approach isn't about transactions—it's about transformation.</li>
          <li>Jim focuses on strategy, not just sales</li>
          <li>His guidance turns equity into long-term gain</li>
          <li>He navigates shifting markets with calm and clarity</li>
          <li>Digital-first tools are used to empower, not overwhelm</li>
          <li>Jim customizes the journey—no one-size-fits-all approach</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- 3. B.E.S.T. OATH -->
  <section class="fp-best">
    <div class="container-page">
      <div class="fp-best__head">
        <span class="eyebrow eyebrow-blue">Our Culture</span>
        <h2 class="display-md">The B.E.S.T. Oath</h2>
        <p class="lede">"B.E.S.T." is the oath every Stairway Mortgage team member signs and carries in their email signature — a daily reminder of who they are and what they stand for. It reflects our culture and our non-negotiable commitment to our clients, our partners, and each other.</p>
      </div>
      <div class="fp-best__grid">
        <div class="fp-best__card">
          <span class="fp-best__letter">B</span>
          <h3>Build</h3>
          <p>We build relationships that honor your vision. Not transactions. Not files. Relationships — the kind where we're still talking five years after closing because we genuinely care about where you're going next.</p>
        </div>
        <div class="fp-best__card">
          <span class="fp-best__letter">E</span>
          <h3>Empower</h3>
          <p>We empower clients with knowledge at every stage of the journey. You will never leave a conversation with us confused about your options. Clear numbers. Honest answers. Full picture — every time.</p>
        </div>
        <div class="fp-best__card">
          <span class="fp-best__letter">S</span>
          <h3>Serve</h3>
          <p>We serve with compassion, integrity, and care. Serving means showing up before you ask, answering questions you didn't know to ask, and being there when the process gets hard. That's the standard.</p>
        </div>
        <div class="fp-best__card">
          <span class="fp-best__letter">T</span>
          <h3>Trust</h3>
          <p>We earn your trust — and we protect it. Trust is not assumed here. It's built one honest conversation at a time, and we commit to being worthy of it at every step.</p>
        </div>
      </div>
      <p class="fp-best__footer mono">Every employee signs this oath. Every email carries it. Every client interaction is measured against it.</p>
    </div>
  </section>

  <!-- 4. STAIRWAY VALUES -->
  <section class="fp-values">
    <div class="container-page">
      <span class="eyebrow eyebrow-rust">Our Foundation</span>
      <h2 class="display-md">STAIRWAY Value System</h2>
      <div class="fp-values__list">
        <div class="fp-values__row"><span class="fp-values__letter">S</span><div><strong>Spirituality (Faith):</strong> God at the center of everything we build</div></div>
        <div class="fp-values__row"><span class="fp-values__letter">T</span><div><strong>Trust (Relationships):</strong> Integrity and respect in all we do</div></div>
        <div class="fp-values__row"><span class="fp-values__letter">A</span><div><strong>Achievement (Career/Business):</strong> A culture of constant progress</div></div>
        <div class="fp-values__row"><span class="fp-values__letter">I</span><div><strong>Impact (Contribution):</strong> Helping others grow with us</div></div>
        <div class="fp-values__row"><span class="fp-values__letter">R</span><div><strong>Resilience (Meaning):</strong> Emotional strength and purpose through challenges</div></div>
        <div class="fp-values__row"><span class="fp-values__letter">W</span><div><strong>Wellness (Vitality):</strong> Balance, health, and alignment</div></div>
        <div class="fp-values__row"><span class="fp-values__letter">A</span><div><strong>Advancement (Growth):</strong> Continuous learning and improvement</div></div>
        <div class="fp-values__row"><span class="fp-values__letter">Y</span><div><strong>Yield (Finances):</strong> Building wealth with responsibility and wisdom</div></div>
      </div>
      <figure class="fp-values__portrait">
        <img src="/wp-content/uploads/2025/06/JIM-BLACKBURN-1112x1536.png" alt="Jim Blackburn" width="1112" height="1536" srcset="/wp-content/uploads/2025/06/JIM-BLACKBURN-1112x1536.png 1112w, /wp-content/uploads/2025/06/JIM-BLACKBURN-600x828.png 600w, /wp-content/uploads/2025/06/JIM-BLACKBURN-217x300.png 217w, /wp-content/uploads/2025/06/JIM-BLACKBURN-742x1024.png 742w, /wp-content/uploads/2025/06/JIM-BLACKBURN-768x1060.png 768w, /wp-content/uploads/2025/06/JIM-BLACKBURN-1483x2048.png 1483w, /wp-content/uploads/2025/06/JIM-BLACKBURN-514x710.png 514w, /wp-content/uploads/2025/06/JIM-BLACKBURN.png 1854w" sizes="(max-width: 480px) 100vw, 480px" loading="lazy" />
      </figure>
    </div>
  </section>

  <!-- 5. MISSION + LEVERAGE -->
  <section class="fp-mission">
    <div class="container-prose">
      <h2 class="display-md">Jim's Mission: Guiding Real People to Real Wealth</h2>
      <p>Whether you're a first-time buyer or a seasoned investor, Jim sees your home as more than a purchase—he sees it as a pathway. A pathway to:</p>
      <ul>
        <li>More freedom</li>
        <li>More knowledge</li>
        <li>More options</li>
        <li>And more purpose-driven impact</li>
      </ul>
      <p>He's not here for one loan—he's here for your legacy.</p>

      <h2 class="display-md">More Than Business—A Life of Growth and Service</h2>
      <p><strong>Jim is a husband, father, community mentor, and devoted learner.</strong> His values flow directly into the company's mission to serve others through wisdom and love.</p>
      <p>He's passionate about:</p>
      <ul>
        <li>Faith and Spiritual Growth</li>
        <li>Personal Development &amp; Leadership</li>
        <li>Fitness and Discipline</li>
        <li>Family Life and Legacy</li>
        <li>Giving Back through Mentorship and Education</li>
      </ul>

      <h2 class="display-md">Leverage Wisely. Grow Wealthy.</h2>
      <p>We believe wealth comes not just from money—but from how you leverage your time, relationships, and purpose. At Stairway Mortgage, this principle guides every plan, every loan, every relationship. We teach our clients how to leverage:</p>
      <ul>
        <li>Capital: <a href="https://stairwaymortgage.com/purchase-inquiry/">Get preapproved.</a></li>
        <li>Connections: <a href="https://stairwaymortgage.com/get-a-local-introduction/">Get a local intro.</a></li>
        <li>Insights: <a href="https://stairwaymortgage.com/guides/">Download a guide.</a></li>
        <li>Timing: <a href="https://stairwaymortgage.com/current-rates/">Subscribe to rate alerts.</a></li>
        <li>Strategy: <a href="https://stairwaymortgage.com/loan-calculator/">Calculate a loan.</a></li>
        <li>Faith: Calculate your <a href="https://stairwaymortgage.com/loan-calculator/spiritual-influence-calculator/">spiritual impact</a> and <a href="https://stairwaymortgage.com/loan-calculator/legacy-planning-calculator/">legacy plan</a>.</li>
      </ul>
      <img src="/wp-content/uploads/2025/06/Mortgage-Loan-Fort-Lauderdale-Florida-1024x803.jpg" alt="" width="1024" height="803" srcset="/wp-content/uploads/2025/06/Mortgage-Loan-Fort-Lauderdale-Florida-1024x803.jpg 1024w, /wp-content/uploads/2025/06/Mortgage-Loan-Fort-Lauderdale-Florida-600x471.jpg 600w, /wp-content/uploads/2025/06/Mortgage-Loan-Fort-Lauderdale-Florida-300x235.jpg 300w, /wp-content/uploads/2025/06/Mortgage-Loan-Fort-Lauderdale-Florida-768x603.jpg 768w, /wp-content/uploads/2025/06/Mortgage-Loan-Fort-Lauderdale-Florida-905x710.jpg 905w, /wp-content/uploads/2025/06/Mortgage-Loan-Fort-Lauderdale-Florida.jpg 1263w" sizes="(max-width: 1024px) 100vw, 1024px" loading="lazy" class="fp-mission__img" />
    </div>
  </section>

  <!-- 6. MANIFESTO / BLOCKQUOTE -->
  <section class="fp-manifesto">
    <div class="container-prose fp-manifesto__inner">
      <blockquote class="fp-manifesto__quote">
        <p>"Real wealth isn't built by working harder—it's built by working smarter, with the right strategy and the right guide."</p>
        <cite>— Jim Blackburn</cite>
      </blockquote>

      <img src="/wp-content/uploads/2025/03/Untitled-design-1-1.png" alt="" loading="lazy" class="fp-manifesto__emblem" width="1385" height="2048"

      <div class="fp-manifesto__poem">
        <p>You see what is when your eyes are open.</p>
        <p>You see what's possible when your eyes are closed.</p>
        <p>But when your heart connects</p>
        <p>to what you see with your eyes closed—</p>
        <p>you become brave enough</p>
        <p>to take one more step when your eyes open.</p>
        <p>And that's all it takes:</p>
        <p>One more step.</p>
        <p>One moment of belief.</p>
        <p>One act of courage.</p>
        <p>At Stairway, we believe you can climb as high as your vision dares to reach.</p>
        <p>There are no ceilings here.</p>
        <p>No rules that say you can't.</p>
        <p>Just the next step—and the one after that.</p>
        <p>Whether you're a client building your future,</p>
        <p>or a partner building your legacy—</p>
        <p>we're here to remind you:</p>
        <p>The staircase to your dreams is already built.</p>
        <p>You just need to take the first step.</p>
        <p>Then the next.</p>
        <p>Then the next.</p>
        <p>And we'll walk it with you.</p>
        <p>No limits. Only momentum.</p>
      </div>
    </div>
  </section>

  <!-- 5b. TESTIMONIALS -->
  <section class="fp-testimonials">
    <div class="container-page">
      <div class="fp-testimonials__head">
        <span class="eyebrow eyebrow-rust">100% Client Satisfaction</span>
        <h2 class="display-md">Real Comments, Real People</h2>
        <p class="lede">Hear from some past clients of our founder.</p>
      </div>
      <div class="fp-testimonials__grid">
        <!-- Alexis Kulick -->
        <div class="fp-testimonial card">
          <div class="fp-testimonial__top">
            <img width="70" height="70" src="/wp-content/uploads/2025/03/Alexis-Kulick-e1742922763349.jpg" alt="Alexis Kulick E1742922763349 | Stairway Mortgage" srcset="/wp-content/uploads/2025/03/Alexis-Kulick-e1742922763349.jpg 833w, /wp-content/uploads/2025/03/Alexis-Kulick-e1742922763349-300x300.jpg 300w, /wp-content/uploads/2025/03/Alexis-Kulick-e1742922763349-100x100.jpg 100w, /wp-content/uploads/2025/03/Alexis-Kulick-e1742922763349-600x600.jpg 600w, /wp-content/uploads/2025/03/Alexis-Kulick-e1742922763349-150x150.jpg 150w, /wp-content/uploads/2025/03/Alexis-Kulick-e1742922763349-768x770.jpg 768w, /wp-content/uploads/2025/03/Alexis-Kulick-e1742922763349-708x710.jpg 708w" sizes="70px" class="fp-testimonial__avatar" />
            <div>
              <strong class="fp-testimonial__name">Alexis Kulick</strong>
              <span class="fp-testimonial__role mono">Director of Digital Campaign at UBS - CALIFORNIA</span>
              <span class="fp-testimonial__via mono">via Facebook</span>
            </div>
          </div>
          <div class="fp-testimonial__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="fp-testimonial__headline"><b>Easy and quick refinance with great rates and expert advice.</b></p>
          <p class="fp-testimonial__body">I recently refinanced my existing mortgage with Jim and his team, and I was so pleased with how easy and quick the whole process was. Jim and his team were very responsive to my questions, and I feel confident that I got the best rate and shaved 9 years off my mortgage. He is very knowledgeable and helped me determine the best option for myself and my family. Definitely recommend him.</p>
        </div>
        <!-- Julian Einfrank -->
        <div class="fp-testimonial card">
          <div class="fp-testimonial__top">
            <img width="70" height="70" src="/wp-content/uploads/2025/03/Julian-Einfrank-e1742922797847.jpeg" alt="Julian Einfrank E1742922797847 | Stairway Mortgage" class="fp-testimonial__avatar" />
            <div>
              <strong class="fp-testimonial__name">Julian Einfrank</strong>
              <span class="fp-testimonial__role mono">Sr. Wealth Advisor Clifton Larson Allen - ILLINOIS</span>
              <span class="fp-testimonial__via mono">via Facebook</span>
            </div>
          </div>
          <div class="fp-testimonial__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="fp-testimonial__headline"><b>Complex loan scenario handled with expertise and care.</b></p>
          <p class="fp-testimonial__body">The process went smoothly. Jim Blackburn is a lending saint. He knows the market well and cares about his clients tremendously. The team made it really easy to do business, uploading documents and getting forms signed. Our situation is a bit complex. Rather than turn us away for some added work, they dug in to get it done right. They like the complexity, whereas other lenders don't want to roll up their sleeves. Highly recommend Jim Blackburn for new loans and refinances!</p>
        </div>
        <!-- Elizabeth Torres -->
        <div class="fp-testimonial card">
          <div class="fp-testimonial__top">
            <img width="70" height="70" src="/wp-content/uploads/2025/03/Elizabeth-Torres.jpeg" alt="Elizabeth Torres | Stairway Mortgage" srcset="/wp-content/uploads/2025/03/Elizabeth-Torres.jpeg 200w, /wp-content/uploads/2025/03/Elizabeth-Torres-100x100.jpeg 100w, /wp-content/uploads/2025/03/Elizabeth-Torres-150x150.jpeg 150w" sizes="70px" class="fp-testimonial__avatar" />
            <div>
              <strong class="fp-testimonial__name">Elizabeth Torres</strong>
              <span class="fp-testimonial__role mono">Senior Branch Mgr. at JP Morgan Chase - ILLINOIS</span>
              <span class="fp-testimonial__via mono">via Facebook</span>
            </div>
          </div>
          <div class="fp-testimonial__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="fp-testimonial__headline"><b>Closed in time for Thanksgiving! Jim and his team were amazing, and we got a much better deal than previous lender.</b></p>
          <p class="fp-testimonial__body">We closed our loan within 19 days. Just in time for Thanksgiving!! Jim and his team are amazing! We initially had gone with a different loan office and the interest rate and down payment was ridiculous. The owner of the company where my husband works referred us to Jim and we are very grateful for that. We had such an amazing experience with Jim and his team! Since our transaction, we've been referring Jim to anyone we know that are thinking of purchasing a house.</p>
        </div>
        <!-- David Livermore -->
        <div class="fp-testimonial card">
          <div class="fp-testimonial__top">
            <img width="70" height="70" src="/wp-content/uploads/2025/03/Livermore-David.png" alt="Livermore David | Stairway Mortgage" class="fp-testimonial__avatar" />
            <div>
              <strong class="fp-testimonial__name">David Livermore</strong>
              <span class="fp-testimonial__role mono">Founder Cultural Intelligence - CALIFORNIA</span>
              <span class="fp-testimonial__via mono">via Google</span>
            </div>
          </div>
          <div class="fp-testimonial__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="fp-testimonial__headline"><b>Secured financing despite market challenges and self-employment.</b></p>
          <p class="fp-testimonial__body">Run, don't walk to work with Jim and his team. Jim helped us get financing when it seemed like an impossible feat. It was hard enough to be managing a home purchase 2000 miles away, but add to that an extremely competitive market and being self-employed, and it seemed impossible until Jim's team got involved. Jim was not only responsive; he consistently went above and beyond by making clear recommendations, working his magic, and ensuring that financing wasn't a barrier for buying our dream house in one of the most competitive markets in the country.</p>
        </div>
        <!-- Christina Curva Carrasco -->
        <div class="fp-testimonial card">
          <div class="fp-testimonial__top">
            <img width="70" height="70" src="/wp-content/uploads/2025/03/Christina-Curva-Carrasco-e1742922902463.jpg" alt="Christina Curva Carrasco E1742922902463 | Stairway Mortgage" srcset="/wp-content/uploads/2025/03/Christina-Curva-Carrasco-e1742922902463.jpg 144w, /wp-content/uploads/2025/03/Christina-Curva-Carrasco-e1742922902463-100x100.jpg 100w" sizes="70px" class="fp-testimonial__avatar" />
            <div>
              <strong class="fp-testimonial__name">Christina Curva Carrasco</strong>
              <span class="fp-testimonial__role mono">Owner at Curated Interiors - WASHINGTON DC</span>
              <span class="fp-testimonial__via mono">via Facebook</span>
            </div>
          </div>
          <div class="fp-testimonial__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="fp-testimonial__headline"><b>Smooth, fast, and hassle-free mortgage and refinance process.</b></p>
          <p class="fp-testimonial__body">Jim and his team are great to work with! We have used Jim twice with our home mortgage. Both times, the process was smooth and uneventful (which is what I wanted). He has kept in touch with us and contacted us when he felt it was the right time for us to refinance! I was amazed at our refinancing process – it took them about a little over two weeks to process all our information and close! I love the new online process of submitting all the information they require – it made it super easy for me to organize and gather all the documents.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. CTA -->
  <section class="section-tight fp-cta">
    <div class="container-prose">
      <div class="card fp-cta__card">
        <h2 class="display-md">Begin Your Journey With a Guide Who Cares About Your Future</h2>
        <p class="lede">At Stairway Mortgage, we bring strategy, heart, and spiritual clarity to every decision.</p>
        <a href="/schedule-call/" class="btn btn-blue btn-arrow">Schedule A Call</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Breadcrumb */
  .fp-breadcrumb { font-family:var(--stw-mono, 'JetBrains Mono'), monospace; font-size:12px; color:var(--color-mute); padding-top:2rem; padding-bottom:1.25rem; }
  .fp-breadcrumb a { color:var(--color-mute); text-decoration:none; }
  .fp-breadcrumb a:hover { color:var(--color-blue); }
  .fp-breadcrumb span { margin-inline:0.4rem; opacity:0.5; }

  /* 1. Hero */
  .fp-hero { padding:clamp(3rem,8vw,6rem) 0 clamp(2rem,5vw,4rem); background:linear-gradient(180deg, var(--color-paper-tint), var(--color-paper)); border-bottom:1px solid var(--color-bone); }
  .fp-hero__title { margin:1rem 0 1.5rem; }
  .fp-hero__lede { max-width:58ch; }

  /* 2. Bio */
  .fp-bio { padding:clamp(3rem,6vw,5rem) 0; }
  .fp-bio__grid { display:grid; grid-template-columns:minmax(0,0.8fr) minmax(0,1fr); gap:clamp(2rem,5vw,4rem); align-items:start; }
  @media(max-width:820px){ .fp-bio__grid { grid-template-columns:1fr; } }
  .fp-bio__images { display:flex; flex-direction:column; gap:1.25rem; }
  .fp-bio__portrait, .fp-bio__scene { width:100%; height:auto; border-radius:14px; border:1px solid var(--color-bone); object-fit:cover; }
  .fp-bio__portrait { max-height:520px; }
  .fp-bio__scene { max-height:300px; }
  .fp-bio__role { font-size:13px; letter-spacing:0.06em; text-transform:uppercase; color:var(--color-mute); margin-bottom:1.5rem; }
  .fp-bio__text h2 { margin:0.5rem 0 0.25rem; }
  .fp-bio__text p { font-size:16px; line-height:1.75; color:var(--color-ink-light); margin-bottom:1.25rem; }
  .fp-bio__text a { color:var(--color-blue); text-decoration:underline; text-underline-offset:2px; }
  .fp-bio__pillars { list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.65rem; }
  .fp-bio__pillars li { display:flex; align-items:flex-start; gap:0.6rem; font-size:15px; line-height:1.55; color:var(--color-ink-light); }
  .fp-bio__pillars li::before { content:'\2713'; color:var(--color-green); font-weight:700; flex:0 0 auto; margin-top:1px; }

