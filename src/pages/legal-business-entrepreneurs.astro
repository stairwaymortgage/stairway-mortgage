---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Self-Employed & Business Owners — Stairway Mortgage" description="Bank-statement and asset-based programs for self-employed borrowers.">
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">Your Profession · Self-Employed & Owners</span>
        <h1 class="display-xl mt-6 mb-6">Loans built for <em class="italic text-[var(--color-blue)]">business owners</em>.</h1>
        <p class="lede max-w-xl mx-auto mb-6">Bank-statement loans, asset-based programs, and P&L-only qualification — because your tax return does not tell the whole story.</p>
        <p class="mono text-[11px] text-[var(--color-mute)] mt-6">NMLS #1072866</p>
        <div class="flex flex-wrap gap-3 justify-center mt-10">
          <a href="/same-day-approval/" class="btn btn-blue btn-arrow text-base px-6 py-3.5">See My Options</a>
          <a href="/contact-us/" class="btn btn-ghost text-base px-6 py-3.5">Talk to Our Team</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
