      display: flex; gap: var(--s-6); list-style: none;
      font-size: var(--text-sm); font-weight: 500;
    }.bizbroker-scope .nav-links a{ color: var(--ink-2); transition: color 0.15s; }.bizbroker-scope .nav-links a:hover{ color: var(--blue); }.bizbroker-scope .nav-cta{
      display: flex; gap: var(--s-3);
    }
    @media (max-width: 900px) {.bizbroker-scope .nav-links{ display: none; }.bizbroker-scope .nav-cta .btn-secondary{ display: none; }
    }.bizbroker-scope .btn{
      display: inline-flex;
      align-items: center;
      gap: var(--s-2);
      padding: var(--s-3) var(--s-5);
      font-family: var(--sans);
      font-size: var(--text-sm);
      font-weight: 500;
      letter-spacing: 0.005em;
      border-radius: 100px;
      transition: all 0.18s ease;
      white-space: nowrap;
    }.bizbroker-scope .btn-primary{
      background: var(--ink);
      color: var(--paper);
      border: 1px solid var(--ink);
    }.bizbroker-scope .btn-primary:hover{
      background: var(--blue);
      border-color: var(--blue);
      transform: translateY(-1px);
    }.bizbroker-scope .btn-secondary{
      background: transparent;
      color: var(--ink);
      border: 1px solid var(--border-strong);
    }.bizbroker-scope .btn-secondary:hover{
      border-color: var(--ink);
    }.bizbroker-scope .btn-light{
      background: var(--white);
      color: var(--ink);
      border: 1px solid var(--border);
    }.bizbroker-scope .btn-light:hover{ background: var(--paper-2); }.bizbroker-scope .btn-large{
      padding: var(--s-4) var(--s-6);
      font-size: var(--text-base);
    }.bizbroker-scope .btn-arrow{
      display: inline-flex; align-items: center; gap: var(--s-2);
      color: var(--blue); font-weight: 500;
      transition: gap 0.18s;
    }.bizbroker-scope .btn-arrow:hover{ gap: var(--s-3); }.bizbroker-scope .btn-arrow::after{ content: '→'; font-family: var(--sans); }.bizbroker-scope .hero{
      padding: 64px 0 48px;
      border-bottom: 1px solid var(--border);
    }.bizbroker-scope .breadcrumb{
      display: flex; gap: var(--s-2);
      font-family: var(--mono);
      font-size: var(--text-xs);
      letter-spacing: 0.08em;
      color: var(--ink-lighter);
      text-transform: uppercase;
      margin-bottom: var(--s-7);
    }.bizbroker-scope .breadcrumb a{ color: var(--ink-lighter); }.bizbroker-scope .breadcrumb a:hover{ color: var(--blue); }.bizbroker-scope .breadcrumb span:last-child{ color: var(--ink); }.bizbroker-scope .hero-eyebrow{ margin-bottom: var(--s-5); }.bizbroker-scope .hero h1{ margin-bottom: var(--s-6); max-width: 18ch; }.bizbroker-scope .hero-subtitle{
      max-width: 56ch;
      margin-bottom: var(--s-7);
    }.bizbroker-scope .hero-actions{
      display: flex; gap: var(--s-3);
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: var(--s-5);
    }.bizbroker-scope .hero-trust{
      font-family: var(--mono);
      font-size: var(--text-xs);
      color: var(--ink-lighter);
      letter-spacing: 0.02em;
      display: flex; align-items: center; gap: var(--s-3);
    }.bizbroker-scope .trust-dot{ width: 6px; height: 6px; border-radius: 50%; background: var(--blue); }.bizbroker-scope .stats{
      background: var(--ink);
      color: var(--paper);
      padding: var(--s-7) 0;
    }.bizbroker-scope .stats-grid{
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--s-5);
    }.bizbroker-scope .stat{
      padding: 0 var(--s-4);
      border-left: 1px solid var(--ink-3);
    }.bizbroker-scope .stat:first-child{ border-left: 0; padding-left: 0; }.bizbroker-scope .stat-num{
      font-family: var(--serif);
      font-size: clamp(1.75rem, 3.2vw, 2.6rem); overflow-wrap: anywhere;
      font-weight: 350;
      line-height: 1.1;
      letter-spacing: -0.03em;
      margin-bottom: var(--s-3);
      font-variation-settings: "opsz" 144;
    }.bizbroker-scope .stat-label{
      font-family: var(--mono);
      font-size: var(--text-xs);
      letter-spacing: 0.05em;
      color: rgba(255,255,255,0.65);
      text-transform: uppercase;
      line-height: 1.4;
    }
    @media (max-width: 720px) {.bizbroker-scope .stats-grid{ grid-template-columns: repeat(2, 1fr); gap: var(--s-7) var(--s-4); }.bizbroker-scope .stat:nth-child(3){ border-left: 0; padding-left: 0; }
    }.bizbroker-scope .section{
      padding: var(--s-10) 0;
    }.bizbroker-scope .section-tinted{ background: var(--paper-2); }.bizbroker-scope .section-dark{ background: var(--ink); color: var(--paper); }.bizbroker-scope .section-header{
      max-width: 720px;
      margin-bottom: var(--s-8);
    }.bizbroker-scope .section-header .eyebrow{ margin-bottom: var(--s-4); }.bizbroker-scope .section-header h2{ margin-bottom: var(--s-5); }.bizbroker-scope .section-header p{ font-size: var(--text-lg); color: var(--ink-2); }.bizbroker-scope .lede-section{ padding: 64px 0; }.bizbroker-scope .lede-section .lede + .lede{ margin-top: var(--s-5); }.bizbroker-scope .data-table{
      width: 100%;
      border-collapse: collapse;
      font-size: var(--text-sm);
      font-feature-settings: 'tnum' 1;
    }.bizbroker-scope .data-table thead th{
      font-family: var(--mono);
      font-size: var(--text-xs);
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--ink-lighter);
      font-weight: 500;
      text-align: left;
      padding: var(--s-3) var(--s-4);
      border-bottom: 1px solid var(--border-strong);
    }.bizbroker-scope .data-table tbody td{
      padding: var(--s-5) var(--s-4);
      border-bottom: 1px solid var(--border);
      vertical-align: top;
    }.bizbroker-scope .data-table tbody tr:hover{ background: rgba(24, 69, 214, 0.025); }.bizbroker-scope .data-table tbody td:first-child{
      font-weight: 500;
      color: var(--ink);
      width: 28%;
    }.bizbroker-scope .data-table tbody td:nth-child(2){
      font-family: var(--mono);
      font-size: var(--text-sm);
      color: var(--blue-deep);
      white-space: nowrap;
      width: 28%;
    }.bizbroker-scope .data-table tbody td:last-child{
      color: var(--ink-2);
      line-height: 1.5;
    }
    @media (max-width: 720px) {.bizbroker-scope .data-table thead{ display: none; }.bizbroker-scope .data-table tbody tr{
        display: block;
        padding: var(--s-5) 0;
        border-bottom: 1px solid var(--border);
      }.bizbroker-scope .data-table tbody td{
        display: block;
        padding: 0 0 var(--s-2);
        border: 0;
        width: 100% !important;
      }.bizbroker-scope .data-table tbody td:first-child{ font-size: var(--text-md); }
    }.bizbroker-scope .methods-intro{ max-width: 720px; margin-bottom: var(--s-8); }.bizbroker-scope .methods-grid{
      display: grid;
      gap: var(--s-5);
    }.bizbroker-scope .method{
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: var(--s-7);
      position: relative;
      transition: border-color 0.18s, transform 0.18s;
    }.bizbroker-scope .method:hover{
      border-color: var(--border-strong);
    }.bizbroker-scope .method-header{
      display: grid;
      grid-template-columns: auto 1fr;
      gap: var(--s-5);
      align-items: start;
      margin-bottom: var(--s-5);
    }.bizbroker-scope .method-num{
      font-family: var(--mono);
      font-size: var(--text-2xl);
      font-weight: 500;
      color: var(--blue);
      line-height: 1;
      padding-top: var(--s-2);
      letter-spacing: -0.02em;
    }.bizbroker-scope .method-title h3{
      margin-bottom: var(--s-3);
      font-size: var(--text-2xl);
      line-height: 1.15;
    }.bizbroker-scope .method-tag{
      display: inline-block;
      font-family: var(--mono);
      font-size: var(--text-xs);
      letter-spacing: 0.03em;
      padding: var(--s-1) var(--s-3);
      background: var(--blue-soft);
      color: var(--blue-deep);
      border-radius: 100px;
      font-weight: 500;
      margin-bottom: var(--s-3);
    }.bizbroker-scope .method-body{
      padding-left: calc(var(--text-2xl) + var(--s-5));
    }.bizbroker-scope .method-body > p{ margin-bottom: var(--s-5); color: var(--ink-2); }.bizbroker-scope .worked-example{
      background: var(--paper-2);
      border-left: 3px solid var(--ink);
      padding: var(--s-5) var(--s-6);
      font-family: var(--mono);
      font-size: var(--text-sm);
      line-height: 1.7;
      border-radius: 0 4px 4px 0;
    }.bizbroker-scope .worked-example.featured{
      background: var(--ink);
      color: var(--paper);
      border-left-color: var(--blue);
    }.bizbroker-scope .worked-example.featured .we-label{ color: rgba(255,255,255,0.6); }.bizbroker-scope .worked-example.featured .we-result{ color: var(--paper); border-color: rgba(255,255,255,0.2); }.bizbroker-scope .worked-example.featured .we-num{ color: var(--paper); }.bizbroker-scope .we-title{
      font-family: var(--sans);
      font-size: var(--text-xs);
      letter-spacing: 0.1em;
      text-transform: uppercase;
