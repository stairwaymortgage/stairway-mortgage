    }.bizbroker-scope .we-result .we-label{ color: var(--ink); }
    @media (max-width: 720px) {.bizbroker-scope .method{ padding: var(--s-5); }.bizbroker-scope .method-body{ padding-left: 0; }.bizbroker-scope .method-num{ font-size: var(--text-xl); }
    }.bizbroker-scope .callout{
      background: var(--blue-tint);
      border: 1px solid rgba(24, 69, 214, 0.12);
      border-radius: 6px;
      padding: var(--s-6) var(--s-7);
      max-width: 760px;
    }.bizbroker-scope .callout-eyebrow{
      font-family: var(--mono);
      font-size: var(--text-xs);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--blue);
      font-weight: 500;
      margin-bottom: var(--s-3);
    }.bizbroker-scope .callout p{
      font-family: var(--serif);
      font-size: var(--text-lg);
      line-height: 1.5;
      color: var(--ink);
      font-weight: 350;
      font-variation-settings: "opsz" 30;
    }.bizbroker-scope .testim-warning{
      background: #FFF1F1;
      border: 1px solid rgba(139, 44, 44, 0.3);
