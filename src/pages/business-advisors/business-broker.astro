      grid-column: 1 / -1;
    }.bizbroker-scope .worked-example.featured .we-divider{ border-top-color: rgba(255,255,255,0.2); }.bizbroker-scope .we-result{
      grid-template-columns: 1fr auto;
      padding-top: var(--s-3);
      border-top: 1px solid var(--border-strong);
      margin-top: var(--s-2);
