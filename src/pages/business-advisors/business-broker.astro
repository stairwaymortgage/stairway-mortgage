      margin-bottom: var(--s-4);
      color: var(--ink);
    }.bizbroker-scope .worked-example.featured .we-title{ color: var(--blue-soft); }.bizbroker-scope .we-line{
      display: grid;
      grid-template-columns: 1fr auto;
      gap: var(--s-4);
      padding: var(--s-2) 0;
    }.bizbroker-scope .we-label{ color: var(--ink-light); }.bizbroker-scope .we-num{ color: var(--ink); font-weight: 500; }.bizbroker-scope .we-divider{
      border-top: 1px dashed var(--border-strong);
