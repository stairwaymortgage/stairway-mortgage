      max-width: 1340px;
      margin: 0 auto;
    }.bizbroker-scope .logo{
      display: flex;
      align-items: center;
      gap: var(--s-3);
      font-family: var(--serif);
      font-size: var(--text-md);
      font-weight: 500;
      color: var(--ink);
      letter-spacing: -0.01em;
      font-variation-settings: "opsz" 30;
    }.bizbroker-scope .logo-mark{
