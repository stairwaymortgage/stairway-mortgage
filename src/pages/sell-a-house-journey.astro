---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Sell a Home — Stairway Mortgage" description="Bridge loans and seller strategies to maximize your next move.">
  <section class="section">
    <div class="container-page text-center max-w-2xl mx-auto">
      <span class="eyebrow eyebrow-blue mb-5">How We Serve</span>
      <h1 class="display-lg mt-5 mb-6">Sell a Home</h1>
      <p class="lede mb-10">This page is being built. Talk to Jim to get started today.</p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/same-day-approval/" class="btn btn-blue btn-arrow">See My Options</a>
        <a href="/contact-us/" class="btn btn-ghost">Talk to Jim</a>
      </div>
    </div>
  </section>
</Layout>
