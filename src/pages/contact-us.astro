---
import Layout from '../layouts/Layout.astro';
import { GHL_WEBHOOK_URL } from '../lib/ghl';
---
<Layout title="Contact Us — Stairway Mortgage" description="Talk to our team. Schedule a call or reach us at (954) 993-1625. Available 7 days a week.">

  <section class="section relative overflow-hidden cu-hero">
    <div class="container-page">
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div class="reveal">
          <span class="eyebrow eyebrow-blue mb-6">Get in Touch</span>
          <h1 class="display-lg mt-5 mb-5">Talk to <em class="not-italic text-[var(--color-blue)]">our team</em>.</h1>
          <p class="lede max-w-xl mb-8">Schedule a call, ask a question, or start your pre-approval. Available 7 days a week, including evenings.</p>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-[var(--color-blue-tint)] flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-blue)" stroke-width="1.6"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.36 1.9.69 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.33 1.85.56 2.81.69A2 2 0 0122 16.92z" stroke-linejoin="round"/></svg>
              </div>
              <div>
                <p class="font-medium text-base mb-0.5">Call us directly</p>
                <a href="tel:+19549931625" class="font-display text-xl text-[var(--color-blue)]">(954) 993-1625</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-[var(--color-blue-tint)] flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-blue)" stroke-width="1.6"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 9h18M8 3v4M16 3v4"/></svg>
              </div>
              <div>
                <p class="font-medium text-base mb-0.5">Response time</p>
                <p class="text-[14px] text-[var(--color-mute)]">Most inquiries answered within 24 hours</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-[var(--color-blue-tint)] flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-blue)" stroke-width="1.6"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <div>
                <p class="font-medium text-base mb-0.5">Hours</p>
                <p class="text-[14px] text-[var(--color-mute)]">7 days a week, including evenings</p>
              </div>
            </div>
          </div>
          <p class="mono text-[11px] text-[var(--color-mute)] mt-8">NMLS #1072866 · A division of NEXA Mortgage · NEXA licensed in 48 states</p>
        </div>

        <div class="reveal" style="transition-delay:100ms;">
          <div class="card p-8 lg:p-10" id="cu-wrap">
            <h2 class="font-display text-xl mb-1">Send us a message</h2>
            <p class="text-[14px] text-[var(--color-mute)] mb-6">We will get back to you within 24 hours.</p>
            <div class="space-y-4" id="cu-form" data-ghl-endpoint={GHL_WEBHOOK_URL}>
              <div class="grid grid-cols-2 gap-3">
                <div><label class="block text-[12px] font-semibold uppercase tracking-wider text-[var(--color-mute)] mb-2">First name</label><input type="text" id="cu-fname" placeholder="First" autocomplete="given-name" class="w-full p-3 border border-[var(--color-bone)] rounded-lg text-base" /></div>
                <div><label class="block text-[12px] font-semibold uppercase tracking-wider text-[var(--color-mute)] mb-2">Last name</label><input type="text" id="cu-lname" placeholder="Last" autocomplete="family-name" class="w-full p-3 border border-[var(--color-bone)] rounded-lg text-base" /></div>
              </div>
              <div><label class="block text-[12px] font-semibold uppercase tracking-wider text-[var(--color-mute)] mb-2">Email</label><input type="email" id="cu-email" placeholder="you@email.com" autocomplete="email" class="w-full p-3 border border-[var(--color-bone)] rounded-lg text-base" /></div>
              <div><label class="block text-[12px] font-semibold uppercase tracking-wider text-[var(--color-mute)] mb-2">Phone</label><input type="tel" id="cu-phone" placeholder="(555) 000-0000" autocomplete="tel" class="w-full p-3 border border-[var(--color-bone)] rounded-lg text-base" /></div>
              <div><label class="block text-[12px] font-semibold uppercase tracking-wider text-[var(--color-mute)] mb-2">How can we help?</label><textarea id="cu-message" placeholder="Tell us about your situation..." class="w-full p-3 border border-[var(--color-bone)] rounded-lg text-base h-24"></textarea></div>
              <input type="text" name="_gotcha" id="cu-gotcha" style="position:absolute;left:-9999px;opacity:0;" tabindex="-1" autocomplete="off" aria-hidden="true" />
              <p class="text-[13px] text-red-600 hidden" id="cu-error"></p>
              <button class="btn btn-blue w-full text-center text-base py-3.5" type="button" id="cu-submit">Send Message</button>
              <p class="text-[11px] text-[var(--color-mute)] text-center">No obligation. Not a commitment to lend.</p>
            </div>
            <div class="text-center py-10" id="cu-success" style="display:none;">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--color-green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-4"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <p class="font-display text-xl mb-2">Message sent.</p>
              <p class="text-[14px] text-[var(--color-mute)]">Our team will respond within 24 hours.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .cu-hero{position:relative;}.cu-hero::before{content:'';position:absolute;top:0;left:0;right:0;height:200px;background:linear-gradient(180deg,var(--color-blue-tint) 0%,transparent 100%);opacity:0.3;pointer-events:none;z-index:0;}
</style>

<script is:inline>
(function(){
  var wrap=document.getElementById('cu-form');
  if(!wrap)return;
  var ENDPOINT=wrap.getAttribute('data-ghl-endpoint')||'';
  var btn=document.getElementById('cu-submit');
  var errEl=document.getElementById('cu-error');
  var sending=false;

  function showErr(m){errEl.textContent=m;errEl.classList.remove('hidden');}

  btn.addEventListener('click',function(){
    if(sending)return;
    var gotcha=document.getElementById('cu-gotcha');
    if(gotcha&&gotcha.value.trim()!==''){document.getElementById('cu-form').style.display='none';document.getElementById('cu-success').style.display='block';return;}

    var first=document.getElementById('cu-fname').value.trim();
    var last=document.getElementById('cu-lname').value.trim();
    var email=document.getElementById('cu-email').value.trim();
    var phone=document.getElementById('cu-phone').value.trim();
    var message=(document.getElementById('cu-message').value||'').trim();

    if(!first||!last)return showErr('Please enter your first and last name.');
    var _em=email.trim(); if(!/^[^\s@]{2,}@[^\s@]+\.[A-Za-z]{2,}$/.test(_em)||/\.\./.test(_em))return showErr('Please enter a valid email.');
    errEl.classList.add('hidden');

    function _getCookie(n){var m=document.cookie.match(new RegExp('(?:^|;\\s*)'+n+'=([^;]+)'));return m?decodeURIComponent(m[1]):'';}
    function _qs(n){try{return new URL(location.href).searchParams.get(n)||'';}catch(e){return '';}}
    function _cleanUmtid(v){return v?String(v).replace(/[^A-Za-z0-9_-]/g,'').slice(0,40):'';}
    function _resolveUmtid(){return _cleanUmtid(_qs('umtid'))||_cleanUmtid(_getCookie('umtid'))||'';}
    function _resolveLoid(){
      var raw = _qs('loid') || _qs('lo_id') || _qs('first_touch_loid') || _getCookie('first_touch_loid') || '';
      var m = String(raw).match(/(\d{3,})/);
      return m ? m[1] : '';
    }
    var payload={
      first_name:first, last_name:last, full_name:(first+' '+last).trim(),
      email:email, phone:phone,
      form_source:'contact_us', form_name:'Contact Us',
      page_url:window.location.href, submitted_at:new Date().toISOString(),
      notes:message,
      umtid: _resolveUmtid(),
      loid: _resolveLoid(),
      source_url: location.href
    };

    sending=true; btn.disabled=true; btn.textContent='Sending\u2026';
    fetch(ENDPOINT,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)})
      .then(function(){document.getElementById('cu-form').style.display='none';document.getElementById('cu-success').style.display='block';})
      .catch(function(){showErr('Something went wrong. Please try again or call us.');})
      .then(function(){sending=false;btn.disabled=false;btn.textContent='Send Message';});
  });
})();
</script>
