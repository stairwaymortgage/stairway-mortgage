    }.pharmacist-scope .breadcrumb a{ color: var(--ink-lighter); }.pharmacist-scope .breadcrumb a:hover{ color: var(--blue); }.pharmacist-scope .breadcrumb span:last-child{ color: var(--ink); }.pharmacist-scope .hero-eyebrow{ margin-bottom: var(--s-5); }.pharmacist-scope .hero h1{ margin-bottom: var(--s-6); max-width: 18ch; }.pharmacist-scope .hero-subtitle{
