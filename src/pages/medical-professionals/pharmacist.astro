        width: 100% !important;
      }.pharmacist-scope .data-table tbody td:first-child{ font-size: var(--text-md); }
    }.pharmacist-scope .methods-intro{ max-width: 720px; margin-bottom: var(--s-8); }.pharmacist-scope .methods-grid{
