  <!-- ============ H2 #11: SOURCES ============ -->
  <section class="sources-section">
    <div class="container">
      <div class="section-header" style="text-align: center; max-width: 720px; margin: 0 auto var(--s-8);">
        <div class="eyebrow">11 &middot; Sources &amp; further reading</div>
        <h2>Sources &amp; further reading.</h2>
      </div>

      <div class="sources-grid">
        <div class="source-group">
          <h3 class="source-group-title">BLS occupational wage data</h3>
          <ul class="source-list">
            <li><a href="https://www.bls.gov/ooh/architecture-and-engineering/marine-engineers-and-naval-architects.htm" target="_blank" rel="noopener noreferrer">BLS OOH &mdash; Marine Engineers &amp; Naval Architects (closest SOC, median $99,510)</a></li>
