---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Current Homeowner — Stairway Mortgage" description="Already own a home? Refinance, tap equity, or plan your next move.">
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">Your Situation · Homeowner</span>
        <h1 class="display-xl mt-6 mb-6">Put your equity to <em class="not-italic text-[var(--color-blue)]">work</em>.</h1>
        <p class="lede max-w-xl mx-auto mb-6">Refinance for a lower rate, access equity with a HELOC, or plan your next property.</p>
        <p class="mono text-[11px] text-[var(--color-mute)] mt-6">NMLS #1072866</p>
        <div class="flex flex-wrap gap-3 justify-center mt-10">
          <a href="/see-my-options/" class="btn btn-blue btn-arrow text-base px-6 py-3.5">See My Options</a>
          <a href="/contact-us/" class="btn btn-ghost text-base px-6 py-3.5">Talk to Our Team</a>
        </div>
      </div>

      <!-- stw-img: Pexels 8120623 -->
      <figure class="hero-photo" style="max-width:1040px;margin:2.5rem auto 0;border-radius:20px;overflow:hidden;box-shadow:0 30px 70px -28px rgba(10,14,26,.45);aspect-ratio:16/9;">
        <img src="https://images.pexels.com/photos/8120623/pexels-photo-8120623.jpeg?auto=compress&cs=tinysrgb&w=1200"
             alt="Happy family relaxing together in the living room of their home" loading="eager"
             style="width:100%;height:100%;object-fit:cover;object-position:center 30%;display:block;"
             onerror="this.onerror=null;this.src='https://placehold.co/1000x1100/16335B/FAFAF9?text=Stairway';">
      </figure>
    </div>
  </section>

  <!-- LIFE GALLERY — real people, real milestones -->
  <section class="section-tight bg-[var(--color-paper-tint)]">
    <div class="container-page">
      <div class="text-center max-w-2xl mx-auto mb-8 reveal">
        <span class="eyebrow eyebrow-blue mb-4">Life in the home you own</span>
        <h2 class="display-lg mt-4">Your equity, <em class="not-italic font-light">working for you</em>.</h2>
      </div>
      <div class="grid sm:grid-cols-3 gap-5">
        <figure class="reveal" style="margin:0;">
          <!-- stw-img: Pexels 9869388 -->
          <div style="border-radius:16px;overflow:hidden;aspect-ratio:4/3;box-shadow:0 20px 45px -22px rgba(10,14,26,.4);">
            <img src="https://images.pexels.com/photos/9869388/pexels-photo-9869388.jpeg?auto=compress&cs=tinysrgb&w=800"
                 alt="Homeowner couple reviewing their options together on a laptop at the kitchen table" loading="lazy"
                 style="width:100%;height:100%;object-fit:cover;object-position:center 35%;display:block;"
                 onerror="this.onerror=null;this.src='https://placehold.co/600x450/16335B/FAFAF9?text=Stairway';">
          </div>
          <figcaption style="text-align:center;font-size:12.5px;color:var(--color-mute);margin-top:0.6rem;">Reviewing your options at the kitchen table</figcaption>
        </figure>
        <figure class="reveal" style="margin:0;transition-delay:80ms;">
          <!-- stw-img: Pexels 7979605 -->
          <div style="border-radius:16px;overflow:hidden;aspect-ratio:4/3;box-shadow:0 20px 45px -22px rgba(10,14,26,.4);">
            <img src="https://images.pexels.com/photos/7979605/pexels-photo-7979605.jpeg?auto=compress&cs=tinysrgb&w=800"
                 alt="Homeowners meeting with a mortgage advisor who understands their goals" loading="lazy"
                 style="width:100%;height:100%;object-fit:cover;object-position:center 35%;display:block;"
                 onerror="this.onerror=null;this.src='https://placehold.co/600x450/16335B/FAFAF9?text=Stairway';">
          </div>
          <figcaption style="text-align:center;font-size:12.5px;color:var(--color-mute);margin-top:0.6rem;">Guidance from a team that knows your goals</figcaption>
        </figure>
        <figure class="reveal" style="margin:0;transition-delay:160ms;">
          <!-- stw-img: Pexels 8293700 -->
          <div style="border-radius:16px;overflow:hidden;aspect-ratio:4/3;box-shadow:0 20px 45px -22px rgba(10,14,26,.4);">
            <img src="https://images.pexels.com/photos/8293700/pexels-photo-8293700.jpeg?auto=compress&cs=tinysrgb&w=800"
                 alt="Happy couple holding keys, ready for their next move" loading="lazy"
                 style="width:100%;height:100%;object-fit:cover;object-position:center 35%;display:block;"
                 onerror="this.onerror=null;this.src='https://placehold.co/600x450/16335B/FAFAF9?text=Stairway';">
          </div>
          <figcaption style="text-align:center;font-size:12.5px;color:var(--color-mute);margin-top:0.6rem;">Ready for the next move when you are</figcaption>
        </figure>
      </div>
    </div>
  </section>
</Layout>
