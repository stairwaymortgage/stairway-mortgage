---
import Layout from '../../layouts/Layout.astro';
import CareerApplyForm from '../../components/CareerApplyForm.astro';
---
<Layout
  title="How to Become a Mortgage Underwriter: Role, Pay & Path (2026)"
  description="How to become a mortgage underwriter: what underwriters do, whether you need a license, what they earn, and how the analytical role compares to higher-ceiling licensed origination."
>

<style is:global>
  /* ============ DESIGN TOKENS ============ */
  .mc-scope {
    color-scheme: light only;
    --ink: #0A0E1A;
    --ink-2: #1E2433;
    --ink-3: #2C3548;
    --ink-light: #4A5568;
    --ink-lighter: #6B7280;
    --paper: #FAFAF7;
    --paper-2: #F4F4EE;
    --paper-3: #EDEDE5;
    --white: #FFFFFF;
    --blue: #1845D6;
    --blue-deep: #0F2EA0;
    --blue-soft: #E8EEFF;
    --blue-tint: #F2F5FF;
    --gold: #B8860B;
    --gold-soft: #F5EBD0;
    --rust: #8B2C2C;
    --green: #2E9E2E;
    --border: #E5E5DE;
    --border-strong: #D4D4C8;
    --border-dark: #2C3548;

    --text-2xs: 0.6875rem;
    --text-xs: 0.75rem;
    --text-sm: 0.875rem;
    --text-base: 1.0625rem;
    --text-md: 1.1875rem;
    --text-lg: 1.375rem;
    --text-xl: 1.625rem;
    --text-2xl: 2rem;
    --text-3xl: 2.75rem;
    --text-4xl: 3.75rem;
    --text-5xl: 5rem;

    --s-1: 0.25rem; --s-2: 0.5rem; --s-3: 0.75rem; --s-4: 1rem;
    --s-5: 1.5rem; --s-6: 2rem; --s-7: 3rem; --s-8: 4rem;
    --s-9: 6rem; --s-10: 8rem; --s-11: 10rem;

    --serif: 'Fraunces', 'Iowan Old Style', Georgia, serif;
    --sans: 'IBM Plex Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    --mono: 'JetBrains Mono', 'SF Mono', Menlo, monospace;

    font-family: var(--sans);
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--ink);
    background: var(--paper);
    font-feature-settings: 'kern' 1, 'liga' 1, 'calt' 1;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  @media (prefers-color-scheme: dark) {
    .mc-scope { background-color: #FAFAF7 !important; color: #0A0E1A !important; color-scheme: light only !important; }
    .mc-scope * { forced-color-adjust: none; }
  }

  .mc-scope *, .mc-scope *::before, .mc-scope *::after { box-sizing: border-box; margin: 0; padding: 0; }
  .mc-scope { scroll-behavior: smooth; }
  .mc-scope img, .mc-scope svg { display: block; max-width: 100%; }
  .mc-scope a { color: inherit; text-decoration: none; }
  .mc-scope button { font: inherit; cursor: pointer; border: 0; background: none; }

  .mc-scope .container { max-width: 1200px; margin: 0 auto; padding: 0 var(--s-6); }
  .mc-scope .container-narrow { max-width: 760px; margin: 0 auto; padding: 0 var(--s-6); }
  .mc-scope .container-wide { max-width: 1340px; margin: 0 auto; padding: 0 var(--s-6); }

  /* ============ TYPOGRAPHY ============ */
  .mc-scope .eyebrow {
    font-family: var(--mono); font-size: var(--text-xs);
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--blue); font-weight: 500; display: inline-block;
  }
  .mc-scope .eyebrow-gold { color: var(--gold); }
  .mc-scope .display-1 {
    font-family: var(--serif); font-size: clamp(2.5rem, 7vw, var(--text-5xl));
    font-weight: 400; line-height: 1.0; letter-spacing: -0.025em;
    font-variation-settings: "opsz" 144, "SOFT" 30; color: var(--ink);
  }
  .mc-scope .display-2 {
    font-family: var(--serif); font-size: clamp(2rem, 5vw, var(--text-3xl));
    font-weight: 400; line-height: 1.05; letter-spacing: -0.02em;
    font-variation-settings: "opsz" 100, "SOFT" 50; color: var(--ink);
  }
  .mc-scope h2 {
    font-family: var(--serif); font-size: clamp(1.75rem, 3.5vw, var(--text-2xl));
    font-weight: 450; line-height: 1.1; letter-spacing: -0.015em;
    color: var(--ink); margin-bottom: var(--s-5);
    font-variation-settings: "opsz" 60, "SOFT" 50;
  }
  .mc-scope h3 {
    font-family: var(--serif); font-size: var(--text-xl); font-weight: 500;
    line-height: 1.25; letter-spacing: -0.01em; color: var(--ink);
    margin-bottom: var(--s-4); font-variation-settings: "opsz" 30;
  }
  .mc-scope h4 {
    font-family: var(--sans); font-size: var(--text-md); font-weight: 600;
    line-height: 1.3; color: var(--ink); margin-bottom: var(--s-3); letter-spacing: -0.005em;
  }
  .mc-scope p { margin-bottom: var(--s-4); }
  .mc-scope p:last-child { margin-bottom: 0; }
  .mc-scope p.lead { font-size: var(--text-md); line-height: 1.55; color: var(--ink-2); font-weight: 350; }
  .mc-scope p.lede {
    font-family: var(--serif); font-size: var(--text-md); line-height: 1.45;
    color: var(--ink); font-weight: 350; font-variation-settings: "opsz" 30;
  }
  .mc-scope .body-text { color: var(--ink-2); }
  .mc-scope .text-muted { color: var(--ink-lighter); }
  .mc-scope .text-small { font-size: var(--text-sm); }
  .mc-scope .text-mono { font-family: var(--mono); font-feature-settings: 'tnum' 1; }
  .mc-scope strong, .mc-scope b { font-weight: 600; color: var(--ink); }
  .mc-scope em, .mc-scope i { font-style: normal; }
  .mc-scope a.inline-link { color: var(--blue); text-decoration: underline; text-underline-offset: 2px; text-decoration-thickness: 1px; }
  .mc-scope a.inline-link:hover { color: var(--blue-deep); }

  /* ============ BUTTONS ============ */
  .mc-scope .btn {
    display: inline-flex; align-items: center; gap: var(--s-2);
    padding: var(--s-3) var(--s-5); font-family: var(--sans);
    font-size: var(--text-sm); font-weight: 500; letter-spacing: 0.005em;
    border-radius: 100px; transition: all 0.18s ease; white-space: nowrap;
  }
  .mc-scope .btn-primary { background: var(--ink); color: var(--paper); border: 1px solid var(--ink); }
  .mc-scope .btn-primary:hover { background: var(--blue); border-color: var(--blue); transform: translateY(-1px); }
  .mc-scope .btn-secondary { background: transparent; color: var(--ink); border: 1px solid var(--border-strong); }
  .mc-scope .btn-secondary:hover { border-color: var(--ink); }
  .mc-scope .btn-light { background: var(--white); color: var(--ink); border: 1px solid var(--border); }
  .mc-scope .btn-light:hover { background: var(--paper-2); }
  .mc-scope .btn-large { padding: var(--s-4) var(--s-6); font-size: var(--text-base); }
  .mc-scope .btn-arrow { display: inline-flex; align-items: center; gap: var(--s-2); color: var(--blue); font-weight: 500; transition: gap 0.18s; }
  .mc-scope .btn-arrow:hover { gap: var(--s-3); }
  .mc-scope .btn-arrow::after { content: '→'; font-family: var(--sans); }

  /* ============ HERO ============ */
  .mc-scope .hero { padding: var(--s-9) 0 var(--s-8); border-bottom: 1px solid var(--border); }
  .mc-scope .breadcrumb {
    display: flex; gap: var(--s-2); font-family: var(--mono); font-size: var(--text-xs);
    letter-spacing: 0.08em; color: var(--ink-lighter); text-transform: uppercase; margin-bottom: var(--s-7);
  }
  .mc-scope .breadcrumb a { color: var(--ink-lighter); }
  .mc-scope .breadcrumb a:hover { color: var(--blue); }
  .mc-scope .breadcrumb span:last-child { color: var(--ink); }
  .mc-scope .hero-eyebrow { margin-bottom: var(--s-5); }
  .mc-scope .hero h1 { margin-bottom: var(--s-6); max-width: 20ch; }
  .mc-scope .hero-subtitle { max-width: 60ch; margin-bottom: var(--s-7); }
  .mc-scope .hero-actions { display: flex; gap: var(--s-3); align-items: center; flex-wrap: wrap; margin-bottom: var(--s-6); }
  .mc-scope .hero-trust {
    font-family: var(--mono); font-size: var(--text-xs); color: var(--ink-lighter);
    letter-spacing: 0.02em; display: flex; align-items: center; gap: var(--s-3); flex-wrap: wrap;
  }
  .mc-scope .trust-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--blue); }

  /* ============ 3-DOOR ROUTER ============ */
  .mc-scope .doors { padding: var(--s-8) 0; background: var(--paper-2); border-bottom: 1px solid var(--border); }
  .mc-scope .doors-head { text-align: center; max-width: 50ch; margin: 0 auto var(--s-7); }
  .mc-scope .door-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--s-5); }
  .mc-scope .door {
    display: block; background: var(--white); border: 1px solid var(--border);
    border-radius: 6px; padding: var(--s-6); transition: all 0.18s ease; position: relative; overflow: hidden;
  }
  .mc-scope .door:hover { border-color: var(--blue); transform: translateY(-3px); box-shadow: 0 12px 30px rgba(10,14,26,0.08); }
  .mc-scope .door-num { font-family: var(--mono); font-size: var(--text-xs); color: var(--blue); letter-spacing: 0.1em; margin-bottom: var(--s-4); display: block; }
  .mc-scope .door h3 { margin-bottom: var(--s-3); }
  .mc-scope .door p { color: var(--ink-light); font-size: var(--text-sm); margin-bottom: var(--s-5); }
  .mc-scope .door .door-cta { font-family: var(--sans); font-size: var(--text-sm); font-weight: 500; color: var(--blue); display: inline-flex; align-items: center; gap: var(--s-2); }
  .mc-scope .door .door-cta::after { content: '→'; transition: transform 0.18s; }
  .mc-scope .door:hover .door-cta::after { transform: translateX(3px); }
  @media (max-width: 860px) { .mc-scope .door-grid { grid-template-columns: 1fr; } }

  /* ============ SECTION ============ */
  .mc-scope .section { padding: var(--s-9) 0; }
  .mc-scope .section-tint { background: var(--paper-2); }
  .mc-scope .section-ink { background: var(--ink); color: var(--paper); }
  .mc-scope .section-ink h2, .mc-scope .section-ink h3, .mc-scope .section-ink h4 { color: var(--white); }
  .mc-scope .section-ink .text-muted { color: #9CA3AF; }
  .mc-scope .section-head { max-width: 60ch; margin-bottom: var(--s-8); }
  .mc-scope .section-head .eyebrow { margin-bottom: var(--s-4); }

  /* ============ STEPS ============ */
  .mc-scope .steps { display: grid; gap: var(--s-5); }
  .mc-scope .step {
    display: grid; grid-template-columns: 60px 1fr; gap: var(--s-5);
    padding: var(--s-6); background: var(--white); border: 1px solid var(--border); border-radius: 6px;
  }
  .mc-scope .step-num {
    font-family: var(--serif); font-size: var(--text-2xl); color: var(--blue);
    font-variation-settings: "opsz" 60; line-height: 1;
  }
  .mc-scope .step h4 { margin-bottom: var(--s-2); }
  .mc-scope .step p { color: var(--ink-light); font-size: var(--text-sm); margin-bottom: 0; }
  .mc-scope .step p + p { margin-top: var(--s-3); }

  /* ============ ROLE GRID ============ */
  .mc-scope .role-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--s-5); }
  .mc-scope .role-card {
    display: block; background: var(--white); border: 1px solid var(--border);
    border-radius: 6px; padding: var(--s-6); transition: all 0.18s ease;
  }
  .mc-scope .role-card:hover { border-color: var(--blue); transform: translateY(-2px); box-shadow: 0 10px 24px rgba(10,14,26,0.06); }
  .mc-scope .role-tag {
    font-family: var(--mono); font-size: var(--text-2xs); letter-spacing: 0.1em;
    text-transform: uppercase; padding: 2px 8px; border-radius: 100px; display: inline-block; margin-bottom: var(--s-4);
  }
  .mc-scope .role-tag.licensed { background: var(--blue-soft); color: var(--blue-deep); }
  .mc-scope .role-tag.industry { background: var(--paper-3); color: var(--ink-light); }
  .mc-scope .role-card h3 { font-size: var(--text-lg); margin-bottom: var(--s-2); }
  .mc-scope .role-card p { color: var(--ink-light); font-size: var(--text-sm); margin-bottom: var(--s-4); }
  .mc-scope .role-card .door-cta { font-size: var(--text-sm); font-weight: 500; color: var(--blue); display: inline-flex; gap: var(--s-2); align-items: center; }
  .mc-scope .role-card .door-cta::after { content: '→'; transition: transform 0.18s; }
  .mc-scope .role-card:hover .door-cta::after { transform: translateX(3px); }
  @media (max-width: 760px) { .mc-scope .role-grid { grid-template-columns: 1fr; } }

  /* ============ STORY INTERLUDE ============ */
  .mc-scope .story { background: var(--ink); color: var(--paper); padding: var(--s-10) 0; }
  .mc-scope .story .container-narrow { position: relative; }
  .mc-scope .story .eyebrow { color: var(--gold); margin-bottom: var(--s-5); }
  .mc-scope .story p { color: #D8DCE4; font-size: var(--text-md); line-height: 1.7; margin-bottom: var(--s-5); }
  .mc-scope .story p.story-lede { font-family: var(--serif); font-size: var(--text-xl); color: var(--white); font-variation-settings: "opsz" 30; line-height: 1.45; }
  .mc-scope .story strong { color: var(--white); }
  .mc-scope .story-photo {
    width: 100%; max-width: 420px; border-radius: 6px; margin: var(--s-6) 0;
    border: 1px solid rgba(255,255,255,0.12);
  }
  .mc-scope .story-caption { font-family: var(--mono); font-size: var(--text-xs); color: #9CA3AF; letter-spacing: 0.04em; margin-top: var(--s-2); }
  .mc-scope .story-rule { width: 40px; height: 2px; background: var(--gold); margin-bottom: var(--s-6); }

  /* ============ STATS BAR ============ */
  .mc-scope .stats-bar { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--s-5); padding: var(--s-7) 0; }
  .mc-scope .stat { text-align: center; }
  .mc-scope .stat-num { font-family: var(--serif); font-size: var(--text-3xl); color: var(--ink); font-variation-settings: "opsz" 80; line-height: 1; margin-bottom: var(--s-2); }
  .mc-scope .section-ink .stat-num { color: var(--white); }
  .mc-scope .stat-label { font-family: var(--mono); font-size: var(--text-2xs); text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink-lighter); }
  @media (max-width: 760px) { .mc-scope .stats-bar { grid-template-columns: repeat(2, 1fr); gap: var(--s-6); } }

  /* ============ FEATURE COLUMNS ============ */
  .mc-scope .cols-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--s-6); }
  .mc-scope .cols-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--s-7); }
  .mc-scope .feature h4 { margin-bottom: var(--s-3); }
  .mc-scope .feature p { color: var(--ink-light); font-size: var(--text-sm); margin-bottom: 0; }
  .mc-scope .feature-icon { width: 40px; height: 40px; border-radius: 8px; background: var(--blue-soft); display: flex; align-items: center; justify-content: center; margin-bottom: var(--s-4); color: var(--blue); font-family: var(--serif); font-size: var(--text-lg); }
  @media (max-width: 860px) { .mc-scope .cols-3 { grid-template-columns: 1fr; } .mc-scope .cols-2 { grid-template-columns: 1fr; } }

  /* ============ TESTIMONIAL ============ */
  .mc-scope .quote-card { background: var(--white); border: 1px solid var(--border); border-left: 3px solid var(--blue); border-radius: 6px; padding: var(--s-7); }
  .mc-scope .quote-card blockquote { font-family: var(--serif); font-size: var(--text-base); line-height: 1.5; color: var(--ink); font-variation-settings: "opsz" 40; margin-bottom: var(--s-5); }
  .mc-scope .quote-author { display: flex; align-items: center; gap: var(--s-4); }
  .mc-scope .quote-author img { width: 48px; height: 48px; border-radius: 50%; object-fit: cover; object-position: 50% 25%; border: 1px solid var(--border); }
  .mc-scope .quote-author .qa-name { font-weight: 600; font-size: var(--text-sm); }
  .mc-scope .quote-author .qa-title { font-size: var(--text-xs); color: var(--ink-lighter); font-family: var(--mono); }

  /* ============ LEAD MAGNET / EMAIL ============ */
  .mc-scope .magnet { background: var(--blue-tint); border: 1px solid var(--blue-soft); border-radius: 8px; padding: var(--s-8); }
  .mc-scope .magnet-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: var(--s-8); align-items: center; }
  .mc-scope .magnet h2 { margin-bottom: var(--s-4); }
  .mc-scope .magnet p { color: var(--ink-light); }
  .mc-scope .magnet-form { display: flex; flex-direction: column; gap: var(--s-3); }
  .mc-scope .magnet-form input {
    padding: var(--s-4); border: 1px solid var(--border-strong); border-radius: 6px;
    font-family: var(--sans); font-size: var(--text-base); background: var(--white);
  }
  .mc-scope .magnet-form input:focus { outline: 2px solid var(--blue); border-color: var(--blue); }
  .mc-scope .form-note { font-size: var(--text-xs); color: var(--ink-lighter); }
  @media (max-width: 860px) { .mc-scope .magnet-grid { grid-template-columns: 1fr; gap: var(--s-6); } }

  /* ============ FAQ ============ */
  .mc-scope .faq-list { border-top: 1px solid var(--border); }
  .mc-scope .faq-item { border-bottom: 1px solid var(--border); }
  .mc-scope .faq-q {
    width: 100%; text-align: left; padding: var(--s-5) 0; display: flex;
    justify-content: space-between; align-items: center; gap: var(--s-4);
    font-family: var(--serif); font-size: var(--text-md); font-weight: 500;
    color: var(--ink); font-variation-settings: "opsz" 30;
  }
  .mc-scope .faq-q:hover { color: var(--blue); }
  .mc-scope .faq-icon { flex-shrink: 0; width: 20px; height: 20px; position: relative; transition: transform 0.2s; }
  .mc-scope .faq-icon::before, .mc-scope .faq-icon::after { content: ''; position: absolute; background: var(--blue); border-radius: 2px; }
  .mc-scope .faq-icon::before { top: 9px; left: 0; width: 20px; height: 2px; }
  .mc-scope .faq-icon::after { top: 0; left: 9px; width: 2px; height: 20px; transition: transform 0.2s; }
  .mc-scope .faq-item.open .faq-icon::after { transform: rotate(90deg); opacity: 0; }
  .mc-scope .faq-a { max-height: 0; overflow: hidden; transition: max-height 0.25s ease; }
  .mc-scope .faq-a-inner { padding: 0 0 var(--s-5); color: var(--ink-light); font-size: var(--text-sm); line-height: 1.65; max-width: 70ch; }
  .mc-scope .faq-item.open .faq-a { max-height: 600px; }

  /* ============ CTA BAND ============ */
  .mc-scope .cta-band { background: var(--ink); color: var(--paper); padding: var(--s-10) 0; text-align: center; }
  .mc-scope .cta-band h2 { color: var(--white); max-width: 22ch; margin: 0 auto var(--s-5); }
  .mc-scope .cta-band p { color: #B8BEC9; max-width: 54ch; margin: 0 auto var(--s-7); }
  .mc-scope .cta-band .hero-actions { justify-content: center; }
  .mc-scope .cta-band .btn-primary { background: var(--white); color: var(--ink); border-color: var(--white); }
  .mc-scope .cta-band .btn-primary:hover { background: var(--blue); color: var(--white); border-color: var(--blue); }
  .mc-scope .cta-band .btn-secondary { color: var(--white); border-color: rgba(255,255,255,0.3); }
  .mc-scope .cta-band .btn-secondary:hover { border-color: var(--white); }

  /* ============ COMPLIANCE / DISCLAIMER ============ */
  .mc-scope .disclaimer { padding: var(--s-7) 0; background: var(--paper-2); border-top: 1px solid var(--border); }
  .mc-scope .disclaimer p { font-size: var(--text-xs); color: var(--ink-lighter); line-height: 1.6; max-width: 90ch; margin-bottom: var(--s-3); }

  .mc-scope .mt-5 { margin-top: var(--s-5); }
  .mc-scope .mt-7 { margin-top: var(--s-7); }
</style>

<!-- ============ JSON-LD: FAQ ============ -->
<script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I become a mortgage underwriter?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most underwriters come up through the industry, often starting in processing or a junior underwriting role and advancing as they master guidelines. Employers look for strong analytical skills and detailed knowledge of loan programs. Industry training and certifications can help you qualify."
      }
    },
    {
      "@type": "Question",
      "name": "Do mortgage underwriters need a license?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Generally, underwriters don't need an NMLS originator license because they evaluate loans rather than originate them. However, the role requires deep guideline knowledge, and some employers prefer or require industry certifications. Requirements vary by employer and loan type."
      }
    },
    {
      "@type": "Question",
      "name": "What does a mortgage underwriter do?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An underwriter evaluates a completed loan file — credit, income, assets, and the property — against lender and program guidelines, then approves, denies, or sets conditions on the loan. They're the risk decision-maker who determines whether a loan can move forward."
      }
    },
    {
      "@type": "Question",
      "name": "How much do mortgage underwriters make?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Underwriters are typically salaried, with pay varying by experience, employer, and specialty. Experienced underwriters in complex loan types can earn well, but it's generally a salary rather than the uncapped commission a licensed originator earns."
      }
    },
    {
      "@type": "Question",
      "name": "Is underwriting a good career?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For analytical, detail-oriented people who like applying rules and assessing risk, it's a solid, respected, in-demand career. It offers stability and clear expertise. People who prefer relationship-building and uncapped income sometimes lean toward origination instead."
      }
    },
    {
      "@type": "Question",
      "name": "What skills does a mortgage underwriter need?",
      "acceptedAnswer": {
