---
// src/pages/guides.astro  (or guides/index.astro — match the existing route)
// Rebuilt from WordPress XML: 1 Roadmap hero + 11 guide cards, each with its own
// 3D book cover (R2) and its own GHL download form. Forest palette + Fraunces/Inter.
import Layout from '../layouts/Layout.astro';

