---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Free Guides — Stairway Mortgage" description="Step-by-step ebooks for every stage of your real estate journey.">
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">Learn · Free Guides</span>
        <h1 class="display-xl mt-6 mb-6">Free guides for <em class="italic text-[var(--color-blue)]">every stage</em>.</h1>
        <p class="lede max-w-xl mx-auto mb-8">The 8-ebook Stairway Roadmap — from first credit card to lasting legacy. Free.</p>
        <div class="flex flex-wrap gap-3 justify-center mt-10">
          <a href="https://forms.stairwaymortgage.com/widget/survey/mjaP6vw7ZpN11NfzOd8c" target="_blank" rel="noopener" class="btn btn-blue btn-arrow text-base px-6 py-3.5">Get the Stairway Roadmap</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
