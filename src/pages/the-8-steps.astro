---
import Layout from '../layouts/Layout.astro';

const rungs = [
  {
    num: '01', title: 'Smart Stewards', tag: 'College Planning', subtitle: 'Student',
    who: 'Students and parents, before homeownership ever begins.',
    desc: 'Credit building, education planning, and learning to use real estate as part of a long-term wealth strategy — long before there\'s a mortgage on the table.',
    shift: 'Learn to steward money first. Balance tuition against the assets you\'ll one day own.',
    primary: { label: 'Start the Climb', href: '/discovery-quiz/' },
    secondary: { label: 'Talk to Our Team', href: '/contact-us/' },
    next: { label: 'Next: First-Time Buyer', href: '#step-2' },
  },
  {
    num: '02', title: 'First-Time Home Buyer', tag: 'The First Door', subtitle: 'Homebuyer',
    who: 'People buying their first home — pre-approved or in process.',
    desc: 'Qualification, pre-approval, making offers, and closing with confidence. Everything it takes to turn a nervous first-timer into a confident closer.',
    shift: 'Move forward with clarity instead of anxiety. This door opens.',
    primary: { label: 'Get Pre-Approved', href: '/same-day-approval/' },
    secondary: { label: 'Talk to Our Team', href: '/contact-us/' },
    next: { label: 'Next: Homeowner', href: '#step-3' },
  },
  {
    num: '03', title: 'Homeowner', tag: 'Equity at Work', subtitle: 'Homeowner',
    who: 'People who already own their home.',
    desc: 'Strategic use of equity, refinancing, and HELOCs — turning the house you live in into a tool that works for you.',
    shift: 'Stop simply owning a home. Start using it as a wealth-building tool.',
    primary: { label: 'See My Options', href: '/refinance-or-heloc-journey/' },
    secondary: { label: 'Talk to Our Team', href: '/contact-us/' },
    next: { label: 'Next: Senior Homeowner', href: '#step-4' },
  },
  {
    num: '04', title: 'Senior Homeowner', tag: '55+ · The Bridge', subtitle: 'Senior Planner',
    who: 'Retirees and those approaching retirement.',
    desc: 'Downsizing, retirement planning, aging in place, and reverse mortgage strategies — making home equity do its most important work yet.',
    shift: 'Maximize the value of a lifetime of ownership. Begin the bridge toward legacy.',
    primary: { label: 'See My Options', href: '/reverse-mortgage-journey/' },
    secondary: { label: 'Talk to Our Team', href: '/contact-us/' },
    next: { label: 'Next: First-Time Investor', href: '#step-5' },
  },
  {
    num: '05', title: 'First-Time Investor', tag: 'From Consumer to Owner', subtitle: 'Investor',
    who: 'People acquiring their first rental or investment property.',
    desc: 'Cash flow analysis, financing strategy including rental-income and flexible-income loans, and the fundamentals of buying your first asset that pays you back.',
    shift: 'The identity shift — from homeowner to investor.',
    primary: { label: 'See Investor Loans', href: '/build-a-wealth-plan-journey/' },
    secondary: { label: 'Talk to Our Team', href: '/contact-us/' },
    next: { label: 'Next: Active Investor', href: '#step-6' },
  },
  {
    num: '06', title: 'Active Investor', tag: 'Scaling the Portfolio', subtitle: 'Portfolio Builder',
    who: 'Investors already building a portfolio.',
    desc: 'Leverage, scaling, cash-flow optimization, and rental-income loans from a lender who moves at deal speed — because momentum is the whole game.',
    shift: 'Systematic, repeatable growth through strategic financing.',
    primary: { label: 'See Investor Loans', href: '/build-a-wealth-plan-journey/' },
    secondary: { label: 'Talk to Our Team', href: '/contact-us/' },
    next: { label: 'Next: Passive Investor', href: '#step-7' },
  },
  {
    num: '07', title: 'Passive Investor', tag: 'Operator to Allocator', subtitle: 'Passive Wealth Creator',
    who: 'Investors who want real estate income without the management.',
    desc: 'Passive income, syndications, tax advantages, and hands-off strategies — real estate as a vehicle, not a second job.',
    shift: 'From operator to allocator. The asset works; you don\'t have to.',
    primary: { label: 'See Passive Options', href: '/build-a-wealth-plan-journey/' },
    secondary: { label: 'Talk to Our Team', href: '/contact-us/' },
    next: { label: 'Next: The Summit', href: '#step-8' },
  },
  {
    num: '08', title: 'Legacy Angel', tag: 'The Summit', subtitle: 'Legacy Builder',
    who: 'Those turning a lifetime of wealth into lasting impact.',
    desc: 'Family legacy, philanthropy, wealth transfer, and generational giving. This is what your money becomes when it outlives you — value that keeps creating impact long after you\'re gone.',
    shift: 'From accumulation for yourself to stewardship for others — the climb comes full circle.',
    primary: { label: 'Start a Legacy Conversation', href: '/contact-us/' },
    next: { label: 'Back to the first step', href: '#step-1', arrow: '↑' },
    summit: true,
  },
];
---

<Layout title="The 8 Steps™ — The Stairway Client System™ | Stairway Mortgage" description="From your first credit decision at 18 to leaving a legacy — the Stairway Client System is one continuous climb. Find your step.">

  <!-- HERO (dark) -->
  <section class="es-hero section-dark">
    <div class="es-aurora" aria-hidden="true"><span></span><span></span><span></span></div>
    <div class="container-page relative" style="z-index:1;">
      <div class="text-center max-w-3xl mx-auto reveal">
        <span class="eyebrow" style="color:rgba(250,250,247,.55);">The Stairway Client System™</span>
        <h1 class="display-xl mt-6 mb-6 text-[var(--color-paper)]" style="max-width:16ch;margin-left:auto;margin-right:auto;">
          Eight steps. One <em class="italic text-[var(--color-blue)]">continuous</em> climb.
        </h1>
        <p class="text-[clamp(17px,1.6vw,21px)] text-[rgba(250,250,247,.72)] max-w-[60ch] mx-auto mb-10">
          A mortgage is not a one-time transaction — it's a single step in a lifelong climb. From the first credit decision at eighteen to the legacy you leave behind, every rung lifts you higher.
        </p>
        <!-- Mini staircase visual -->
        <div class="es-stair" aria-hidden="true">
          {[14,26,38,50,62,74,86,100].map((h, i) => (
            <i style={`height:${h}%;${i === 7 ? 'background:linear-gradient(180deg,#fff,rgba(255,255,255,.3))' : ''}`}></i>
          ))}
        </div>
        <p class="mono text-[13px] tracking-[.18em] uppercase text-[rgba(250,250,247,.45)] mt-10">
          Leverage Wisely. &nbsp;Grow Wealthy.
        </p>
      </div>
    </div>
  </section>

  <!-- TWO PHASES -->
  <section class="section-tight bg-[var(--color-paper-tint)] border-b border-[var(--color-bone)]">
    <div class="container-page">
      <div class="es-phases reveal">
        <div class="es-phase">
          <span class="eyebrow eyebrow-blue">Steps 1–4</span>
          <h3 class="font-display text-[23px] mt-2 mb-1">Live in it.</h3>
          <p class="text-[15px] text-[var(--color-mute)] max-w-[38ch]">Real estate as a home — building credit, buying, owning, and planning for later life.</p>
        </div>
        <div class="es-phase-rule" aria-hidden="true"></div>
        <div class="es-phase">
          <span class="eyebrow eyebrow-rust">Steps 5–8</span>
          <h3 class="font-display text-[23px] mt-2 mb-1">Build wealth with it.</h3>
          <p class="text-[15px] text-[var(--color-mute)] max-w-[38ch]">Real estate as an asset — your first deal, a growing portfolio, passive income, and lasting impact.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- THE CLIMB -->
  <section class="section">
    <div class="container-page">
      <div class="text-center max-w-[60ch] mx-auto mb-5 reveal">
        <span class="eyebrow eyebrow-blue">The Climb</span>
        <h2 class="display-md mt-4 mb-4">Where are you <em class="italic text-[var(--color-rust)]">standing today?</em></h2>
        <p class="text-[17px] text-[var(--color-mute)]">Each rung is a real moment in a real estate life. They connect — every step graduates into the next, all the way to the summit.</p>
      </div>

      <!-- Progression spine -->
      <p class="es-spine mono reveal">
        <b>Student</b> <span class="text-[var(--color-bone)]">→</span>
        <b>Homebuyer</b> <span class="text-[var(--color-bone)]">→</span>
        <b>Homeowner</b> <span class="text-[var(--color-bone)]">→</span>
        <b>Senior Planner</b> <span class="text-[var(--color-bone)]">→</span>
        <b>Investor</b> <span class="text-[var(--color-bone)]">→</span>
        <b>Portfolio Builder</b> <span class="text-[var(--color-bone)]">→</span>
        <b>Passive Wealth Creator</b> <span class="text-[var(--color-bone)]">→</span>
        <b>Legacy Builder</b>
      </p>

      <!-- 8 Rungs -->
      {rungs.map((r, i) => (
        <article class={`es-rung reveal ${r.summit ? 'es-rung--summit' : ''}`} id={`step-${i+1}`} style={`margin-left:${i * 3}%;`}>
          <div class="es-rung__num font-display">{r.num}</div>
          <div class="es-rung__body">
            <h3 class="font-display text-[30px] mb-0.5">{r.title}</h3>
            <span class="es-rung__tag mono">{r.tag}</span>
            <p class="es-rung__who"><strong>Who:</strong> {r.who}</p>
            <p class="es-rung__desc">{r.desc}</p>
            <p class="es-rung__shift">{r.shift}</p>
          </div>
          <div class="es-rung__cta">
            <a class={`btn ${r.summit ? 'btn-ghost' : 'btn-blue'}`} href={r.primary.href}>{r.primary.label}</a>
            {r.secondary && <a class="btn btn-ghost" href={r.secondary.href}>{r.secondary.label}</a>}
            <a class="es-next mono" href={r.next.href}>{r.next.label} {r.next.arrow || '↓'}</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ══ STW ACCORDION GRID ══ -->
<style>
.stw-ac-section{padding:72px 0;background:#fafaf8;border-top:1px solid #e8e4dc;}
.stw-ac-inner{max-width:1200px;margin:0 auto;padding:0 24px;}
.stw-ac-header{text-align:center;margin-bottom:48px;}
.stw-ac-eyebrow{display:inline-block;font-size:11px;letter-spacing:.12em;text-transform:uppercase;font-weight:600;color:#1845D6;background:#dce8ff;padding:3px 10px;border-radius:20px;margin-bottom:14px;}
.stw-ac-title{font-family:'DM Serif Display',Georgia,serif;font-size:clamp(26px,3.5vw,38px);line-height:1.2;color:#0f1117;margin-bottom:10px;}
.stw-ac-sub{font-size:15px;color:#6b6b6b;max-width:540px;margin:0 auto;}
/* Grid wraps both cards and panels */
.stw-ac-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;}
@media(max-width:1000px){.stw-ac-grid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:540px){.stw-ac-grid{grid-template-columns:1fr;}}
/* Card */
.ac-card{background:#fff;border:1.5px solid #e8e4dc;border-radius:12px;padding:20px 18px;cursor:pointer;display:flex;flex-direction:column;transition:border-color .15s,box-shadow .15s;}
.ac-card:hover,.ac-card.active{border-color:var(--sc);box-shadow:0 0 0 2px color-mix(in srgb,var(--sc) 18%,transparent);}
.ac-card-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:18px;}
.ac-num{font-family:'JetBrains Mono',monospace;font-size:13px;color:#888;font-weight:500;}
.ac-card-arrow{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.06);transition:background .15s,color .15s;color:#888;}
.ac-card-arrow svg{width:10px;height:10px;}
.ac-card:hover .ac-card-arrow,.ac-card.active .ac-card-arrow{background:var(--sc);color:#fff;}
.ac-name{font-family:'DM Serif Display',Georgia,serif;font-size:18px;color:#0f1117;margin-bottom:5px;line-height:1.25;}
.ac-desc{font-size:13px;color:#6b6b6b;line-height:1.5;flex:1;}
.ac-explore{margin-top:14px;padding-top:12px;border-top:1px solid #e8e4dc;font-size:12px;font-weight:500;color:var(--sc);}
/* Panel — spans full grid width */
.ac-panel{display:none;grid-column:1/-1;background:#fff;border:1.5px solid #e8e4dc;border-radius:12px;overflow:hidden;}
.ac-panel.open{display:block;}
.ac-close{display:flex;align-self:flex-end;margin:14px 16px 0 auto;background:none;border:none;cursor:pointer;font-size:12px;color:#888;font-family:'Inter',sans-serif;}
.ac-close:hover{color:#0f1117;}
.ac-panel-inner{padding:24px 28px 28px;}
.ac-panel-header{display:flex;align-items:flex-start;gap:14px;padding-bottom:18px;border-bottom:1px solid #e8e4dc;margin-bottom:20px;}
.ac-badge{width:40px;height:40px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:500;color:#fff;flex-shrink:0;}
.ac-panel-name{font-family:'DM Serif Display',Georgia,serif;font-size:24px;color:#0f1117;margin-bottom:3px;}
.ac-panel-sub{font-size:13px;color:#888;font-style:italic;}
.ac-intro{font-size:14.5px;color:#333;line-height:1.7;margin-bottom:18px;}
.ac-discover{border-left:3px solid #ccc;background:#f8f9ff;border-radius:0 8px 8px 0;padding:14px 16px;margin-bottom:20px;}
.ac-discover-label{font-size:10px;letter-spacing:.1em;text-transform:uppercase;font-weight:600;margin-bottom:10px;}
.ac-discover-list{list-style:none;padding:0;margin:0;}
.ac-discover-list li{display:flex;gap:8px;align-items:flex-start;font-size:13.5px;color:#333;line-height:1.55;margin-bottom:7px;}
.ac-discover-list li:last-child{margin-bottom:0;}
.ac-discover-list li::before{content:'→';flex-shrink:0;font-size:12px;margin-top:2px;}
/* Parts grid */
.ac-parts{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:20px;}
@media(max-width:700px){.ac-parts{grid-template-columns:1fr;}}
.ac-part{background:#fafaf8;border:1px solid #e8e4dc;border-radius:9px;padding:16px 14px;}
.ac-part-head{display:flex;align-items:flex-start;gap:8px;margin-bottom:12px;padding-bottom:10px;border-bottom:1px solid #ede9e3;}
.ac-roman{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:500;padding:3px 7px;border-radius:4px;white-space:nowrap;flex-shrink:0;}
.ac-part-name{font-size:12.5px;font-weight:600;color:#0f1117;line-height:1.35;}
.ac-chapters{list-style:none;padding:0;margin:0;}
.ac-chapters li{display:flex;align-items:flex-start;gap:7px;font-size:12px;color:#444;padding:4px 0;border-bottom:1px solid rgba(0,0,0,0.04);line-height:1.5;}
.ac-chapters li:last-child{border-bottom:none;}
.ac-chapters li::before{content:'';width:4px;height:4px;border-radius:50%;flex-shrink:0;margin-top:6px;background:currentColor;opacity:.4;}
/* CTAs */
.ac-ctas{display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
.ac-btn-primary{display:inline-flex;align-items:center;gap:5px;background:#0f1117;color:#fff;font-size:13.5px;font-weight:500;padding:11px 22px;border-radius:8px;text-decoration:none;font-family:'Inter',sans-serif;}
.ac-btn-primary:hover{background:#333;}
.ac-btn-ghost{font-size:13px;color:#0f1117;text-decoration:none;border:1.5px solid #e8e4dc;padding:10px 18px;border-radius:8px;font-family:'Inter',sans-serif;}
.ac-btn-ghost:hover{background:#f3f1ec;}
.ac-meta{font-family:'JetBrains Mono',monospace;font-size:11px;color:#bbb;margin-left:auto;}
/* fallback no color-mix */
@supports not (background:color-mix(in srgb,red 18%,transparent)){.ac-card.active{box-shadow:0 0 0 2px rgba(0,0,0,.12);}}
</style>
<section class="stw-ac-section">
  <div class="stw-ac-inner">
    <div class="stw-ac-header">
      <span class="stw-ac-eyebrow">Eight steps. One climb.</span>
      <h2 class="stw-ac-title">Find your step. Start climbing.</h2>
      <p class="stw-ac-sub">Each step is a real moment in a real estate life. You only need the one you're standing on today.</p>
    </div>
    <div class="stw-ac-grid">
<div class="ac-card" data-idx="0" style="--sc:#7B61FF">
  <div class="ac-card-top">
    <span class="ac-num">01</span>
    <div class="ac-card-arrow"><svg viewBox="0 0 12 12" fill="none"><path d="M3 9L9 3M9 3H4M9 3V8" stroke="currentColor" stroke-width="1.4"/></svg></div>
  </div>
  <div class="ac-name">Smart Stewards</div>
  <div class="ac-desc">Building credit and financial foundation.</div>
  <div class="ac-explore">Explore this stage →</div>
</div>
<div class="ac-panel" id="ac-panel-0">
  <button class="ac-close" onclick="closePanel(0)">✕ Close</button>
  <div class="ac-panel-inner">
    <div class="ac-panel-header">
      <div class="ac-badge" style="background:#7B61FF">01</div>
      <div><div class="ac-panel-name">Smart Stewards</div><div class="ac-panel-sub">Building credit and financial foundation.</div></div>
    </div>
    <p class="ac-intro">Legacy begins at home — not with money, but with values. This playbook teaches families how to build credit early, turn education costs into equity, and raise financially confident children.</p>
    <div class="ac-discover" style="border-color:#7B61FF">
      <div class="ac-discover-label" style="color:#7B61FF">What you'll discover in this playbook</div>
      <ul class="ac-discover-list"><li>Give your teen a 100-point credit score head start — without spending a dime</li><li>Why one family's student graduated with equity instead of debt using a simple FHA strategy</li><li>The 4-unit college strategy that turns housing costs into cash flow</li></ul>
    </div>
    <div class="ac-parts"><div class="ac-part"><div class="ac-part-head"><span class="ac-roman" style="color:#7B61FF;background:#7B61FF18">Part I</span><span class="ac-part-name">The invisible resume</span></div><ul class="ac-chapters"><li>What is a credit score and why does it matter?</li><li>Why waiting until 18 is too late — time as a multiplier</li><li>The power of authorized users</li><li>Teaching financial responsibility early</li><li>Breaking the "us vs them" mentality about money</li><li>How to start the money conversation at home</li></ul></div><div class="ac-part"><div class="ac-part-head"><span class="ac-roman" style="color:#7B61FF;background:#7B61FF18">Part II</span><span class="ac-part-name">Turning college into a wealth event</span></div><ul class="ac-chapters"><li>Building a family financial plan</li><li>Your family credit strategy</li><li>The college housing trap</li><li>The 4-unit strategy — real case study</li><li>How to qualify while still in school</li><li>Don't want 4 units? Try 1!</li></ul></div><div class="ac-part"><div class="ac-part-head"><span class="ac-roman" style="color:#7B61FF;background:#7B61FF18">Part III</span><span class="ac-part-name">Starting your legacy now</span></div><ul class="ac-chapters"><li>What if college isn't part of the plan?</li><li>It's not just about the kids — the whole family's trajectory</li></ul></div></div>
    <div class="ac-ctas">
      <a href="/the-8-steps/smart-stewards/" class="ac-btn-primary" target="_blank" rel="noopener">Explore the full Smart Stewards guide →</a>
      <a href="https://academy.stairwaymortgage.com/courses/offers/c5945b87-2852-4182-a121-35a461f0e2ac" class="ac-btn-ghost" target="_blank" rel="noopener">Start the course</a>
      <span class="ac-meta">14 chapters · Beginner</span>
    </div>
  </div>
</div>
<div class="ac-card" data-idx="1" style="--sc:#1845D6">
  <div class="ac-card-top">
    <span class="ac-num">02</span>
    <div class="ac-card-arrow"><svg viewBox="0 0 12 12" fill="none"><path d="M3 9L9 3M9 3H4M9 3V8" stroke="currentColor" stroke-width="1.4"/></svg></div>
  </div>
  <div class="ac-name">First-Time Buyers</div>
