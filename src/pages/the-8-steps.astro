<script is:inline>
(function(){
  var open = -1;
  function closePanel(idx){
    var panel = document.getElementById('ac-panel-'+idx);
    var card = document.querySelector('.ac-card[data-idx="'+idx+'"]');
    if(panel) panel.classList.remove('open');
    if(card) card.classList.remove('active');
    open = -1;
  }
  window.closePanel = closePanel;
  document.querySelectorAll('.ac-card').forEach(function(card){
    card.addEventListener('click', function(){
      var idx = parseInt(card.dataset.idx);
      if(open === idx){ closePanel(idx); return; }
      if(open >= 0) closePanel(open);
      card.classList.add('active');
      var panel = document.getElementById('ac-panel-'+idx);
      if(panel){
        panel.classList.add('open');
        setTimeout(function(){ panel.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 50);
      }
      open = idx;
    });
  });
})();
</script>
