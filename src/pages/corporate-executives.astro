---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Corporate Executives — Stairway Mortgage" description="Stock comp, RSU, and bonus-friendly loan programs for executives.">
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">Your Profession · Corporate Executives</span>
        <h1 class="display-xl mt-6 mb-6">Loans that understand <em class="italic text-[var(--color-blue)]">executive compensation</em>.</h1>
        <p class="lede max-w-xl mx-auto mb-6">RSUs, stock options, bonuses, and deferred comp — we qualify you on the full picture.</p>
        <p class="mono text-[11px] text-[var(--color-mute)] mt-6">NMLS #1072866</p>
        <div class="flex flex-wrap gap-3 justify-center mt-10">
          <a href="/same-day-approval/" class="btn btn-blue btn-arrow text-base px-6 py-3.5">See My Options</a>
          <a href="/contact-us/" class="btn btn-ghost text-base px-6 py-3.5">Talk to Our Team</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
