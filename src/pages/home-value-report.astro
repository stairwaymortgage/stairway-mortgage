---
import Layout from '../layouts/Layout.astro';
import { GHL_WEBHOOK_URL } from '../lib/ghl';
---
<Layout title="Home Value Report — Stairway Mortgage" description="See what your home is worth today. Free equity report from our team — no obligation.">

  <section class="section relative overflow-hidden hvr-hero">
    <div class="container-page">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <span class="eyebrow eyebrow-blue mb-6">Tools · Home Value</span>
          <h1 class="display-lg mt-5 mb-5">What is your home <em class="italic text-[var(--color-blue)]">worth today</em>?</h1>
          <p class="lede max-w-xl mb-8">Get a free equity report from our team. We analyze comparable sales, market trends, and your specific property — then show you what you can do with that equity.</p>
          <div class="space-y-4 mb-8">
            <div class="flex items-start gap-3"><span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[var(--color-green)] shrink-0"></span><span class="text-[15px]">Comparable sales analysis for your area</span></div>
            <div class="flex items-start gap-3"><span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[var(--color-green)] shrink-0"></span><span class="text-[15px]">How much equity you can access</span></div>
            <div class="flex items-start gap-3"><span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[var(--color-green)] shrink-0"></span><span class="text-[15px]">Refinance, HELOC, and cash-out options</span></div>
          </div>
          <p class="mono text-[11px] text-[var(--color-mute)]">NMLS #1072866 · Free, no obligation</p>
        </div>
        <div class="reveal" style="transition-delay:100ms;">
          <div class="card p-8 lg:p-10" id="hvr-wrap">
            <h2 class="font-display text-xl mb-1">Request your free report</h2>
            <p class="text-[14px] text-[var(--color-mute)] mb-6">Our team will prepare a personalized equity analysis.</p>
            <div class="space-y-4" id="hvr-form" data-ghl-endpoint={GHL_WEBHOOK_URL}>
              <div class="grid grid-cols-2 gap-3">
                <div><label class="block text-[12px] font-semibold uppercase tracking-wider text-[var(--color-mute)] mb-2">First name</label><input type="text" id="hvr-first" placeholder="First" autocomplete="given-name" class="w-full p-3 border border-[var(--color-bone)] rounded-lg text-base" /></div>
                <div><label class="block text-[12px] font-semibold uppercase tracking-wider text-[var(--color-mute)] mb-2">Last name</label><input type="text" id="hvr-last" placeholder="Last" autocomplete="family-name" class="w-full p-3 border border-[var(--color-bone)] rounded-lg text-base" /></div>
              </div>
              <div><label class="block text-[12px] font-semibold uppercase tracking-wider text-[var(--color-mute)] mb-2">Email</label><input type="email" id="hvr-email" placeholder="you@email.com" autocomplete="email" class="w-full p-3 border border-[var(--color-bone)] rounded-lg text-base" /></div>
              <div><label class="block text-[12px] font-semibold uppercase tracking-wider text-[var(--color-mute)] mb-2">Phone</label><input type="tel" id="hvr-phone" placeholder="(555) 555-5555" autocomplete="tel" class="w-full p-3 border border-[var(--color-bone)] rounded-lg text-base" /></div>
              <div><label class="block text-[12px] font-semibold uppercase tracking-wider text-[var(--color-mute)] mb-2">Property address</label><input type="text" id="hvr-address" placeholder="123 Main St, City, State" class="w-full p-3 border border-[var(--color-bone)] rounded-lg text-base" /></div>
              <input type="text" name="_gotcha" id="hvr-gotcha" style="position:absolute;left:-9999px;opacity:0;" tabindex="-1" autocomplete="off" aria-hidden="true" />
              <p class="text-[13px] text-red-600 hidden" id="hvr-error"></p>
              <button class="btn btn-blue w-full text-center text-base py-3.5" type="button" id="hvr-submit">Get My Report</button>
              <p class="text-[11px] text-[var(--color-mute)] text-center">Free, no obligation. We do not sell your information.</p>
            </div>
            <div class="text-center py-10" id="hvr-success" style="display:none;">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--color-green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-4"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <p class="font-display text-xl mb-2">Request received.</p>
              <p class="text-[14px] text-[var(--color-mute)]">Our team will prepare your equity report and reach out within 24 hours.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>.hvr-hero{position:relative;}.hvr-hero::before{content:'';position:absolute;top:0;left:0;right:0;height:200px;background:linear-gradient(180deg,var(--color-blue-tint) 0%,transparent 100%);opacity:0.3;pointer-events:none;z-index:0;}</style>

<script is:inline>
(function(){
  var wrap=document.getElementById('hvr-form');
  if(!wrap)return;
  var ENDPOINT=wrap.getAttribute('data-ghl-endpoint')||'';
  var btn=document.getElementById('hvr-submit');
  var errEl=document.getElementById('hvr-error');
  var sending=false;

  function showErr(m){errEl.textContent=m;errEl.classList.remove('hidden');}

  btn.addEventListener('click',function(){
    if(sending)return;
    var gotcha=document.getElementById('hvr-gotcha');
    if(gotcha&&gotcha.value.trim()!==''){document.getElementById('hvr-form').style.display='none';document.getElementById('hvr-success').style.display='block';return;}

    var first=document.getElementById('hvr-first').value.trim();
    var last=document.getElementById('hvr-last').value.trim();
    var email=document.getElementById('hvr-email').value.trim();
    var phone=document.getElementById('hvr-phone').value.trim();
    var address=document.getElementById('hvr-address').value.trim();

    if(!first||!last)return showErr('Please enter your first and last name.');
    if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email))return showErr('Please enter a valid email.');
    if(phone.replace(/\D/g,'').length<10)return showErr('Please enter a valid phone number.');
    errEl.classList.add('hidden');

    function _getCookie(n){var m=document.cookie.match(new RegExp('(?:^|;\\s*)'+n+'=([^;]+)'));return m?decodeURIComponent(m[1]):'';}
    function _qs(n){try{return new URL(location.href).searchParams.get(n)||'';}catch(e){return '';}}
    function _cleanUmtid(v){return v?String(v).replace(/[^A-Za-z0-9_-]/g,'').slice(0,40):'';}
    function _resolveUmtid(){return _cleanUmtid(_qs('umtid'))||_cleanUmtid(_getCookie('umtid'))||'';}
    function _resolveLoid(){
      var raw = _qs('loid') || _qs('lo_id') || _qs('first_touch_loid') || _getCookie('first_touch_loid') || '';
      var m = String(raw).match(/(\d{3,})/);
      return m ? m[1] : '';
    }
    var payload={
      first_name:first, last_name:last, full_name:(first+' '+last).trim(),
      email:email, phone:phone,
      form_source:'home_value_report', form_name:'Home Value Report',
      page_url:window.location.href, submitted_at:new Date().toISOString(),
      notes:'Property address: '+address,
      umtid: _resolveUmtid(),
      loid: _resolveLoid(),
      utm_source: _qs('utm_source')||_getCookie('utm_source')||'',
      utm_medium: _qs('utm_medium')||_getCookie('utm_medium')||'',
      utm_campaign: _qs('utm_campaign')||_getCookie('utm_campaign')||'',
      utm_term: _qs('utm_term')||_getCookie('utm_term')||'',
      utm_content: _qs('utm_content')||_getCookie('utm_content')||'',
      source_url: _getCookie('first_touch_url')||location.href
    };

    sending=true; btn.disabled=true; btn.textContent='Sending\u2026';
    fetch(ENDPOINT,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)})
      .then(function(){document.getElementById('hvr-form').style.display='none';document.getElementById('hvr-success').style.display='block';})
      .catch(function(){showErr('Something went wrong. Please try again or call us.');})
      .then(function(){sending=false;btn.disabled=false;btn.textContent='Get My Report';});
  });
})();
</script>
