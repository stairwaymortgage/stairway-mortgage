    s.async = true; s.defer = true;
    s.onerror = function(){};
    document.head.appendChild(s);
  }
  function attachPlaces(input){
    loadPlaces(function(){
      try{
        var ac = new google.maps.places.Autocomplete(input, {
          types:['address'], componentRestrictions:{country:'us'},
          fields:['formatted_address']
        });
        ac.addListener('place_changed', function(){ var p=ac.getPlace(); if(p&&p.formatted_address) input.value=p.formatted_address; });
        input.addEventListener('keydown', function(e){ if(e.key==='Enter') e.preventDefault(); });
      }catch(e){}
    });
  }
  document.querySelectorAll('.hvr-address-input').forEach(attachPlaces);
})();
</script>

<!-- FORM SUBMISSION + ATTRIBUTION -->
<script is:inline>
(function(){
  var wrap=document.getElementById('hvr-form');
  if(!wrap)return;
  var ENDPOINT=wrap.getAttribute('data-ghl-endpoint')||'';
  var errEl=document.getElementById('hvr-error');
  var sending=false;

  function showErr(m){errEl.textContent=m;errEl.classList.remove('hvr-hidden');}

  function _getCookie(n){var m=document.cookie.match(new RegExp('(?:^|;\\s*)'+n+'=([^;]+)'));return m?decodeURIComponent(m[1]):'';}
  function _qs(n){try{return new URL(location.href).searchParams.get(n)||'';}catch(e){return '';}}
  function _cleanUmtid(v){return v?String(v).replace(/[^A-Za-z0-9_-]/g,'').slice(0,40):'';}
  function _resolveUmtid(){return _cleanUmtid(_qs('umtid'))||_cleanUmtid(_getCookie('umtid'))||'';}
  function _resolveLoid(){
    var raw = _qs('loid') || _qs('lo_id') || _qs('first_touch_loid') || _getCookie('first_touch_loid') || '';
    var m = String(raw).match(/(\d{3,})/);
    return m ? m[1] : '';
  }

  function submitForm(ids){
    if(sending)return;
    var gotcha=document.getElementById('hvr-gotcha');
    if(gotcha&&gotcha.value.trim()!==''){showSuccess();return;}

    function val(id){var el=document.getElementById(id);return el&&el.value?el.value.trim():'';}
    var first=val(ids.first),last=val(ids.last),email=val(ids.email),phone=val(ids.phone),address=val(ids.address);

    if(!first||!last)return showErr('Please enter your first and last name.');
    if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email))return showErr('Please enter a valid email.');
    if(!address)return showErr('Please enter your property address.');
    if(phone&&phone.replace(/\D/g,'').length<10)return showErr('That phone number looks incomplete — leave it blank if you prefer not to share it.');
    errEl.classList.add('hvr-hidden');

    var payload={
      first_name:first, last_name:last, full_name:(first+' '+last).trim(),
      email:email, phone:phone,
      form_source:'home_value_report', form_name:'Home Value Report',
      page_url:window.location.href, submitted_at:new Date().toISOString(),
      notes:'Property address: '+address+(phone?'':' | (no phone — opted out of call)'),
      umtid: _resolveUmtid(),
      loid: _resolveLoid(),
      utm_source: _qs('utm_source')||_getCookie('utm_source')||'',
      utm_medium: _qs('utm_medium')||_getCookie('utm_medium')||'',
      utm_campaign: _qs('utm_campaign')||_getCookie('utm_campaign')||'',
      utm_term: _qs('utm_term')||_getCookie('utm_term')||'',
      utm_content: _qs('utm_content')||_getCookie('utm_content')||'',
      source_url: _getCookie('first_touch_url')||location.href
    };

    sending=true;
    if(ids.btn){ids.btn.disabled=true;ids.btn.dataset.label=ids.btn.textContent;ids.btn.textContent='Sending\u2026';}
    fetch(ENDPOINT,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)})
      .then(function(){showSuccess();})
      .catch(function(){showErr('Something went wrong. Please try again or call us.');})
      .then(function(){sending=false;if(ids.btn){ids.btn.disabled=false;ids.btn.textContent=ids.btn.dataset.label||'See My Home Value';}});
  }

  function showSuccess(){
    var form=document.getElementById('hvr-form');if(form)form.style.display='none';
    var s=document.getElementById('hvr-success');if(s)s.classList.remove('hvr-hidden');
    var top=document.getElementById('hvr-top');if(top&&top.scrollIntoView)top.scrollIntoView({behavior:'smooth',block:'center'});
  }

  var topBtn=document.getElementById('hvr-submit');
  if(topBtn)topBtn.addEventListener('click',function(){submitForm({first:'hvr-first',last:'hvr-last',email:'hvr-email',phone:'hvr-phone',address:'hvr-address',btn:topBtn});});
  var sndBtn=document.getElementById('hvr2-submit');
  if(sndBtn)sndBtn.addEventListener('click',function(){submitForm({first:'hvr2-first',last:'hvr2-last',email:'hvr2-email',phone:'hvr2-phone',address:'hvr2-address',btn:sndBtn});});
})();
</script>
