---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Home Value Report — Stairway Mortgage" description="See what your home is worth today. Instant property valuation.">
  <section class="section relative overflow-hidden">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="eyebrow eyebrow-blue mb-6">Tools · Home Value Report</span>
        <h1 class="display-xl mt-6 mb-6">What is your home <em class="italic text-[var(--color-blue)]">worth</em>?</h1>
        <p class="lede max-w-xl mx-auto mb-8">Get an estimate of your home value — then talk to our team about what you can do with that equity.</p>
        <div class="card max-w-lg mx-auto p-8 text-center">
          <p class="text-[14px] text-[var(--color-mute)]"><!-- TODO: Wire to valuation API --> Talk to our team for a free equity review.</p>
        </div>
        <div class="flex flex-wrap gap-3 justify-center mt-10">
          <a href="/contact-us/" class="btn btn-ghost text-base px-6 py-3.5">Talk to Our Team</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
