---
import Layout from '../../layouts/Layout.astro';
import archiveData from '../../data/archive-data.json';
import taxonomy from '../../data/taxonomy.json';

export function getStaticPaths() {
  return archiveData.categories.map((cat) => ({
    params: { slug: cat.slug },
    props: { cat },
  }));
}

const { cat } = Astro.props;

// Strip the "N. " ordering prefix for display
const displayName = cat.name.replace(/^\d+\.\s*/, '');

// Build a slug→title map from taxonomy.json posts array
const titleMap: Record<string, string> = {};
for (const p of taxonomy.posts) {
  // taxonomy slug looks like "/2025/07/29/house-hacking/" — extract last segment
  const seg = p.slug.replace(/\/$/, '').split('/').pop()!;
  titleMap[seg] = p.title;
}

const posts = cat.posts.map((slug: string) => ({
  slug,
  title: titleMap[slug] || slug.replace(/-/g, ' '),
}));

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://stairwaymortgage.com/" },
    { "@type": "ListItem", position: 2, name: "Blog", item: "https://stairwaymortgage.com/blog/" },
    { "@type": "ListItem", position: 3, name: displayName },
  ],
};
---

<Layout
  title={`${displayName} — Stairway Mortgage Blog`}
  description={`Browse all ${displayName} articles from Stairway Mortgage.`}
  canonical={`https://stairwaymortgage.com/category/${cat.slug}/`}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <header class="bl-hero">
    <div class="container-page">
      <span class="eyebrow eyebrow-blue">Category</span>
      <h1 class="display-xl bl-hero__title">{displayName}</h1>
      <p class="lede bl-hero__lede">{posts.length} article{posts.length !== 1 ? 's' : ''} in this category.</p>
    </div>
  </header>

  <section class="bl-catalog">
    <div class="container-page">
      <div class="bl-grid">
        {posts.map((p: { slug: string; title: string }) => (
          <a href={`/blog/${p.slug}/`} class="bl-card">
            <span class="bl-card__cat mono">{displayName}</span>
            <h3 class="bl-card__title">{p.title}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>

<style>
  .bl-hero { padding: clamp(3rem,7vw,5.5rem) 0 clamp(2rem,4vw,3rem); background: linear-gradient(180deg, var(--color-paper-tint), var(--color-paper)); border-bottom: 1px solid var(--color-bone); }
  .bl-hero__title { margin: 1rem 0 1.25rem; }
  .bl-hero__lede { max-width: 56ch; margin-bottom: 2rem; }
  .bl-catalog { padding: clamp(2rem,4vw,3rem) 0 clamp(3rem,7vw,5rem); }
  .bl-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(300px,1fr)); gap: 1.1rem; }
  .bl-card { position: relative; display: flex; flex-direction: column; gap: 0.6rem; padding: 1.6rem; border: 1px solid var(--color-bone); border-radius: 14px; background: var(--color-paper); text-decoration: none; transition: border-color .2s, transform .2s, box-shadow .2s; }
  .bl-card:hover { transform: translateY(-3px); box-shadow: 0 14px 34px -16px rgba(10,14,26,0.22); border-color: var(--color-blue); }
  .bl-card__cat { font-size: 10.5px; letter-spacing: 0.07em; text-transform: uppercase; color: var(--color-blue); }
  .bl-card__title { font-family: var(--stw-display, 'Fraunces'), Georgia, serif; font-weight: 500; font-size: 1.3rem; line-height: 1.18; color: var(--color-ink); letter-spacing: -0.01em; }
</style>
</Layout>
