      line-height: 1.3;
      color: var(--ink);
      margin-bottom: var(--s-3);
      letter-spacing: -0.005em;
    }.av-scope p{ margin-bottom: var(--s-4); }.av-scope p:last-child{ margin-bottom: 0; }.av-scope p.lead{
      font-size: var(--text-lg);
      line-height: 1.55;
      color: var(--ink-2);
      font-weight: 350;
    }.av-scope p.lede{
