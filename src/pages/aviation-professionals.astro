      --text-3xl: 2.75rem;   
      --text-4xl: 3.75rem;   
      --text-5xl: 5rem;      
      --s-1: 0.25rem;
      --s-2: 0.5rem;
      --s-3: 0.75rem;
      --s-4: 1rem;
      --s-5: 1.5rem;
      --s-6: 2rem;
      --s-7: 3rem;
      --s-8: 4rem;
      --s-9: 6rem;
      --s-10: 8rem;
      --s-11: 10rem;
      --serif: 'Fraunces', 'Iowan Old Style', Georgia, serif;
      --sans: 'IBM Plex Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      --mono: 'JetBrains Mono', 'SF Mono', Menlo, monospace;
    }
    @media (prefers-color-scheme: dark) {.av-scope, .av-scope{
        background-color: #FAFAF7 !important;
        color: #0A0E1A !important;
        color-scheme: light only !important;
      }.av-scope *{
        forced-color-adjust: none;
      }
    }.av-scope, .av-scope *::before, .av-scope *::after{ box-sizing: border-box; margin: 0; padding: 0; }.av-scope{ scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }.av-scope{
      font-family: var(--sans);
      font-size: var(--text-base);
      line-height: 1.6;
      color: var(--ink);
      background: var(--paper);
      font-feature-settings: 'kern' 1, 'liga' 1, 'calt' 1;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }.av-scope img, .av-scope svg{ display: block; max-width: 100%; }.av-scope a{ color: inherit; text-decoration: none; }.av-scope button{ font: inherit; cursor: pointer; border: 0; background: none; }.av-scope .container{ max-width: 1200px; margin: 0 auto; padding: 0 var(--s-6); }.av-scope .container-narrow{ max-width: 760px; margin: 0 auto; padding: 0 var(--s-6); }.av-scope .container-wide{ max-width: 1340px; margin: 0 auto; padding: 0 var(--s-6); }.av-scope .eyebrow{
