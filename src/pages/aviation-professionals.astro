      padding: var(--s-3) var(--s-5);
      font-family: var(--sans);
      font-size: var(--text-sm);
      font-weight: 500;
      letter-spacing: 0.005em;
      border-radius: 100px;
      transition: all 0.18s ease;
      white-space: nowrap;
