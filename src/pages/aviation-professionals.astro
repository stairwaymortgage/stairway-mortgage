        <a href="https://stairwaymortgage.com/aviation-professionals/aircraft-mechanic/" class="btn btn-on-dark-secondary" style="font-size: var(--text-sm);">Aircraft Mechanics &rarr;</a>
        <a href="https://stairwaymortgage.com/aviation-professionals/air-traffic-controller/" class="btn btn-on-dark-secondary" style="font-size: var(--text-sm);">Air Traffic Controllers &rarr;</a>
      </div>
    </div>
  </section>

