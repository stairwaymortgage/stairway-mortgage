---
// DonateForm.astro — Stairway Mortgage "Donate Now" multi-step MODAL.
// Native replacement for the old external GHL donation survey (JaFWaMekf5ieavS4KUSb).
//
// Mirrors the CareerApplyForm (.caf) pattern under its own .dnf scope: opens as a
// centered overlay when any [data-donate-open] trigger is clicked; closes on the X,
// backdrop click, and Esc; body scroll locked while open. Hidden by default.
//
// Self-contained: own `.dnf` scope + tokens (independent of the page's .cc-scope),
// is:inline plain JS (NO TypeScript — TS breaks the Astro build).
//
// Receipt upload reuses the live Worker (POST multipart {file, folder:"donation-receipts"}
// → JSON {url}); lead posts JSON to GHL_WEBHOOK_URL (fd7a3b30). Attribution mirrors the
// site-canonical attributionFields() (LO_MAP → lo_name etc.).
//
// USAGE:
//   import DonateForm from '../components/DonateForm.astro';
//   <button type="button" data-donate-open>Donate Now</button>
//   <DonateForm />
import { GHL_WEBHOOK_URL } from '../lib/ghl';
---

<div class="dnf-overlay" id="dnf-overlay" aria-hidden="true">
  <div class="dnf" id="dnf-root" role="dialog" aria-modal="true" aria-label="Donate Now" data-ghl-endpoint={GHL_WEBHOOK_URL}>
    <button type="button" class="dnf-close" data-donate-close aria-label="Close">&times;</button>

    <div class="dnf-card" id="dnf-form">
      <div class="dnf-progress" aria-hidden="true"><div class="dnf-progress-bar" id="dnf-bar"></div></div>
      <div class="dnf-progress-label text-mono" id="dnf-steplabel">Step 1</div>

      <div class="dnf-stage" id="dnf-stage"></div>

      <p class="dnf-error" id="dnf-error" style="display:none;"></p>

      <div class="dnf-nav">
        <button type="button" class="dnf-btn dnf-btn-ghost dnf-prev" id="dnf-prev">&larr; Back</button>
        <button type="button" class="dnf-btn dnf-btn-primary dnf-next" id="dnf-next">Next &rarr;</button>
      </div>

      <!-- honeypot: bots fill this, humans don't -->
      <input type="text" id="dnf-hp" name="donate_website_hp" tabindex="-1" autocomplete="off"
             class="dnf-hp" aria-hidden="true" />
    </div>

    <div class="dnf-success" id="dnf-success" style="display:none;">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="dnf-success-icon" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      <p class="dnf-success-title">Thank you for giving back.</p>
      <p class="dnf-success-sub">We&rsquo;ve received your donation details &mdash; our team will review your receipt and match your gift. We&rsquo;ll be in touch shortly.</p>
    </div>
  </div>
</div>

<style is:global>
  /* ============ DonateForm modal — scoped to .dnf (self-contained tokens) ============ */
  .dnf-overlay, .dnf-overlay * { box-sizing: border-box; }
  .dnf-overlay {
    position: fixed; inset: 0; z-index: 99999; display: none;
    background: rgba(10,14,26,0.55); backdrop-filter: blur(3px);
    align-items: center; justify-content: center; padding: 20px;
    font-family: 'IBM Plex Sans', system-ui, -apple-system, sans-serif;
  }
  .dnf-overlay.dnf-active { display: flex; }

  .dnf {
    --ink: #0A0E1A; --ink-2: #1E2433; --ink-lighter: #6B7280;
    --paper: #FAFAF7; --paper-2: #F4F4EE; --paper-3: #EDEDE5; --white: #FFFFFF;
    --blue: #1845D6; --blue-deep: #0F2EA0; --gold: #B8860B;
    --border: #E5E5DE; --border-strong: #D4D4C8;
    --serif: 'Fraunces', 'Iowan Old Style', Georgia, serif;
    --sans: 'IBM Plex Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    --mono: 'JetBrains Mono', 'SF Mono', Menlo, monospace;
    position: relative; width: 100%; max-width: 560px; max-height: 92vh; overflow-y: auto;
    background: var(--paper); border-radius: 16px; padding: 30px 30px 28px;
    box-shadow: 0 30px 90px rgba(0,0,0,0.38); color: var(--ink);
    font-family: var(--sans); text-align: left;
  }
  @media (max-width: 480px) { .dnf { padding: 40px 18px 22px; border-radius: 14px; } }

  .dnf-close {
    position: absolute; top: 14px; right: 18px; z-index: 2;
    border: 0; background: none; font-size: 30px; line-height: 1; color: var(--ink);
    cursor: pointer; opacity: .45; padding: 0;
  }
  .dnf-close:hover { opacity: 1; }

  .dnf-progress { height: 6px; border-radius: 99px; background: var(--paper-3); overflow: hidden; margin-top: 4px; }
  .dnf-progress-bar { height: 100%; width: 0%; background: var(--blue); border-radius: 99px; transition: width .35s cubic-bezier(.4,0,.2,1); }
  .dnf-progress-label { font-family: var(--mono); font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: var(--ink-lighter); margin: 12px 0 20px; }
  .dnf .text-mono { font-family: var(--mono); }

  .dnf-stage { min-height: 150px; }
  .dnf-q { font-family: var(--serif); font-size: 26px; font-weight: 500; line-height: 1.2; letter-spacing: -.01em; color: var(--ink); margin: 0 0 6px; }
  .dnf-sub { font-size: 14px; color: var(--ink-lighter); line-height: 1.5; margin: 0 0 22px; }
  .dnf-q:only-child { margin-bottom: 22px; }

  .dnf-field { margin-top: 6px; }
  .dnf-input {
    width: 100%; padding: 14px 16px; border: 1px solid var(--border-strong); border-radius: 8px;
    font-size: 16px; font-family: var(--sans); color: var(--ink); background: var(--white); outline: none;
    transition: border-color .15s, box-shadow .15s;
  }
  .dnf-input::placeholder { color: #a6a6a0; }
  .dnf-input:focus { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(24,69,214,.12); }
  .dnf-textarea { resize: vertical; min-height: 110px; line-height: 1.5; }

  /* file */
  .dnf-file { width: 100%; padding: 12px; border: 1px dashed var(--border-strong); border-radius: 8px; font-size: 14px; cursor: pointer; background: var(--white); }
  .dnf-file::file-selector-button {
    font-family: var(--sans); font-size: 12px; font-weight: 600; margin-right: 12px; padding: 8px 12px;
    border: 1px solid var(--border-strong); border-radius: 6px; background: var(--paper-2); color: var(--ink); cursor: pointer;
  }
  .dnf-file::file-selector-button:hover { background: var(--paper-3); border-color: var(--ink); }
  .dnf-filenote { margin-top: 10px; font-family: var(--mono); font-size: 13px; color: #2E9E2E; }
  .dnf-skip { display: none; margin-top: 12px; background: none; border: 0; color: var(--blue); font-size: 13px; text-decoration: underline; cursor: pointer; padding: 0; font-family: var(--sans); }

  /* radio / options */
  .dnf-options { display: grid; gap: 10px; }
  .dnf-opt {
    display: flex; align-items: center; gap: 12px; cursor: pointer; user-select: none;
    border: 1.5px solid var(--border-strong); border-radius: 10px; padding: 14px 16px;
    background: var(--white); font-size: 15px; color: var(--ink); transition: border-color .15s, background .15s;
  }
  .dnf-opt:hover { border-color: var(--ink); background: var(--paper-2); }
  .dnf-opt.dnf-sel { border-color: var(--blue); background: #F2F5FF; }
  .dnf-opt input { width: 18px; height: 18px; accent-color: var(--blue); flex: 0 0 auto; }

  /* consent */
  .dnf-consent-row { display: flex; gap: 12px; align-items: flex-start; cursor: pointer; font-size: 13px; line-height: 1.55; color: var(--ink-2); }
  .dnf-consent-row input { width: 18px; height: 18px; accent-color: var(--blue); flex: 0 0 auto; margin-top: 2px; }
  .dnf-consent-links { margin-top: 14px; font-size: 12px; color: var(--ink-lighter); }
  .dnf-consent-links a { color: var(--blue); text-decoration: underline; }

  .dnf-error { font-size: 13px; color: #c0392b; margin: 16px 0 0; }

  .dnf-nav { display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-top: 26px; }
  .dnf-btn { font-family: var(--sans); font-size: 15px; font-weight: 500; border-radius: 100px; padding: 13px 26px; cursor: pointer; border: 1px solid transparent; transition: all .15s; }
  .dnf-btn-primary { background: var(--ink); color: var(--paper); border-color: var(--ink); }
  .dnf-btn-primary:hover:not(:disabled) { background: var(--blue); border-color: var(--blue); }
  .dnf-btn-primary:disabled { opacity: .4; cursor: default; }
  .dnf-btn-ghost { background: transparent; color: var(--ink); border-color: var(--border-strong); }
  .dnf-btn-ghost:hover { border-color: var(--ink); }

  .dnf-hp { position: absolute !important; left: -9999px !important; width: 1px !important; height: 1px !important; opacity: 0 !important; }

  .dnf-success { text-align: center; padding: 34px 10px 24px; }
  .dnf-success-icon { color: #2ecc71; margin: 0 auto 16px; display: block; }
  .dnf-success-title { font-family: var(--serif); font-size: 24px; font-weight: 500; margin: 0 0 10px; color: var(--ink); }
  .dnf-success-sub { font-size: 15px; color: var(--ink-2); max-width: 40ch; margin: 0 auto; line-height: 1.5; }
</style>

<script is:inline>
(function(){
  var overlay=document.getElementById('dnf-overlay');
  var root=document.getElementById('dnf-root');
  if(!overlay||!root)return;
  var ENDPOINT=root.getAttribute('data-ghl-endpoint')||'';
  var UPLOAD_ENDPOINT='https://stairway-upload.jimb-3a9.workers.dev';

  var formEl=document.getElementById('dnf-form');
  var successEl=document.getElementById('dnf-success');
  var stage=document.getElementById('dnf-stage');
  var bar=document.getElementById('dnf-bar');
  var stepLabel=document.getElementById('dnf-steplabel');
  var prevBtn=document.getElementById('dnf-prev');
  var nextBtn=document.getElementById('dnf-next');
  var errEl=document.getElementById('dnf-error');

  // ---- 12-step sequence (mirrors the original GHL donation survey order) ----
  var steps=[
    { key:'how_much_did_you_donate_we_match_up_to_100', type:'number', required:true, q:'How much did you donate?', sub:'We match up to $100.', placeholder:'e.g. 100' },
    { key:'donation_receipt_url', type:'file', folder:'donation-receipts', q:'Upload your donation receipt', sub:'PDF or image. Optional — you can continue without it.', accept:'.pdf,.jpg,.jpeg,.png,.webp' },
    { key:'how_would_you_like_your_donor_name_to_appear_online', type:'radio', required:true, q:'How would you like your donor name to appear online?',
      options:['Personal Name','Business Name','Anonymous'] },
    { key:'what_is_the_name_of_the_organization_you_donated_to', type:'text', q:'Name of the organization you donated to', placeholder:'Organization name' },
    { key:'what_is_the_phone_number_of_the_organization_you_donated_to', type:'tel', q:'Phone number of the organization', placeholder:'(555) 555-5555' },
    { key:'what_is_the_email_of_the_organization_you_donated_to', type:'email', q:'Email of the organization', placeholder:'org@email.com' },
    { key:'what_is_the_full_name_of_your_contact_at_the_organization_you_donated_to', type:'text', q:'Your contact’s name at the organization', placeholder:'First and last' },
    { key:'full_name', type:'text', required:true, q:'What’s your full name?', placeholder:'First and last' },
    { key:'company', type:'text', q:'Your business name', sub:'If applicable.', placeholder:'Business name' },
    { key:'email', type:'email', required:true, q:'What’s your email?', placeholder:'you@email.com' },
    { key:'phone', type:'tel', required:true, q:'What’s your mobile phone number?', placeholder:'(555) 555-5555' },
    { key:'sms_consent', type:'consent', required:true, submit:true, q:'One last thing' }
  ];

  var state={
    how_much_did_you_donate_we_match_up_to_100:'', donation_receipt_url:'',
    how_would_you_like_your_donor_name_to_appear_online:'',
    what_is_the_name_of_the_organization_you_donated_to:'',
    what_is_the_phone_number_of_the_organization_you_donated_to:'',
    what_is_the_email_of_the_organization_you_donated_to:'',
    what_is_the_full_name_of_your_contact_at_the_organization_you_donated_to:'',
    full_name:'', company:'', email:'', phone:'', sms_consent:false
  };
  var idx=0, uploading=false, sending=false;

  function el(tag,cls){ var n=document.createElement(tag); if(cls)n.className=cls; return n; }
  function esc(t){ var d=document.createElement('div'); d.textContent=(t==null?'':t); return d.innerHTML; }
  function showErr(m){ errEl.textContent=m; errEl.style.display='block'; }
  function hideErr(){ errEl.style.display='none'; }

  // ---- attribution (mirrors the site-canonical attributionFields() in PurchaseForm) ----
  function getCookie(name){var m=document.cookie.match(new RegExp('(?:^|;\\s*)'+name+'=([^;]+)'));return m?decodeURIComponent(m[1]):null;}
  function qs(name){try{return new URL(location.href).searchParams.get(name)||null;}catch(e){return null;}}
  var LO_MAP={ "1072866": { name:"Jim Blackburn", slug:"jim-blackburn" }, "1072877": { name:"Dhruv Parashar", slug:"dhruv-parashar" } };
  function loidNum(){ var raw=getCookie('first_touch_loid')||qs('lo_id')||qs('loid')||qs('first_touch_loid'); if(!raw) return null; var m=String(raw).match(/(\d{3,})/); return m?m[1]:null; }
  function cleanUmtid(v){return v?String(v).replace(/[^A-Za-z0-9_-]/g,'').slice(0,40):'';}
  function attributionFields(){
    var num=loidNum(); var lo=num&&LO_MAP[num]?LO_MAP[num]:null;
    return {
      loid: num||"", lo_id: num||"", lo_name: lo?lo.name:"", lo_slug: lo?lo.slug:"",
      loan_officer_name: lo?lo.name:"",                      // captured dynamically, never hardcoded
      umtid: cleanUmtid(qs('umtid'))||cleanUmtid(getCookie('umtid'))||"",
      utm_source:qs('utm_source')||getCookie('utm_source')||"", utm_medium:qs('utm_medium')||getCookie('utm_medium')||"",
      utm_campaign:qs('utm_campaign')||getCookie('utm_campaign')||"", utm_term:qs('utm_term')||getCookie('utm_term')||"",
      utm_content:qs('utm_content')||getCookie('utm_content')||"",
      source_url: getCookie('first_touch_url')||window.location.href
    };
  }

  function isValid(){
    var s=steps[idx]; var v=state[s.key];
    if(s.type==='file') return true;                       // optional; upload happens on Next
    if(s.type==='radio') return s.required?!!v:true;
    if(s.type==='text'||s.type==='textarea'||s.type==='number') return s.required?!!(v&&String(v).trim()):true;
    if(s.type==='email') return s.required?/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test((v||'').trim()):true;
    if(s.type==='tel')   return s.required?((v||'').replace(/\D/g,'').length>=10):true;
    if(s.type==='consent') return state.sms_consent===true;
    return true;
  }
  function updateNext(){ nextBtn.disabled = (!isValid()) || uploading || sending; }

  function enterGuard(e){
    if(e.key!=='Enter') return;
    e.preventDefault();
    if(!steps[idx].submit && isValid()) goNext();   // Enter advances; never auto-submits
  }

  function render(){
    var s=steps[idx];
    stage.innerHTML='';
    var head=el('div');
    head.innerHTML='<div class="dnf-q">'+esc(s.q)+'</div>'+(s.sub?'<div class="dnf-sub">'+esc(s.sub)+'</div>':'');
    stage.appendChild(head);
    hideErr();

    if(s.type==='file'){
      var fwrap=el('div','dnf-field');
      var inp=el('input','dnf-file'); inp.type='file'; inp.id='dnf-file'; if(s.accept) inp.accept=s.accept;
      inp.addEventListener('change',function(){ state[s.key]=''; hideErr(); var sk=document.getElementById('dnf-skip'); if(sk)sk.style.display='none'; });
      fwrap.appendChild(inp);
      if(state[s.key]){ var ok=el('div','dnf-filenote'); ok.textContent='✓ Uploaded'; fwrap.appendChild(ok); }
      var skip=el('button','dnf-skip'); skip.type='button'; skip.id='dnf-skip'; skip.textContent='Continue without a receipt';
      skip.addEventListener('click',function(){ advance(); });
      fwrap.appendChild(skip);
      stage.appendChild(fwrap);
    }
    else if(s.type==='text'||s.type==='email'||s.type==='tel'||s.type==='number'){
      var f=el('div','dnf-field');
      var input=el('input','dnf-input');
      input.type=(s.type==='text'?'text':s.type); input.placeholder=s.placeholder||''; input.value=state[s.key]||'';
      if(s.type==='tel') input.setAttribute('inputmode','tel');
      if(s.type==='number'){ input.setAttribute('inputmode','decimal'); input.min='0'; }
      input.addEventListener('input',function(){ state[s.key]=input.value; updateNext(); });
      input.addEventListener('keydown',enterGuard);
      f.appendChild(input); stage.appendChild(f);
      setTimeout(function(){ try{ input.focus(); }catch(e){} },50);
    }
    else if(s.type==='radio'){
      var rbox=el('div','dnf-options');
      s.options.forEach(function(opt){
        var lab=el('label','dnf-opt'+(state[s.key]===opt?' dnf-sel':''));
        var rb=document.createElement('input'); rb.type='radio'; rb.name='dnf-radio-'+idx; rb.value=opt; rb.checked=(state[s.key]===opt);
        rb.addEventListener('change',function(){
          state[s.key]=opt;
          Array.prototype.forEach.call(rbox.querySelectorAll('.dnf-opt'),function(n){ n.classList.remove('dnf-sel'); });
          lab.classList.add('dnf-sel');
          updateNext();
        });
        lab.appendChild(rb); var sp=document.createElement('span'); sp.textContent=opt; lab.appendChild(sp);
        rbox.appendChild(lab);
      });
      stage.appendChild(rbox);
    }
    else if(s.type==='consent'){
      var c=el('div','dnf-consent');
      var lab=el('label','dnf-consent-row');
      var cb=document.createElement('input'); cb.type='checkbox'; cb.id='dnf-consent-cb'; cb.checked=!!state.sms_consent;
      cb.addEventListener('change',function(){ state.sms_consent=cb.checked; updateNext(); });
      var txt=document.createElement('span');
      txt.innerHTML='I consent to receive SMS notifications, alerts &amp; occasional marketing communication from Stairway Mortgage. Message frequency varies. Message &amp; data rates may apply. Text HELP to (954) 993-1625 for assistance. Reply STOP to unsubscribe.';
      lab.appendChild(cb); lab.appendChild(txt); c.appendChild(lab);
      var links=el('div','dnf-consent-links');
      links.innerHTML='<a href="/privacy/" target="_blank" rel="noopener">Privacy Policy</a> &middot; <a href="/terms/" target="_blank" rel="noopener">Terms</a>';
      c.appendChild(links);
      stage.appendChild(c);
    }

    var total=steps.length;
    bar.style.width=Math.round(((idx+1)/total)*100)+'%';
    stepLabel.textContent='Step '+(idx+1)+' of '+total;
    prevBtn.style.visibility = idx===0 ? 'hidden' : 'visible';
    nextBtn.textContent = s.submit ? 'Submit Donation' : 'Next →';
    updateNext();
  }

  function advance(){ if(idx<steps.length-1){ idx++; render(); } }
  function goPrev(){ if(idx>0){ idx--; render(); } }

  function goNext(){
    if(uploading||sending) return;
    var s=steps[idx];
    if(!isValid()) return;

    if(s.type==='file'){
      var fi=document.getElementById('dnf-file');
      var file=(fi&&fi.files&&fi.files[0])?fi.files[0]:null;
      if(file && !state[s.key]){
        // Upload to the R2 Worker FIRST, then advance. No manual Content-Type
        // (browser sets the multipart boundary). folder from the step.
        uploading=true; updateNext(); nextBtn.textContent='Uploading…'; hideErr();
        var fd=new FormData(); fd.append('file',file); fd.append('folder',s.folder||'uploads');
        fetch(UPLOAD_ENDPOINT,{method:'POST',body:fd})
          .then(function(res){ if(!res.ok) throw new Error('upload '+res.status); return res.json(); })
          .then(function(data){ state[s.key]=(data&&data.url)?data.url:''; uploading=false; nextBtn.textContent='Next →'; advance(); })
          .catch(function(){
            uploading=false; nextBtn.textContent='Next →'; updateNext();
            showErr('We couldn’t upload that file — try again, or continue without it.');
            var sk=document.getElementById('dnf-skip'); if(sk) sk.style.display='inline-block';
          });
        return;
      }
      advance(); return;
    }

    if(s.submit){ submit(); return; }
    advance();
  }

  function submit(){
    if(sending) return;
    var hp=document.getElementById('dnf-hp');
    if(hp && hp.value.trim()!==''){ showSuccess(); return; }   // honeypot: fake success, no POST
    if(!state.sms_consent){ showErr('Please agree to the SMS consent to submit.'); return; }

    var parts=(state.full_name||'').trim().split(/\s+/);
    var first=parts.shift()||''; var last=parts.join(' ')||'';
    var attr=attributionFields();
    var payload={
      form_source:'donate_now', form_name:'Donate Now',
      first_name:first, last_name:last, full_name:(state.full_name||'').trim(),
      email:(state.email||'').trim(), phone:(state.phone||'').trim(),
      page_url:window.location.href, submitted_at:new Date().toISOString()
    };
    // Copy each collected answer into the payload under its own (already-GHL) key.
    // Handled separately: name/email/phone/consent (standard) and company (aliased below).
    var skip={ full_name:1, email:1, phone:1, sms_consent:1, company:1 };
    for(var k in state){ if(state.hasOwnProperty(k) && !skip[k]){ payload[k]=(state[k]==null?'':state[k]); } }
    // Business name → standard `company` key + `business_name` fallback alias.
    payload.company=(state.company||'').trim();
    payload.business_name=(state.company||'').trim();
    payload.sms_consent = state.sms_consent ? 'yes' : 'no';
    payload.loid=attr.loid; payload.lo_id=attr.lo_id; payload.lo_name=attr.lo_name; payload.lo_slug=attr.lo_slug;
    payload.loan_officer_name=attr.loan_officer_name; payload.umtid=attr.umtid;
    payload.utm_source=attr.utm_source; payload.utm_medium=attr.utm_medium; payload.utm_campaign=attr.utm_campaign;
    payload.utm_term=attr.utm_term; payload.utm_content=attr.utm_content; payload.source_url=attr.source_url;

    sending=true; nextBtn.disabled=true; nextBtn.textContent='Sending…';
    fetch(ENDPOINT,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)})
      .then(function(){ showSuccess(); })
      .catch(function(){ showErr('Something went wrong. Please try again, or call us at (954) 993-1625.'); })
      .then(function(){ sending=false; nextBtn.disabled=false; nextBtn.textContent='Submit Donation'; });
  }

  function showSuccess(){ formEl.style.display='none'; successEl.style.display='block'; }

  // ---- modal open/close (mirrors CareerApplyForm) ----
  function openModal(){ overlay.classList.add('dnf-active'); overlay.setAttribute('aria-hidden','false'); document.body.style.overflow='hidden'; }
  function closeModal(){ overlay.classList.remove('dnf-active'); overlay.setAttribute('aria-hidden','true'); document.body.style.overflow=''; }
  window.STW_OPEN_dnf=openModal;

  nextBtn.addEventListener('click',goNext);
  prevBtn.addEventListener('click',goPrev);
  document.addEventListener('click',function(e){
    var o=e.target.closest?e.target.closest('[data-donate-open]'):null; if(o){ e.preventDefault(); openModal(); }
    var c=e.target.closest?e.target.closest('[data-donate-close]'):null; if(c){ e.preventDefault(); closeModal(); }
  });
  overlay.addEventListener('click',function(e){ if(e.target===overlay){ closeModal(); } });
  document.addEventListener('keydown',function(e){ if(e.key==='Escape'&&overlay.classList.contains('dnf-active')){ closeModal(); } });

  render();   // pre-render step 1 (overlay stays hidden until a trigger opens it)
})();
</script>
