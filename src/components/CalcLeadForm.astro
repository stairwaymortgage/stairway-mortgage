      'no-doc-loan-refinance': 'nodoc_refinance_rate_reduction',
      'no-doc-loan-cash-out-refinance': 'nodoc_cashout_refinance',
      'non-warrantable-condo-loan': 'nonwarrantable_condo_purchase',
      'non-warrantable-condo-loan-refinance': 'nonwarrantable_condo_refinance',
      'non-warrantable-condo-loan-cash-out-refinance': 'nonwarrantable_condo_cashout_refinance',
      'resort-condo-loan': 'resort_condo_purchase',
      'resort-condo-loan-refinance': 'resort_condo_refinance',
      'resort-condo-loan-cash-out-refinance': 'resort_condo_cashout_refinance',
      'section-184-loan': 'section_184_purchase',
      'section-184-loan-refinance': 'section_184_refinance',
      'section-184-loan-cash-out-refinance': 'section_184_cashout_refinance',
      'hard-money-loan': 'hard_money_loan',
      'home-equity-loan': 'home_equity_loan',
      'home-improvement-loan': 'home_improvement_loan',
      'p-and-l-loan': 'pl_loan_purchase',
      'usda-construction-loan': 'usda_new_construction',
      'build-to-rent': 'build_to_rent',
      'rental-property-calculator': 'buy_and_hold_cashflow_appreciation',
      'passive-income-calculator': 'passive_income_and_tax_advantage',
      'legacy-planning-calculator': 'legacy_impact_planner',
      'telemarketing-revenue-calculator': 'phone_profit_calculator',
      // --- End newly-created fields ---
      '1031-exchange-calculator': '1031_exchange_capital_gains_tax_savings__purchase_calculator_results',
      '1099-loan': '1099_mortgage_calculator',
      '15-vs-30-year-mortgage-rate-comparison': '15_vs_30_year_mortgage_rate_comparison',
      '50-30-20-budget-calculator': '50_30_20_budget_calculator',
      'anti-steering-disclosure': 'antisteering_disclosure_calculator_results',
      'bah-home-affordability-calculator': 'bah_home_affordability_calculator',
      'bridge-loan': 'bridge_loan_capital_gains_tax_exclusion__payment_recast_calculator_results',
      'brrrr-method': 'brrrr_method_calculator_buy_rehab_rent_refi_cash_out_repeat_results',
      'build-to-sell': 'build_to_sell_spec_home_calculator_purchase_teardown_build_sell_profit_results',
      'closing-costs-calculator-for-buyer': 'closing_costs_calculator_for_buyer',
      'college-costs-calculator': 'college_housing_costs_vs_investment_property_results',
      'compare-3-rate-payments-points-only': 'compare_3_ratepayments__points_only_results',
      'compare-3-rate-payments-total-costs': 'compare_3_ratepayments__total_costs_results',
      'compare-mortgage-rates-calculator': 'compare_2_rates_interest_costs_results',
      'conventional-construction-loan': 'conventional_new_construction_loan_payment_calculator_results',
      'conventional-loan': 'conventional_purchase_loan_payment_calculator_results',
      'conventional-loan-cash-out-refinance': 'conventional_cashout_refinance_loan_payment_calculator_results',
      'conventional-loan-refinance': 'conventional_refinance_rate_reduction_loan_payment_calculator_results',
      'debt-ratio-calculator': 'debt_ratio_calculator',
      'debt-service-coverage-ratio-calculator': 'dscr_investment_purchase_loan_payment_calculator_results',
      'dscr-loan': 'dscr_investment_purchase_loan_payment_calculator_results',
      'property-management-cost-calculator': 'dscr_investment_purchase_loan_payment_calculator_results',
      'dscr-loan-refinance': 'dscr_investment_rate_reduction_refinance_results',
      'down-payment-assistance': 'fha_purchase_loan_payment_calculator_results',
      'estimate-mortgage-payment': 'estimate_mortgage_payment',
      'fha-203k-loan': 'fha_203k_renovation_purchase_loan_payment_calculator_results',
      'fha-203k-loan-refinance': 'fha_203k_renovation_refinance_loan_payment_calculator_results',
      'fha-construction-loan': 'fha_new_construction_loan_payment_calculator_results',
      'fha-loan': 'fha_purchase_loan_payment_calculator_results',
      'fha-loan-cash-out-refinance': 'fha_cashout_refinance_loan_payment_calculator_results',
      'fha-loan-multifamily': 'fha_24_unit_home_purchase_cash_flow_appreciation_calculator_results',
      'fha-loan-refinance': 'fha_streamline_refinance_rate_reduction_savings_calculator_results',
      'fha-streamline-refinance': 'fha_streamline_refinance_rate_reduction_savings_calculator_results',
      'fix-and-flip-loan': 'fixandflip_profit_calculator_buysell_results',
      'flood-insurance-calculator': 'flood_insurance_calculator',
      'heloc': 'heloc_loan_payment_calculator_results',
      'home-affordability-calculator': 'home_affordability_calculator_to_ghl',
      'homestyle-renovation-loan': 'conventional_renovation_homestyle_purchase_loan_payment_calculator_results',
      'homestyle-renovation-loan-refinance': 'conventional_renovation_homestyle_refinance_loan_payment_calculator_results',
      'house-insurance-cost-calculator': 'house_insurance_cost_calculator',
      'how-to-calculate-my-net-worth': 'how_to_calculate_my_net_worth',
      'interest-only-payment-calculator': 'interest_only_payment_calculator',
      'investment-growth-calculator': 'investment_growth_calculator_results',
      'jumbo-construction-loan': 'jumbo_ground_up_construction_payoff_tear_down__build_calculator_results',
      'jumbo-loan': 'jumbo_purchase_loan_payment_calculator_results',
      'jumbo-loan-cash-out-refinance': 'jumbo_cashout_refinance_loan_payment_calculator_results',
      'jumbo-loan-refinance': 'jumbo_refinance_rate_reduction_loan_payment_calculator_results',
      'jumbo-loan-purchase-renovation': 'jumbo_renovation_purchase_loan_payment_calculator_results',
      'jumbo-loan-renovation-refinance': 'jumbo_renovation_refinance_loan_payment_calculator_results',
      'military-tax-benefits-calculator': 'military_tax_benefits_calculator',
      'mortgage-income-calculator': 'mortgage_income_calculator',
      'mortgage-payoff-calculator-with-extra-payments': 'mortgage_payoff_calculator_with_extra_payments',
      'multifamily-loan-calculator': 'multifamily_loan_calculator',
      'net-proceeds-calculator': 'net_proceeds_calculator',
      'portfolio-analyzers': 'portfolio_analyzers',
      'property-value-estimator': 'property_value_estimator',
      'rate-buy-down-calculator': 'rate_buy_down_calculator',
      'renovation-estimator': 'renovation_estimator',
      'rent-versus-buying-a-home-calculator': 'rent_versus_buying_a_home_calculator',
      'reserves-calculation': 'reserves_calculation',
      'reverse-mortgage': 'reverse_mortgage_home_purchase_loan_calculator_results',
      'reverse-mortgage-cash-out-refinance': 'reverse_mortgage_cash_out_refinance_calculator_results',
      'reverse-mortgage-income': 'reverse_mortgage_legacy_inheritance_estimator_results',
      'reverse-mortgage-legacy': 'reverse_mortgage_legacy_inheritance_estimator_results',
      'spiritual-influence-calculator': 'spiritual_impact_calculator_results',
      'usda-loan': 'usda_purchase_loan_payment_calculator_results',
      'usda-loan-cash-out-refinance': 'usda_cash_out_refinance_loan_payment_calculator_results',
      'usda-loan-refinance': 'usda_refinance_interest_rate_reduction_loan_payment_calculator_results',
      'usda-loan-renovation': 'usda_refinance_interest_rate_reduction_loan_payment_calculator_results',
      'va-construction-loan': 'va_new_construction_loan_payment_calculator_results',
      'va-high-balance-loan': 'va_high_balance_purchase_loan_payment_calculator_results',
      'va-irrrl': 'va_irrrl_refinance_interest_rate_reduction_loan_calculator_results',
      'va-loan': 'va_purchase_loan_payment_calculator_results',
      'va-loan-cash-out-refinance': 'va_cash_out_refinance_loan_payment_calculator_results',
      'va-loan-refinance-renovation': 'va_renovation_refinance_loan_payment_calculator_results',
      'va-loan-purchase-renovation': 'va_renovation_purchase_loan_payment_calculator_results',
      'spec-home-loan-acquisition-and-development': 'build_to_sell_spec_home_calculator_purchase_teardown_build_sell_profit_results'
    };

    // ---------- DOM scraping (one component, all pages) ----------
    function cleanText(s) { return (s || '').replace(/\s+/g, ' ').trim(); }

    function labelFor(el) {
      var lbl = null;
      if (el.id) {
        try { lbl = document.querySelector('label[for="' + (window.CSS && CSS.escape ? CSS.escape(el.id) : el.id) + '"]'); } catch (e) {}
      }
      if (!lbl) {
        var f = el.closest('.field');
        if (f) lbl = f.querySelector('label, .lbl');
      }
      if (!lbl) return '';
      var clone = lbl.cloneNode(true);
      // The live slider value lives in a .slider-out span INSIDE the label —
      // strip it so the label isn't duplicated with the value.
      var outs = clone.querySelectorAll('.slider-out');
      for (var i = 0; i < outs.length; i++) outs[i].parentNode.removeChild(outs[i]);
      return cleanText(clone.textContent).replace(/[: \s]+$/, '');
    }

    function valueFor(el) {
      if (el.tagName === 'SELECT') {
        return el.selectedOptions && el.selectedOptions[0] ? cleanText(el.selectedOptions[0].text) : '';
      }
      if (el.type === 'range') {
        var f = el.closest('.field');
        var out = f ? f.querySelector('.slider-out') : null;
        return out ? cleanText(out.textContent) : cleanText(el.value); // unit already in slider-out
      }
      var v = cleanText(el.value);
      if (v === '') return '';
      if (el.closest('.input-money')) v = '$' + v;
      var f2 = el.closest('.field');
      if (f2) {
        var suf = f2.querySelector('.suffix');
        if (suf && suf.textContent.indexOf('%') !== -1) v = v + '%';
      }
      return v;
    }

    function scrapeInputs() {
      var out = [];
      var rootIn = document.querySelector('.calc-inputs');
      if (!rootIn) return out;

      // Radio groups: one entry per group, value = the checked option's text.
      var seen = {};
      var radios = rootIn.querySelectorAll('input[type="radio"]');
      for (var i = 0; i < radios.length; i++) {
        var name = radios[i].name;
        if (!name || seen[name]) continue;
        seen[name] = true;
        var field = radios[i].closest('.field');
        var label = '';
        if (field) {
          var grp = field.querySelector('.lbl');
          label = grp ? cleanText(grp.textContent) : '';
        }
        var checked = rootIn.querySelector('input[name="' + (window.CSS && CSS.escape ? CSS.escape(name) : name) + '"]:checked');
        var val = '';
        if (checked) {
          var wrap = checked.closest('label');
          val = wrap ? cleanText(wrap.textContent) : checked.value;
        }
        if (label && val) out.push(label + ': ' + val);
      }

      // Everything else: text/number/select/range (skip hidden, radio, checkbox, honeypot).
      var els = rootIn.querySelectorAll('input:not([type="radio"]):not([type="checkbox"]):not([type="hidden"]), select');
      for (var j = 0; j < els.length; j++) {
        var el = els[j];
        if (el.offsetParent === null && el.type !== 'range') continue; // hidden / collapsed
        var lab = labelFor(el);
        var v = valueFor(el);
        if (lab && v !== '') out.push(lab + ': ' + v);
      }
      return out;
    }

    function scrapeResults() {
      var out = [];
      var rootR = document.querySelector('.calc-results');
      if (!rootR) return out;
      var rows = rootR.querySelectorAll('.result'); // includes dynamic rows (e.g. #yearRows); .summary-sub headers are <p>, skipped
      for (var i = 0; i < rows.length; i++) {
        var lbl = rows[i].querySelector('.result-label');
        var val = rows[i].querySelector('.result-value');
        if (!lbl || !val) continue;
        var lt = cleanText(lbl.textContent);
        var vt = cleanText(val.textContent);
        if (lt && vt) out.push(lt + ': ' + vt);
      }
      return out;
    }

    function scrape(slug) {
      var h1 = document.querySelector('h1');
      var title = h1 ? cleanText(h1.textContent) : '';
      var inputs = scrapeInputs();
      var results = scrapeResults();
      var notes = 'Calculator: ' + title +
                  '\n\nINPUTS\n' + inputs.join('\n') +
                  '\n\nRESULTS\n' + results.join('\n');
      captured = { slug: slug, notes: notes, title: title };
    }

    // ---------- open / close ----------
    function open(slug) {
      scrape(slug);
      if (titleEl && captured.title) titleEl.textContent = captured.title;
      form.hidden = false;
      thanks.hidden = true;
      errorEl.hidden = true;
      root.classList.add('clf-open');
      root.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      var first = document.getElementById('clf-first');
      if (first) setTimeout(function () { first.focus(); }, 30);
    }
    function close() {
      root.classList.remove('clf-open');
      root.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    // Delegate so it works no matter where the CTA sits on the page.
    document.addEventListener('click', function (e) {
      var cta = e.target.closest ? e.target.closest('[data-calc-cta]') : null;
      if (cta) {
        e.preventDefault();
        open(cta.getAttribute('data-calc-slug') || '');
        return;
      }
      if (e.target.closest && e.target.closest('[data-clf-close]')) { close(); return; }
      if (e.target === overlay) { close(); }
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && root.classList.contains('clf-open')) close();
    });

    // ---------- submit ----------
    function showError(msg) { errorEl.textContent = msg; errorEl.hidden = false; }

    function send(payload) {
      // Mirrors src/lib/ghl.ts submitToGHL semantics (URL sourced from ghl.ts).
      return fetch(ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault(); // Enter-key + button both land here; no native navigation.
      if (sending) return;

      // Honeypot — silently "succeed".
      var gotcha = form.querySelector('[name="_gotcha"]');
      if (gotcha && gotcha.value.trim() !== '') { form.hidden = true; thanks.hidden = false; return; }

      var first = cleanText(form.first.value);
      var last  = cleanText(form.last.value);
      var email = cleanText(form.email.value);
      var phone = cleanText(form.phone.value);

      if (!first || !last) return showError('Please enter your first and last name.');
      var _em=email.trim(); if(!/^[^\s@]{2,}@[^\s@]+\.[A-Za-z]{2,}$/.test(_em)||/\.\./.test(_em)) return showError('Please enter a valid email address.');
      var _pd=phone.replace(/\D/g,''); if(_pd.length<10||_pd.length>15) return showError('Please enter a valid phone number.');
      errorEl.hidden = true;

      // Key names mirror the confirmed-working GetLocalIntroForm payload exactly
      // (snake_case) so GHL's inbound-webhook contact mapping picks up name + phone.
      var payload = {
        first_name: first,
        last_name: last,
        full_name: (first + ' ' + last).trim(),
        email: email,
        phone: phone,
        form_source: 'calc_' + captured.slug,
        form_name: captured.title,
        page_url: location.href,
        submitted_at: new Date().toISOString(),
        umtid: _resolveUmtid(),
        loid: _resolveLoid(),
        source_url: location.href
      };
      // Snapshot goes under the slug's dedicated GHL field key if mapped, else "notes".
      payload[FIELD_MAP[captured.slug] || 'notes'] = captured.notes;

      sending = true;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';

      send(payload)
        .then(function () { form.hidden = true; thanks.hidden = false; })
        .catch(function () {
          // Network/CORS failure — surface so we don't fake success during testing.
          showError('Something went wrong. Please try again or call us.');
        })
        .then(function () {
          sending = false;
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send My Results';
        });
    });
  })();
</script>

<style>
  /* Tokens (hardcoded — shared component must not depend on per-page CSS vars) */
  #calc-lead-root { --clf-ink:#0A0E1A; --clf-paper:#FAFAF7; --clf-blue:#1845D6; --clf-bone:#E7E4DA; --clf-mute:#6B7280; }
  #calc-lead-root[aria-hidden="true"] { display:none; }
  #calc-lead-root .clf-overlay {
    position:fixed; inset:0; z-index:9999; display:flex; align-items:center; justify-content:center;
    padding:20px; background:rgba(10,14,26,.6); backdrop-filter:blur(4px); -webkit-backdrop-filter:blur(4px);
  }
  #calc-lead-root .clf-modal {
    position:relative; width:100%; max-width:440px; max-height:92vh; overflow:auto;
