.testimonial-card__quote:before{content:"“";color:var(--t-accent);opacity:.55;font-size:28px;vertical-align:-8px;margin-right:1px;font-family:var(--stw-display, 'Fraunces'), Georgia, serif}
.testimonial-card__quote:after{content:"”";color:var(--t-accent);opacity:.55;font-size:28px;vertical-align:-14px;margin-left:1px;font-family:var(--stw-display, 'Fraunces'), Georgia, serif}
