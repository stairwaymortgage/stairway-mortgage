@media(max-width:768px){.reviews-platform{padding:22px 20px;gap:16px;flex-direction:column;text-align:center}.reviews-platform__top{justify-content:center}.reviews-rating-big{display:flex;flex-direction:column;gap:8px;align-items:center}.reviews-star-big{width:24px;height:24px}}
