.testimonial-card__author-avatar:before{content:attr(data-initials);position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:var(--stw-display, 'Fraunces'), Georgia, serif;font-size:13px;color:var(--color-ink);letter-spacing:-.02em}
.testimonial-card__author-photo{position:relative;z-index:1;width:100%;height:100%;object-fit:cover;object-position:center 25%;border-radius:50%}
.testimonial-card__source-img{width:18px;height:18px;border-radius:4px;display:block;object-fit:cover}
.testimonial-card__author-name{font-size:13.5px;font-weight:500;color:var(--color-ink);letter-spacing:-.005em;line-height:1.2}
