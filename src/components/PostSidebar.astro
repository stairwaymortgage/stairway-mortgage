---
/*  PostSidebar — reproduces the old WP blog sidebar natively.
    Layers (top→bottom): blog search · newsletter · Stairway Academy e-book ·
    Browse by Category · Advisory Topics (categories) · Top Topics (tags).
    The three dropdowns are wired to the REAL taxonomy (11 categories / 79 tags)
    and navigate to crawlable /category/{slug}/ and /tag/{slug}/ archives.    */
import taxonomy from '../data/taxonomy.json';
// Webhook URL sourced from the single source of truth (ghl.ts). The submit
// handler is is:inline plain-JS and can't import an ES module, so the URL is
// passed to it via the form's data-ghl-endpoint attribute (same pattern as
// CalcLeadForm.astro).
import { GHL_WEBHOOK_URL } from '../lib/ghl';

const categories = Object.entries(taxonomy.categories)
  // strip the leading "N. " ordering prefix for display, keep slug
  .map(([slug, name]) => ({ slug, name: name.replace(/^\d+\.\s*/, '') }))
  .sort((a, b) => a.name.localeCompare(b.name));

const tags = Object.entries(taxonomy.tags)
  .map(([slug, name]) => ({ slug, name }))
  .sort((a, b) => a.name.localeCompare(b.name));
---

<aside class="post-sidebar">
  <!-- Blog search (client-side, navigates to /blog/?q=) -->
  <div class="ps-block">
    <form class="ps-search" action="/blog/" method="get" role="search">
      <input type="search" name="q" placeholder="Search blog…" aria-label="Search blog" class="ps-search__input" />
      <button type="submit" class="btn btn-blue ps-search__btn">Search</button>
    </form>
  </div>

  <!-- Newsletter -->
  <div class="ps-block ps-card">
    <h3 class="display-sm ps-card__title">Subscribe to our newsletter</h3>
    <p class="ps-card__sub">Get new posts and insights in your inbox.</p>
    <form class="ps-news" id="ps-news-form" data-ghl-endpoint={GHL_WEBHOOK_URL} novalidate>
      <input type="email" name="email" id="ps-news-email" placeholder="Enter your email" aria-label="Email address" class="ps-news__input" required />
      <button type="submit" class="btn btn-blue ps-news__btn">Subscribe</button>
      <input type="text" name="ps_news_hp" id="ps-news-hp" tabindex="-1" autocomplete="new-password" data-lpignore="true" data-1p-ignore data-form-type="other" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;pointer-events:none;" />
    </form>
  </div>

  <!-- Stairway Academy e-book promo -->
  <a class="ps-block ps-ebook" href="/guides/">
    <span class="ps-ebook__eyebrow mono">Download your free e-book</span>
    <span class="ps-ebook__title font-display">Stairway Academy</span>
    <span class="ps-ebook__cta btn btn-ghost btn-arrow">Get the guides</span>
  </a>

  <!-- Browse by Category -->
  <div class="ps-block">
    <label class="ps-label" for="ps-cat">Browse by Category</label>
    <select id="ps-cat" class="ps-select" data-archive="category">
      <option value="">Select a category</option>
      {categories.map(c => <option value={c.slug}>{c.name}</option>)}
    </select>
  </div>

  <!-- Advisory Topics (categories, re-skinned per Jim) -->
  <div class="ps-block">
    <label class="ps-label" for="ps-advisory">Advisory Topics</label>
    <select id="ps-advisory" class="ps-select" data-archive="category">
      <option value="">Select an advisory topic</option>
      {categories.map(c => <option value={c.slug}>{c.name}</option>)}
    </select>
  </div>

  <!-- Top Topics (tags, re-skinned per Jim) -->
  <div class="ps-block">
    <label class="ps-label" for="ps-top">Top Topics</label>
    <select id="ps-top" class="ps-select" data-archive="tag">
      <option value="">Select a top topic</option>
      {tags.map(t => <option value={t.slug}>{t.name}</option>)}
    </select>
  </div>
</aside>

<script is:inline>
  // Dropdowns navigate to the crawlable archive for the chosen term.
  document.querySelectorAll('.ps-select').forEach(function (sel) {
    sel.addEventListener('change', function () {
      if (!this.value) return;
      var base = this.dataset.archive === 'tag' ? '/tag/' : '/category/';
      window.location.href = base + this.value + '/';
    });
  });

  // Newsletter — JS-handled submit to the GHL inbound webhook (no native GET
  // navigation to forms.stairwaymortgage.com). Attribution helpers mirror
  // CalcLeadForm.astro exactly; endpoint comes from the data attribute (ghl.ts).
  (function () {
    var form = document.getElementById('ps-news-form');
    if (!form) return;
    var ENDPOINT = form.getAttribute('data-ghl-endpoint') || '';
    var hp = document.getElementById('ps-news-hp');
    var emailEl = document.getElementById('ps-news-email');

    // Autofill-blocking: only treat the honeypot as "filled" if a human focused it.
    if (hp) {
      hp.addEventListener('focus', function () { hp.setAttribute('data-touched', '1'); });
      setTimeout(function () { if (hp && hp.getAttribute('data-touched') !== '1') hp.value = ''; }, 1200);
    }

    function _getCookie(n){var m=document.cookie.match(new RegExp('(?:^|;\\s*)'+n+'=([^;]+)'));return m?decodeURIComponent(m[1]):'';}
    function _qs(n){try{return new URL(location.href).searchParams.get(n)||'';}catch(e){return '';}}
    function _cleanUmtid(v){return v?String(v).replace(/[^A-Za-z0-9_-]/g,'').slice(0,40):'';}
    function _resolveUmtid(){return _cleanUmtid(_qs('umtid'))||_cleanUmtid(_getCookie('umtid'))||'';}
    function _resolveLoid(){
      var raw = _qs('loid') || _qs('lo_id') || _qs('first_touch_loid') || _getCookie('first_touch_loid') || '';
      var m = String(raw).match(/(\d{3,})/);
      return m ? m[1] : '';
    }

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      // Honeypot: only block if the field was genuinely focused + filled (bot).
      if (hp && hp.value && hp.getAttribute('data-touched') === '1') return;

      var email = (emailEl && emailEl.value || '').trim();
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { if (emailEl) emailEl.focus(); return; }

      var payload = {
        email: email,
        form_source: 'blog_newsletter',
        form_name: 'Blog Newsletter',
        umtid: _resolveUmtid(),
        loid: _resolveLoid(),
        page_url: location.href,
        source_url: location.href,
        submitted_at: new Date().toISOString()
      };

      // POST to the shared GHL inbound webhook — same proven fetch() pattern as the
      // other 12 site forms. Awaited (keepalive lets it finish through the redirect).
      try {
        await fetch(ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
          keepalive: true
        });
      } catch (err) { /* swallow — still redirect so UX isn't blocked */ }

      // Redirect to the hosted newsletter form (carries the email through).
      window.location.href = 'https://forms.stairwaymortgage.com/widget/form/newsletter?email=' + encodeURIComponent(email);
    });
  })();
</script>

<style>
  .post-sidebar { display: flex; flex-direction: column; gap: 1.5rem; position: sticky; top: 6rem; }
  .ps-block { border: 1px solid var(--color-bone); border-radius: 12px; padding: 1.25rem; background: var(--color-paper); }

  .ps-search { display: flex; gap: 0.5rem; }
  .ps-search__input,
  .ps-news__input {
    flex: 1; min-width: 0; padding: 0.7rem 0.85rem; font-family: var(--stw-body, 'Inter'), system-ui, sans-serif; font-size: 14px;
    border: 1px solid var(--color-bone); border-radius: 8px; background: var(--color-paper-tint); color: var(--color-ink);
  }
  .ps-search__input:focus, .ps-news__input:focus { outline: none; border-color: var(--color-blue); }
  .ps-search__btn, .ps-news__btn { padding-inline: 1rem; }

  .ps-card { background: var(--color-ink); color: var(--color-paper); border-color: var(--color-ink); }
  .ps-card__title { color: var(--color-paper); margin-bottom: 0.35rem; }
  .ps-card__sub { font-size: 14px; opacity: 0.72; margin-bottom: 1rem; }
  .ps-news { display: flex; flex-direction: column; gap: 0.6rem; }
  .ps-card .ps-news__input { background: rgba(250,250,247,0.08); border-color: rgba(250,250,247,0.2); color: var(--color-paper); }
  .ps-card .ps-news__input::placeholder { color: rgba(250,250,247,0.5); }

  .ps-ebook {
    display: flex; flex-direction: column; gap: 0.5rem; text-decoration: none;
    background: linear-gradient(135deg, var(--color-blue-deep), var(--color-blue)); color: var(--color-paper);
    border-radius: 12px; padding: 1.5rem; border: none;
  }
  .ps-ebook__eyebrow { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.8; }
  .ps-ebook__title { font-size: 1.75rem; line-height: 1.05; }
  .ps-ebook__cta { margin-top: 0.5rem; background: transparent; color: var(--color-paper); border-color: rgba(250,250,247,0.4); }
  .ps-ebook__cta:hover { background: var(--color-paper); color: var(--color-ink); }

  .ps-label {
    display: block; font-family: var(--stw-body, 'Inter'), system-ui, sans-serif; font-size: 13px; font-weight: 600;
    letter-spacing: 0.02em; margin-bottom: 0.55rem; color: var(--color-ink);
  }
  .ps-select {
    width: 100%; padding: 0.7rem 0.85rem; font-family: var(--stw-body, 'Inter'), system-ui, sans-serif; font-size: 14px;
    border: 1px solid var(--color-bone); border-radius: 8px; background: var(--color-paper-tint);
    color: var(--color-ink); cursor: pointer;
  }
  .ps-select:focus { outline: none; border-color: var(--color-blue); }
</style>
