---
/*  DscrFlowInfographic — native SVG decision-path infographic, Stairway tokens.
    Shows how a borrower routes to DSCR vs conventional financing. Pure SVG,
    no JS, fully crawlable. Reusable on any DSCR-topic page.                     */
---

<figure class="dscr-flow reveal" aria-labelledby="dscr-flow-cap">
  <svg viewBox="0 0 680 380" width="100%" role="img" aria-labelledby="dscr-flow-title">
    <title id="dscr-flow-title">DSCR versus conventional financing decision path</title>
    <defs>
      <marker id="swarr" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M2 1L8 5L2 9" fill="none" stroke="var(--color-mute)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </marker>
    </defs>

    <!-- Start -->
    <rect x="250" y="24" width="180" height="52" rx="10" fill="var(--color-paper-tint)" stroke="var(--color-bone)" stroke-width="1"/>
    <text x="340" y="46" text-anchor="middle" class="fl-t">Investment property</text>
    <text x="340" y="64" text-anchor="middle" class="fl-s">Buying or refinancing</text>

    <line x1="340" y1="76" x2="340" y2="112" stroke="var(--color-mute)" stroke-width="1.5" marker-end="url(#swarr)"/>

    <!-- Decision -->
    <rect x="250" y="112" width="180" height="52" rx="10" fill="var(--color-blue-tint)" stroke="var(--color-blue)" stroke-width="1"/>
    <text x="340" y="134" text-anchor="middle" class="fl-t" style="fill:var(--color-blue-deep)">Income easy to</text>
    <text x="340" y="152" text-anchor="middle" class="fl-t" style="fill:var(--color-blue-deep)">document?</text>

    <!-- Yes branch -->
    <path d="M250 138 L150 138 L150 224" fill="none" stroke="var(--color-mute)" stroke-width="1.5" marker-end="url(#swarr)"/>
    <text x="150" y="196" text-anchor="middle" class="fl-s">Yes · W-2, returns</text>

    <!-- No branch -->
    <path d="M430 138 L530 138 L530 224" fill="none" stroke="var(--color-mute)" stroke-width="1.5" marker-end="url(#swarr)"/>
    <text x="530" y="196" text-anchor="middle" class="fl-s">No · self-employed</text>

    <!-- Conventional -->
    <rect x="60" y="224" width="180" height="52" rx="10" fill="var(--color-paper-tint)" stroke="var(--color-bone)" stroke-width="1"/>
    <text x="150" y="246" text-anchor="middle" class="fl-t">Conventional loan</text>
    <text x="150" y="264" text-anchor="middle" class="fl-s">Lowest rates, more docs</text>

    <!-- DSCR -->
    <rect x="440" y="224" width="180" height="52" rx="10" fill="var(--color-rust-tint)" stroke="var(--color-rust)" stroke-width="1"/>
    <text x="530" y="246" text-anchor="middle" class="fl-t" style="fill:var(--color-rust)">DSCR loan</text>
    <text x="530" y="264" text-anchor="middle" class="fl-s">Property income qualifies</text>

    <line x1="530" y1="276" x2="530" y2="312" stroke="var(--color-mute)" stroke-width="1.5" marker-end="url(#swarr)"/>
    <rect x="440" y="312" width="180" height="44" rx="10" fill="var(--color-paper)" stroke="var(--color-bone)" stroke-width="1"/>
    <text x="530" y="339" text-anchor="middle" class="fl-s">Rent ÷ payment ≥ 1.0</text>
  </svg>
  <figcaption id="dscr-flow-cap" class="dscr-flow__cap mono">How lenders route investors to DSCR vs. conventional financing</figcaption>
</figure>

<style>
  .dscr-flow { margin: 3rem 0; padding: 1.5rem; border: 1px solid var(--color-bone); border-radius: 16px; background: var(--color-paper); }
  .fl-t { font-family: var(--font-body); font-size: 14px; font-weight: 600; fill: var(--color-ink); }
  .fl-s { font-family: var(--font-body); font-size: 12px; fill: var(--color-mute); }
  .dscr-flow__cap { text-align: center; font-size: 11px; color: var(--color-mute); margin-top: 1rem; letter-spacing: 0.04em; }
</style>
