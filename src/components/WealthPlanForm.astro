---
// WealthPlanForm.astro — Stairway Mortgage "Build a Wealth Plan" multi-step MODAL.
// Native replacement for the old external GHL wealth-plan survey.
//
// Mirrors the DonateForm (.dnf) / CareerApplyForm (.caf) pattern under its own
// .wpf scope: opens as a centered overlay when any [data-wealth-open] trigger is
// clicked; closes on the X, backdrop click, and Esc; body scroll locked while
// open. Hidden by default.
//
// Self-contained: own `.wpf` scope + tokens (independent of the page scope),
// is:inline plain JS (NO TypeScript — TS breaks the Astro build).
//
// Lead posts JSON to WEALTH_WEBHOOK_URL (e8c4995a — shared reverse-mortgage GHL
// workflow; branch on form_source:'build_a_wealth_plan'). Attribution mirrors the
// site-canonical attributionFields() (LO_MAP → lo_name etc.).
//
// USAGE:
//   import WealthPlanForm from '../components/WealthPlanForm.astro';
//   <button type="button" data-wealth-open>Build a Wealth Plan</button>
//   <WealthPlanForm />
import { WEALTH_WEBHOOK_URL } from '../lib/ghl';
---

<div class="wpf-overlay" id="wpf-overlay" aria-hidden="true">
  <div class="wpf" id="wpf-root" role="dialog" aria-modal="true" aria-label="Build a Wealth Plan" data-ghl-endpoint={WEALTH_WEBHOOK_URL}>
    <button type="button" class="wpf-close" data-wealth-close aria-label="Close">&times;</button>

    <div class="wpf-card" id="wpf-form">
      <div class="wpf-progress" aria-hidden="true"><div class="wpf-progress-bar" id="wpf-bar"></div></div>
      <div class="wpf-progress-label text-mono" id="wpf-steplabel">Step 1</div>

      <div class="wpf-stage" id="wpf-stage"></div>

      <p class="wpf-error" id="wpf-error" style="display:none;"></p>

      <div class="wpf-nav">
        <button type="button" class="wpf-btn wpf-btn-ghost wpf-prev" id="wpf-prev">&larr; Back</button>
        <button type="button" class="wpf-btn wpf-btn-primary wpf-next" id="wpf-next">Next &rarr;</button>
      </div>

      <!-- honeypot: bots fill this, humans don't -->
      <input type="text" id="wpf-hp" name="wealth_website_hp" tabindex="-1" autocomplete="off"
             class="wpf-hp" aria-hidden="true" />
    </div>

    <div class="wpf-success" id="wpf-success" style="display:none;">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="wpf-success-icon" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      <p class="wpf-success-title">Your wealth plan is on its way.</p>
      <p class="wpf-success-sub">We&rsquo;ve received your details &mdash; our team will map out your options and reach out shortly to start building your plan.</p>
    </div>
  </div>
</div>

<style is:global>
  /* ============ WealthPlanForm modal — scoped to .wpf (self-contained tokens) ============ */
  .wpf-overlay, .wpf-overlay * { box-sizing: border-box; }
  .wpf-overlay {
    position: fixed; inset: 0; z-index: 99999; display: none;
    background: rgba(10,14,26,0.55); backdrop-filter: blur(3px);
    align-items: center; justify-content: center; padding: 20px;
    font-family: 'IBM Plex Sans', system-ui, -apple-system, sans-serif;
  }
  .wpf-overlay.wpf-active { display: flex; }

  .wpf {
    --ink: #0A0E1A; --ink-2: #1E2433; --ink-lighter: #6B7280;
    --paper: #FAFAF7; --paper-2: #F4F4EE; --paper-3: #EDEDE5; --white: #FFFFFF;
    --blue: #1845D6; --blue-deep: #0F2EA0; --gold: #B8860B;
    --border: #E5E5DE; --border-strong: #D4D4C8;
    --serif: 'Fraunces', 'Iowan Old Style', Georgia, serif;
    --sans: 'IBM Plex Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    --mono: 'JetBrains Mono', 'SF Mono', Menlo, monospace;
    position: relative; width: 100%; max-width: 560px; max-height: 92vh; overflow-y: auto;
    background: var(--paper); border-radius: 16px; padding: 30px 30px 28px;
    box-shadow: 0 30px 90px rgba(0,0,0,0.38); color: var(--ink);
    font-family: var(--sans); text-align: left;
  }
  @media (max-width: 480px) { .wpf { padding: 40px 18px 22px; border-radius: 14px; } }

  .wpf-close {
    position: absolute; top: 14px; right: 18px; z-index: 2;
    border: 0; background: none; font-size: 30px; line-height: 1; color: var(--ink);
    cursor: pointer; opacity: .45; padding: 0;
  }
  .wpf-close:hover { opacity: 1; }

  .wpf-progress { height: 6px; border-radius: 99px; background: var(--paper-3); overflow: hidden; margin-top: 4px; }
  .wpf-progress-bar { height: 100%; width: 0%; background: var(--blue); border-radius: 99px; transition: width .35s cubic-bezier(.4,0,.2,1); }
  .wpf-progress-label { font-family: var(--mono); font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: var(--ink-lighter); margin: 12px 0 20px; }
  .wpf .text-mono { font-family: var(--mono); }

  .wpf-stage { min-height: 150px; }
  .wpf-q { font-family: var(--serif); font-size: 26px; font-weight: 500; line-height: 1.2; letter-spacing: -.01em; color: var(--ink); margin: 0 0 6px; }
  .wpf-sub { font-size: 14px; color: var(--ink-lighter); line-height: 1.5; margin: 0 0 22px; }
  .wpf-q:only-child { margin-bottom: 22px; }

  .wpf-field { margin-top: 6px; }
  .wpf-input {
    width: 100%; padding: 14px 16px; border: 1px solid var(--border-strong); border-radius: 8px;
    font-size: 16px; font-family: var(--sans); color: var(--ink); background: var(--white); outline: none;
    transition: border-color .15s, box-shadow .15s;
  }
  .wpf-input::placeholder { color: #a6a6a0; }
  .wpf-input:focus { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(24,69,214,.12); }

  /* consent */
  .wpf-consent-row { display: flex; gap: 12px; align-items: flex-start; cursor: pointer; font-size: 13px; line-height: 1.55; color: var(--ink-2); }
  .wpf-consent-row input { width: 18px; height: 18px; accent-color: var(--blue); flex: 0 0 auto; margin-top: 2px; }
  .wpf-consent-links { margin-top: 14px; font-size: 12px; color: var(--ink-lighter); }
  .wpf-consent-links a { color: var(--blue); text-decoration: underline; }

  .wpf-error { font-size: 13px; color: #c0392b; margin: 16px 0 0; }

  .wpf-nav { display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-top: 26px; }
  .wpf-btn { font-family: var(--sans); font-size: 15px; font-weight: 500; border-radius: 100px; padding: 13px 26px; cursor: pointer; border: 1px solid transparent; transition: all .15s; }
  .wpf-btn-primary { background: var(--ink); color: var(--paper); border-color: var(--ink); }
  .wpf-btn-primary:hover:not(:disabled) { background: var(--blue); border-color: var(--blue); }
  .wpf-btn-primary:disabled { opacity: .4; cursor: default; }
  .wpf-btn-ghost { background: transparent; color: var(--ink); border-color: var(--border-strong); }
  .wpf-btn-ghost:hover { border-color: var(--ink); }

  .wpf-hp { position: absolute !important; left: -9999px !important; width: 1px !important; height: 1px !important; opacity: 0 !important; }

  .wpf-success { text-align: center; padding: 34px 10px 24px; }
  .wpf-success-icon { color: #2ecc71; margin: 0 auto 16px; display: block; }
  .wpf-success-title { font-family: var(--serif); font-size: 24px; font-weight: 500; margin: 0 0 10px; color: var(--ink); }
  .wpf-success-sub { font-size: 15px; color: var(--ink-2); max-width: 40ch; margin: 0 auto; line-height: 1.5; }
</style>

<script is:inline>
(function(){
  var overlay=document.getElementById('wpf-overlay');
  var root=document.getElementById('wpf-root');
  if(!overlay||!root)return;
  var ENDPOINT=root.getAttribute('data-ghl-endpoint')||'';

  var formEl=document.getElementById('wpf-form');
  var successEl=document.getElementById('wpf-success');
  var stage=document.getElementById('wpf-stage');
  var bar=document.getElementById('wpf-bar');
  var stepLabel=document.getElementById('wpf-steplabel');
  var prevBtn=document.getElementById('wpf-prev');
  var nextBtn=document.getElementById('wpf-next');
  var errEl=document.getElementById('wpf-error');

  // ---- 7-step sequence (mirrors the original GHL wealth-plan survey order) ----
  var steps=[
    { key:'what_age_would_you_like_to_be_financially_independent_2', type:'number', required:true, q:'What age would you like to be financially independent?', placeholder:'e.g. 55' },
    { key:'monthly_income_when_financially_independent_2', type:'number', q:'When financially independent and debt-free, how much monthly income would you need to feel comfortable?', sub:'Optional.', placeholder:'e.g. 10000' },
    { key:'total_net_worth_today_2', type:'number', q:'Approximately, what is your total net worth today?', sub:'Optional.', placeholder:'e.g. 250000' },
    { key:'full_name', type:'text', required:true, q:'What’s your full name?', placeholder:'First and last' },
    { key:'email', type:'email', required:true, q:'What’s your email?', placeholder:'you@email.com' },
    { key:'phone', type:'tel', required:true, q:'What’s your mobile phone number?', placeholder:'(555) 555-5555' },
    { key:'sms_consent', type:'consent', required:true, submit:true, q:'One last thing' }
  ];

  var state={
    what_age_would_you_like_to_be_financially_independent_2:'',
    monthly_income_when_financially_independent_2:'',
    total_net_worth_today_2:'',
    full_name:'', email:'', phone:'', sms_consent:false
  };
  var idx=0, sending=false;

  function el(tag,cls){ var n=document.createElement(tag); if(cls)n.className=cls; return n; }
  function esc(t){ var d=document.createElement('div'); d.textContent=(t==null?'':t); return d.innerHTML; }
  function showErr(m){ errEl.textContent=m; errEl.style.display='block'; }
  function hideErr(){ errEl.style.display='none'; }

  // ---- attribution (mirrors the site-canonical attributionFields() in PurchaseForm) ----
  function getCookie(name){var m=document.cookie.match(new RegExp('(?:^|;\\s*)'+name+'=([^;]+)'));return m?decodeURIComponent(m[1]):null;}
  function qs(name){try{return new URL(location.href).searchParams.get(name)||null;}catch(e){return null;}}
  var LO_MAP={ "1072866": { name:"Jim Blackburn", slug:"jim-blackburn" }, "1072877": { name:"Dhruv Parashar", slug:"dhruv-parashar" } };
  function loidNum(){ var raw=getCookie('first_touch_loid')||qs('lo_id')||qs('loid')||qs('first_touch_loid'); if(!raw) return null; var m=String(raw).match(/(\d{3,})/); return m?m[1]:null; }
  function cleanUmtid(v){return v?String(v).replace(/[^A-Za-z0-9_-]/g,'').slice(0,40):'';}
  function attributionFields(){
    var num=loidNum(); var lo=num&&LO_MAP[num]?LO_MAP[num]:null;
    return {
      loid: num||"", lo_id: num||"", lo_name: lo?lo.name:"", lo_slug: lo?lo.slug:"",
      loan_officer_name: lo?lo.name:"",                      // captured dynamically, never hardcoded
      umtid: cleanUmtid(qs('umtid'))||cleanUmtid(getCookie('umtid'))||"",
      utm_source:qs('utm_source')||getCookie('utm_source')||"", utm_medium:qs('utm_medium')||getCookie('utm_medium')||"",
      utm_campaign:qs('utm_campaign')||getCookie('utm_campaign')||"", utm_term:qs('utm_term')||getCookie('utm_term')||"",
      utm_content:qs('utm_content')||getCookie('utm_content')||"",
      source_url: getCookie('first_touch_url')||window.location.href
    };
  }

  function isValid(){
    var s=steps[idx]; var v=state[s.key];
    if(s.type==='text'||s.type==='number') return s.required?!!(v&&String(v).trim()):true;
    if(s.type==='email') return s.required?/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test((v||'').trim()):true;
    if(s.type==='tel')   return s.required?((v||'').replace(/\D/g,'').length>=10):true;
    if(s.type==='consent') return state.sms_consent===true;
    return true;
  }
  function updateNext(){ nextBtn.disabled = (!isValid()) || sending; }

  function enterGuard(e){
    if(e.key!=='Enter') return;
    e.preventDefault();
    if(!steps[idx].submit && isValid()) goNext();   // Enter advances; never auto-submits
  }

  function render(){
    var s=steps[idx];
    stage.innerHTML='';
    var head=el('div');
    head.innerHTML='<div class="wpf-q">'+esc(s.q)+'</div>'+(s.sub?'<div class="wpf-sub">'+esc(s.sub)+'</div>':'');
    stage.appendChild(head);
    hideErr();

    if(s.type==='text'||s.type==='email'||s.type==='tel'||s.type==='number'){
      var f=el('div','wpf-field');
      var input=el('input','wpf-input');
      input.type=(s.type==='text'?'text':s.type); input.placeholder=s.placeholder||''; input.value=state[s.key]||'';
      if(s.type==='tel') input.setAttribute('inputmode','tel');
      if(s.type==='number'){ input.setAttribute('inputmode','decimal'); input.min='0'; }
      input.addEventListener('input',function(){ state[s.key]=input.value; updateNext(); });
      input.addEventListener('keydown',enterGuard);
      f.appendChild(input); stage.appendChild(f);
      setTimeout(function(){ try{ input.focus(); }catch(e){} },50);
    }
    else if(s.type==='consent'){
      var c=el('div','wpf-consent');
      var lab=el('label','wpf-consent-row');
      var cb=document.createElement('input'); cb.type='checkbox'; cb.id='wpf-consent-cb'; cb.checked=!!state.sms_consent;
      cb.addEventListener('change',function(){ state.sms_consent=cb.checked; updateNext(); });
      var txt=document.createElement('span');
      txt.innerHTML='I consent to receive SMS notifications, alerts &amp; occasional marketing communication from Stairway Mortgage. Message frequency varies. Message &amp; data rates may apply. Text HELP to (954) 993-1625 for assistance. Reply STOP to unsubscribe.';
      lab.appendChild(cb); lab.appendChild(txt); c.appendChild(lab);
      var links=el('div','wpf-consent-links');
      links.innerHTML='<a href="/privacy/" target="_blank" rel="noopener">Privacy Policy</a> &middot; <a href="/terms/" target="_blank" rel="noopener">Terms</a>';
      c.appendChild(links);
      stage.appendChild(c);
    }

    var total=steps.length;
    bar.style.width=Math.round(((idx+1)/total)*100)+'%';
    stepLabel.textContent='Step '+(idx+1)+' of '+total;
    prevBtn.style.visibility = idx===0 ? 'hidden' : 'visible';
    nextBtn.textContent = s.submit ? 'Build My Plan' : 'Next →';
    updateNext();
  }

  function advance(){ if(idx<steps.length-1){ idx++; render(); } }
  function goPrev(){ if(idx>0){ idx--; render(); } }

  function goNext(){
    if(sending) return;
    var s=steps[idx];
    if(!isValid()) return;
    if(s.submit){ submit(); return; }
    advance();
  }

  function submit(){
    if(sending) return;
    var hp=document.getElementById('wpf-hp');
    if(hp && hp.value.trim()!==''){ showSuccess(); return; }   // honeypot: fake success, no POST
    if(!state.sms_consent){ showErr('Please agree to the SMS consent to submit.'); return; }

    var parts=(state.full_name||'').trim().split(/\s+/);
    var first=parts.shift()||''; var last=parts.join(' ')||'';
    var attr=attributionFields();
    var payload={
      form_source:'build_a_wealth_plan', form_name:'Build a Wealth Plan',
      first_name:first, last_name:last, full_name:(state.full_name||'').trim(),
      email:(state.email||'').trim(), phone:(state.phone||'').trim(),
      page_url:window.location.href, submitted_at:new Date().toISOString()
    };
    // Copy each collected answer into the payload under its own (already-GHL) key.
    // Handled separately: name/email/phone/consent (standard).
    var skip={ full_name:1, email:1, phone:1, sms_consent:1 };
    for(var k in state){ if(state.hasOwnProperty(k) && !skip[k]){ payload[k]=(state[k]==null?'':state[k]); } }
    payload.sms_consent = state.sms_consent ? 'yes' : 'no';
    payload.loid=attr.loid; payload.lo_id=attr.lo_id; payload.lo_name=attr.lo_name; payload.lo_slug=attr.lo_slug;
    payload.loan_officer_name=attr.loan_officer_name; payload.umtid=attr.umtid;
    payload.utm_source=attr.utm_source; payload.utm_medium=attr.utm_medium; payload.utm_campaign=attr.utm_campaign;
    payload.utm_term=attr.utm_term; payload.utm_content=attr.utm_content; payload.source_url=attr.source_url;

    sending=true; nextBtn.disabled=true; nextBtn.textContent='Sending…';
    fetch(ENDPOINT,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)})
      .then(function(){ showSuccess(); })
      .catch(function(){ showErr('Something went wrong. Please try again, or call us at (954) 993-1625.'); })
      .then(function(){ sending=false; nextBtn.disabled=false; nextBtn.textContent='Build My Plan'; });
  }

  function showSuccess(){ formEl.style.display='none'; successEl.style.display='block'; }

  // ---- modal open/close (mirrors DonateForm/CareerApplyForm) ----
  function openModal(){ overlay.classList.add('wpf-active'); overlay.setAttribute('aria-hidden','false'); document.body.style.overflow='hidden'; }
  function closeModal(){ overlay.classList.remove('wpf-active'); overlay.setAttribute('aria-hidden','true'); document.body.style.overflow=''; }
  window.STW_OPEN_wpf=openModal;

  nextBtn.addEventListener('click',goNext);
  prevBtn.addEventListener('click',goPrev);
  document.addEventListener('click',function(e){
    var o=e.target.closest?e.target.closest('[data-wealth-open]'):null; if(o){ e.preventDefault(); openModal(); }
    var c=e.target.closest?e.target.closest('[data-wealth-close]'):null; if(c){ e.preventDefault(); closeModal(); }
  });
  overlay.addEventListener('click',function(e){ if(e.target===overlay){ closeModal(); } });
  document.addEventListener('keydown',function(e){ if(e.key==='Escape'&&overlay.classList.contains('wpf-active')){ closeModal(); } });

  render();   // pre-render step 1 (overlay stays hidden until a trigger opens it)
})();
</script>
