---
/**
 * DiscoveryQuizForm.astro — Stairway Discovery Quiz (rebuild of Outgrow quiz).
 *
 * Conversational popup (.aic family). Linear, 35 questions + contact capture.
 * - Primary Profile = Q1. Secondary = scored from answer persona-tags.
 * - Guided-score section (0-3 per professional): scores of 0-1 surface introductions.
 * - Personalized dual-persona result with merge fields {fullname}/{Q2}/{Q7}/{Q8}.
 * - Submits to GHL webhook (form_source: discovery-quiz) with all answers + profiles + gaps.
 *
 * is:inline + plain JS (no TS). Enter-key submit guard. OTP placeholder 000000 (none here —
 * quiz uses plain contact capture, no phone verify in original, so no OTP).
 *
 * Trigger: any element with [data-open-discovery-quiz].
 */
---

<div class="dq-overlay" id="dq-overlay" hidden>
  <div class="aic dq" role="dialog" aria-modal="true" aria-label="Stairway Discovery Quiz">
    <span class="aic__aurora aic__aurora--1" aria-hidden="true"></span>
    <span class="aic__aurora aic__aurora--2" aria-hidden="true"></span>

    <div class="aic__header">
      <span class="aic__spark" aria-hidden="true">✦</span>
      <div class="aic__brand">
        <span class="aic__title">Stairway Discovery <span class="aic__badge">AI</span></span>
        <span class="aic__live"><span class="aic__dot"></span>Live · 3–5 minutes</span>
      </div>
      <button type="button" class="aic__close" id="dq-close" aria-label="Close">✕</button>
    </div>

    <div class="dq-progress" aria-hidden="true"><div class="dq-progress__bar" id="dq-bar"></div></div>
    <p class="dq-stepcount" id="dq-stepcount"></p>

    <div class="aic__body" id="dq-body">
      <!-- Intro -->
      <div class="dq-screen" id="dq-intro">
        <div class="aic__msg aic__msg--bot">Hi 👋 Welcome to the <strong>Stairway Discovery Quiz</strong>.</div>
        <p class="dq-introcopy">Discover where you are on your financial journey — and what smart step to take next. We'll help you identify opportunities, avoid costly mistakes, and connect you with the right tools, experts, and strategies to grow wealth with confidence.</p>
        <button type="button" class="dq-btn dq-btn--go" id="dq-start">Get Started →</button>
      </div>

      <!-- Question host (rendered by JS) -->
      <div class="dq-screen" id="dq-question" hidden>
        <div class="aic__msg aic__msg--bot" id="dq-q-title"></div>
        <p class="dq-q-sub" id="dq-q-sub" hidden></p>
        <div class="dq-options" id="dq-options"></div>
        <p class="dq-err" id="dq-q-err"></p>
        <div class="dq-nav">
          <button type="button" class="dq-btn dq-btn--ghost" id="dq-prev" aria-label="Back">←</button>
          <button type="button" class="dq-btn dq-btn--go" id="dq-next" aria-label="Next">→</button>
        </div>
      </div>

      <!-- Contact capture -->
      <div class="dq-screen" id="dq-contact" hidden>
        <div class="aic__msg aic__msg--bot">Almost there — how can we get in touch?</div>
        <input type="text" name="_gotcha" id="dq-gotcha" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;opacity:0;height:0;width:0;" aria-hidden="true" />
        <label class="dq-label">Full name <span class="dq-req">*</span></label>
        <input class="dq-input" type="text" id="dq-name" placeholder="First and last name" autocomplete="name" />
        <p class="dq-err" data-err="name"></p>
        <label class="dq-label">Email <span class="dq-req">*</span></label>
        <input class="dq-input" type="email" id="dq-email" placeholder="you@email.com" autocomplete="email" />
        <p class="dq-err" data-err="email"></p>
        <label class="dq-label">Mobile phone <span class="dq-req">*</span></label>
        <input class="dq-input" type="tel" id="dq-phone" placeholder="(954) 993-1625" autocomplete="tel" />
        <p class="dq-err" data-err="phone"></p>
        <label class="dq-consent">
          <input type="checkbox" id="dq-consent" />
          <span>I Consent to Receive SMS Notifications, Alerts &amp; Occasional Marketing Communication from company. Message frequency varies. Message &amp; data rates may apply. Text HELP to (954) 993-1625 for assistance. You can reply STOP to unsubscribe at any time.</span>
        </label>
        <p class="dq-err" data-err="consent"></p>
        <p class="dq-fine">This form collects information voluntarily for the purpose of communication only. Stairway Mortgage is a division of NEXA Mortgage LLC.</p>
        <div class="dq-nav">
          <button type="button" class="dq-btn dq-btn--ghost" id="dq-contact-prev" aria-label="Back">←</button>
          <button type="button" class="dq-btn dq-btn--go" id="dq-submit">See My Results →</button>
        </div>
      </div>

      <!-- Result (rendered by JS) -->
      <div class="dq-screen" id="dq-result" hidden>
        <div id="dq-result-content"></div>
      </div>
    </div>

    <div class="aic__footer">Stairway Mortgage · Guiding your every step</div>
  </div>
</div>

<style>
  .dq-overlay[hidden] { display: none; }
  .dq-overlay { position: fixed; inset: 0; z-index: 9999; background: rgba(10,14,26,.45); backdrop-filter: blur(4px); display: grid; place-items: center; padding: 1.25rem; animation: dq-fade .25s ease; }
  @keyframes dq-fade { from { opacity: 0 } to { opacity: 1 } }

  /* LIGHT / Outgrow-style theme */
  .aic.dq {
    --ink: #0A0E1A; --blue: #1845D6; --blue-deep: #0F2EA0; --violet: #6F46FF; --green: #2E9E2E;
    --line: #e6e7ea; --muted: #6b7280; --soft: #f4f5f7;
    --serif: 'Fraunces',Georgia,serif; --sans: 'IBM Plex Sans',sans-serif; --mono: 'JetBrains Mono',monospace;
    position: relative; width: 100%; max-width: 560px; max-height: 92vh; overflow: hidden auto;
    background: #ffffff; color: var(--ink);
    border-radius: 18px; box-shadow: 0 32px 80px -24px rgba(10,14,26,.35), 0 0 0 1px #0a0e1a0d;
    isolation: isolate; font-family: var(--sans); animation: dq-pop .35s cubic-bezier(.2,.8,.2,1);
  }
  @keyframes dq-pop { from { transform: translateY(16px) scale(.97); opacity: 0 } to { transform: none; opacity: 1 } }

  /* aurora blobs hidden in light theme */
  .aic__aurora { display: none; }

  .aic__header { position: relative; z-index: 1; display: flex; align-items: center; gap: .7rem; padding: 1.1rem 1.4rem .9rem; border-bottom: 1px solid var(--line); }
  .aic__spark { color: var(--blue); font-size: 1.2rem; }
  .aic__brand { display: flex; flex-direction: column; gap: .15rem; flex: 1; }
  .aic__title { font-family: var(--serif); font-size: 1.05rem; font-weight: 500; color: var(--ink); display: flex; align-items: center; gap: .5rem; }
  .aic__badge { font-family: var(--mono); font-size: .58rem; letter-spacing: .08em; background: var(--blue); color: #fff; padding: .12rem .4rem; border-radius: 5px; }
  .aic__live { font-family: var(--mono); font-size: .66rem; color: var(--muted); display: flex; align-items: center; gap: .4rem; }
  .aic__dot { width: 7px; height: 7px; border-radius: 50%; background: var(--green); animation: dq-pulse 2s ease-in-out infinite; }
  @keyframes dq-pulse { 0%,100% { box-shadow: 0 0 0 0 #2E9E2E66 } 50% { box-shadow: 0 0 0 5px #2E9E2E00 } }
  .aic__close { background: var(--soft); border: 0; color: #444; width: 30px; height: 30px; border-radius: 999px; cursor: pointer; font-size: .8rem; }
  .aic__close:hover { background: #e7e9ee; }

  .dq-progress { position: relative; z-index: 1; height: 6px; background: var(--soft); margin: 1.1rem 1.4rem 0; border-radius: 99px; overflow: hidden; }
  .dq-progress__bar { height: 100%; width: 0%; background: var(--ink); transition: width .4s cubic-bezier(.4,0,.2,1); }
  .dq-stepcount { position: relative; z-index: 1; font-family: var(--mono); font-size: .66rem; letter-spacing: .04em; color: var(--muted); margin: .5rem 1.4rem 0; }

  /* center nav arrows like Outgrow */
  .dq-nav { display: flex; justify-content: center; gap: .8rem; margin-bottom: 1.4rem; order: -1; }
  .dq-btn--ghost, .dq-btn--go.dq-navbtn { width: 44px; height: 44px; border-radius: 999px; padding: 0; display: grid; place-items: center; }

  .aic__body { position: relative; z-index: 1; padding: 1.25rem 1.6rem 1.6rem; text-align: center; }
  .aic__msg { font-family: var(--serif); font-size: 1.4rem; font-weight: 500; line-height: 1.3; margin: .25rem 0 1.4rem; color: var(--ink); animation: dq-in .35s ease; }
  .aic__msg strong { color: var(--ink); }
  @keyframes dq-in { from { opacity: 0; transform: translateY(8px) } to { opacity: 1; transform: none } }
  .dq-introcopy { font-size: .95rem; line-height: 1.6; color: #4b5563; margin: 0 0 1.5rem; }
  .dq-q-sub { font-size: .9rem; color: var(--muted); margin: -.9rem 0 1.2rem; }
  .dq-q-heading { display: block; font-family: var(--mono); font-size: .7rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--royal); margin-bottom: .4rem; }
  .dq-q-main { display: block; font-weight: 500; }

  .dq-options { display: flex; flex-direction: column; gap: .6rem; align-items: stretch; text-align: left; }
  .dq-opt { display: flex; cursor: pointer; }
  .dq-opt input { position: absolute; opacity: 0; }
  .dq-opt span { flex: 1; padding: .8rem 1rem .8rem 2.6rem; border-radius: 10px; background: #fff; border: 1.5px solid var(--line); font-size: .95rem; transition: all .15s; line-height: 1.4; text-align: left; position: relative; color: var(--ink); }
  /* radio circle on the left */
  .dq-opt span::before { content: ''; position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); width: 18px; height: 18px; border-radius: 50%; border: 2px solid #c4c8d0; background: #fff; transition: all .15s; }
  .dq-opt:hover span { border-color: var(--ink); }
  .dq-opt input:checked + span { border-color: var(--ink); background: var(--soft); }
  .dq-opt input:checked + span::before { border-color: var(--ink); background: var(--ink); box-shadow: inset 0 0 0 3px #fff; }

  /* rating + short option grid */
  .dq-options--grid { display: flex; flex-direction: row; flex-wrap: wrap; gap: .5rem; justify-content: flex-start; }
  .dq-options--grid .dq-opt span { padding: .7rem 1rem; white-space: nowrap; text-align: center; }
  .dq-options--grid .dq-opt span::before { display: none; }
  .dq-options--grid .dq-opt input:checked + span { background: var(--ink); color: #fff; border-color: var(--ink); }
  .dq-rating .dq-opt span { min-width: 52px; font-family: var(--mono); font-size: 1rem; }

  .dq-label { display: block; font-size: .85rem; color: #374151; margin: .9rem 0 .35rem; text-align: left; }
  .dq-req { color: #d11; }
  .dq-input { width: 100%; box-sizing: border-box; font-family: var(--sans); font-size: 1rem; padding: .85rem .9rem; border-radius: 10px; background: #fff; border: 1.5px solid var(--line); color: var(--ink); }
  .dq-input::placeholder { color: #9aa1ad; }
  .dq-input:focus { outline: none; border-color: var(--ink); box-shadow: 0 0 0 3px #0a0e1a14; }
  .dq-consent { display: flex; gap: .6rem; align-items: flex-start; font-size: .82rem; line-height: 1.5; color: #4b5563; cursor: pointer; margin-top: 1rem; text-align: left; }
  .dq-consent input { margin-top: .15rem; accent-color: var(--ink); flex-shrink: 0; }
  .dq-fine { font-size: .72rem; color: var(--muted); margin: 1rem 0 0; line-height: 1.6; text-align: left; }
  .dq-err { color: #d11; font-size: .8rem; margin: .4rem 0 0; min-height: .9rem; text-align: left; }

  .dq-btn { font-family: var(--sans); font-weight: 600; font-size: 1rem; cursor: pointer; border: 1.5px solid transparent; transition: background .18s, transform .1s, opacity .15s; }
  .dq-btn:active { transform: translateY(1px); }
  /* round black nav buttons (Outgrow style) */
  #dq-prev, #dq-next, #dq-start, #dq-submit, #dq-contact-prev { }
  .dq-btn--ghost { width: 44px; height: 44px; border-radius: 999px; padding: 0; background: #c7c7c7; color: #fff; display: grid; place-items: center; font-size: 1.1rem; }
  .dq-btn--ghost:hover { background: #b3b3b3; }
  .dq-btn--go { border-radius: 999px; background: var(--ink); color: #fff; }
  .dq-btn--go:hover { background: #1a2030; }
  .dq-btn--go:disabled { opacity: .5; cursor: not-allowed; }
  /* next/prev arrows as round; start/submit as pill */
  #dq-next, #dq-prev { width: 44px; height: 44px; border-radius: 999px; padding: 0; display: grid; place-items: center; font-size: 1.1rem; }
  #dq-next { background: var(--ink); color: #fff; }
  #dq-start, #dq-submit { padding: .85rem 2rem; border-radius: 999px; margin: .5rem auto 0; display: inline-block; }

  .aic__footer { position: relative; z-index: 1; font-family: var(--mono); font-size: .64rem; color: var(--muted); text-align: center; padding: .9rem 1.4rem; border-top: 1px solid var(--line); font-style: italic; }

  /* Result */
  .dq-result-intro { text-align: left; margin-bottom: 1.75rem; }
  .dq-result-intro h3 { font-family: var(--serif); font-weight: 500; font-size: 1.5rem; color: var(--ink); margin: 0 0 .6rem; line-height: 1.25; }
  .dq-result-intro p { font-size: .92rem; color: #4b5563; line-height: 1.6; margin: 0; }

  .dq-card { background: #fff; border: 1.5px solid var(--line); border-radius: 16px; padding: 1.6rem; margin-bottom: 1.1rem; text-align: left; box-shadow: 0 8px 28px -14px rgba(10,14,26,.15); transition: box-shadow .2s; }
  .dq-card:hover { box-shadow: 0 12px 36px -12px rgba(10,14,26,.22); }
  .dq-card--secondary { border-color: #e0ddf7; }
  .dq-card__tag { font-family: var(--mono); font-size: .62rem; letter-spacing: .1em; text-transform: uppercase; color: var(--royal); display: block; margin-bottom: .4rem; }
  .dq-card__tag--secondary { color: var(--violet); }
  .dq-card__name { font-family: var(--serif); font-size: 1.4rem; font-weight: 500; color: var(--ink); margin: 0 0 .2rem; }
  .dq-card__line { font-family: var(--serif); font-style: italic; font-weight: 400; color: var(--muted); font-size: .9rem; margin: 0 0 1rem; }
  .dq-card__body { font-size: .9rem; line-height: 1.65; color: #374151; margin: 0 0 1.25rem; }
  .dq-card__cta { display: inline-block; background: var(--ink); color: #fff; text-decoration: none; font-weight: 600; font-size: .88rem; padding: .75rem 1.6rem; border-radius: 999px; transition: background .15s, transform .1s; }
  .dq-card__cta:hover { background: #1a2030; transform: translateY(-1px); }

  .dq-gaps { background: var(--soft); border: 1.5px solid var(--line); border-radius: 16px; padding: 1.6rem; margin-bottom: 1.1rem; text-align: left; }
  .dq-gaps h4 { font-family: var(--serif); font-size: 1.15rem; font-weight: 500; color: var(--ink); margin: 0 0 .5rem; }
  .dq-gaps p { font-size: .88rem; color: #4b5563; line-height: 1.6; margin: 0 0 .75rem; }
  .dq-gaps ul { margin: 0 0 1.1rem; padding-left: 1.2rem; color: #374151; font-size: .88rem; line-height: 1.6; }
  .dq-gaps li { margin-bottom: .3rem; }

  .dq-final { text-align: left; padding: 1.25rem 0 .25rem; border-top: 1px solid var(--line); margin-top: .5rem; }
  .dq-final h3 { font-family: var(--serif); font-weight: 500; font-size: 1.3rem; color: var(--ink); margin: 0 0 .5rem; }
  .dq-final p { font-size: .9rem; color: #4b5563; margin: 0 0 1.1rem; line-height: 1.6; }
</style>

<script is:inline>
  (function () {
    var overlay = document.getElementById('dq-overlay');
    if (!overlay) return;

    // ---------- PERSONA DEFINITIONS ----------
    var PERSONAS = {
      'smart-steward-parent': { name: 'Smart Steward Parent', line: 'Laying the Groundwork for Wealth',
        body: "You're not just supporting your kid — you're guiding them toward a future with more freedom, options, and clarity. This step is about using your knowledge, resources, and influence to help your children build strong financial roots." },
      'smart-steward-student': { name: 'Smart Steward Student', line: 'Laying the Groundwork for Wealth',
        body: "You're not just thinking about funds or your first job — you're already looking ahead. You're learning how money works, how credit gets built, and how to play the long game when it comes to validating and owning real stuff." },
      'first-time-buyer': { name: 'First-Time Home Buyer', line: 'Laying the Groundwork for Wealth',
        body: "You're not just shopping for a home — you're making one of the biggest financial moves of your life. This step is about clarity, preparation, and power: knowing what to expect, and how to avoid the rookie mistakes that cost time and money." },
      'homeowner': { name: 'Homeowner', line: 'Laying the Groundwork for Wealth',
        body: "Owning a home is already a powerful move. Now it's time to ask: is your home working for you? This step is about tapping into the opportunity you've already built — reducing debt, growing equity, and making smart equity decisions." },
      'senior-homeowner': { name: 'Senior Homeowner (55+)', line: "Protecting What You've Built, Planning What's Next",
        body: "You've spent years building equity and stability. Now it's about using that foundation to create comfort, support your loved ones, and make smart decisions for the next chapter — on your terms." },
      'first-time-investor': { name: 'First-Time Investor', line: 'Laying the Groundwork for Wealth',
        body: "You're not just saving money — you're ready to put it to work. This step is all about strategy, clarity, and confidence. You don't need to be rich: you just need to start smart, build with intention, and surround yourself with people who've done it before." },
      'active-investor': { name: 'Active Investor', line: 'Scaling Your Portfolio with Intention',
        body: "You're not new to this — you bought, sold, leveraged, or renovated. Maybe you've done it all. But the goal now isn't just more properties: it's smarter growth. This step is about getting better financing, and unlocking equity plays that keep you scaling." },
      'passive-investor': { name: 'Passive Investor', line: 'Letting Your Money Do the Work',
        body: "You've worked hard to earn, save, and position yourself. Now it's about smarter movement: finding better deals, protecting cash, and passive income that feels truly passive. This step is about aligning your capital with operators you trust." },
      'legacy-angel': { name: 'Legacy Angel', line: 'Designing Wealth That Lasts Beyond You',
        body: "You've built more than assets — you've built options. This step is about something bigger: an impact that lasts. Whether it's writing up your kids, supporting your faith or favorite causes, or creating a legacy that reflects your values — this is your next level." }
    };

    // ---------- QUESTIONS ----------
    // type: 'single' (radio), 'rating' (0-3), 'info' (instruction only)
    // tags: persona weights applied when that option is chosen
    // P = persona keys shorthand
    var P = {
      SSP:'smart-steward-parent', SSS:'smart-steward-student', FTB:'first-time-buyer',
      HO:'homeowner', SHO:'senior-homeowner', FTI:'first-time-investor',
      AI:'active-investor', PI:'passive-investor', LA:'legacy-angel'
    };
    function t(){ /* build a tag map from args: t(P.AI, P.FTI) */ var o={}; for(var i=0;i<arguments.length;i++){o[arguments[i]]=1;} return o; }

    var QUESTIONS = [
      { id:'q1_persona', type:'single', required:true, primary:true, title:'Which best describes you today?',
        opts:[
          {label:"I'm a Legacy Angel with multiple assets to protect and a vision to impact generations to come.", primary:P.LA},
          {label:"I'm a Passive Investor still accumulating shares or holdings that generate income and growth without my effort.", primary:P.PI},
          {label:"I'm an Active Investor who is regularly accumulating properties.", primary:P.AI},
          {label:"I'm a First-Time Investor exploring real estate investing.", primary:P.FTI},
          {label:"I'm a Senior Homeowner (55+) researching my home equity senior benefits.", primary:P.SHO},
          {label:"I'm a Homeowner learning about debt consolidation, home renovation, and other ways to grow my home equity.", primary:P.HO},
          {label:"I'm a First-Time Buyer deciding between a home or investment.", primary:P.FTB},
          {label:"I'm a Parent researching college housing / investment for my child.", primary:P.SSP},
          {label:"I'm a Student researching college housing / investment for myself.", primary:P.SSS},
          {label:"I'm just exploring and not sure where I fit yet.", primary:null}
        ]},
      { id:'q2_concern', type:'single', merge:'Q2', title:'What concerns you most about your financial future?',
        opts:[
          {label:"Losing my hard-earned wealth to taxes instead of passing it to family or causes I care about.", tags:t(P.LA)},
          {label:"Running out of income — even with investments in place.", tags:t(P.PI,P.SHO)},
          {label:"Making smart decisions whether to keep accumulating single-unit properties — or shift to a smarter, more scalable strategy.", tags:t(P.AI)},
          {label:"Learning the investment skills I was never taught — and avoiding rookie mistakes.", tags:t(P.FTI)},
          {label:"Being able to stay in my home comfortably and affordably.", tags:t(P.SHO)},
          {label:"Building credit and getting financially ready for my first big move.", tags:t(P.FTB)},
          {label:'Making smarter equity decisions so I can pay off "dumb" debt and begin growing my wealth.', tags:t(P.HO)},
          {label:"Finding affordable college housing while planning for the future.", tags:t(P.SSP,P.SSS)},
          {label:"Teaching my child investment skills and setting the family up for a wealthy future.", tags:t(P.SSP)},
          {label:"None of this concerns me", tags:{}}
        ]},
      { id:'q3_college', type:'single', title:'Will you, a child or grandchild be attending college in the future?',
        opts:[ {label:'No',tags:{}}, {label:'12 months or less',tags:t(P.SSP,P.SSS)}, {label:'1-4 years',tags:t(P.SSP,P.SSS)}, {label:'5 years +',tags:t(P.SSP)} ]},
      { id:'q4_proptypes', type:'single', title:'What types of properties do you own?',
        opts:[ {label:'Residential & commercial properties',tags:t(P.AI,P.LA)}, {label:'Multiple houses',tags:t(P.AI)}, {label:'Just my home',tags:t(P.HO)}, {label:'Renting',tags:t(P.FTB,P.FTI)}, {label:'Living with family',tags:t(P.SSS,P.FTB)} ]},
      { id:'q5_propcount', type:'single', title:'How many properties do you own?',
        opts:[ {label:'10+',tags:t(P.LA,P.AI)}, {label:'5-10',tags:t(P.AI)}, {label:'2-4',tags:t(P.AI,P.PI)}, {label:'1',tags:t(P.HO)}, {label:'Owned in the past, not today',tags:t(P.FTI)}, {label:'Never owned',tags:t(P.FTB,P.FTI)} ]},
      { id:'q6_important_year', type:'single', title:"What's most important to you this year?",
        opts:[
          {label:'Structuring my legacy to impact people or causes I care about',tags:t(P.LA)},
          {label:'Earning optimal yield on assets passively with professional managers',tags:t(P.PI)},
          {label:'Getting in front of as many deals as possible',tags:t(P.AI)},
          {label:'Being introduced to quality local partners to manage deals',tags:t(P.AI,P.PI)},
          {label:'Staying in my home during retirement',tags:t(P.SHO)},
          {label:'Upgrading my home for space and comfort',tags:t(P.HO)},
          {label:'Supporting my children and family',tags:t(P.SSP)},
          {label:'Building a retirement income plan that gives me confidence',tags:t(P.SHO,P.PI)},
          {label:'Paying off debt to reduce monthly expenses and begin building wealth',tags:t(P.HO)},
          {label:'Solidifying a plan for relocation and deciding to sell or not with confidence',tags:t(P.HO)},
          {label:'Buying a home to live in and create memories',tags:t(P.FTB)},
          {label:'Creating a wealth plan that makes me feel secure',tags:t(P.FTI)},
          {label:'Deciding with confidence whether renting or buying at college is best',tags:t(P.SSP,P.SSS)}
        ]},
      { id:'q7_important_today', type:'single', merge:'Q7', title:'What is most important to you today?',
        opts:[
