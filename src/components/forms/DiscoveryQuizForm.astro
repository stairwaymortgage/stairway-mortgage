    // ---------- STATE ----------
    var answers = {};      // qid -> {label, value, tags, primary}
    var scores = {};       // persona -> count
    var idx = -1;          // -1 = intro; 0..N-1 questions; then contact; then result
    var phase = 'intro';   // intro | quiz | contact | result

    var els = {
      bar: document.getElementById('dq-bar'),
      stepcount: document.getElementById('dq-stepcount'),
      intro: document.getElementById('dq-intro'),
      question: document.getElementById('dq-question'),
      contact: document.getElementById('dq-contact'),
      result: document.getElementById('dq-result'),
      qTitle: document.getElementById('dq-q-title'),
      qSub: document.getElementById('dq-q-sub'),
      options: document.getElementById('dq-options'),
      qErr: document.getElementById('dq-q-err'),
      prev: document.getElementById('dq-prev'),
      next: document.getElementById('dq-next'),
      resultContent: document.getElementById('dq-result-content')
    };

    // ---------- OPEN / CLOSE ----------
    document.addEventListener('click', function (e) {
      var tr = e.target.closest('[data-open-discovery-quiz]');
      if (tr) { e.preventDefault(); overlay.hidden = false; document.body.style.overflow = 'hidden'; }
    });
    function close() { overlay.hidden = true; document.body.style.overflow = ''; }
    document.getElementById('dq-close').addEventListener('click', close);
    overlay.addEventListener('click', function (e) { if (e.target === overlay) close(); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !overlay.hidden) close(); });

    // ---------- NAV HELPERS ----------
    function totalSteps() { return QUESTIONS.length + 1; } // +1 contact
    function showScreen(name) {
      els.intro.hidden = name !== 'intro';
      els.question.hidden = name !== 'quiz';
      els.contact.hidden = name !== 'contact';
      els.result.hidden = name !== 'result';
    }
    function setProgress(stepNum, totalNum, label) {
      els.bar.style.width = (stepNum / totalNum * 100) + '%';
      els.stepcount.textContent = label || ('Step ' + stepNum + ' of ' + totalNum);
    }

    document.getElementById('dq-start').addEventListener('click', function () {
      phase = 'quiz'; idx = 0; renderQuestion();
    });

    // ---------- RENDER QUESTION ----------
    function renderQuestion() {
      showScreen('quiz');
      var q = QUESTIONS[idx];
      els.qErr.textContent = '';
      els.qTitle.innerHTML = q.heading
        ? ('<span class="dq-q-heading">' + q.heading + '</span><span class="dq-q-main">' + q.title + '</span>')
        : ('<span class="dq-q-main">' + q.title + '</span>');
      if (q.sub) { els.qSub.hidden = false; els.qSub.textContent = q.sub; } else { els.qSub.hidden = true; }
      setProgress(idx + 1, totalSteps(), 'Step ' + (idx + 1) + ' of ' + totalSteps());

      els.options.innerHTML = '';
      els.prev.style.visibility = idx === 0 ? 'hidden' : 'visible';

      if (q.type === 'info') {
        els.options.className = 'dq-options';
        var info = document.createElement('p');
        info.className = 'dq-introcopy';
        info.textContent = q.info;
        els.options.appendChild(info);
        els.next.textContent = '→';
        return;
      }

      els.next.textContent = '→';
      var isRating = q.type === 'rating';
      els.options.className = isRating ? 'dq-options dq-options--grid dq-rating' : 'dq-options';

      var opts = isRating
        ? [{label:'0',value:0},{label:'1',value:1},{label:'2',value:2},{label:'3',value:3}]
        : q.opts.map(function(o,i){ return {label:o.label, value:i}; });

      opts.forEach(function (o) {
        var lab = document.createElement('label');
        lab.className = 'dq-opt';
        var inp = document.createElement('input');
        inp.type = 'radio'; inp.name = q.id; inp.value = o.value;
        var saved = answers[q.id];
        if (saved && String(saved.value) === String(o.value)) inp.checked = true;
        // Auto-advance on selection (single + rating only, not multi-choice)
        inp.addEventListener('change', function () {
          setTimeout(function () {
            if (recordAnswer()) {
              if (idx < QUESTIONS.length - 1) { idx++; renderQuestion(); }
              else { phase = 'contact'; showContact(); }
            }
          }, 250);
        });
        var sp = document.createElement('span'); sp.textContent = o.label;
        lab.appendChild(inp); lab.appendChild(sp);
        els.options.appendChild(lab);
      });
    }

    function recordAnswer() {
      var q = QUESTIONS[idx];
      if (q.type === 'info') return true;
      var sel = els.options.querySelector('input[name="' + q.id + '"]:checked');
      if (!sel) {
        if (q.required) { els.qErr.textContent = 'Please choose an option.'; return false; }
        // optional & unanswered: clear any prior and allow
        delete answers[q.id]; return true;
      }
      var val = sel.value;
      if (q.type === 'rating') {
        answers[q.id] = { label: q.gap, value: parseInt(val,10), rating: true };
      } else {
        var opt = q.opts[parseInt(val,10)];
        answers[q.id] = { label: opt.label, value: parseInt(val,10), tags: opt.tags || {}, primary: opt.primary || null };
      }
      return true;
    }

    els.next.addEventListener('click', function () {
      if (!recordAnswer()) return;
      if (idx < QUESTIONS.length - 1) { idx++; renderQuestion(); }
      else { phase = 'contact'; showContact(); }
    });
    els.prev.addEventListener('click', function () {
      if (idx > 0) { idx--; renderQuestion(); }
    });

    // ---------- CONTACT ----------
    function showContact() {
      showScreen('contact');
      setProgress(totalSteps(), totalSteps(), 'Final step · almost done');
    }
    document.getElementById('dq-contact-prev').addEventListener('click', function () {
      phase = 'quiz'; idx = QUESTIONS.length - 1; renderQuestion();
    });

    function setErr(name, msg) { var el = els.contact.querySelector('[data-err="' + name + '"]'); if (el) el.textContent = msg; }
    function isEmail(v){ return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim()); }
    function isPhone(v){ return v.replace(/\D/g,'').length >= 10; }

    document.getElementById('dq-submit').addEventListener('click', submitQuiz);

    function submitQuiz() {
      var name = document.getElementById('dq-name').value.trim();
      var email = document.getElementById('dq-email').value.trim();
      var phone = document.getElementById('dq-phone').value.trim();
      var consent = document.getElementById('dq-consent').checked;
      var honeypot = document.getElementById('dq-gotcha').value;
      var ok = true;
      if (!name) { setErr('name','Please enter your name.'); ok=false; } else setErr('name','');
      if (!isEmail(email)) { setErr('email','Please enter a valid email.'); ok=false; } else setErr('email','');
      if (!isPhone(phone)) { setErr('phone','Please enter a valid phone.'); ok=false; } else setErr('phone','');
      if (!consent) { setErr('consent','Please check the box to continue.'); ok=false; } else setErr('consent','');
      if (!ok) return;

      var result = computeResult();
      var payload = buildPayload(name, email, phone, result);

      if (honeypot && honeypot.trim() !== '') { renderResult(result, name); return; }

      var btn = document.getElementById('dq-submit');
      btn.disabled = true; btn.textContent = 'Calculating…';
      fetch('https://services.leadconnectorhq.com/hooks/ipRIuBMrlyPNaFSXDz3q/webhook-trigger/5ef42c22-f8cf-48a8-af4c-998abe55d20d', {
        method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload)
      }).then(function(){ renderResult(result, name); })
        .catch(function(){ renderResult(result, name); }); // show result regardless; lead retry handled server-side
    }

    // ---------- SCORING ----------
    function computeResult() {
      // tally persona scores from tagged answers
      var tally = {};
      Object.keys(PERSONAS).forEach(function(k){ tally[k]=0; });
      var primary = null;
      Object.keys(answers).forEach(function(qid){
        var a = answers[qid];
        if (a.primary) primary = a.primary;
        if (a.tags) Object.keys(a.tags).forEach(function(p){ tally[p] += a.tags[p]; });
      });
      // primary: if Q1 gave a primary use it; else (just exploring) top tally
      var ranked = Object.keys(tally).sort(function(a,b){ return tally[b]-tally[a]; });
      if (!primary) primary = ranked[0];
      // secondary = top persona that's not primary
      var secondary = null;
      for (var i=0;i<ranked.length;i++){ if (ranked[i] !== primary) { secondary = ranked[i]; break; } }
      // guided gaps: rating answers scored 0 or 1
      var gaps = [];
      QUESTIONS.forEach(function(q){
        if (q.type === 'rating') {
          var a = answers[q.id];
          if (a && a.value <= 1) gaps.push({ label: q.gap, intro: q.intro });
        }
      });
      // de-dup intros
      var seenIntro = {}; var introList = [];
      gaps.forEach(function(g){ if(!seenIntro[g.intro]){ seenIntro[g.intro]=1; introList.push(g.intro); } });
      return { primary: primary, secondary: secondary, tally: tally, gaps: gaps, introList: introList };
    }

    // ---------- GHL FIELD KEY MAP (my question id -> GHL custom field key) ----------
    var GHL_KEYS = {
      q1_persona:'q1_which_best_describes_you_today',
      q2_concern:'q2_what_concerns_you_most_about_your_financial_future',
      q3_college:'q3_will_you_a_child_or_grandchild_be_attending_college_in_the_future',
      q4_proptypes:'q4_what_types_of_properties_do_you_own',
      q5_propcount:'q5_how_many_properties_do_you_own',
      q6_important_year:'q6_whats_most_important_to_you_this_year',
      q7_important_today:'q7_what_is_most_important_to_you_today',
      q8_buy_timeline:'q8_planning_to_buy_in_12_months_or_less',
      q9_improvement:'q9_which_part_of_owning_real_estate_can_use_improvement',
      q10_equity_goals:'q10_what_are_your_most_important_home_equity_goals',
      q11_sell_timeline:'q11_planning_to_sell_in_next_12_months',
      q12_buy_concern:'q12_what_concerns_you_most_about_buying_your_next_property',
      q13_involved:'q13_how_involved_do_you_want_to_be_in_investing',
      q14_capital:'q14_how_much_capital_do_you_have_liquid_and_ready_to_deploy',
      q15_contribute:'q15_how_would_you_contribute_to_an_investment_team',
      q16_challenged:'q16_where_do_you_feel_challenged_as_an_investor',
      q17_hesitation:'q17_whats_your_biggest_hesitation_about_investing_in_real_estate',
      q18_passive_years:'q18_in_how_many_years_would_you_like_to_have_enough_passive_income_to_live_on',
      q19_income_need:'q19_how_much_income_do_you_need_annually_to_live_comfortably',
      q20_income_now:'q20_how_much_income_annually_are_your_assets_generating_now',
      q21_age:'q21_whats_your_age_range',
      q22_management:'q22_are_you_considering_property_management_or_looking_for_tenant',
      q23_passive_attr:'q23_what_is_the_1_attribute_you_look_for_in_a_passive_investment',
      q24_children_wealth:'q24_want_to_help_your_children_or_grandchildren_build_wealth',
      q25_charitable:'q25_want_to_leave_a_charitable_footprint_on_humanity_in_honor_of_your_life',
      q26_legacy_focus:'q26_what_legacy_are_you_most_focused_on_building',
      gs_buying_realtor:'q27_buying_real_estate_how_guided_did_the_last_buying_realtor',
      gs_listing_realtor:'q28_listing_real_estate_how_guided_did_the_last_listing_realtor',
      gs_mortgage:'q29_home_equity_growth_how_guided_did_your_mortgage_advisor',
      gs_insurance:'q30_risk_insurance_coverage_how_guided_did_your_insurance_broker',
      gs_investment:'q31_investment_growth_plan_how_guided_did_your_investment_advisor',
      gs_financial_planner:'q32_retirement_income_planning_how_guided_did_your_financial_planner',
      gs_accountant:'q33_tax_strategy_how_guided_did_your_accountant',
      gs_asset_attorney:'q34_asset_protection_legal_planning_how_guided_did_your_attorney',
      gs_estate_attorney:'q35_estate_planning_wealth_transfer_how_guided_did_your_attorney',
      gs_ppm_attorney:'q36_private_capital_raising_506b_506c_how_guided_did_your_private_placement_attorney',
      gs_nonprofit_attorney:'q37_nonprofit_formation_501c3_501c4_how_guided_did_your_nonprofit_attorney',
      gs_life_changes:'q38_support_during_major_life_changes_how_supported_would_you_feel'
    };

    // ---------- PAYLOAD ----------
    function buildPayload(name, email, phone, result) {
      var sp = name.indexOf(' ');
      var first = sp === -1 ? name : name.slice(0,sp);
      var last = sp === -1 ? '' : name.slice(sp+1);
      var data = {
        form_source: 'discovery-quiz', form_name: 'Stairway Discovery Quiz',
        first_name: first, last_name: last, email: email, phone: phone,
        // GHL "OG" mirror fields
        full_name_og: name, first_name_og: first, last_name_og: last,
        quiz_name_og: 'Stairway Discovery Quiz', lead_source_og: 'Website - Discovery Quiz',
        created_at_og: new Date().toISOString(),
        // Primary persona -> Discovery Outcome field
        discovery_outcome: PERSONAS[result.primary] ? PERSONAS[result.primary].name : result.primary,
        primary_profile: PERSONAS[result.primary] ? PERSONAS[result.primary].name : result.primary,
        secondary_profile: PERSONAS[result.secondary] ? PERSONAS[result.secondary].name : result.secondary,
        guidance_gap_count: result.gaps.length,
        guidance_gaps: result.gaps.map(function(g){ return g.label; }).join(', '),
        recommended_intros: result.introList.join(', '),
        page_url: window.location.href, submitted_at: new Date().toISOString()
      };
      // each answer -> its exact GHL custom field key (fallback to q_<id> if unmapped)
      var summary = [];
      QUESTIONS.forEach(function(q){
        var a = answers[q.id];
        if (!a) return;
        var val = a.rating ? String(a.value) : a.label;
        var key = GHL_KEYS[q.id] || ('q_' + q.id);
        data[key] = val;
        summary.push(q.title.replace(/<[^>]*>/g,'') + ': ' + val);
      });
      data.quiz_summary = summary.join('\n');
      return data;
    }

    // ---------- RENDER RESULT ----------
    function mergeText(str, name) {
      var q2 = answers['q2_concern'] ? answers['q2_concern'].label : 'your goals';
      var q7 = answers['q7_important_today'] ? answers['q7_important_today'].label : 'what matters most';
      var q8 = answers['q8_buy_timeline'] ? answers['q8_buy_timeline'].label : '';
      return str.replace(/\{fullname\}/g, name.split(' ')[0])
                .replace(/\{Q2\}/g, q2).replace(/\{Q7\}/g, q7).replace(/\{Q8\}/g, q8);
    }
    function card(personaKey, isPrimary, name) {
      var p = PERSONAS[personaKey]; if (!p) return '';
      return '<div class="dq-card' + (isPrimary?'':' dq-card--secondary') + '">' +
        '<span class="dq-card__tag ' + (isPrimary?'':'dq-card__tag--secondary') + '">' + (isPrimary?'Your Primary Profile':'Secondary Profile to Explore') + '</span>' +
        '<div class="dq-card__name">' + p.name + '</div>' +
        '<div class="dq-card__line">' + p.line + '</div>' +
        '<p class="dq-card__body">' + p.body + '</p>' +
        '<a class="dq-card__cta" href="https://stairwaymortgage.com/guides/">Get the ' + p.name + ' Guide →</a>' +
        '</div>';
    }
    function renderResult(result, name) {
      showScreen('result');
      setProgress(totalSteps(), totalSteps(), 'Your results');
      var first = name.split(' ')[0];
      var html = '';
      html += '<div class="dq-result-intro"><h3>' + mergeText("You're in the driver's seat {fullname}! Now it's time to take your next step toward {Q7}.", name) + '</h3>' +
              "<p>Below you'll find your Primary Profile — the stage that best reflects your current goals — plus a Secondary Profile you may want to begin exploring.</p></div>";
      html += card(result.primary, true, name);
      if (result.secondary && result.secondary !== result.primary) html += card(result.secondary, false, name);
      if (result.introList.length) {
        html += '<div class="dq-gaps"><h4>Strengthen your team</h4>' +
          '<p>Based on your answers, these are the relationships where a trusted introduction could help most:</p><ul>' +
          result.introList.map(function(i){ return '<li>' + i + '</li>'; }).join('') + '</ul>' +
          '<a class="dq-card__cta" href="https://stairwaymortgage.com/get-a-local-introduction/">Get a Local Introduction →</a></div>';
      }
      html += '<div class="dq-final"><h3>' + mergeText('Ready to talk {fullname}?', name) + '</h3>' +
              '<p>' + mergeText("Let's map your next step together so you can {Q2}. Schedule a call with a Stairway Advisor and turn your goals into a plan.", name) + '</p>' +
              '<a class="dq-card__cta" href="https://stairwaymortgage.com/schedule-call/">Schedule a Call →</a></div>';
      els.resultContent.innerHTML = html;
      els.body = document.getElementById('dq-body'); if (els.body) els.body.scrollTop = 0;
    }

    // init
    showScreen('intro');
    setProgress(0, totalSteps(), 'Stairway Discovery Quiz · 3–5 min');
  })();
</script>
