---
/**
 * BuildAHouseForm.astro
 * Multi-step construction-loan intake. Rebuild of the GHL "Build A House" survey.
 *
 * - Visible question steps mirror the original survey order.
 * - Hidden attribution fields (lo_*, utm_*, fbclid, slug, source_url, first/last_touch_loid)
 *   are read at runtime from URL query params, then cookies, then left empty.
 * - Submits through the shared submitToGHL() helper with form_source "build-a-house".
 * - Design: site tokens (--ink/--paper/--blue/--rust), Fraunces / IBM Plex Sans / JetBrains Mono.
 *
 * Compliance: no rate promises. Division line + "not a commitment to lend" shown.
 * SMS consent is required (mirrors original). Phone "Verify" (GHL OTP) intentionally omitted.
 */
---

<section class="bah-scope" id="build-a-house-form">
  <div class="bah-card card">
    <!-- Progress -->
    <div class="bah-progress" aria-hidden="true">
      <div class="bah-progress__bar" id="bah-bar"></div>
    </div>
    <p class="bah-step-count mono" id="bah-step-count">Step 1 of 11</p>

    <form id="bah-form" novalidate>
      <!-- Honeypot: hidden from humans, bots fill it -->
      <input type="text" name="_gotcha" id="bah-gotcha" tabindex="-1" autocomplete="off"
             style="position:absolute;left:-9999px;opacity:0;height:0;width:0;" aria-hidden="true" />

      <!-- STEP 1 — State -->
      <div class="bah-slide" data-step="1">
        <p class="eyebrow mono">Construction Financing</p>
        <h3 class="bah-q">Which state are you looking to build in?</h3>
        <input class="bah-input" type="text" name="build_state" id="bah-build_state"
               required placeholder="e.g. Florida" autocomplete="address-level1" />
        <p class="bah-err" data-err-for="build_state"></p>
      </div>

      <!-- STEP 2 — City -->
      <div class="bah-slide" data-step="2" hidden>
        <h3 class="bah-q">Which city are you looking to build in?</h3>
        <input class="bah-input" type="text" name="build_city" placeholder="e.g. Fort Lauderdale" autocomplete="address-level2" />
      </div>

      <!-- STEP 3 — Identified land -->
      <div class="bah-slide" data-step="3" hidden>
        <h3 class="bah-q">Have you identified the land?</h3>
        <div class="bah-radios">
          <label class="bah-radio"><input type="radio" name="identified_land" value="Already own it" /><span>Already own it</span></label>
          <label class="bah-radio"><input type="radio" name="identified_land" value="Found it, need to buy it" /><span>Found it, need to buy it</span></label>
          <label class="bah-radio"><input type="radio" name="identified_land" value="Need to find it" /><span>Need to find it</span></label>
        </div>
      </div>

      <!-- STEP 4 — Purpose -->
      <div class="bah-slide" data-step="4" hidden>
        <h3 class="bah-q">Are you building a home to live, vacation, rent or sell for profit?</h3>
        <div class="bah-radios">
          <label class="bah-radio"><input type="radio" name="build_purpose" value="Home to live" /><span>Home to live</span></label>
          <label class="bah-radio"><input type="radio" name="build_purpose" value="Vacation home" /><span>Vacation home</span></label>
          <label class="bah-radio"><input type="radio" name="build_purpose" value="Rental property" /><span>Rental property</span></label>
          <label class="bah-radio"><input type="radio" name="build_purpose" value="Build to sell" /><span>Build to sell</span></label>
        </div>
      </div>

      <!-- STEP 5 — Land value -->
      <div class="bah-slide" data-step="5" hidden>
        <h3 class="bah-q">How much is the estimated land price or value?</h3>
        <input class="bah-input" type="text" inputmode="numeric" name="estimated_land_value"
               id="bah-land" placeholder="$" autocomplete="off" />
      </div>

      <!-- STEP 6 — Construction budget -->
      <div class="bah-slide" data-step="6" hidden>
        <h3 class="bah-q">How much are you looking to spend on construction?</h3>
        <input class="bah-input" type="text" inputmode="numeric" name="construction_budget"
               id="bah-budget" placeholder="$" autocomplete="off" />
      </div>

      <!-- STEP 7 — Anything else -->
      <div class="bah-slide" data-step="7" hidden>
        <h3 class="bah-q">Anything else you'd like to share?</h3>
        <textarea class="bah-input bah-textarea" name="anything_else" rows="4"
                  placeholder="Optional"></textarea>
      </div>

      <!-- STEP 8 — Full name -->
      <div class="bah-slide" data-step="8" hidden>
        <h3 class="bah-q">Full name</h3>
        <input class="bah-input" type="text" name="full_name" id="bah-name"
               placeholder="First and last name" autocomplete="name" />
      </div>

      <!-- STEP 9 — Email -->
      <div class="bah-slide" data-step="9" hidden>
        <h3 class="bah-q">Email <span class="bah-req">*</span></h3>
        <input class="bah-input" type="email" name="email" id="bah-email"
               required placeholder="you@email.com" autocomplete="email" />
        <p class="bah-err" data-err-for="email"></p>
      </div>

      <!-- STEP 10 — Phone + OTP gate (OTP is a PLACEHOLDER stub: code 000000, no SMS sent. Replace post-domain-switch with Twilio/GHL verify.) -->
      <div class="bah-slide" data-step="10" hidden>
        <h3 class="bah-q">Phone <span class="bah-req">*</span></h3>
        <div class="bah-phone-row">
          <input class="bah-input" type="tel" name="phone" id="bah-phone"
                 required placeholder="(954) 993-1625" autocomplete="tel" />
          <button type="button" class="bah-btn bah-btn--ghost bah-verify" id="bah-send-otp">Verify Phone</button>
        </div>
        <p class="bah-err" data-err-for="phone"></p>

        <!-- OTP entry (revealed after Verify Phone) -->
        <div class="bah-otp" id="bah-otp-wrap" hidden>
          <p class="bah-otp__hint mono">Enter the 6-digit code to verify your number.</p>
          <div class="bah-phone-row">
            <input class="bah-input" type="text" inputmode="numeric" maxlength="6"
                   id="bah-otp-input" placeholder="000000" autocomplete="one-time-code" />
            <button type="button" class="bah-btn bah-btn--blue bah-verify" id="bah-check-otp">Confirm</button>
          </div>
          <p class="bah-err" data-err-for="otp"></p>
          <p class="bah-otp__verified mono" id="bah-otp-ok" hidden>&#10003; Phone verified</p>
        </div>
      </div>

      <!-- STEP 11 — SMS consent + submit -->
      <div class="bah-slide" data-step="11" hidden>
        <h3 class="bah-q">Almost done</h3>
        <label class="bah-consent">
          <input type="checkbox" name="sms_consent" id="bah-consent" required />
          <span>I Consent to Receive SMS Notifications, Alerts &amp; Occasional Marketing
          Communication from company. Message frequency varies. Message &amp; data rates may apply.
          Text HELP to (954) 993-1625 for assistance. You can reply STOP to unsubscribe at any time.</span>
        </label>
        <p class="bah-err" data-err-for="sms_consent"></p>
        <p class="bah-fineprint mono">
          Stairway Mortgage is a division of NEXA Mortgage LLC. Submitting this form is not a
          commitment to lend. <a href="/privacy-policy/">Privacy Policy</a> ·
          <a href="/terms-of-service/">Terms of Service</a>
        </p>
      </div>

      <!-- Hidden attribution fields (populated by JS at runtime) -->
      <input type="hidden" name="phone_verified" id="bah-phone-verified" value="false" />
      <input type="hidden" name="first_touch_loid" />
      <input type="hidden" name="last_touch_loid" />
      <input type="hidden" name="lo_id" />
      <input type="hidden" name="lo_slug" />
      <input type="hidden" name="lo_state" />
      <input type="hidden" name="lo_name" />
      <input type="hidden" name="lo_city" />
      <input type="hidden" name="slug" />
      <input type="hidden" name="source_url" />
      <input type="hidden" name="utm_source" />
      <input type="hidden" name="utm_medium" />
      <input type="hidden" name="utm_campaign" />
      <input type="hidden" name="utm_term" />
      <input type="hidden" name="utm_content" />
      <input type="hidden" name="fbclid" />

      <!-- Nav -->
      <div class="bah-nav">
        <button type="button" class="bah-btn bah-btn--ghost" id="bah-prev" hidden>&larr; Back</button>
        <button type="button" class="bah-btn bah-btn--blue" id="bah-next">Next &rarr;</button>
        <button type="submit" class="bah-btn bah-btn--blue" id="bah-submit" hidden>See My Options</button>
      </div>
    </form>

    <!-- Success state -->
    <div class="bah-success" id="bah-success" hidden>
      <div class="bah-success__mark">&#10003;</div>
      <h3 class="bah-q">Thank you — we've got it.</h3>
      <p class="bah-lede">A member of our team will reach out to talk through your construction
      financing options. No obligation, no pressure.</p>
    </div>
  </div>
</section>

<style>
  .bah-scope {
    --ink: #0A0E1A; --ink-light: #4A5568; --ink-lighter: #6B7280;
    --paper: #FAFAF7; --blue: #1845D6; --blue-deep: #0F2EA0;
    --blue-soft: #E8EEFF; --blue-tint: #F2F5FF; --rust: #8B2C2C; --green: #2E9E2E;
    --serif: 'Fraunces','Iowan Old Style',Georgia,serif;
    --sans: 'IBM Plex Sans',-apple-system,BlinkMacSystemFont,sans-serif;
    --mono: 'JetBrains Mono','SF Mono',Menlo,monospace;
    font-family: var(--sans);
    color: var(--ink);
    max-width: 640px;
    margin: 0 auto;
  }
  .bah-card {
    background: var(--paper);
    border: 1px solid #EAE7DE;
    border-radius: 16px;
    padding: 2.5rem;
    box-shadow: 0 12px 40px rgba(10,14,26,0.06);
  }
  .bah-progress { height: 4px; background: #EAE7DE; border-radius: 99px; overflow: hidden; }
  .bah-progress__bar {
    height: 100%; width: 9%; background: var(--blue);
    border-radius: 99px; transition: width .35s cubic-bezier(.4,0,.2,1);
  }
  .bah-step-count {
    font-family: var(--mono); font-size: .72rem; letter-spacing: .08em;
    text-transform: uppercase; color: var(--ink-lighter);
    margin: .75rem 0 1.75rem;
  }
  .eyebrow {
    font-family: var(--mono); font-size: .72rem; letter-spacing: .12em;
    text-transform: uppercase; color: var(--blue); margin: 0 0 .5rem;
  }
  .bah-q {
    font-family: var(--serif); font-weight: 500; font-size: 1.6rem;
    line-height: 1.25; margin: 0 0 1.25rem; color: var(--ink);
  }
  .bah-req { color: var(--rust); }
  .bah-input {
    width: 100%; font-family: var(--sans); font-size: 1.05rem;
    padding: .85rem 1rem; border: 1.5px solid #D8D4C8; border-radius: 10px;
    background: #fff; color: var(--ink); transition: border-color .2s, box-shadow .2s;
    box-sizing: border-box;
  }
  .bah-input:focus {
    outline: none; border-color: var(--blue);
    box-shadow: 0 0 0 3px var(--blue-soft);
  }
  .bah-textarea { resize: vertical; min-height: 96px; }
  .bah-phone-row { display: flex; gap: .6rem; align-items: stretch; }
  .bah-phone-row .bah-input { flex: 1; }
  .bah-verify { white-space: nowrap; flex-shrink: 0; }
  .bah-otp { margin-top: 1.1rem; padding-top: 1.1rem; border-top: 1px dashed #D8D4C8; }
  .bah-otp__hint { font-family: var(--mono); font-size: .72rem; letter-spacing: .04em; color: var(--ink-lighter); margin: 0 0 .6rem; text-transform: uppercase; }
  .bah-otp__verified { font-family: var(--mono); font-size: .8rem; color: var(--green); margin: .5rem 0 0; }
  .bah-radios { display: flex; flex-direction: column; gap: .65rem; }
  .bah-radio {
    display: flex; align-items: center; gap: .75rem; cursor: pointer;
    padding: .9rem 1rem; border: 1.5px solid #D8D4C8; border-radius: 10px;
    background: #fff; transition: border-color .2s, background .2s;
    font-size: 1rem;
  }
  .bah-radio:hover { border-color: var(--blue); background: var(--blue-tint); }
  .bah-radio input { accent-color: var(--blue); width: 1.1rem; height: 1.1rem; }
  .bah-radio:has(input:checked) { border-color: var(--blue); background: var(--blue-tint); }
  .bah-consent {
    display: flex; gap: .75rem; align-items: flex-start;
    font-size: .9rem; line-height: 1.5; color: var(--ink-light); cursor: pointer;
  }
  .bah-consent input { margin-top: .2rem; accent-color: var(--blue); width: 1.1rem; height: 1.1rem; flex-shrink: 0; }
  .bah-fineprint {
    font-family: var(--mono); font-size: .68rem; line-height: 1.6;
    color: var(--ink-lighter); margin: 1.25rem 0 0;
  }
  .bah-fineprint a { color: var(--blue); text-decoration: none; }
  .bah-err {
    color: var(--rust); font-size: .82rem; margin: .5rem 0 0; min-height: 1rem;
  }
  .bah-nav { display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-top: 2rem; }
  .bah-btn {
    font-family: var(--sans); font-weight: 600; font-size: .95rem;
    padding: .8rem 1.6rem; border-radius: 10px; cursor: pointer;
    border: 1.5px solid transparent; transition: background .2s, transform .1s;
  }
  .bah-btn:active { transform: translateY(1px); }
  .bah-btn--blue { background: var(--blue); color: #fff; margin-left: auto; }
  .bah-btn--blue:hover { background: var(--blue-deep); }
  .bah-btn--blue:disabled { opacity: .6; cursor: not-allowed; }
  .bah-btn--ghost { background: transparent; color: var(--ink-light); border-color: #D8D4C8; }
  .bah-btn--ghost:hover { border-color: var(--ink-light); }
  .bah-success { text-align: center; padding: 1rem 0; }
  .bah-success__mark {
    width: 64px; height: 64px; margin: 0 auto 1.25rem; border-radius: 50%;
    background: var(--green); color: #fff; font-size: 2rem;
    display: grid; place-items: center;
  }
  .bah-lede { font-size: 1.05rem; line-height: 1.6; color: var(--ink-light); margin: 0; }
  @media (max-width: 520px) {
    .bah-card { padding: 1.75rem 1.25rem; }
    .bah-q { font-size: 1.35rem; }
  }
</style>

<script>
  (function () {
    const form = document.getElementById('bah-form') as HTMLFormElement | null;
    if (!form) return;

    const slides = Array.from(form.querySelectorAll('.bah-slide')) as HTMLElement[];
    const total = slides.length;
    const bar = document.getElementById('bah-bar') as HTMLElement;
    const stepCount = document.getElementById('bah-step-count') as HTMLElement;
    const prevBtn = document.getElementById('bah-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('bah-next') as HTMLButtonElement;
    const submitBtn = document.getElementById('bah-submit') as HTMLButtonElement;
    const successEl = document.getElementById('bah-success') as HTMLElement;
    let current = 0;

    // --- Populate hidden attribution fields from URL params, then cookies ---
    const params = new URLSearchParams(window.location.search);
    function getCookie(name: string): string {
      const m = document.cookie.match('(^|;)\\s*' + name + '\\s*=\\s*([^;]+)');
      return m ? decodeURIComponent(m.pop() as string) : '';
    }
    const hiddenKeys = ['first_touch_loid','last_touch_loid','lo_id','lo_slug','lo_state',
      'lo_name','lo_city','slug','source_url','utm_source','utm_medium','utm_campaign',
      'utm_term','utm_content','fbclid'];
    hiddenKeys.forEach((k) => {
      const el = form.querySelector(`[name="${k}"]`) as HTMLInputElement | null;
      if (!el) return;
      el.value = params.get(k) || getCookie(k) || '';
    });
    // source_url defaults to the current page if not supplied
    const srcEl = form.querySelector('[name="source_url"]') as HTMLInputElement;
    if (srcEl && !srcEl.value) srcEl.value = window.location.href;

    function showStep(i: number) {
      slides.forEach((s, idx) => (s.hidden = idx !== i));
      current = i;
      bar.style.width = ((i + 1) / total) * 100 + '%';
      stepCount.textContent = `Step ${i + 1} of ${total}`;
      prevBtn.hidden = i === 0;
      const last = i === total - 1;
      nextBtn.hidden = last;
      submitBtn.hidden = !last;
    }

    function setErr(name: string, msg: string) {
      const el = form.querySelector(`[data-err-for="${name}"]`) as HTMLElement | null;
      if (el) el.textContent = msg;
    }

    const isEmail = (v: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim());
    const isPhone = (v: string) => v.replace(/\D/g, '').length >= 10;

    // ---- OTP PLACEHOLDER (stub) ----
    // No SMS is sent. Accepts code "000000". Replace post-domain-switch with
    // a real Twilio/GHL-verify call via a Vercel serverless route. See DOMAIN-SWITCH-TODO.md.
    const PLACEHOLDER_OTP = '000000';
    const sendOtpBtn = document.getElementById('bah-send-otp') as HTMLButtonElement;
    const otpWrap = document.getElementById('bah-otp-wrap') as HTMLElement;
    const otpInput = document.getElementById('bah-otp-input') as HTMLInputElement;
    const checkOtpBtn = document.getElementById('bah-check-otp') as HTMLButtonElement;
    const otpOk = document.getElementById('bah-otp-ok') as HTMLElement;
    const phoneVerifiedField = document.getElementById('bah-phone-verified') as HTMLInputElement;

    sendOtpBtn.addEventListener('click', () => {
      const v = (form.querySelector('[name="phone"]') as HTMLInputElement).value;
      if (!isPhone(v)) { setErr('phone', 'Enter a valid phone number first.'); return; }
      setErr('phone', '');
      otpWrap.hidden = false;
      otpInput.focus();
      // (stub) In production this is where the SMS code is requested from the server.
    });

    checkOtpBtn.addEventListener('click', () => {
      if (otpInput.value.trim() === PLACEHOLDER_OTP) {
        phoneVerifiedField.value = 'true';
        otpOk.hidden = false;
        setErr('otp', '');
        otpInput.disabled = true;
        checkOtpBtn.disabled = true;
      } else {
        setErr('otp', 'Incorrect code. (Test code: 000000)');
      }
    });

    function validateStep(i: number): boolean {
      const slide = slides[i];
      const step = slide.getAttribute('data-step');
      if (step === '1') {
        const v = (form.querySelector('[name="build_state"]') as HTMLInputElement).value;
        if (!v.trim()) { setErr('build_state', 'Please enter a state.'); return false; }
        setErr('build_state', '');
      }
      if (step === '9') {
        const v = (form.querySelector('[name="email"]') as HTMLInputElement).value;
        if (!isEmail(v)) { setErr('email', 'Please enter a valid email.'); return false; }
        setErr('email', '');
      }
      if (step === '10') {
        const v = (form.querySelector('[name="phone"]') as HTMLInputElement).value;
        if (!isPhone(v)) { setErr('phone', 'Please enter a valid phone number.'); return false; }
        setErr('phone', '');
        if (phoneVerifiedField.value !== 'true') {
          setErr('otp', 'Please verify your phone to continue. (Tap Verify Phone, code 000000)');
          if (otpWrap.hidden) { otpWrap.hidden = false; }
          return false;
        }
        setErr('otp', '');
      }
      if (step === '11') {
        const c = (form.querySelector('[name="sms_consent"]') as HTMLInputElement).checked;
        if (!c) { setErr('sms_consent', 'Please check the box to continue.'); return false; }
        setErr('sms_consent', '');
      }
      return true;
    }

    nextBtn.addEventListener('click', () => {
      if (!validateStep(current)) return;
      if (current < total - 1) showStep(current + 1);
    });
    prevBtn.addEventListener('click', () => { if (current > 0) showStep(current - 1); });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!validateStep(current)) return;

      const honeypot = (document.getElementById('bah-gotcha') as HTMLInputElement).value;

      const fd = new FormData(form);
      const data: Record<string, string> = {};
      fd.forEach((val, key) => { data[key] = String(val); });

      // Split full name into first/last for GHL standard fields
      const fullName = (data.full_name || '').trim();
      const sp = fullName.indexOf(' ');
      const first_name = sp === -1 ? fullName : fullName.slice(0, sp);
      const last_name = sp === -1 ? '' : fullName.slice(sp + 1);

      const payload = {
        form_source: 'build-a-house',
        form_name: 'Build A House',
        first_name,
        last_name,
        email: data.email || '',
        phone: data.phone || '',
        ...data,
        page_url: window.location.href,
        submitted_at: new Date().toISOString(),
      };

      // Honeypot: pretend success, don't send
      if (honeypot && honeypot.trim() !== '') {
        form.hidden = true; successEl.hidden = false; return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';

      const WEBHOOK = 'https://services.leadconnectorhq.com/hooks/ipRIuBMrlyPNaFSXDz3q/webhook-trigger/fd7a3b30-ddf9-4415-b751-bfa88beda702';
      try {
        await fetch(WEBHOOK, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        // GHL webhooks return opaque/empty; treat reaching here as success.
        form.hidden = true;
        successEl.hidden = false;
      } catch (err) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'See My Options';
        setErr('sms_consent', 'Something went wrong. Please try again or call (954) 993-1625.');
      }
    });

    showStep(0);
  })();
</script>
