---
// ReverseMortgageForm.astro
// Stairway Mortgage — Reverse Mortgage conversational popup
// Pattern: light/white theme, is:inline + plain JS (NO TypeScript), Enter-key guard, honeypot.
// Own GHL webhook + unique form_source. Lead fires ONCE at Submit (all answers included).
//
// USAGE:
//   ---
//   import ReverseMortgageForm from "../components/ReverseMortgageForm.astro";
//   ---
//   <ReverseMortgageForm />
//   <!-- Trigger anywhere: -->
//   <button data-rm-open>Get Started</button>
//
// TODO BEFORE GO-LIVE:
//   1. Swap REVERSE_MORTGAGE_TRIGGER_ID below with the real GHL Inbound Webhook trigger ID.
//   2. Swap the booking URL placeholder (data-booking-url="#") with the real Calendly/GHL link.
---

<div id="rm-overlay" class="rm-overlay" aria-hidden="true">
  <div class="rm-modal" role="dialog" aria-modal="true" aria-label="Reverse Mortgage">
    <button type="button" class="rm-close" data-rm-close aria-label="Close">&times;</button>

    <!-- Progress -->
    <div class="rm-progress-wrap" id="rm-progress-wrap">
      <div class="rm-progress-track"><div class="rm-progress-bar" id="rm-progress-bar"></div></div>
      <div class="rm-progress-pct" id="rm-progress-pct">0%</div>
    </div>

    <!-- Nav -->
    <div class="rm-nav" id="rm-nav">
      <button type="button" class="rm-nav-btn rm-prev" id="rm-prev">&larr; Previous</button>
      <button type="button" class="rm-nav-btn rm-next" id="rm-next">Next &rarr;</button>
    </div>

    <!-- Honeypot (hidden) -->
    <input type="text" id="rm-hp" name="company_website" tabindex="-1" autocomplete="off"
           style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;" aria-hidden="true" />

    <!-- Steps mount here -->
    <div class="rm-stage" id="rm-stage"></div>
  </div>
</div>

<style>
  .rm-overlay{
    position:fixed; inset:0; z-index:99999; display:none;
    background:rgba(10,14,26,.55); backdrop-filter:blur(2px);
    align-items:center; justify-content:center; padding:20px;
  }
  .rm-overlay.rm-active{ display:flex; }

  .rm-modal{
    position:relative; width:100%; max-width:760px; max-height:92vh; overflow-y:auto;
    background:#fff; border-radius:18px; box-shadow:0 30px 80px rgba(0,0,0,.35);
    padding:48px 40px 56px; font-family:'IBM Plex Sans',system-ui,-apple-system,sans-serif;
    color:#0A0E1A;
  }
  @media(max-width:560px){ .rm-modal{ padding:40px 22px 44px; border-radius:14px; } }

  .rm-close{
    position:absolute; top:14px; right:18px; border:0; background:none;
    font-size:30px; line-height:1; color:#0A0E1A; cursor:pointer; opacity:.5;
  }
  .rm-close:hover{ opacity:1; }

  /* Progress */
  .rm-progress-wrap{ margin:0 auto 26px; max-width:520px; text-align:center; }
  .rm-progress-track{ height:9px; border-radius:99px; background:#e7e7e2; overflow:hidden; }
  .rm-progress-bar{ height:100%; width:0%; background:#0A0E1A; border-radius:99px; transition:width .35s ease; }
  .rm-progress-pct{ font-family:'JetBrains Mono',monospace; font-size:13px; color:#0A0E1A; margin-top:8px; }

  /* Nav */
  .rm-nav{ display:flex; justify-content:space-between; align-items:center; max-width:600px; margin:0 auto 18px; }
  .rm-nav-btn{
    border:0; background:none; cursor:pointer; font-family:'IBM Plex Sans',sans-serif;
    font-size:15px; color:#0A0E1A; padding:6px 4px;
  }
  .rm-nav-btn:disabled{ opacity:.3; cursor:default; }
  .rm-nav-btn:hover:not(:disabled){ opacity:.65; }

  /* Stage */
  .rm-stage{ max-width:640px; margin:0 auto; text-align:center; }
  .rm-step{ display:none; animation:rmFade .3s ease; }
  .rm-step.rm-show{ display:block; }
  @keyframes rmFade{ from{opacity:0; transform:translateY(6px);} to{opacity:1; transform:none;} }

  .rm-q{ font-family:'Fraunces',Georgia,serif; font-weight:500; font-size:30px; line-height:1.2; margin:18px 0 6px; }
  @media(max-width:560px){ .rm-q{ font-size:24px; } }
  .rm-sub{ font-family:'Fraunces',Georgia,serif; font-style:italic; font-size:18px; color:#555; margin:0 0 26px; line-height:1.4; }

  /* Option pills (circle + label) */
  .rm-options{ display:flex; flex-wrap:wrap; gap:12px; justify-content:center; margin-top:8px; }
  .rm-opt{
    display:inline-flex; align-items:center; gap:11px; cursor:pointer;
    border:1.5px solid #0A0E1A; border-radius:10px; padding:14px 20px;
    background:#fff; font-size:16px; color:#0A0E1A; transition:all .15s ease; user-select:none;
  }
  .rm-opt:hover{ background:#f6f6f2; }
  .rm-opt .rm-circle{
    width:20px; height:20px; border-radius:50%; border:2px solid #0A0E1A; flex:0 0 auto;
    display:inline-block; position:relative; transition:all .15s ease;
  }
  .rm-opt.rm-sel{ background:#0A0E1A; color:#fff; }
  .rm-opt.rm-sel .rm-circle{ border-color:#fff; background:#fff; }
  .rm-opt.rm-sel .rm-circle::after{
    content:''; position:absolute; inset:4px; border-radius:50%; background:#0A0E1A;
  }
  .rm-opt-other{ flex:1 1 220px; min-width:200px; }
  .rm-opt-other input{
    border:0; background:none; outline:none; font-size:16px; color:inherit; width:100%;
    font-family:'IBM Plex Sans',sans-serif;
  }
  .rm-opt-other input::placeholder{ color:#999; }

  /* Text inputs */
  .rm-input{
    width:100%; max-width:560px; box-sizing:border-box; margin:0 auto;
    border:1.5px solid #0A0E1A; border-radius:10px; padding:16px 18px;
    font-size:16px; font-family:'IBM Plex Sans',sans-serif; color:#0A0E1A; background:#fff; outline:none;
  }
  .rm-input::placeholder{ color:#999; }
  .rm-input:focus{ box-shadow:0 0 0 3px rgba(24,69,214,.15); }
  .rm-input-label{ display:block; text-align:left; max-width:560px; margin:18px auto 6px;
    font-size:13px; font-weight:600; color:#0A0E1A; }
  .rm-input-label .rm-req{ color:#8B2C2C; }

  /* Slider */
  .rm-slider-wrap{ max-width:560px; margin:18px auto 0; }
  .rm-slider-val{
    display:inline-block; border:1.5px solid #0A0E1A; border-radius:6px;
    padding:4px 12px; font-size:14px; font-family:'JetBrains Mono',monospace; margin-bottom:14px;
  }
  .rm-slider{ -webkit-appearance:none; appearance:none; width:100%; height:4px; border-radius:99px; background:#0A0E1A; outline:none; }
  .rm-slider::-webkit-slider-thumb{ -webkit-appearance:none; appearance:none; width:26px; height:26px; border-radius:50%; background:#0A0E1A; cursor:pointer; }
  .rm-slider::-moz-range-thumb{ width:26px; height:26px; border:0; border-radius:50%; background:#0A0E1A; cursor:pointer; }
  .rm-slider-ends{ display:flex; justify-content:space-between; margin-top:12px; }
  .rm-slider-end{ background:#e7e7e2; border-radius:6px; padding:5px 12px; font-size:13px; font-family:'JetBrains Mono',monospace; }

  /* Pill submit/cta */
  .rm-cta{
    display:inline-block; margin-top:30px; border:0; cursor:pointer;
    background:#0A0E1A; color:#fff; border-radius:99px; padding:16px 42px;
    font-size:16px; font-family:'IBM Plex Sans',sans-serif;
  }
  .rm-cta:hover{ background:#2d2350; }
  .rm-cta:disabled{ opacity:.5; cursor:default; }

  .rm-consent{ max-width:560px; margin:22px auto 0; font-size:13px; line-height:1.55; color:#555; text-align:left; }
  .rm-consent a{ color:#1845D6; text-decoration:underline; }
  .rm-err{ color:#8B2C2C; font-size:13px; margin-top:10px; min-height:16px; }

  /* Thank-you */
  .rm-thanks{ text-align:center; }
  .rm-thanks h2{ font-family:'Fraunces',Georgia,serif; font-weight:500; font-size:28px; margin:6px 0 14px; }
  .rm-thanks p{ font-size:17px; color:#333; margin:0 0 26px; }
  .rm-thanks .rm-link{ color:#1845D6; font-weight:600; }
  .rm-stairs-img{ max-width:420px; width:100%; border-radius:10px; margin-top:8px; }
</style>

<script is:inline>
  (function () {
    // ---- CONFIG ----------------------------------------------------------
    var WEBHOOK_BASE = "https://services.leadconnectorhq.com/hooks/ipRIuBMrlyPNaFSXDz3q/webhook-trigger/";
    var TRIGGER_ID   = "REVERSE_MORTGAGE_TRIGGER_ID"; // TODO: swap with real GHL trigger ID
    var WEBHOOK_URL  = WEBHOOK_BASE + TRIGGER_ID;
    var FORM_SOURCE  = "reverse-mortgage";
    var BOOKING_URL  = "#"; // TODO: swap with real Calendly/GHL booking link

    // ---- STATE -----------------------------------------------------------
    var state = {
      reason: "", reason_other: "",
      referrer: "",
      home_in_mind: "",
      youngest_spouse_age: "",
      military_service: "",
      home_address: "",
      annual_income: "",
      credit_score: "",
      full_name: "", email: "", phone: "",
      free_credit_report: "",
      date_of_birth: "",
      anything_else: ""
    };
    var idx = 0;

    // ---- STEP DEFINITIONS -------------------------------------------------
    // type: choice | text | slider | contact | review (thank-you handled separately)
    var steps = [
      { key:"reason", type:"choice", q:"Why are you considering a reverse mortgage?", sub:"Besides no payments for life…",
        options:["Receive monthly income","Buy a new home","Cash out equity","Consolidate debts to reduce monthly payments","Renovate to enjoy","Renovate to sell"], other:true, required:true },
      { key:"referrer", type:"text", q:"Let's start with this—what's the name of the Loan Officer or person who referred you here?",
        placeholder:"Enter their full name", required:false },
      { key:"home_in_mind", type:"choice", q:"Got a home in mind?",
        options:["Yes - I live in the home now","Yes - I'd like to make an offer","Yes - My offer was accepted and I need financing","No - I'm just beginning my search","Yes - it's complicated. I'd like to discuss."], required:true },
      { key:"youngest_spouse_age", type:"slider", q:"How old is the youngest spouse?", sub:"Under age 55 can be listed as \"non-borrower.\"",
        min:1, max:120, start:62, fmt:"plain", required:true },
      { key:"military_service", type:"choice", q:"Military service for you or your spouse?",
        sub:"If yes, thank you sincerely for everything your family sacrificed. You are deeply loved and honored by our family at Stairway.",
        options:["Yes","No"], required:true },
      { key:"home_address", type:"text", q:"Current home address?", sub:"Typically the address listed on your social security check. ;)",
        placeholder:"Begin typing the address", required:true },
      { key:"annual_income", type:"slider", q:"Annual income?", sub:"Estimate all borrowers employment and retirement income.",
        min:0, max:500000, start:25000, step:1000, fmt:"k", required:true },
      { key:"credit_score", type:"choice", q:"Credit score?", sub:"Just an estimate!",
        options:["800s","700s","600s","500s","No credit established in U.S."], required:true },
      { key:"contact", type:"contact", q:"How can we get in touch?", required:true },
      { key:"free_credit_report", type:"choice", q:"Would you like to receive a free credit report?",
        options:["Yes","No"], required:true },
      { key:"date_of_birth", type:"text", q:"Date of birth? (optional)", sub:"Only for identity verification. No impact to your score. :)",
        placeholder:"MM/DD/YYYY", required:false, inputmode:"numeric" },
      { key:"anything_else", type:"text", q:"Would you like to share anything else?", placeholder:"Type your response here", required:false, submit:true }
    ];
    // NOTE: SSN intentionally DROPPED (compliance — not collected via web form/webhook).

    // ---- DOM refs ---------------------------------------------------------
    var overlay   = document.getElementById("rm-overlay");
    var stage     = document.getElementById("rm-stage");
    var bar       = document.getElementById("rm-progress-bar");
    var pct       = document.getElementById("rm-progress-pct");
    var prevBtn   = document.getElementById("rm-prev");
    var nextBtn   = document.getElementById("rm-next");
    var nav       = document.getElementById("rm-nav");
    var progWrap  = document.getElementById("rm-progress-wrap");
    var hp        = document.getElementById("rm-hp");

    // ---- helpers ----------------------------------------------------------
    function fmtVal(s, v){
      if(s.fmt === "k"){ return v >= 1000 ? Math.round(v/1000) + "K" : String(v); }
      return String(v);
    }
    function esc(t){ var d=document.createElement("div"); d.textContent=t==null?"":t; return d.innerHTML; }

    // ---- render -----------------------------------------------------------
    function render(){
      var s = steps[idx];
      stage.innerHTML = "";
      var wrap = document.createElement("div");
      wrap.className = "rm-step rm-show";

      var qHtml = '<div class="rm-q">' + esc(s.q) + '</div>';
      if(s.sub){ qHtml += '<div class="rm-sub">' + esc(s.sub) + '</div>'; }
      wrap.innerHTML = qHtml;

      if(s.type === "choice"){
        var box = document.createElement("div");
        box.className = "rm-options";
        s.options.forEach(function(opt){
          var el = document.createElement("div");
          el.className = "rm-opt" + (state[s.key] === opt ? " rm-sel" : "");
          el.innerHTML = '<span class="rm-circle"></span><span>' + esc(opt) + '</span>';
          el.addEventListener("click", function(){
            state[s.key] = opt;
            if(s.key === "reason"){ state.reason_other = ""; }
            render();
          });
          box.appendChild(el);
        });
        if(s.other){
          var oth = document.createElement("label");
          oth.className = "rm-opt rm-opt-other" + (state.reason_other ? " rm-sel" : "");
          oth.innerHTML = '<span class="rm-circle"></span>';
          var inp = document.createElement("input");
          inp.type = "text"; inp.placeholder = "Other"; inp.value = state.reason_other || "";
          inp.addEventListener("input", function(){
            state.reason_other = inp.value;
            if(inp.value){ state.reason = ""; }
            oth.classList.toggle("rm-sel", !!inp.value);
            // de-select circle options
            Array.prototype.forEach.call(box.querySelectorAll(".rm-opt:not(.rm-opt-other)"), function(n){ n.classList.remove("rm-sel"); });
          });
          inp.addEventListener("keydown", enterGuard);
          oth.appendChild(inp);
          box.appendChild(oth);
        }
        wrap.appendChild(box);
      }

      else if(s.type === "text"){
        var input = document.createElement("input");
        input.className = "rm-input"; input.type = "text";
        input.placeholder = s.placeholder || "";
        input.value = state[s.key] || "";
        if(s.inputmode){ input.setAttribute("inputmode", s.inputmode); }
        input.addEventListener("input", function(){ state[s.key] = input.value; });
        input.addEventListener("keydown", enterGuard);
        wrap.appendChild(input);
      }

      else if(s.type === "slider"){
        var sw = document.createElement("div"); sw.className = "rm-slider-wrap";
        var cur = state[s.key] !== "" ? Number(state[s.key]) : s.start;
        var valBox = document.createElement("div"); valBox.className = "rm-slider-val"; valBox.textContent = fmtVal(s, cur);
        var sl = document.createElement("input");
        sl.type = "range"; sl.className = "rm-slider";
        sl.min = s.min; sl.max = s.max; sl.step = s.step || 1; sl.value = cur;
        state[s.key] = String(cur);
        sl.addEventListener("input", function(){ state[s.key] = sl.value; valBox.textContent = fmtVal(s, Number(sl.value)); });
        var ends = document.createElement("div"); ends.className = "rm-slider-ends";
        ends.innerHTML = '<span class="rm-slider-end">' + fmtVal(s, s.min) + '</span>' +
                         '<span class="rm-slider-end">' + fmtVal(s, s.max) + '</span>';
        sw.appendChild(valBox); sw.appendChild(sl); sw.appendChild(ends);
        wrap.appendChild(sw);
      }

      else if(s.type === "contact"){
        var c = document.createElement("div");
        c.innerHTML =
          '<label class="rm-input-label">Full Name <span class="rm-req">*</span></label>' +
          '<input class="rm-input" id="rm-fn" type="text" placeholder="Your full name" value="' + esc(state.full_name) + '">' +
          '<label class="rm-input-label">Email <span class="rm-req">*</span></label>' +
          '<input class="rm-input" id="rm-em" type="email" placeholder="you@email.com" value="' + esc(state.email) + '">' +
          '<label class="rm-input-label">Mobile Phone Number <span class="rm-req">*</span></label>' +
          '<input class="rm-input" id="rm-ph" type="tel" placeholder="(555) 555-5555" value="' + esc(state.phone) + '">' +
          '<div class="rm-consent">By clicking "Get Rates," I agree to Stairway Mortgage\'s ' +
          '<a href="/terms-of-use/" target="_blank" rel="noopener">Terms of Use</a> and ' +
          '<a href="/privacy-policy/" target="_blank" rel="noopener">Privacy Policy</a>. ' +
          'I also consent to receive calls, text messages, and/or pre-recorded voicemails via automated technology' +
          '—even if I\'m on a Do Not Call list. Consent is not a condition of purchase. I can opt out any time by replying "STOP."</div>' +
          '<div class="rm-err" id="rm-contact-err"></div>';
        wrap.appendChild(c);
        var fn = c.querySelector("#rm-fn"), em = c.querySelector("#rm-em"), ph = c.querySelector("#rm-ph");
        fn.addEventListener("input", function(){ state.full_name = fn.value; });
        em.addEventListener("input", function(){ state.email = em.value; });
        ph.addEventListener("input", function(){ state.phone = ph.value; });
        [fn, em, ph].forEach(function(n){ n.addEventListener("keydown", enterGuard); });
      }

      stage.appendChild(wrap);

      // progress + nav
      var total = steps.length;
      var p = Math.round(((idx) / total) * 100);
      if(idx === total - 1){ p = 100; }
      else { p = Math.round(((idx+1) / total) * 100); }
      bar.style.width = p + "%"; pct.textContent = p + "%";

      prevBtn.disabled = (idx === 0);
      nextBtn.innerHTML = s.submit ? 'Submit &#10003;' : 'Next &rarr;';
    }

    // ---- Enter-key guard: advance instead of native submit ----------------
    function enterGuard(e){
      if(e.key === "Enter"){
        e.preventDefault();
        goNext();
      }
    }

    // ---- validation -------------------------------------------------------
    function validateCurrent(){
      var s = steps[idx];
      if(!s.required) return true;

      if(s.type === "choice"){
        if(s.key === "reason"){ return !!(state.reason || state.reason_other); }
        return !!state[s.key];
      }
      if(s.type === "text"){ return !!(state[s.key] && state[s.key].trim()); }
      if(s.type === "slider"){ return state[s.key] !== ""; }
      if(s.type === "contact"){
        var err = document.getElementById("rm-contact-err");
        if(!state.full_name.trim()){ if(err) err.textContent = "Please enter your full name."; return false; }
        if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(state.email.trim())){ if(err) err.textContent = "Please enter a valid email."; return false; }
        if(state.phone.replace(/\D/g,"").length < 10){ if(err) err.textContent = "Please enter a valid phone number."; return false; }
        if(err) err.textContent = "";
        return true;
      }
      return true;
    }

    // ---- navigation -------------------------------------------------------
    function goNext(){
      if(!validateCurrent()){
        if(steps[idx].type !== "contact"){ flashError(); }
        return;
      }
      if(idx === steps.length - 1){ submit(); return; }
      idx++; render();
    }
    function goPrev(){ if(idx > 0){ idx--; render(); } }

    function flashError(){
      // brief visual nudge on the stage
      stage.style.transition = "none";
      stage.style.opacity = "0.4";
      setTimeout(function(){ stage.style.transition = "opacity .25s"; stage.style.opacity = "1"; }, 60);
    }

    // ---- submit -----------------------------------------------------------
    function submit(){
      if(hp && hp.value){ return; } // honeypot tripped — silently drop

      var parts = (state.full_name || "").trim().split(/\s+/);
      var first = parts.shift() || "";
      var last  = parts.join(" ") || "";

      var reasonFinal = state.reason || (state.reason_other ? ("Other: " + state.reason_other) : "");

      var payload = {
        form_source: FORM_SOURCE,
        first_name: first,
        last_name: last,
        full_name: (state.full_name || "").trim(),
        email: (state.email || "").trim(),
        phone: (state.phone || "").trim(),
        reason_for_reverse_mortgage: reasonFinal,
        referrer_name: state.referrer || "",
        home_in_mind: state.home_in_mind || "",
        youngest_spouse_age: state.youngest_spouse_age || "",
        military_service: state.military_service || "",
        home_address: state.home_address || "",
        annual_income: state.annual_income || "",
        credit_score: state.credit_score || "",
        free_credit_report: state.free_credit_report || "",
        date_of_birth: state.date_of_birth || "",
        anything_else: state.anything_else || "",
        page_url: window.location.origin + window.location.pathname
      };

      // fire-and-forget; thank-you shows regardless of network
      try{
        fetch(WEBHOOK_URL, {
          method:"POST",
          headers:{ "Content-Type":"application/json" },
          body: JSON.stringify(payload),
          keepalive: true
        }).catch(function(){});
      }catch(e){}

      showThanks(first, last);
    }

    function showThanks(first, last){
      progWrap.style.display = "none";
      nav.style.display = "none";
      var name = (first + " " + last).trim();
      stage.innerHTML =
        '<div class="rm-thanks">' +
          '<h2>Congratulations on taking your 1st step' + (name ? " " + esc(name) : "") + '!</h2>' +
          '<p>Please <a class="rm-link" href="' + BOOKING_URL + '" data-booking-url target="_blank" rel="noopener">click here</a> to schedule your review call.</p>' +
          '<a href="' + BOOKING_URL + '" data-booking-url target="_blank" rel="noopener">' +
            '<img class="rm-stairs-img" src="/images/stairway-stairs.jpg" alt="Stairway" ' +
            'onerror="this.style.display=\'none\'">' +
          '</a>' +
        '</div>';
    }

    // ---- open/close -------------------------------------------------------
    function open(){
      idx = 0;
      progWrap.style.display = "";
      nav.style.display = "";
      render();
      overlay.classList.add("rm-active");
      overlay.setAttribute("aria-hidden","false");
      document.body.style.overflow = "hidden";
    }
    function close(){
      overlay.classList.remove("rm-active");
      overlay.setAttribute("aria-hidden","true");
      document.body.style.overflow = "";
    }

    // ---- wire events ------------------------------------------------------
    nextBtn.addEventListener("click", goNext);
    prevBtn.addEventListener("click", goPrev);

    document.addEventListener("click", function(e){
      var opener = e.target.closest ? e.target.closest("[data-rm-open]") : null;
      if(opener){ e.preventDefault(); open(); }
      var closer = e.target.closest ? e.target.closest("[data-rm-close]") : null;
      if(closer){ e.preventDefault(); close(); }
    });
    overlay.addEventListener("click", function(e){ if(e.target === overlay){ close(); } });
    document.addEventListener("keydown", function(e){ if(e.key === "Escape" && overlay.classList.contains("rm-active")){ close(); } });
  })();
</script>
