---
/*  Stairway Mortgage — Conversion-focused header
    3 layers: trust strip · main bar with 3 mega-menus · sticky condensed on scroll
    Self-contained: styles + script bundled in component                          */

/* ── Menu data ───────────────────────────────────────────────── */
const menus = [
  {
    id: 'mega-mortgage',
    label: 'Get a Mortgage',
    columns: [
      {
        heading: 'Most Popular',
        links: [
          { icon: 'home',    title: 'Buy a Home',          desc: 'Purchase your next property',        href: '/buy-a-house-journey/' },
          { icon: 'refresh', title: 'Refinance or HELOC',  desc: 'Lower your rate or tap equity',      href: '/refinance-or-heloc-journey/' },
          { icon: 'hammer',  title: 'Build a Home',        desc: 'Construction-to-permanent loans',    href: '/build-a-house-journey/' },
        ],
      },
      {
        heading: 'More Paths',
        links: [
          { icon: 'wrench',   title: 'Renovate',            desc: 'Fund improvements or fix-and-flip',  href: '/renovate-a-house-journey/' },
          { icon: 'heart',    title: 'Reverse Mortgage',    desc: 'Income from your home, 55+',         href: '/reverse-mortgage-journey/' },
          { icon: 'tag',      title: 'Sell a Home',         desc: 'Bridge loans & seller strategies',   href: '/sell-a-house-journey/' },
          { icon: 'chart',    title: 'Build a Wealth Plan', desc: 'Real estate as a wealth engine',     href: '/build-a-wealth-plan-journey/' },
        ],
      },
    ],
    feature: {
      title: 'See your options in about a minute',
      cta: { label: 'See My Options', href: '/same-day-approval/' },
    },
    quickQuotes: [
      { label: 'Purchase',      href: '/purchase-inquiry/' },
      { label: 'Refi / HELOC',  href: '/refinance-or-heloc-inquiry/' },
      { label: 'Reverse',       href: '/reverse-mortgage-inquiry/' },
      { label: 'Same-Day',      href: '/same-day-approval/' },
      { label: 'Apply for Mortgage', href: 'https://stairwaymortgage.my1003app.com/', rel: 'noopener' },
    ],
  },
  {
    id: 'mega-situation',
    label: 'Your Situation',
    columns: [
      {
        heading: "Where you're at",
        links: [
          { icon: 'plane',   title: 'Relocate Anywhere™',    desc: 'Agents in all 50 states',            href: '/relocate-anywhere/' },
          { icon: 'key',     title: 'First-Time Buyer',     desc: 'Buying your very first home',        href: '/first-time-buyers-journey/' },
          { icon: 'home',    title: 'Current Homeowner',     desc: 'Refinance, renovate, or leverage',   href: '/homeowners-journey/' },
          { icon: 'heart',   title: 'Homeowner 55+',        desc: 'Retirement income & downsizing',     href: '/senior-homeowners-55-journey/' },
          { icon: 'chart',   title: 'Real-Estate Investor', desc: 'Scale your rental portfolio',        href: '/active-investors-journey/' },
        ],
      },
      {
        heading: 'Clients We Serve — By Profession',
        links: [
          { icon: 'plane',   title: 'Aviation Professionals', desc: 'Pilot & crew specialist lending',  href: '/aviation-professionals/', live: true },
          { icon: 'medical', title: 'Medical Professionals',              desc: 'Physician & nurse loan programs',     live: false },
          { icon: 'medical', title: 'Dental & Wellness Professionals',    desc: 'Specialized healthcare lending',      live: false },
          { icon: 'brief',   title: 'Corporate Executives',              desc: 'Stock-comp & RSU-friendly loans',     live: false },
          { icon: 'pen',     title: 'Creative Earners',                  desc: 'Flexible income documentation',       live: false },
          { icon: 'user',    title: 'Professional Services',             desc: 'Legal & entrepreneurs',               live: false },
          { icon: 'ship',    title: 'Yacht Professionals',               desc: 'Maritime industry lending',            live: false },
          { icon: 'trend',   title: 'Sales Professionals',               desc: 'Commission-based income programs',    live: false },
        ],
      },
    ],
    feature: {
      title: "Let's build a plan around your situation",
      cta: { label: 'Build My Plan', href: '/discovery-quiz/' },
    },
  },
  {
    id: 'mega-tools',
    label: 'Free Tools & Rates',
    columns: [
      {
        heading: 'Tools & rates',
        links: [
          { icon: 'grad',    title: 'The 8 Steps™',          desc: 'The Stairway Client System',         href: '/the-8-steps/' },
          { icon: 'calc',    title: 'Loan Calculators',     desc: 'Run the numbers yourself',           href: '/loan-calculators/' },
          { icon: 'trend',   title: "Today's Rates",        desc: 'Live wholesale rate check',          href: '/current-rates/' },
          { icon: 'home',    title: 'Home Value Report',    desc: 'Instant property valuation',         href: '/home-value-report/' },
          { icon: 'search',  title: 'Private Home Search',  desc: 'MLS access, no spam',                href: '/private-home-search/' },
        ],
      },
      {
        heading: 'Learn & proof',
        links: [
          { icon: 'file',    title: 'Case Studies',         desc: 'Real clients, real numbers',         href: '/case-studies/' },
          { icon: 'pen',     title: 'Blog',                 desc: 'Market updates & tips',              href: '/blog/' },
          { icon: 'book',    title: 'Free Guides',          desc: 'Step-by-step ebooks',                href: '/guides/' },
          { icon: 'grad',    title: 'Courses',              desc: 'Video learning library',             href: '/courses/' },
        ],
      },
    ],
    feature: {
      title: 'Find your top financial priorities',
      cta: { label: 'Discovery Quiz', href: '/discovery-quiz/' },
    },
  },
];

/* ── Icon SVG paths (16×16 viewBox) ──────────────────────── */
const icons: Record<string, string> = {
  home:    'M8 1L1 7v8h5v-4h4v4h5V7L8 1z',
  refresh: 'M2 8a6 6 0 0110.3-4.2M14 8a6 6 0 01-10.3 4.2',
  hammer:  'M10 2L6 6l4 4 4-4-4-4zM6 6L1 11l2 2 5-5',
  wrench:  'M5 3a4 4 0 015.6 5.6l4 4-1.4 1.4-4-4A4 4 0 015 3z',
  heart:   'M8 14s-5.5-3.5-5.5-7A3 3 0 018 4.5 3 3 0 0113.5 7C13.5 10.5 8 14 8 14z',
  tag:     'M1 1h6l7 7-6 6-7-7V1zm3 3a1 1 0 100-2 1 1 0 000 2z',
  chart:   'M1 14h14M3 10v4M7 6v8M11 8v6',
  key:     'M12 7a3 3 0 11-6 0 3 3 0 016 0zm-3 3v4m-2 0h4',
  medical: 'M6 1v4H2v4h4v4h4V9h4V5h-4V1H6z',
  plane:   'M8 2L3 8h3v6h4V8h3L8 2z',
  brief:   'M2 5h12v9H2V5zm4-3h4v3H6V2z',
  user:    'M8 8a3 3 0 100-6 3 3 0 000 6zm-5 6a5 5 0 0110 0H3z',
  pen:     'M12 2l2 2-9 9H3v-2l9-9z',
  calc:    'M3 1h10v14H3V1zm2 3h6m-6 3h3m3 0h0m-6 3h3m3 0h0',
  trend:   'M1 12l4-4 3 2 7-8',
  search:  'M11 11l3 3m-4-2a5 5 0 110-10 5 5 0 010 10z',
  file:    'M4 1h6l4 4v10H4V1zm6 0v4h4',
  book:    'M2 2h5v12H2V2zm7 0h5v12H9V2z',
  grad:    'M8 1L1 5l7 4 7-4-7-4zM3 7v4l5 3 5-3V7',
  ship:    'M1 13c2 1 4 1 6 0s4-1 6 0M3 9l5-6 5 6M8 3v6',
};
---

<!-- ═══════════════════════════════════════════════════════════
     LAYER 1 — Trust Strip
     ═══════════════════════════════════════════════════════════ -->
<div class="hdr-trust" aria-label="Trust signals">
  <div class="container-page">
    <div class="hdr-trust__inner">
      <div class="hdr-trust__left">
        <span class="hdr-trust__item">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="var(--color-green)" aria-hidden="true"><path d="M8 0l2.5 5 5.5.8-4 3.9.9 5.3L8 12.5 3.1 15l.9-5.3-4-3.9L5.5 5z"/></svg>
          5.0 · 624 reviews
        </span>
        <span class="hdr-trust__sep">·</span>
        <span class="hdr-trust__item">NEXA licensed in 48 states</span>
        <span class="hdr-trust__sep">·</span>
        <span class="hdr-trust__item">Jim Blackburn · <span class="mono">NMLS #1072866</span></span>
      </div>
      <span class="hdr-trust__right">Equal Housing Lender</span>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════
     LAYER 2 — Main Navigation Bar
     ═══════════════════════════════════════════════════════════ -->
<header class="hdr-main" id="hdr-main">
  <div class="container-page">
    <div class="hdr-main__inner">

      <!-- Logo -->
      <a href="/" class="hdr-logo" aria-label="Stairway Mortgage — home">
        <img src="/logo-header.png" alt="Stairway Mortgage" class="hdr-logo__img" />
      </a>

      <!-- Desktop mega-menu triggers -->
      <nav class="hdr-nav" aria-label="Main navigation">
        {menus.map((m) => (
          <div class="hdr-nav__item" data-menu-wrap>
            <button
              class="hdr-nav__trigger"
              aria-controls={m.id}
              aria-expanded="false"
              aria-haspopup="true"
            >
              {m.label}
              <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="hdr-nav__chevron">
                <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        ))}
      </nav>

      <!-- Right: phone + CTA -->
      <div class="hdr-actions">
        <a href="tel:+19549931625" class="hdr-phone" aria-label="Call (954) 993-1625">
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><path d="M6 3l-1.4-.7c-.5-.3-1.2-.1-1.5.3L2 4.2c-.4.6-.3 1.5.2 2C4 8.3 7.7 12 9.8 13.8c.5.4 1.3.5 1.9.1l1.6-1.1c.5-.3.6-1 .3-1.5L13 10l-2.5-.3-1.2 1.2c-.8-.5-2.5-2.2-3-3l1.2-1.2L6 3z"/></svg>
          <span class="hdr-phone__number mono">(954) 993-1625</span>
        </a>
        <div class="hdr-cta-wrap">
          <a href="https://stairwaymortgage.my1003app.com/agent/jimblackburn/inquiry" rel="noopener" class="btn btn-blue hdr-cta">See My Options</a>
          <span class="hdr-cta-sub">60-sec match · no credit pull</span>
        </div>
      </div>

      <!-- Mobile hamburger -->
      <button class="hdr-burger" aria-label="Open menu" aria-expanded="false" id="hdr-burger">
        <span class="hdr-burger__line"></span>
        <span class="hdr-burger__line"></span>
        <span class="hdr-burger__line"></span>
      </button>
    </div>
  </div>

  <!-- ── Mega-menu panels (desktop) ── -->
  {menus.map((m) => (
    <div class="mega" id={m.id} role="region" aria-label={m.label + ' menu'}>
      <div class="container-page">
        {m.id === 'mega-situation' && (
          <a href="/your-journey/" class="mega__journey-cta">
            <span class="mega__journey-icon" aria-hidden="true">&#x2302;</span>
            <span class="mega__journey-text">
              <strong>Not sure where you fit?</strong>
              <span>See the 8-step Stairway Journey</span>
            </span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="mega__journey-arrow"><path d="M3 11L11 3M11 3H5M11 3V9" stroke="currentColor" stroke-width="1.4"/></svg>
          </a>
        )}
        <div class="mega__grid">
          <!-- Link columns -->
          <div class="mega__cols">
            {m.columns.map((col) => (
              <div class="mega__col">
                <h3 class="mega__heading">{col.heading}</h3>
                <ul class="mega__list">
                  {col.links.map((link) => (
                    <li>
                      {link.live === false ? (
                        <span class="mega__link mega__link--soon">
                          <span class="mega__icon mega__icon--soon" aria-hidden="true">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                              <path d={icons[link.icon] || icons.home}/>
                            </svg>
                          </span>
                          <span class="mega__link-text">
                            <strong>{link.title} <span class="mega__soon-badge">SOON</span></strong>
                            <span>{link.desc}</span>
                          </span>
                        </span>
                      ) : (
                        <a href={link.href} class="mega__link">
                          <span class="mega__icon" aria-hidden="true">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                              <path d={icons[link.icon] || icons.home}/>
                            </svg>
                          </span>
                          <span class="mega__link-text">
                            <strong>{link.title}</strong>
                            <span>{link.desc}</span>
                          </span>
                        </a>
                      )}
                      {link.subs && (
                        <ul class="mega__subs">
                          {link.subs.map((sub) => (
                            <li><a href={sub.href} class="mega__sub-link">{sub.title}</a></li>
                          ))}
                        </ul>
                      )}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
          <!-- Feature card -->
          <div class="mega__feature">
            <div class="mega__feature-card">
              <p class="mega__feature-title font-display">{m.feature.title}</p>
              <a href={m.feature.cta.href} class="btn btn-blue mega__feature-btn">{m.feature.cta.label}</a>
            </div>
          </div>
        </div>
        {/* Quick-quote chips (only on Get a Mortgage) */}
        {m.quickQuotes && (
          <div class="mega__quotes">
            <span class="mega__quotes-label">Quick quotes:</span>
            {m.quickQuotes.map((q) => (
              <a href={q.href} class="mega__quote-chip">{q.label}</a>
            ))}
          </div>
        )}
      </div>
    </div>
  ))}
</header>

<!-- ═══════════════════════════════════════════════════════════
     LAYER 3 — Sticky Condensed Bar (appears on scroll)
     ═══════════════════════════════════════════════════════════ -->
<div class="hdr-sticky" id="hdr-sticky" aria-hidden="true">
  <div class="container-page">
    <div class="hdr-sticky__inner">
      <a href="/" class="hdr-logo hdr-logo--sm" aria-label="Home">
        <img src="/logo-header.png" alt="Stairway Mortgage" class="hdr-logo__img" />
      </a>
      <div class="hdr-sticky__right">
        <a href="tel:+19549931625" class="hdr-phone hdr-phone--sm" aria-label="Call">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><path d="M6 3l-1.4-.7c-.5-.3-1.2-.1-1.5.3L2 4.2c-.4.6-.3 1.5.2 2C4 8.3 7.7 12 9.8 13.8c.5.4 1.3.5 1.9.1l1.6-1.1c.5-.3.6-1 .3-1.5L13 10l-2.5-.3-1.2 1.2c-.8-.5-2.5-2.2-3-3l1.2-1.2L6 3z"/></svg>
          <span class="mono">(954) 993-1625</span>
        </a>
        <a href="https://stairwaymortgage.my1003app.com/agent/jimblackburn/inquiry" rel="noopener" class="btn btn-blue hdr-cta hdr-cta--sm">See My Options</a>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════
     MOBILE DRAWER
     ═══════════════════════════════════════════════════════════ -->
<div class="hdr-drawer" id="hdr-drawer" aria-hidden="true">
  <div class="hdr-drawer__top">
    <a href="https://stairwaymortgage.my1003app.com/agent/jimblackburn/inquiry" rel="noopener" class="btn btn-blue hdr-drawer__cta">See My Options</a>
    <p class="hdr-drawer__cta-sub">60-sec match · no credit pull</p>
  </div>
  <nav class="hdr-drawer__nav" aria-label="Mobile navigation">
    {menus.map((m) => (
      <details class="hdr-drawer__section">
        <summary class="hdr-drawer__summary font-display">
          {m.label}
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="hdr-drawer__plus" aria-hidden="true">
            <path d="M6 2v8M2 6h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </summary>
        <div class="hdr-drawer__links">
          {m.columns.flatMap(c => c.links).map(link => (
            link.live === false ? (
              <span class="hdr-drawer__link hdr-drawer__link--soon">{link.title} <span class="mega__soon-badge">SOON</span></span>
            ) : (
              <Fragment>
                <a href={link.href} class="hdr-drawer__link">{link.title}</a>
                {link.subs && link.subs.map(sub => (
                  <a href={sub.href} class="hdr-drawer__link hdr-drawer__sub-link">{sub.title}</a>
                ))}
              </Fragment>
            )
          ))}
        </div>
      </details>
    ))}
  </nav>
  <div class="hdr-drawer__bottom">
    <a href="tel:+19549931625" class="btn btn-ghost hdr-drawer__call">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><path d="M6 3l-1.4-.7c-.5-.3-1.2-.1-1.5.3L2 4.2c-.4.6-.3 1.5.2 2C4 8.3 7.7 12 9.8 13.8c.5.4 1.3.5 1.9.1l1.6-1.1c.5-.3.6-1 .3-1.5L13 10l-2.5-.3-1.2 1.2c-.8-.5-2.5-2.2-3-3l1.2-1.2L6 3z"/></svg>
      Call (954) 993-1625
    </a>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════
     SCOPED STYLES
     ═══════════════════════════════════════════════════════════ -->
<style>
  /* ── Trust strip ── */
  .hdr-trust {
    background: var(--color-ink);
    color: var(--color-paper);
    font-size: 11.5px;
    letter-spacing: 0.01em;
    line-height: 34px;
    height: 34px;
    overflow: hidden;
    position: relative;
    z-index: 52;
  }
  .hdr-trust__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .hdr-trust__left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: nowrap;
    overflow: hidden;
  }
  .hdr-trust__item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    white-space: nowrap;
    opacity: 0.85;
  }
  .hdr-trust__sep { opacity: 0.3; }
  .hdr-trust__right {
    white-space: nowrap;
    opacity: 0.6;
    font-size: 10.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ── Main bar ── */
  .hdr-main {
    position: sticky;
    top: 0;
    z-index: 51;
    background: rgba(250, 250, 247, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-bone);
  }
  .hdr-main__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 64px;
  }

  /* ── Logo ── */
  .hdr-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .hdr-logo__img { height: 54px; width: auto; display: block; }
  .hdr-logo--sm .hdr-logo__img { height: 38px; }

  /* ── Nav triggers ── */
  .hdr-nav {
    display: none;
    align-items: center;
    gap: 2px;
    flex: 1;
    justify-content: center;
  }
  @media (min-width: 980px) { .hdr-nav { display: flex; } }
  .hdr-nav__trigger {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 0.55rem 0.9rem;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-ink);
    background: none;
    border: none;
    cursor: pointer;
    border-radius: 6px;
    transition: background 0.15s;
    letter-spacing: -0.005em;
  }
  .hdr-nav__trigger:hover,
  .hdr-nav__trigger[aria-expanded="true"] {
    background: var(--color-paper-tint);
  }
  .hdr-nav__chevron { transition: transform 0.2s; }
  .hdr-nav__trigger[aria-expanded="true"] .hdr-nav__chevron {
    transform: rotate(180deg);
  }

  /* ── Actions (phone + CTA) ── */
  .hdr-actions {
    display: none;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }
  @media (min-width: 980px) { .hdr-actions { display: flex; } }
  .hdr-phone {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
    color: var(--color-ink);
    transition: color 0.15s;
  }
  .hdr-phone:hover { color: var(--color-blue); }
  .hdr-phone__number { font-size: 13.5px; }
  .hdr-cta-wrap { text-align: center; }
  .hdr-cta { font-size: 13.5px !important; padding: 0.6rem 1.1rem !important; }
  .hdr-cta-sub {
    display: block;
    font-size: 10px;
    color: var(--color-mute);
    margin-top: 2px;
    letter-spacing: 0.02em;
  }

  /* ── Hamburger ── */
  .hdr-burger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
    margin-right: -8px;
    background: none;
    border: none;
    cursor: pointer;
  }
  @media (min-width: 980px) { .hdr-burger { display: none; } }
  .hdr-burger__line {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-ink);
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.25s;
  }
  .hdr-burger.is-open .hdr-burger__line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hdr-burger.is-open .hdr-burger__line:nth-child(2) { opacity: 0; }
  .hdr-burger.is-open .hdr-burger__line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Mega-menu panels ── */
  .mega {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--color-paper);
    border-top: 1px solid var(--color-bone);
    box-shadow: 0 24px 48px -24px rgba(10, 14, 26, 0.12);
    padding: 2rem 0 1.5rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 0.2s, transform 0.2s, visibility 0.2s;
    z-index: 60;
