  .rf-nav{ display:flex; justify-content:space-between; align-items:center; max-width:560px; margin:0 auto 28px; }
  .rf-nav-btn{ border:0; background:none; cursor:pointer; font-family:'IBM Plex Sans',sans-serif; font-size:15px; color:#0A0E1A; padding:6px 2px; letter-spacing:.01em; }
  .rf-nav-btn:disabled{ opacity:.25; cursor:default; }
  .rf-nav-btn:hover:not(:disabled){ color:#2d2350; }
  .rf-next{ font-weight:600; }
  .rf-stage{ max-width:600px; margin:0 auto; }
