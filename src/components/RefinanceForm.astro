            setTimeout(function(){ goNext(); }, 220);
          });
          box.appendChild(o);
        });
        wrap.appendChild(box);
      }
      else if(s.type==="text"){
        var input = el("input","rf-input");
        input.type="text"; input.placeholder=s.placeholder||""; input.value=state[s.key]||"";
        if(s.inputmode){ input.setAttribute("inputmode", s.inputmode); }
        input.addEventListener("input", function(){ state[s.key]=input.value; });
        input.addEventListener("keydown", enterGuard);
        wrap.appendChild(input);
        setTimeout(function(){ input.focus(); }, 50);
      }
      else if(s.type==="location"){
        var lw = el("div","rf-locwrap");
        var li = el("input","rf-input");
        li.type="text"; li.placeholder=s.placeholder||"Start typing your address\u2026"; li.value=state[s.key]||"";
        li.setAttribute("autocomplete","off");
        li.addEventListener("input", function(){
          state[s.key]=li.value;
          // if the user edits after a pick, the parsed fields may be stale; mark unconfirmed
          state.addr_confirmed = "";
        });
        li.addEventListener("keydown", function(e){
          // Don't let Enter submit while the Places dropdown is open / mid-type
          if(e.key==="Enter"){ e.preventDefault(); }
        });
        lw.appendChild(li);
        // small confirmation line shown after a valid pick
        var conf = el("div","rf-addr-conf"); conf.id="rf-addr-conf";
        conf.innerHTML = state.addr_confirmed ? ('\u2713 '+esc(state.addr_confirmed)) : "";
        conf.style.display = state.addr_confirmed ? "block" : "none";
        lw.appendChild(conf);
        wrap.appendChild(lw);
        setTimeout(function(){ li.focus(); }, 50);
        // attach Google Places autocomplete (loads the script on first use)
        STW_attachPlaces(li, conf, state);
      }
      else if(s.type==="slider"){
        var sw = el("div","rf-slider-wrap");
        var cur = (state[s.key]!=="" && state[s.key]!=null) ? Number(state[s.key]) : s.start;
        state[s.key]=String(cur);
        var valBox = el("div","rf-slider-val"); valBox.innerHTML=fmtVal(s,cur);
        var sl = el("input","rf-slider");
        sl.type="range"; sl.min=s.min; sl.max=s.max; sl.step=s.step||1; sl.value=cur;
        function paint(){ var p=((Number(sl.value)-s.min)/(s.max-s.min))*100; sl.style.backgroundSize=p+"% 100%"; }
        paint();
        sl.addEventListener("input", function(){ state[s.key]=sl.value; valBox.innerHTML=fmtVal(s,Number(sl.value)); paint(); });
        var ends = el("div","rf-slider-ends");
        ends.innerHTML = '<span class="rf-slider-end">'+fmtVal(s,s.min)+'</span><span class="rf-slider-end">'+fmtVal(s,s.max)+'</span>';
        sw.appendChild(valBox); sw.appendChild(sl); sw.appendChild(ends);
        wrap.appendChild(sw);
      }
      else if(s.type==="contact"){
        var c = el("div","rf-contact");
        c.innerHTML =
          '<label class="rf-input-label">Full Name <span class="rf-req">*</span></label>'+
          '<input class="rf-input" id="rf-fn" type="text" placeholder="Your full name" value="'+esc(state.full_name)+'">'+
          '<label class="rf-input-label">Email <span class="rf-req">*</span></label>'+
          '<input class="rf-input" id="rf-em" type="email" placeholder="you@email.com" value="'+esc(state.email)+'">'+
          '<label class="rf-input-label">Mobile Phone Number <span class="rf-req">*</span></label>'+
          '<input class="rf-input" id="rf-ph" type="tel" placeholder="(555) 555-5555" value="'+esc(state.phone)+'">'+
          '<div class="rf-consent">By clicking "See My Options," I agree to Stairway Mortgage\'s <a href="/terms/" target="_blank" rel="noopener">Terms of Use</a> and <a href="/privacy/" target="_blank" rel="noopener">Privacy Policy</a>. I also consent to receive calls, text messages, and/or pre-recorded voicemails via automated technology—even if I\'m on a Do Not Call list. Consent is not a condition of purchase. I can opt out any time by replying "STOP."</div>'+
          '<div class="rf-trust">Jim Blackburn · NMLS #1072866</div>'+
          '<div class="rf-err" id="rf-contact-err"></div>';
        wrap.appendChild(c);
        var fn=c.querySelector("#rf-fn"), em=c.querySelector("#rf-em"), ph=c.querySelector("#rf-ph");
        fn.addEventListener("input", function(){ state.full_name=fn.value; });
        em.addEventListener("input", function(){ state.email=em.value; });
        ph.addEventListener("input", function(){ state.phone=ph.value; });
        [fn,em,ph].forEach(function(n){ n.addEventListener("keydown", enterGuard); });
      }

      stage.appendChild(wrap);
      var total = steps.length;
      var p = (idx===total-1) ? 100 : Math.round(((idx+1)/total)*100);
      bar.style.width=p+"%"; pct.textContent=p+"%";
      prevBtn.disabled = (idx===0);
      nextBtn.innerHTML = (idx===total-1) ? 'Submit &#10003;' : 'Next &rarr;';
    }

    function enterGuard(e){ if(e.key==="Enter"){ e.preventDefault(); goNext(); } }

    function validateCurrent(){
      var s = steps[idx];
      if(!s.required) return true;
      if(s.type==="choice"){ return !!state[s.key]; }
      if(s.type==="text"){ return !!(state[s.key]&&state[s.key].trim()); }
      if(s.type==="location"){ return !!(state[s.key] && state[s.key].trim()); }
      if(s.type==="slider"){ return state[s.key]!==""; }
      if(s.type==="contact"){
        var err=document.getElementById("rf-contact-err");
        if(!state.full_name.trim()){ if(err) err.textContent="Please enter your full name."; return false; }
        if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(state.email.trim())){ if(err) err.textContent="Please enter a valid email."; return false; }
        if(state.phone.replace(/\D/g,"").length<10){ if(err) err.textContent="Please enter a valid phone number."; return false; }
        if(err) err.textContent=""; return true;
      }
      return true;
    }

    function goNext(){
      if(!validateCurrent()){ if(steps[idx].type!=="contact"){ flashError(); } return; }
      if(idx===steps.length-1){ submit(); return; }
      idx++; render();
    }
    function goPrev(){ if(idx>0){ idx--; render(); } }
    function flashError(){ stage.style.transition="none"; stage.style.opacity="0.4"; setTimeout(function(){ stage.style.transition="opacity .25s"; stage.style.opacity="1"; },60); }

    function submit(){
      if(hp && hp.value && hp.getAttribute("data-touched")==="1"){ return; }
      var parts=(state.full_name||"").trim().split(/\s+/);
      var first=parts.shift()||""; var last=parts.join(" ")||"";
      var payload = {
        form_source:FORM_SOURCE, loan_purpose:LOAN_PURPOSE,
        first_name:first, last_name:last, full_name:(state.full_name||"").trim(),
        email:(state.email||"").trim(), phone:(state.phone||"").trim(),
        page_url:window.location.origin+window.location.pathname
      };
      var skip = {full_name:1,email:1,phone:1};
      for(var k in state){ if(state.hasOwnProperty(k) && !skip[k]){ payload[k]=(state[k]==null?"":state[k]); } }
      var attr = attributionFields();
      payload.lo_id=attr.lo_id; payload.lo_name=attr.lo_name; payload.lo_slug=attr.lo_slug; payload.umtid=attr.umtid;
      payload.utm_source=attr.utm_source; payload.utm_medium=attr.utm_medium; payload.utm_campaign=attr.utm_campaign;
      payload.utm_term=attr.utm_term; payload.utm_content=attr.utm_content; payload.source_url=attr.source_url;

      try{ fetch(WEBHOOK_URL,{ method:"POST", headers:{"Content-Type":"application/json"}, body:JSON.stringify(payload), keepalive:true }).catch(function(){}); }catch(e){}
      showThanks(first,last);
    }

    function showThanks(first,last){
      progWrap.style.display="none"; nav.style.display="none";
      var name=(first+" "+last).trim();
      stage.innerHTML =
        '<div class="rf-thanks rf-step rf-show">'+
          '<h2>Congratulations on taking your 1st step'+(name?" "+esc(name):"")+'!</h2>'+
          '<p>Please <a class="rf-link" href="'+BOOKING_URL+'" data-booking-url target="_blank" rel="noopener">click here</a> to schedule your review call, or our team will reach out shortly.</p>'+
        '</div>';
    }

    function openModal(){ idx=0; progWrap.style.display=""; nav.style.display=""; render(); overlay.classList.add("rf-active"); overlay.setAttribute("aria-hidden","false"); document.body.style.overflow="hidden"; }
    function closeModal(){ overlay.classList.remove("rf-active"); overlay.setAttribute("aria-hidden","true"); document.body.style.overflow=""; }
    window.STW_OPEN_rf = openModal;

    nextBtn.addEventListener("click", goNext);
    prevBtn.addEventListener("click", goPrev);
    document.addEventListener("click", function(e){
      var o=e.target.closest?e.target.closest("[data-rf-open]"):null; if(o){ e.preventDefault(); openModal(); }
      var c=e.target.closest?e.target.closest("[data-rf-close]"):null; if(c){ e.preventDefault(); closeModal(); }
    });
    overlay.addEventListener("click", function(e){ if(e.target===overlay){ closeModal(); } });
    document.addEventListener("keydown", function(e){ if(e.key==="Escape"&&overlay.classList.contains("rf-active")){ closeModal(); } });
  })();
</script>
