  /* Google Places dropdown — styled to match the Stairway popup */
  .pac-container{ z-index:100000 !important; border-radius:12px; margin-top:6px; border:1.5px solid #d9d9d1;
    box-shadow:0 16px 40px rgba(10,14,26,.18); font-family:'IBM Plex Sans',sans-serif; overflow:hidden; }
  .pac-item{ padding:11px 16px; font-size:14.5px; color:#0A0E1A; cursor:pointer; border-top:1px solid #f0f0ea; }
  .pac-item:first-child{ border-top:0; }
  .pac-item:hover,.pac-item-selected{ background:#faf9f6; }
  .pac-item-query{ font-size:14.5px; color:#0A0E1A; }
  .pac-matched{ font-weight:600; }
  .pac-icon{ display:none; }
  .rf-grid2{ display:grid; grid-template-columns:1fr 1fr; gap:14px; margin:16px auto 0; text-align:left; }
  @media(max-width:480px){ .rf-grid2{ grid-template-columns:1fr; } }
  .rf-grid2 .rf-input{ margin:0; }
  .rf-contact{ max-width:540px; margin:0 auto; text-align:left; }
  .rf-contact .rf-input{ margin:0; }
  .rf-input-label{ display:block; margin:18px 0 7px; font-size:12.5px; font-weight:600; letter-spacing:.02em; color:#3a3a35; }
  .rf-input-label:first-child{ margin-top:0; }
