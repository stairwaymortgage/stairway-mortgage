    line-height:1; color:#0A0E1A; cursor:pointer; opacity:.45; padding:0; }
  .rf-close:hover{ opacity:1; }
  .rf-progress-wrap{ margin:0 auto 30px; max-width:480px; }
  .rf-progress-track{ height:8px; border-radius:99px; background:#ececE6; overflow:hidden; }
