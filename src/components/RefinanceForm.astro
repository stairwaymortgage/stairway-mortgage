<div id="rf-overlay" class="rf-overlay" aria-hidden="true">
  <div class="rf-modal" role="dialog" aria-modal="true" aria-label="Refinance">
    <button type="button" class="rf-close" data-rf-close aria-label="Close">&times;</button>
    <div class="rf-progress-wrap" id="rf-progress-wrap">
      <div class="rf-progress-track"><div class="rf-progress-bar" id="rf-progress-bar"></div></div>
      <div class="rf-progress-pct" id="rf-progress-pct">0%</div>
    </div>
    <div class="rf-nav" id="rf-nav">
      <button type="button" class="rf-nav-btn rf-prev" id="rf-prev">&larr; Previous</button>
      <button type="button" class="rf-nav-btn rf-next" id="rf-next">Next &rarr;</button>
    </div>
    <input type="text" id="rf-hp" name="rf_hp_field" tabindex="-1" autocomplete="new-password"
           class="rf-hp" aria-hidden="true" data-lpignore="true" data-1p-ignore data-form-type="other" />
    <div class="rf-stage" id="rf-stage"></div>
  </div>
</div>

<style is:global>
  .rf-overlay,.rf-overlay *{ box-sizing:border-box; }
  .rf-overlay{ position:fixed; inset:0; z-index:99999; display:none; background:rgba(10,14,26,.55);
