  .rf-overlay.rf-active{ display:flex; }
  .rf-hp{ position:absolute !important; left:-9999px !important; width:1px !important; height:1px !important; opacity:0 !important; }
  .rf-modal{ position:relative; width:100%; max-width:720px; max-height:92vh; overflow-y:auto;
    background:#fff; border-radius:20px; box-shadow:0 30px 90px rgba(0,0,0,.38);
    padding:52px 44px 56px; color:#0A0E1A; text-align:center; }
  @media(max-width:560px){ .rf-modal{ padding:44px 20px 46px; border-radius:16px; } }
