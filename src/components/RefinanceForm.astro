  .rf-thanks .rf-link{ color:#1845D6; font-weight:600; text-decoration:none; }
  .rf-thanks .rf-link:hover{ text-decoration:underline; }
</style>

<script is:inline>
  (function () {
    var WEBHOOK_URL = "https://services.leadconnectorhq.com/hooks/ipRIuBMrlyPNaFSXDz3q/webhook-trigger/fd7a3b30-ddf9-4415-b751-bfa88beda702";
    var FORM_SOURCE  = "refinance";
    var LOAN_PURPOSE = "refinance";
    var BOOKING_URL  = "https://www.stairwaymortgage.com/schedule-call/";

    // ---- Attribution (LOID / UMTID / UTM / source_url) ----------------------
    // Canonical block — identical to the live standalone forms (private-home-search,
    // home-value-report). Captures last-touch attribution so leads carry UMTID + LOID
    // + source URL into GHL. DO NOT diverge from the standalone pattern.
    function getCookie(name){var m=document.cookie.match(new RegExp('(?:^|;\\s*)'+name+'=([^;]+)'));return m?decodeURIComponent(m[1]):null;}
    function qs(name){try{return new URL(location.href).searchParams.get(name)||null;}catch(e){return null;}}
    var LO_MAP = { "1072866": { name:"Jim Blackburn", slug:"jim-blackburn" }, "1072877": { name:"Dhruv Parashar", slug:"dhruv-parashar" } };
    function loidNum(){ var raw=getCookie('first_touch_loid')||qs('lo_id')||qs('loid'); if(!raw) return null; var m=String(raw).match(/(\d{3,})/); return m?m[1]:null; }
    function attributionFields(){
      var num=loidNum(); var lo=num&&LO_MAP[num]?LO_MAP[num]:null;
      return { lo_id:num||"", lo_name:lo?lo.name:"", lo_slug:lo?lo.slug:"", umtid:getCookie('umtid')||qs('umtid')||"",
        utm_source:qs('utm_source')||"", utm_medium:qs('utm_medium')||"", utm_campaign:qs('utm_campaign')||"",
        utm_term:qs('utm_term')||"", utm_content:qs('utm_content')||"", source_url:window.location.href };
    }


    // ---- Google Places (address autocomplete) -------------------------------
    // Loaded once per page, shared by all funnels via window.__STW_PLACES.
    // SECURITY: restrict this key in Google Cloud Console to your domains
    // (HTTP referrers) + Maps JavaScript API + Places API only.
    var GOOGLE_PLACES_KEY = "AIzaSyA72a6nAbAUZoeE718Z5_PtvZkDhPLL3v0"; // TODO: confirm restricted to stairwaymortgage.com / *.vercel.app
    function STW_loadPlaces(cb){
      if(window.google && window.google.maps && window.google.maps.places){ cb(); return; }
      window.__STW_PLACES = window.__STW_PLACES || { loading:false, queue:[] };
      window.__STW_PLACES.queue.push(cb);
      if(window.__STW_PLACES.loading) return;
      window.__STW_PLACES.loading = true;
      window.__stwPlacesReady = function(){
        (window.__STW_PLACES.queue||[]).forEach(function(fn){ try{ fn(); }catch(e){} });
        window.__STW_PLACES.queue = [];
      };
      var s = document.createElement("script");
      s.src = "https://maps.googleapis.com/maps/api/js?key="+GOOGLE_PLACES_KEY+"&libraries=places&callback=__stwPlacesReady&loading=async";
      s.async = true; s.defer = true;
      s.onerror = function(){ /* graceful fallback: plain text field still works */ };
      document.head.appendChild(s);
    }
    function STW_attachPlaces(input, conf, state){
      STW_loadPlaces(function(){
        try{
          var ac = new google.maps.places.Autocomplete(input, {
            types:["address"], componentRestrictions:{country:"us"},
            fields:["address_components","formatted_address","geometry"]
          });
          ac.addListener("place_changed", function(){
            var p = ac.getPlace();
            if(!p || !p.address_components) return;
            var get=function(type,short){
              for(var i=0;i<p.address_components.length;i++){
                var c=p.address_components[i];
                if(c.types.indexOf(type)>=0) return short ? c.short_name : c.long_name;
              }
              return "";
            };
            var streetNo=get("street_number"), route=get("route");
            state.addr_street = (streetNo?streetNo+" ":"")+route;
            state.loc_city  = get("locality") || get("sublocality") || get("postal_town");
            state.loc_state = get("administrative_area_level_1", true);
            state.loc_zip   = get("postal_code");
            state.loc_county= get("administrative_area_level_2");
            if(p.geometry && p.geometry.location){
              state.addr_lat = p.geometry.location.lat();
              state.addr_lng = p.geometry.location.lng();
            }
            var full = p.formatted_address || ((state.addr_street?state.addr_street+", ":"")+state.loc_city+", "+state.loc_state+" "+state.loc_zip);
            input.value = full;
            state[input.getAttribute("data-key")||"property_location"] = full;
            state.property_location = full;
            state.addr_confirmed = full;
            if(conf){ conf.innerHTML = "\u2713 "+full; conf.style.display="block"; }
          });
          // store key for the input so handler can write back to the right state field
        }catch(e){ /* fallback: plain text input */ }
      });
    }

    var steps = [{"key": "property_type", "type": "choice", "q": "What type of property will you be refinancing?", "options": ["Single Family", "Condominium", "Town Home", "Multi-Family"], "required": true}, {"key": "occupancy", "type": "choice", "q": "How will this property be used?", "options": ["Primary Home", "Secondary Home", "Rental Property"], "required": true}, {"key": "property_location", "type": "location", "q": "Where is the property located?", "placeholder": "Start typing your address…", "required": true}, {"key": "property_value", "type": "slider", "q": "What’s the estimated value of the property?", "min": 50000, "max": 10000000, "start": 400000, "step": 5000, "fmt": "money", "required": true}, {"key": "mortgage_balance", "type": "slider", "q": "What’s the remaining balance on the mortgage?", "min": 0, "max": 100, "start": 80, "step": 1, "fmt": "pct", "pctOf": "property_value", "required": true}, {"key": "current_rate", "type": "slider", "q": "What’s your current interest rate?", "min": 1, "max": 12, "start": 5, "step": 0.125, "fmt": "ratepct", "required": true}, {"key": "second_mortgage", "type": "choice", "q": "Do you have a second mortgage?", "options": ["Yes", "No"], "required": true}, {"key": "cash_out", "type": "slider", "q": "Would you like to borrow additional cash?", "min": 0, "max": 500000, "start": 0, "step": 5000, "fmt": "money", "required": true}, {"key": "late_payments", "type": "choice", "q": "Have you made any late mortgage payments in the last year?", "options": ["No", "1 Late Payment", "2+ Late Payments"], "required": true}, {"key": "credit_score", "type": "choice", "q": "What is your estimated credit score?", "options": ["780+", "740 - 779", "700 - 739", "660 - 699", "620 - 659", "580 - 619", "Below 580"], "required": true}, {"key": "military_service", "type": "choice", "q": "Are you or your spouse an active military member, reserve member or veteran?", "options": ["Active Service", "Veteran", "Non Active Reserve National Guard", "None"], "required": true}, {"key": "employment_status", "type": "choice", "q": "What’s your employment status?", "options": ["Employed", "Self Employed / 1099 Independent Contractor", "Retired"], "required": true}, {"key": "annual_income", "type": "text", "q": "What is the gross annual income of the borrower or borrowers?", "placeholder": "$", "inputmode": "numeric", "required": true}, {"key": "bankruptcy_7yr", "type": "choice", "q": "Have you filed for bankruptcy in the last 7 years?", "options": ["Yes", "No"], "required": true}, {"key": "foreclosure_7yr", "type": "choice", "q": "Have you filed for foreclosure in the last 7 years?", "options": ["Yes", "No"], "required": true}, {"key": "contact", "type": "contact", "q": "Almost done — how can we reach you with your options?", "required": true}];
    var state = {"property_type": "", "occupancy": "", "property_location": "", "addr_street": "", "loc_city": "", "loc_state": "", "loc_zip": "", "loc_county": "", "addr_lat": "", "addr_lng": "", "addr_confirmed": "", "property_value": "", "mortgage_balance": "", "current_rate": "", "second_mortgage": "", "cash_out": "", "late_payments": "", "credit_score": "", "military_service": "", "employment_status": "", "annual_income": "", "bankruptcy_7yr": "", "foreclosure_7yr": "", "full_name": "", "email": "", "phone": ""};
    var idx = 0;

    var overlay  = document.getElementById("rf-overlay");
    var stage    = document.getElementById("rf-stage");
    var bar      = document.getElementById("rf-progress-bar");
    var pct      = document.getElementById("rf-progress-pct");
    var prevBtn  = document.getElementById("rf-prev");
    var nextBtn  = document.getElementById("rf-next");
    var nav      = document.getElementById("rf-nav");
    var progWrap = document.getElementById("rf-progress-wrap");
    var hp       = document.getElementById("rf-hp");
    if(hp){
      hp.addEventListener("focus", function(){ hp.setAttribute("data-touched","1"); });
      setTimeout(function(){ if(hp.getAttribute("data-touched")!=="1"){ hp.value=""; } }, 1200);
    }

    function commas(n){ return String(n).replace(/\B(?=(\d{3})+(?!\d))/g, ","); }
    function fmtVal(s, v){
      if(s.fmt==="k"){ return v>=1000 ? "$"+commas(Math.round(v/1000))+"K" : "$"+commas(v); }
      if(s.fmt==="money"){ return "$"+commas(v); }
      if(s.fmt==="ratepct"){ return (Math.round(v*1000)/1000)+"%"; }
      if(s.fmt==="pct"){
        var base = s.pctOf ? Number(state[s.pctOf]||0) : 0;
        if(s.pctOf){ var d=Math.round(base*(v/100)); return '$'+commas(d)+' <span class="rf-pct">('+v+'%)</span>'; }
        return v+"%";
      }
      return String(v);
    }
    function esc(t){ var d=document.createElement("div"); d.textContent=(t==null?"":t); return d.innerHTML; }
    function el(tag, cls){ var n=document.createElement(tag); if(cls) n.className=cls; return n; }

    function render(){
      var s = steps[idx];
      stage.innerHTML = "";
      var wrap = el("div","rf-step rf-show");
      var head = el("div");
      head.innerHTML = '<div class="rf-q">'+esc(s.q)+'</div>' + (s.sub ? '<div class="rf-sub">'+esc(s.sub)+'</div>' : '');
      wrap.appendChild(head);

      if(s.type==="choice"){
        var box = el("div","rf-options");
        s.options.forEach(function(opt){
          var o = el("div","rf-opt"+(state[s.key]===opt?" rf-sel":""));
