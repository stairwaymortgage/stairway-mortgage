  .rf-consent a{ color:#1845D6; text-decoration:underline; }
  .rf-trust{ max-width:540px; margin:18px auto 0; font-size:12px; color:#9a9a93; font-family:'JetBrains Mono',ui-monospace,monospace; text-align:center; }
  .rf-err{ color:#8B2C2C; font-size:13px; margin-top:12px; min-height:16px; text-align:left; max-width:540px; margin-left:auto; margin-right:auto; }
  .rf-thanks h2{ font-family:'Fraunces',Georgia,serif; font-weight:500; font-size:30px; line-height:1.25; margin:8px 0 18px; }
