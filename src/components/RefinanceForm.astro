  .rf-slider::-webkit-slider-thumb{ -webkit-appearance:none; appearance:none; width:28px; height:28px; border-radius:50%; background:#0A0E1A; cursor:pointer; box-shadow:0 3px 10px rgba(0,0,0,.28); border:3px solid #fff; }
