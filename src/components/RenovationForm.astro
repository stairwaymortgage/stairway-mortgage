        var months = ["January","February","March","April","May","June","July","August","September","October","November","December"];
        var nowY = new Date().getFullYear();
        var monthSel = '<div><label class="rn-input-label">Month</label><select class="rn-input" id="rn-my-month"><option value="">Month</option>';
        months.forEach(function(m,i){ monthSel += '<option value="'+m+'"'+(state[s.key+"_month"]===m?" selected":"")+'>'+m+'</option>'; });
        monthSel += '</select></div>';
        var yearSel = '<div><label class="rn-input-label">Year</label><select class="rn-input" id="rn-my-year"><option value="">Year</option>';
        for(var y=nowY; y>=nowY-40; y--){ yearSel += '<option value="'+y+'"'+(String(state[s.key+"_year"])===String(y)?" selected":"")+'>'+y+'</option>'; }
        yearSel += '</select></div>';
        grid.innerHTML = monthSel + yearSel;
        myWrap.appendChild(grid); wrap.appendChild(myWrap);
        var mEl = grid.querySelector("#rn-my-month"), yEl = grid.querySelector("#rn-my-year");
        function syncMY(){ state[s.key+"_month"]=mEl.value; state[s.key+"_year"]=yEl.value; state[s.key]=(mEl.value&&yEl.value)?(mEl.value+" "+yEl.value):""; }
        mEl.addEventListener("change", syncMY); yEl.addEventListener("change", syncMY);
      }
      else if(s.type==="location"){
        var lw = el("div","rn-locwrap");
        var li = el("input","rn-input");
        li.type="text"; li.placeholder=s.placeholder||"Start typing your address\u2026"; li.value=state[s.key]||"";
        li.setAttribute("autocomplete","off");
        li.setAttribute("data-key", s.key);
        li.addEventListener("input", function(){
          state[s.key]=li.value;
          // if the user edits after a pick, the parsed fields may be stale; mark unconfirmed
          state.addr_confirmed = "";
        });
        li.addEventListener("keydown", function(e){
          // Don't let Enter submit while the Places dropdown is open / mid-type
          if(e.key==="Enter"){ e.preventDefault(); }
        });
        lw.appendChild(li);
        // small confirmation line shown after a valid pick
        var conf = el("div","rn-addr-conf"); conf.id="rn-addr-conf";
        conf.innerHTML = state.addr_confirmed ? ('\u2713 '+esc(state.addr_confirmed)) : "";
        conf.style.display = state.addr_confirmed ? "block" : "none";
        lw.appendChild(conf);
        wrap.appendChild(lw);
        setTimeout(function(){ li.focus(); }, 50);
        // attach Google Places autocomplete (loads the script on first use)
        STW_attachPlaces(li, conf, state);
      }
      else if(s.type==="slider"){
        var sw = el("div","rn-slider-wrap");
        var cur = (state[s.key]!=="" && state[s.key]!=null) ? Number(state[s.key]) : s.start;
        state[s.key]=String(cur);
        var valBox = el("div","rn-slider-val"); valBox.innerHTML=fmtVal(s,cur);
        var sl = el("input","rn-slider");
        sl.type="range"; sl.min=s.min; sl.max=s.max; sl.step=s.step||1; sl.value=cur;
        function paint(){ var p=((Number(sl.value)-s.min)/(s.max-s.min))*100; sl.style.backgroundSize=p+"% 100%"; }
        paint();
        sl.addEventListener("input", function(){ state[s.key]=sl.value; valBox.innerHTML=fmtVal(s,Number(sl.value)); paint(); });
        var ends = el("div","rn-slider-ends");
        ends.innerHTML = '<span class="rn-slider-end">'+fmtVal(s,s.min)+'</span><span class="rn-slider-end">'+fmtVal(s,s.max)+'</span>';
        sw.appendChild(valBox); sw.appendChild(sl); sw.appendChild(ends);
        wrap.appendChild(sw);
      }
      else if(s.type==="contact"){
        var c = el("div","rn-contact");
        c.innerHTML =
          '<label class="rn-input-label">Full Name <span class="rn-req">*</span></label>'+
          '<input class="rn-input" id="rn-fn" type="text" placeholder="Your full name" value="'+esc(state.full_name)+'">'+
          '<label class="rn-input-label">Email <span class="rn-req">*</span></label>'+
          '<input class="rn-input" id="rn-em" type="email" placeholder="you@email.com" value="'+esc(state.email)+'">'+
          '<label class="rn-input-label">Mobile Phone Number <span class="rn-req">*</span></label>'+
          '<input class="rn-input" id="rn-ph" type="tel" placeholder="(555) 555-5555" value="'+esc(state.phone)+'">'+
          '<div class="rn-consent">By clicking "See My Options," I agree to Stairway Mortgage\'s <a href="/terms/" target="_blank" rel="noopener">Terms of Use</a> and <a href="/privacy/" target="_blank" rel="noopener">Privacy Policy</a>. I also consent to receive calls, text messages, and/or pre-recorded voicemails via automated technology—even if I\'m on a Do Not Call list. Consent is not a condition of purchase. I can opt out any time by replying "STOP."</div>'+
          '<div class="rn-trust">Jim Blackburn · NMLS #1072866</div>'+
          '<div class="rn-err" id="rn-contact-err"></div>';
        wrap.appendChild(c);
        var fn=c.querySelector("#rn-fn"), em=c.querySelector("#rn-em"), ph=c.querySelector("#rn-ph");
        fn.addEventListener("input", function(){ state.full_name=fn.value; });
        em.addEventListener("input", function(){ state.email=em.value; });
        ph.addEventListener("input", function(){ state.phone=ph.value; });
        [fn,em,ph].forEach(function(n){ n.addEventListener("keydown", enterGuard); });
      }

      // Steps that DON'T auto-advance get a prominent bottom Continue button so it's
      // obvious how to proceed (choices auto-advance and don't need this).
      if(s.type!=="choice"){
        var contWrap = el("div","rn-continue-wrap");
        var contBtn = el("button","rn-continue");
        contBtn.type="button";
        contBtn.innerHTML = (nextVisible(idx) >= steps.length) ? 'Submit &#10003;' : 'Continue &rarr;';
        contBtn.addEventListener("click", goNext);
        contWrap.appendChild(contBtn);
        wrap.appendChild(contWrap);
      }

      stage.appendChild(wrap);
      // progress + submit based on VISIBLE steps (conditional steps may be hidden)
      var visibleIdxs = []; for(var vi=0; vi<steps.length; vi++){ if(stepVisible(vi)) visibleIdxs.push(vi); }
      var posInVisible = visibleIdxs.indexOf(idx);
      var totalVisible = visibleIdxs.length;
      var isLast = (nextVisible(idx) >= steps.length);
      var p = isLast ? 100 : Math.round(((posInVisible+1)/totalVisible)*100);
      bar.style.width=p+"%"; pct.textContent=p+"%";
      prevBtn.disabled = (prevVisible(idx) < 0);
      nextBtn.innerHTML = isLast ? 'Submit &#10003;' : 'Next &rarr;';
    }

    function enterGuard(e){ if(e.key==="Enter"){ e.preventDefault(); goNext(); } }

    function validateCurrent(){
      var s = steps[idx];
      if(!s.required) return true;
      if(s.type==="choice"){ return !!state[s.key]; }
      if(s.type==="multiselect"){ return Array.isArray(state[s.key]) && state[s.key].length>0; }
      if(s.type==="monthyear"){ return !!(state[s.key+"_month"] && state[s.key+"_year"]); }
      if(s.type==="text"){ return !!(state[s.key]&&state[s.key].trim()); }
      if(s.type==="location"){ return !!(state[s.key] && state[s.key].trim()); }
      if(s.type==="slider"){ return state[s.key]!==""; }
      if(s.type==="contact"){
        var err=document.getElementById("rn-contact-err");
        if(!state.full_name.trim()){ if(err) err.textContent="Please enter your full name."; return false; }
        var _em=state.email.trim(); if(!/^[^\s@]{2,}@[^\s@]+\.[A-Za-z]{2,}$/.test(_em)||/\.\./.test(_em)){ if(err) err.textContent="Please enter a valid email."; return false; }
        var _pd=state.phone.replace(/\D/g,""); if(_pd.length<10||_pd.length>15){ if(err) err.textContent="Please enter a valid phone number."; return false; }
        if(err) err.textContent=""; return true;
      }
      return true;
    }

    // Conditional steps: a step may declare a showIf rule (key + allowed values) and is skipped when unmet.
    function stepVisible(i){
      var st = steps[i];
      if(!st || !st.showIf) return true;
      var v = state[st.showIf.key];
      return st.showIf.in.indexOf(v) >= 0;
    }
    function nextVisible(from){ var i=from+1; while(i<steps.length && !stepVisible(i)){ i++; } return i; }
    function prevVisible(from){ var i=from-1; while(i>=0 && !stepVisible(i)){ i--; } return i; }

    function goNext(){
      if(!validateCurrent()){ if(steps[idx].type!=="contact"){ flashError(); } return; }
      var ni = nextVisible(idx);
      if(ni>=steps.length){ submit(); return; }
      idx=ni; render();
    }
    function goPrev(){ var pi=prevVisible(idx); if(pi>=0){ idx=pi; render(); } }
    function flashError(){ stage.style.transition="none"; stage.style.opacity="0.4"; setTimeout(function(){ stage.style.transition="opacity .25s"; stage.style.opacity="1"; },60); }

    function submit(){
      if(hp && hp.value && hp.getAttribute("data-touched")==="1"){ return; }
      var parts=(state.full_name||"").trim().split(/\s+/);
      var first=parts.shift()||""; var last=parts.join(" ")||"";
      function _getCk(n){var m=document.cookie.match(new RegExp('(?:^|;\\s*)'+n+'=([^;]+)'));return m?decodeURIComponent(m[1]):'';}
      function _qp(n){try{return new URL(location.href).searchParams.get(n)||'';}catch(e){return '';}}
      function _resolveUmtid(){var v=_qp('umtid')||_getCk('umtid')||'';return v.replace(/[^A-Za-z0-9_-]/g,'').slice(0,40);}
      function _resolveLoid(){var raw=_qp('loid')||_qp('lo_id')||_qp('first_touch_loid')||_getCk('first_touch_loid')||'';var m=String(raw).match(/(\d{3,})/);return m?m[1]:'';}
      var payload = {
        form_source:FORM_SOURCE, loan_purpose:LOAN_PURPOSE,
        first_name:first, last_name:last, full_name:(state.full_name||"").trim(),
        email:(state.email||"").trim(), phone:(state.phone||"").trim(),
        page_url:window.location.origin+window.location.pathname
      };
      var skip = {full_name:1,email:1,phone:1};
      for(var k in state){ if(state.hasOwnProperty(k) && !skip[k]){ var vv=state[k]; if(Array.isArray(vv)){ vv=vv.join(", "); } payload[k]=(vv==null?"":vv); } }
      payload.umtid = _resolveUmtid();
      payload.loid = _resolveLoid();
      try{ fetch(WEBHOOK_URL,{ method:"POST", headers:{"Content-Type":"application/json"}, body:JSON.stringify(payload), keepalive:true }).catch(function(){}); }catch(e){}
      showThanks(first,last);
    }

    function showThanks(first,last){
      progWrap.style.display="none"; nav.style.display="none";
      var name=(first+" "+last).trim();
      stage.innerHTML =
        '<div class="rn-thanks rn-step rn-show">'+
          '<h2>Congratulations on taking your 1st step'+(name?" "+esc(name):"")+'!</h2>'+
          '<p>Please <a class="rn-link" href="'+BOOKING_URL+'" data-booking-url target="_blank" rel="noopener">click here</a> to schedule your review call, or our team will reach out shortly.</p>'+
        '</div>';
    }

    function openModal(){ idx=0; progWrap.style.display=""; nav.style.display=""; render(); overlay.classList.add("rn-active"); overlay.setAttribute("aria-hidden","false"); document.body.style.overflow="hidden"; }
    function closeModal(){ overlay.classList.remove("rn-active"); overlay.setAttribute("aria-hidden","true"); document.body.style.overflow=""; }
    window.STW_OPEN_rn = openModal;

    nextBtn.addEventListener("click", goNext);
    prevBtn.addEventListener("click", goPrev);
    document.addEventListener("click", function(e){
      var o=e.target.closest?e.target.closest("[data-rn-open]"):null; if(o){ e.preventDefault(); openModal(); }
      var c=e.target.closest?e.target.closest("[data-rn-close]"):null; if(c){ e.preventDefault(); closeModal(); }
    });
    overlay.addEventListener("click", function(e){ if(e.target===overlay){ closeModal(); } });
    document.addEventListener("keydown", function(e){ if(e.key==="Escape"&&overlay.classList.contains("rn-active")){ closeModal(); } });
  })();
</script>
