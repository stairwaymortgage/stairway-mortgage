<div id="rn-overlay" class="rn-overlay" aria-hidden="true">
  <div class="rn-modal" role="dialog" aria-modal="true" aria-label="Renovation">
    <button type="button" class="rn-close" data-rn-close aria-label="Close">&times;</button>
    <div class="rn-progress-wrap" id="rn-progress-wrap">
      <div class="rn-progress-track"><div class="rn-progress-bar" id="rn-progress-bar"></div></div>
      <div class="rn-progress-pct" id="rn-progress-pct">0%</div>
    </div>
    <div class="rn-nav" id="rn-nav">
      <button type="button" class="rn-nav-btn rn-prev" id="rn-prev">&larr; Previous</button>
      <button type="button" class="rn-nav-btn rn-next" id="rn-next">Next &rarr;</button>
    </div>
    <input type="text" id="rn-hp" name="rn_hp_field" tabindex="-1" autocomplete="new-password"
           class="rn-hp" aria-hidden="true" data-lpignore="true" data-1p-ignore data-form-type="other" />
    <div class="rn-stage" id="rn-stage"></div>
  </div>
</div>

