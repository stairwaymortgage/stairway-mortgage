---
// ReverseMortgageForm.astro
// Stairway Mortgage — Reverse Mortgage conversational popup
// Pattern: light/white theme, is:inline + plain JS (NO TypeScript), Enter-key guard, honeypot.
// Own GHL webhook + unique form_source. Lead fires ONCE at Submit (all answers included).
//
// IMPORTANT: styles use <style is:global>. The option/step elements are built at RUNTIME by
// the inline script, so Astro's default SCOPED styles (which add a per-element data-astro hash)
// do NOT apply to them. is:global guarantees every .rm-* rule lands on JS-created nodes too.
//
// USAGE:
//   ---
//   import ReverseMortgageForm from "../components/ReverseMortgageForm.astro";
//   ---
//   <button data-rm-open>Get Started</button>
//   <ReverseMortgageForm />
//
// TODO BEFORE GO-LIVE (both marked in <script>):
//   1. TRIGGER_ID is set (GHL Reverse Mortgage webhook). Change only if the workflow changes.
//   2. Swap BOOKING_URL ("#") with the real Calendly/GHL booking link.
---

<div id="rm-overlay" class="rm-overlay" aria-hidden="true">
  <div class="rm-modal" role="dialog" aria-modal="true" aria-label="Reverse Mortgage">
    <button type="button" class="rm-close" data-rm-close aria-label="Close">&times;</button>

    <div class="rm-progress-wrap" id="rm-progress-wrap">
      <div class="rm-progress-track"><div class="rm-progress-bar" id="rm-progress-bar"></div></div>
      <div class="rm-progress-pct" id="rm-progress-pct">0%</div>
    </div>

    <div class="rm-nav" id="rm-nav">
      <button type="button" class="rm-nav-btn rm-prev" id="rm-prev">&larr; Previous</button>
      <button type="button" class="rm-nav-btn rm-next" id="rm-next">Next &rarr;</button>
    </div>

    <input type="text" id="rm-hp" name="rm_hp_field" tabindex="-1" autocomplete="new-password"
           class="rm-hp" aria-hidden="true" data-lpignore="true" data-1p-ignore data-form-type="other" />

    <div class="rm-stage" id="rm-stage"></div>
  </div>
</div>

<style is:global>
  /* ============ Reverse Mortgage popup (global so runtime-built nodes get styled) ============ */
  .rm-overlay,.rm-overlay *{ box-sizing:border-box; }

  .rm-overlay{
    position:fixed; inset:0; z-index:99999; display:none;
    background:rgba(10,14,26,.55); backdrop-filter:blur(3px);
    align-items:center; justify-content:center; padding:20px;
    font-family:'IBM Plex Sans',system-ui,-apple-system,sans-serif;
  }
  .rm-overlay.rm-active{ display:flex; }

  .rm-hp{ position:absolute !important; left:-9999px !important; width:1px !important; height:1px !important; opacity:0 !important; }

  .rm-modal{
    position:relative; width:100%; max-width:720px; max-height:92vh; overflow-y:auto;
    background:#fff; border-radius:20px; box-shadow:0 30px 90px rgba(0,0,0,.38);
    padding:52px 44px 56px; color:#0A0E1A; text-align:center;
  }
  @media(max-width:560px){ .rm-modal{ padding:44px 20px 46px; border-radius:16px; } }

  .rm-close{
    position:absolute; top:16px; right:20px; border:0; background:none;
    font-size:30px; line-height:1; color:#0A0E1A; cursor:pointer; opacity:.45; padding:0;
  }
  .rm-close:hover{ opacity:1; }

  /* Progress */
  .rm-progress-wrap{ margin:0 auto 30px; max-width:480px; }
  .rm-progress-track{ height:8px; border-radius:99px; background:#ececE6; overflow:hidden; }
  .rm-progress-bar{ height:100%; width:0%; background:#0A0E1A; border-radius:99px; transition:width .4s cubic-bezier(.4,0,.2,1); }
  .rm-progress-pct{ font-family:'JetBrains Mono',ui-monospace,monospace; font-size:12px; letter-spacing:.04em; color:#9a9a93; margin-top:10px; }

  /* Nav */
  .rm-nav{ display:flex; justify-content:space-between; align-items:center; max-width:560px; margin:0 auto 28px; }
  .rm-nav-btn{
    border:0; background:none; cursor:pointer; font-family:'IBM Plex Sans',sans-serif;
    font-size:15px; color:#0A0E1A; padding:6px 2px; letter-spacing:.01em;
  }
  .rm-nav-btn:disabled{ opacity:.25; cursor:default; }
  .rm-nav-btn:hover:not(:disabled){ color:#2d2350; }
  .rm-next{ font-weight:600; }

  /* Stage */
  .rm-stage{ max-width:600px; margin:0 auto; }
  .rm-step{ display:none; }
  .rm-step.rm-show{ display:block; animation:rmFade .32s ease; }
  @keyframes rmFade{ from{opacity:0; transform:translateY(8px);} to{opacity:1; transform:none;} }

  .rm-q{
    font-family:'Fraunces',Georgia,serif; font-weight:500; font-size:31px; line-height:1.22;
    margin:6px 0 8px; letter-spacing:-.01em; color:#0A0E1A;
  }
  @media(max-width:560px){ .rm-q{ font-size:25px; } }
  .rm-sub{
    font-family:'Fraunces',Georgia,serif; font-style:italic; font-weight:400;
    font-size:18px; color:#6b6b63; margin:0 0 30px; line-height:1.45; max-width:520px; margin-left:auto; margin-right:auto;
  }
  .rm-q + .rm-options, .rm-q + .rm-slider-wrap, .rm-q + .rm-input, .rm-q + .rm-contact{ margin-top:30px; }

  /* Option cards (circle radio + label) */
  .rm-options{ display:flex; flex-wrap:wrap; gap:14px; justify-content:center; }
  .rm-opt{
    display:inline-flex; align-items:center; gap:13px; cursor:pointer;
    border:1.5px solid #d9d9d1; border-radius:14px; padding:17px 24px;
    background:#fff; font-size:16px; line-height:1.3; color:#0A0E1A;
    transition:border-color .15s ease, background .15s ease, box-shadow .15s ease, transform .08s ease;
    user-select:none; text-align:left;
  }
  .rm-opt:hover{ border-color:#0A0E1A; background:#faf9f6; }
  .rm-opt:active{ transform:scale(.985); }
  .rm-circle{
    width:22px; height:22px; border-radius:50%; border:2px solid #c2c2b8; flex:0 0 auto;
    display:inline-flex; align-items:center; justify-content:center; transition:border-color .15s ease; background:#fff;
  }
  .rm-circle::after{
    content:''; width:10px; height:10px; border-radius:50%; background:transparent; transition:background .15s ease, transform .15s ease; transform:scale(.4);
  }
  .rm-opt.rm-sel{ border-color:#0A0E1A; background:#0A0E1A; color:#fff; box-shadow:0 8px 22px rgba(10,14,26,.18); }
  .rm-opt.rm-sel .rm-circle{ border-color:#fff; }
  .rm-opt.rm-sel .rm-circle::after{ background:#fff; transform:scale(1); }

  .rm-opt-other{ flex:1 1 240px; min-width:220px; }
  .rm-opt-other input{
    border:0; background:none; outline:none; font-size:16px; color:inherit; width:100%;
    font-family:'IBM Plex Sans',sans-serif;
  }
  .rm-opt-other input::placeholder{ color:#a6a6a0; }
  .rm-opt-other.rm-sel input::placeholder{ color:rgba(255,255,255,.6); }

  /* Text inputs */
  .rm-input{
    width:100%; max-width:540px; margin:0 auto; display:block;
    border:1.5px solid #d9d9d1; border-radius:12px; padding:17px 20px;
    font-size:16px; font-family:'IBM Plex Sans',sans-serif; color:#0A0E1A; background:#fff; outline:none;
    transition:border-color .15s ease, box-shadow .15s ease;
  }
  .rm-input::placeholder{ color:#a6a6a0; }
  .rm-input:focus{ border-color:#0A0E1A; box-shadow:0 0 0 4px rgba(45,35,80,.12); }

  .rm-contact{ max-width:540px; margin:0 auto; text-align:left; }
  .rm-contact .rm-input{ margin:0; }
  .rm-input-label{ display:block; margin:18px 0 7px; font-size:12.5px; font-weight:600; letter-spacing:.02em; color:#3a3a35; }
  .rm-input-label:first-child{ margin-top:0; }
  .rm-req{ color:#8B2C2C; }

  /* Slider */
  .rm-slider-wrap{ max-width:540px; margin:0 auto; }
  .rm-slider-val{
    display:inline-block; border:1.5px solid #0A0E1A; border-radius:9px;
    padding:7px 18px; font-size:16px; font-family:'JetBrains Mono',ui-monospace,monospace;
    margin-bottom:22px; min-width:70px;
  }
  .rm-slider{ -webkit-appearance:none; appearance:none; width:100%; height:5px; border-radius:99px;
    background:linear-gradient(#0A0E1A,#0A0E1A) no-repeat, #e4e4dd; background-size:50% 100%; outline:none; }
  .rm-slider::-webkit-slider-thumb{ -webkit-appearance:none; appearance:none; width:28px; height:28px; border-radius:50%;
    background:#0A0E1A; cursor:pointer; box-shadow:0 3px 10px rgba(0,0,0,.28); border:3px solid #fff; }
  .rm-slider::-moz-range-thumb{ width:28px; height:28px; border:3px solid #fff; border-radius:50%; background:#0A0E1A; cursor:pointer; }
  .rm-slider-ends{ display:flex; justify-content:space-between; margin-top:16px; }
  .rm-slider-end{ background:#f0f0ea; border-radius:8px; padding:6px 14px; font-size:13px; color:#5a5a52; font-family:'JetBrains Mono',ui-monospace,monospace; }

  /* CTA / submit */
  .rm-cta{
    display:inline-block; margin-top:34px; border:0; cursor:pointer;
    background:#0A0E1A; color:#fff; border-radius:99px; padding:17px 46px;
    font-size:16px; font-weight:500; font-family:'IBM Plex Sans',sans-serif; transition:background .15s ease;
  }
  .rm-cta:hover{ background:#2d2350; }
  .rm-cta:disabled{ opacity:.5; cursor:default; }

  .rm-consent{ max-width:540px; margin:24px auto 0; font-size:12.5px; line-height:1.6; color:#7a7a72; text-align:left; }
  .rm-consent a{ color:#1845D6; text-decoration:underline; }
  .rm-err{ color:#8B2C2C; font-size:13px; margin-top:12px; min-height:16px; text-align:left; max-width:540px; margin-left:auto; margin-right:auto; }

  /* Thank-you */
  .rm-thanks h2{ font-family:'Fraunces',Georgia,serif; font-weight:500; font-size:30px; line-height:1.25; margin:8px 0 18px; }
  .rm-thanks p{ font-size:18px; color:#3a3a35; margin:0 0 28px; line-height:1.5; }
  .rm-thanks .rm-link{ color:#1845D6; font-weight:600; text-decoration:none; }
  .rm-thanks .rm-link:hover{ text-decoration:underline; }
  .rm-stairs-img{ max-width:460px; width:100%; border-radius:12px; box-shadow:0 14px 40px rgba(0,0,0,.18); }
</style>

<script is:inline>
  (function () {
    // ---- CONFIG ----------------------------------------------------------
    var WEBHOOK_BASE = "https://services.leadconnectorhq.com/hooks/ipRIuBMrlyPNaFSXDz3q/webhook-trigger/";
    var TRIGGER_ID   = "e8c4995a-513a-41ac-b1a8-051c7ef6bd96"; // GHL — Stairway Reverse Mortgage
    var WEBHOOK_URL  = WEBHOOK_BASE + TRIGGER_ID;
    var FORM_SOURCE  = "reverse-mortgage";
    var BOOKING_URL  = "https://www.stairwaymortgage.com/schedule-call/";

    // ---- Attribution (LOID / UMTID / UTM / source_url) ----------------------
    // Canonical block — identical to the live standalone forms (private-home-search,
    // home-value-report). Captures last-touch attribution so leads carry UMTID + LOID
    // + source URL into GHL. DO NOT diverge from the standalone pattern.
    function getCookie(name){var m=document.cookie.match(new RegExp('(?:^|;\\s*)'+name+'=([^;]+)'));return m?decodeURIComponent(m[1]):null;}
    function qs(name){try{return new URL(location.href).searchParams.get(name)||null;}catch(e){return null;}}
    var LO_MAP = { "1072866": { name:"Jim Blackburn", slug:"jim-blackburn" }, "1072877": { name:"Dhruv Parashar", slug:"dhruv-parashar" } };
    function loidNum(){ var raw=getCookie('first_touch_loid')||qs('lo_id')||qs('loid'); if(!raw) return null; var m=String(raw).match(/(\d{3,})/); return m?m[1]:null; }
    function attributionFields(){
      var num=loidNum(); var lo=num&&LO_MAP[num]?LO_MAP[num]:null;
      return { lo_id:num||"", lo_name:lo?lo.name:"", lo_slug:lo?lo.slug:"", umtid:getCookie('umtid')||qs('umtid')||"",
        utm_source:qs('utm_source')||getCookie('utm_source')||"", utm_medium:qs('utm_medium')||getCookie('utm_medium')||"", utm_campaign:qs('utm_campaign')||getCookie('utm_campaign')||"",
        utm_term:qs('utm_term')||getCookie('utm_term')||"", utm_content:qs('utm_content')||getCookie('utm_content')||"", source_url:getCookie('first_touch_url')||window.location.href };
    }


    var state = {
      reason:"", reason_other:"", referrer:"", home_in_mind:"", youngest_spouse_age:"",
      military_service:"", home_address:"", annual_income:"", credit_score:"",
      full_name:"", email:"", phone:"", free_credit_report:"", date_of_birth:"", anything_else:""
    };
    var idx = 0;

    var steps = [
      { key:"reason", type:"choice", q:"Why are you considering a reverse mortgage?", sub:"Besides no payments for life…",
        options:["Receive monthly income","Buy a new home","Cash out equity","Consolidate debts to reduce monthly payments","Renovate to enjoy","Renovate to sell"], other:true, required:true },
      { key:"referrer", type:"text", q:"Let's start with this—what's the name of the Loan Officer or person who referred you here?",
        placeholder:"Enter their full name", required:false },
      { key:"home_in_mind", type:"choice", q:"Got a home in mind?",
        options:["Yes - I live in the home now","Yes - I'd like to make an offer","Yes - My offer was accepted and I need financing","No - I'm just beginning my search","Yes - it's complicated. I'd like to discuss."], required:true },
      { key:"youngest_spouse_age", type:"slider", q:"How old is the youngest spouse?", sub:"Under age 55 can be listed as \"non-borrower.\"",
        min:1, max:120, start:62, fmt:"plain", required:true },
      { key:"military_service", type:"choice", q:"Military service for you or your spouse?",
        sub:"If yes, thank you sincerely for everything your family sacrificed. You are deeply loved and honored by our family at Stairway.",
        options:["Yes","No"], required:true },
      { key:"home_address", type:"text", q:"Current home address?", sub:"Typically the address listed on your social security check. ;)",
        placeholder:"Begin typing the address", required:true },
      { key:"annual_income", type:"slider", q:"Annual income?", sub:"Estimate all borrowers employment and retirement income.",
        min:0, max:500000, start:25000, step:1000, fmt:"k", required:true },
      { key:"credit_score", type:"choice", q:"Credit score?", sub:"Just an estimate!",
        options:["800s","700s","600s","500s","No credit established in U.S."], required:true },
      { key:"contact", type:"contact", q:"How can we get in touch?", required:true },
      { key:"free_credit_report", type:"choice", q:"Would you like to receive a free credit report?",
        options:["Yes","No"], required:true },
      { key:"date_of_birth", type:"text", q:"Date of birth? (optional)", sub:"Only for identity verification. No impact to your score. :)",
        placeholder:"MM/DD/YYYY", required:false, inputmode:"numeric" },
      { key:"anything_else", type:"text", q:"Would you like to share anything else?", placeholder:"Type your response here", required:false, submit:true }
    ];
    // NOTE: SSN intentionally DROPPED (compliance).

    var overlay  = document.getElementById("rm-overlay");
    var stage    = document.getElementById("rm-stage");
    var bar      = document.getElementById("rm-progress-bar");
    var pct      = document.getElementById("rm-progress-pct");
    var prevBtn  = document.getElementById("rm-prev");
    var nextBtn  = document.getElementById("rm-next");
    var nav      = document.getElementById("rm-nav");
    var progWrap = document.getElementById("rm-progress-wrap");
    var hp       = document.getElementById("rm-hp");
    // Honeypot guard: real users who tab into it get flagged; browser autofill does not focus it.
    if(hp){
      hp.addEventListener("focus", function(){ hp.setAttribute("data-touched","1"); });
      // Strip any browser-autofilled value shortly after load so it can't false-trip the check.
      setTimeout(function(){ if(hp.getAttribute("data-touched")!=="1"){ hp.value=""; } }, 1200);
    }

    function fmtVal(s, v){ if(s.fmt==="k"){ return v>=1000 ? Math.round(v/1000)+"K" : String(v); } return String(v); }
    function esc(t){ var d=document.createElement("div"); d.textContent=(t==null?"":t); return d.innerHTML; }
    function el(tag, cls){ var n=document.createElement(tag); if(cls) n.className=cls; return n; }

    function render(){
      var s = steps[idx];
      stage.innerHTML = "";
      var wrap = el("div","rm-step rm-show");

      var head = el("div");
      head.innerHTML = '<div class="rm-q">'+esc(s.q)+'</div>' + (s.sub ? '<div class="rm-sub">'+esc(s.sub)+'</div>' : '');
      wrap.appendChild(head);

      if(s.type==="choice"){
        var box = el("div","rm-options");
        s.options.forEach(function(opt){
          var o = el("div","rm-opt"+(state[s.key]===opt?" rm-sel":""));
          o.innerHTML = '<span class="rm-circle"></span><span>'+esc(opt)+'</span>';
          o.addEventListener("click", function(){
            state[s.key]=opt;
            if(s.key==="reason"){ state.reason_other=""; }
            // Tapping a preset option ALWAYS auto-advances (no Next click needed).
            // Only the separate "Other" free-text field (below) requires Next, since the
            // user is mid-typing there.
            Array.prototype.forEach.call(box.querySelectorAll(".rm-opt"), function(n){ n.classList.remove("rm-sel"); });
            o.classList.add("rm-sel");
            setTimeout(function(){ goNext(); }, 220);
          });
          box.appendChild(o);
        });
        if(s.other){
          var oth = el("label","rm-opt rm-opt-other"+(state.reason_other?" rm-sel":""));
          oth.innerHTML = '<span class="rm-circle"></span>';
          var inp = document.createElement("input");
          inp.type="text"; inp.placeholder="Other"; inp.value=state.reason_other||"";
          inp.addEventListener("input", function(){
            state.reason_other=inp.value;
            if(inp.value){ state.reason=""; }
            oth.classList.toggle("rm-sel", !!inp.value);
            Array.prototype.forEach.call(box.querySelectorAll(".rm-opt:not(.rm-opt-other)"), function(n){ n.classList.remove("rm-sel"); });
          });
          inp.addEventListener("keydown", enterGuard);
          inp.addEventListener("click", function(e){ e.stopPropagation(); });
          oth.appendChild(inp);
          box.appendChild(oth);
        }
        wrap.appendChild(box);
      }

      else if(s.type==="text"){
        var input = el("input","rm-input");
        input.type="text"; input.placeholder=s.placeholder||""; input.value=state[s.key]||"";
        if(s.inputmode){ input.setAttribute("inputmode", s.inputmode); }
        input.addEventListener("input", function(){ state[s.key]=input.value; });
        input.addEventListener("keydown", enterGuard);
        wrap.appendChild(input);
        setTimeout(function(){ input.focus(); }, 50);
      }

      else if(s.type==="slider"){
        var sw = el("div","rm-slider-wrap");
        var cur = state[s.key]!=="" ? Number(state[s.key]) : s.start;
        state[s.key]=String(cur);
        var valBox = el("div","rm-slider-val"); valBox.textContent=fmtVal(s,cur);
        var sl = el("input","rm-slider");
        sl.type="range"; sl.min=s.min; sl.max=s.max; sl.step=s.step||1; sl.value=cur;
        function paint(){ var p=((Number(sl.value)-s.min)/(s.max-s.min))*100; sl.style.backgroundSize=p+"% 100%"; }
        paint();
        sl.addEventListener("input", function(){ state[s.key]=sl.value; valBox.textContent=fmtVal(s,Number(sl.value)); paint(); });
        var ends = el("div","rm-slider-ends");
        ends.innerHTML = '<span class="rm-slider-end">'+fmtVal(s,s.min)+'</span><span class="rm-slider-end">'+fmtVal(s,s.max)+'</span>';
        sw.appendChild(valBox); sw.appendChild(sl); sw.appendChild(ends);
        wrap.appendChild(sw);
      }

      else if(s.type==="contact"){
        var c = el("div","rm-contact");
        c.innerHTML =
          '<label class="rm-input-label">Full Name <span class="rm-req">*</span></label>'+
          '<input class="rm-input" id="rm-fn" type="text" placeholder="Your full name" value="'+esc(state.full_name)+'">'+
          '<label class="rm-input-label">Email <span class="rm-req">*</span></label>'+
          '<input class="rm-input" id="rm-em" type="email" placeholder="you@email.com" value="'+esc(state.email)+'">'+
          '<label class="rm-input-label">Mobile Phone Number <span class="rm-req">*</span></label>'+
          '<input class="rm-input" id="rm-ph" type="tel" placeholder="(555) 555-5555" value="'+esc(state.phone)+'">'+
          '<div class="rm-consent">By clicking "Get Rates," I agree to Stairway Mortgage\'s '+
          '<a href="/terms/" target="_blank" rel="noopener">Terms of Use</a> and '+
          '<a href="/privacy/" target="_blank" rel="noopener">Privacy Policy</a>. '+
          'I also consent to receive calls, text messages, and/or pre-recorded voicemails via automated technology'+
          '—even if I\'m on a Do Not Call list. Consent is not a condition of purchase. I can opt out any time by replying "STOP."</div>'+
          '<div class="rm-err" id="rm-contact-err"></div>';
        wrap.appendChild(c);
        var fn=c.querySelector("#rm-fn"), em=c.querySelector("#rm-em"), ph=c.querySelector("#rm-ph");
        fn.addEventListener("input", function(){ state.full_name=fn.value; });
        em.addEventListener("input", function(){ state.email=em.value; });
        ph.addEventListener("input", function(){ state.phone=ph.value; });
        [fn,em,ph].forEach(function(n){ n.addEventListener("keydown", enterGuard); });
      }

      stage.appendChild(wrap);

      var total = steps.length;
      var p = (idx===total-1) ? 100 : Math.round(((idx+1)/total)*100);
      bar.style.width=p+"%"; pct.textContent=p+"%";
      prevBtn.disabled = (idx===0);
      nextBtn.innerHTML = s.submit ? 'Submit &#10003;' : 'Next &rarr;';
    }

    function enterGuard(e){ if(e.key==="Enter"){ e.preventDefault(); goNext(); } }

    function validateCurrent(){
      var s = steps[idx];
      if(!s.required) return true;
      if(s.type==="choice"){ return s.key==="reason" ? !!(state.reason||state.reason_other) : !!state[s.key]; }
      if(s.type==="text"){ return !!(state[s.key]&&state[s.key].trim()); }
      if(s.type==="slider"){ return state[s.key]!==""; }
      if(s.type==="contact"){
        var err=document.getElementById("rm-contact-err");
        if(!state.full_name.trim()){ if(err) err.textContent="Please enter your full name."; return false; }
        if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(state.email.trim())){ if(err) err.textContent="Please enter a valid email."; return false; }
        if(state.phone.replace(/\D/g,"").length<10){ if(err) err.textContent="Please enter a valid phone number."; return false; }
        if(err) err.textContent=""; return true;
      }
      return true;
    }

    function goNext(){
      if(!validateCurrent()){ if(steps[idx].type!=="contact"){ flashError(); } return; }
      if(idx===steps.length-1){ submit(); return; }
      idx++; render();
    }
    function goPrev(){ if(idx>0){ idx--; render(); } }
    function flashError(){ stage.style.transition="none"; stage.style.opacity="0.4"; setTimeout(function(){ stage.style.transition="opacity .25s"; stage.style.opacity="1"; },60); }

    function submit(){
      // Honeypot: only treat as bot if the field was actually FOCUSED/typed by a user.
      // Browsers sometimes autofill hidden fields (e.g. company name) — that must NOT block real submits.
      if(hp && hp.value && hp.getAttribute("data-touched")==="1"){ return; }
      var parts=(state.full_name||"").trim().split(/\s+/);
      var first=parts.shift()||""; var last=parts.join(" ")||"";
      var reasonFinal = state.reason || (state.reason_other ? ("Other: "+state.reason_other) : "");
      var payload = {
        form_source:FORM_SOURCE, first_name:first, last_name:last, full_name:(state.full_name||"").trim(),
        email:(state.email||"").trim(), phone:(state.phone||"").trim(),
        reason_for_reverse_mortgage:reasonFinal, referrer_name:state.referrer||"",
        home_in_mind:state.home_in_mind||"", youngest_spouse_age:state.youngest_spouse_age||"",
        military_service:state.military_service||"", home_address:state.home_address||"",
        annual_income:state.annual_income||"", credit_score:state.credit_score||"",
        free_credit_report:state.free_credit_report||"", date_of_birth:state.date_of_birth||"",
        anything_else:state.anything_else||"", page_url:window.location.origin+window.location.pathname
      };
      var attr = attributionFields();
      payload.lo_id=attr.lo_id; payload.lo_name=attr.lo_name; payload.lo_slug=attr.lo_slug; payload.umtid=attr.umtid;
      payload.utm_source=attr.utm_source; payload.utm_medium=attr.utm_medium; payload.utm_campaign=attr.utm_campaign;
      payload.utm_term=attr.utm_term; payload.utm_content=attr.utm_content; payload.source_url=attr.source_url;

      try{ fetch(WEBHOOK_URL,{ method:"POST", headers:{"Content-Type":"application/json"}, body:JSON.stringify(payload), keepalive:true }).catch(function(){}); }catch(e){}
      showThanks(first,last);
    }

    function showThanks(first,last){
      progWrap.style.display="none"; nav.style.display="none";
      var name=(first+" "+last).trim();
      stage.innerHTML =
        '<div class="rm-thanks rm-step rm-show">'+
          '<h2>Congratulations on taking your 1st step'+(name?" "+esc(name):"")+'!</h2>'+
          '<p>Please <a class="rm-link" href="'+BOOKING_URL+'" data-booking-url target="_blank" rel="noopener">click here</a> to schedule your review call.</p>'+
        '</div>';
    }

    function open(){
      idx=0; progWrap.style.display=""; nav.style.display=""; render();
      overlay.classList.add("rm-active"); overlay.setAttribute("aria-hidden","false");
      document.body.style.overflow="hidden";
    }
    function close(){
      overlay.classList.remove("rm-active"); overlay.setAttribute("aria-hidden","true");
      document.body.style.overflow="";
    }

    nextBtn.addEventListener("click", goNext);
    prevBtn.addEventListener("click", goPrev);
    document.addEventListener("click", function(e){
      var o=e.target.closest?e.target.closest("[data-rm-open]"):null; if(o){ e.preventDefault(); open(); }
      var c=e.target.closest?e.target.closest("[data-rm-close]"):null; if(c){ e.preventDefault(); close(); }
    });
    overlay.addEventListener("click", function(e){ if(e.target===overlay){ close(); } });
    document.addEventListener("keydown", function(e){ if(e.key==="Escape"&&overlay.classList.contains("rm-active")){ close(); } });
  })();
</script>
