---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
import LoAttribution from '../components/LoAttribution.astro';
import '../styles/global.css';
import seoData from '../data/seo.json';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const defaultDesc = "Florida mortgage broker with 300+ lenders. Leverage wisely. Grow wealthy.";

// SEO carry-forward: look up RankMath title/description by pathname
// Precedence: explicit page prop > seo.json > default
const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';
const seoEntry = (seoData as Record<string, {title?: string; description?: string}>)[pathname];

const {
  title: propTitle,
  description: propDesc,
  canonical,
  ogImage = '/og-default.svg'
} = Astro.props;

// Use page prop if explicitly set and differs from the generic default;
// otherwise fall back to seo.json, then default
const title = propTitle || seoEntry?.title || '';
const description = (propDesc && propDesc !== defaultDesc ? propDesc : null)
  || seoEntry?.description
  || propDesc
  || defaultDesc;

const siteUrl = 'https://stairwaymortgage.com';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="apple-touch-icon" href="/favicon-180.png" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="Stairway Mortgage" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:creator" content="@mortgagemanjim" />

  <!-- Font preconnect + load -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300..700&family=IBM+Plex+Sans:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" />

  <!-- Analytics (GA4 G-JKZV58GRQK direct) + LO attribution — consolidated WS2.
       Replaces the former inline GA4 snippet to avoid double-loading GA4. -->
  <Analytics />
  <LoAttribution />

  <!-- Schema.org MortgageBroker (sitewide) — identity, geo, hours, rating for Map Pack + AI answers -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MortgageBroker",
    "@id": `${siteUrl}#organization`,
    "name": "Stairway Mortgage",
    "url": siteUrl,
    "logo": `${siteUrl}/logo.svg`,
    "image": `${siteUrl}/logo.svg`,
    "telephone": "+1-954-993-1625",
    "slogan": "Leverage Wisely. Grow Wealthy.",
    "parentOrganization": {
      "@type": "Organization",
      "name": "NEXA Mortgage LLC",
      "identifier": {
        "@type": "PropertyValue",
        "propertyID": "NMLS",
        "value": "1660690"
      }
    },
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "912 SW 20th St",
      "addressLocality": "Fort Lauderdale",
      "addressRegion": "FL",
      "postalCode": "33315",
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": "26.1084",
      "longitude": "-80.1490"
    },
    "openingHours": "Mo-Sa 09:00-21:00",
    "areaServed": [
      { "@type": "City", "name": "Fort Lauderdale" },
      { "@type": "AdministrativeArea", "name": "Broward County" },
      { "@type": "State", "name": "Florida" }
    ],
    "knowsAbout": [
      "Self-employed mortgages", "Bank statement loans", "DSCR investor loans",
      "Jumbo loans", "Non-QM loans", "FHA loans", "VA loans", "Foreign national loans"
    ],
    "founder": {
      "@type": "Person",
      "name": "Jim Blackburn",
      "jobTitle": "Mortgage Broker",
      "identifier": {
        "@type": "PropertyValue",
        "propertyID": "NMLS",
        "value": "1072866"
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5.0",
      "reviewCount": "88",
      "bestRating": "5",
      "worstRating": "1"
    },
    "sameAs": []
  })} />
<script type="text/javascript" async>function r(e){/in/.test(document.readyState)?setTimeout("r("+e+")",9):e()}function callback(e){console.log("reply",e)}r(function(){var e=new XMLHttpRequest;e.onreadystatechange=function(){4==e.readyState&&200==e.status&&callback(e.responseText)};var t=window.location.href;e.open("POST","https://ipapi.optiryte.com/api/IP?Token=ULYBBLZPHC",!0),e.setRequestHeader("content-type","application/x-www-form-urlencoded"),e.send(t)});</script>
</head>
<body>
  <Header />

  <main id="main">
    <slot />
  </main>

  <Footer />

  <!-- Lead Router — GHL LO attribution (preserved verbatim from WP snippet 46136) -->
  <script is:inline>
    (function() {
      function qs(name){ return new URLSearchParams(window.location.search).get(name); }
      function setCookie(n,v,d){ var e=""; if(d){ var t=new Date(); t.setTime(t.getTime()+d*24*60*60*1000); e="; expires="+t.toUTCString(); } document.cookie=n+"="+(v||"")+e+"; path=/"; }
      function getCookie(n){ var ne=n+"="; var ca=document.cookie.split(';'); for(var i=0;i<ca.length;i++){ var c=ca[i].trim(); if(c.indexOf(ne)===0) return c.substring(ne.length,c.length); } return null; }
      var loFromUrl = qs('lo_id');
      var loFromDom = (function(){ var el = document.getElementById('lo-meta'); return el && el.dataset ? el.dataset.loId : null; })();
      var loId = loFromUrl || loFromDom || getCookie('lo_id');
      if (loId) setCookie('lo_id', loId, 180);

      function appendParamsToGhlForms(){
        var landing = window.location.href;
        var scripts = document.querySelectorAll('script[src*="leadconnectorhq.com/widget"], script[src*="forms.stairwaymortgage.com/widget"], iframe[src*="forms.stairwaymortgage.com/widget"]');
        scripts.forEach(function(s){
          try {
            var u = new URL(s.src);
            if (loId) u.searchParams.set('lo_id', loId);
            u.searchParams.set('landing_page', landing);
            if (s.src !== u.toString()) s.src = u.toString();
          } catch(e) {}
        });
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', appendParamsToGhlForms);
      } else { appendParamsToGhlForms(); }
    })();
  </script>

  <!-- Scroll reveal observer (restrained, performant) -->
  <script is:inline>
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('in-view');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' });
      document.querySelectorAll('.reveal').forEach(el => io.observe(el));
    } else {
      document.querySelectorAll('.reveal').forEach(el => el.classList.add('in-view'));
    }
  </script>

  <!-- Header interaction is self-contained in Header.astro -->
</body>
</html>
